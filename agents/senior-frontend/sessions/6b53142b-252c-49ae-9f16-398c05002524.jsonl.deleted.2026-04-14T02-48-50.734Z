{"type":"message","id":"6cbd8284","parentId":"e220affa","timestamp":"2026-04-14T01:58:24.904Z","message":{"role":"toolResult","toolCallId":"call_function_bqefzr0lutse_1","toolName":"read","content":[{"type":"text","text":"import axios from \"axios\";\n\nconst API_SERVER = import.meta.env.VITE_API_SERVER;\n\nconst API = axios.create({\n  baseURL: API_SERVER + \"/api/v1\",\n  headers: { \"Content-Type\": \"application/json\" },\n});\n\nconst RefreshAPI = axios.create({\n  baseURL: API_SERVER + \"/api/v1\",\n  headers: { \"Content-Type\": \"application/json\" },\n});\n\nRefreshAPI.interceptors.request.use((config) => {\n  const refreshToken = localStorage.getItem(\"refreshToken\");\n  if (refreshToken) config.headers[\"x-dtlx-auth\"] = refreshToken;\n  return config;\n});\n\nAPI.interceptors.request.use(\n  (config) => {\n    const token = localStorage.getItem(\"accessToken\");\n    if (token) config.headers[\"x-dtlx-auth\"] = token;\n    return config;\n  },\n  (error) => Promise.reject(error)\n);\n\nlet isRefreshing = false;\nlet refreshSubscribers = [];\n\nfunction onRefreshed(token) {\n  refreshSubscribers.forEach((cb) => cb(token));\n  refreshSubscribers = [];\n}\n\nfunction addRefreshSubscriber(cb) {\n  refreshSubscribers.push(cb);\n}\n\nAPI.interceptors.response.use(\n  (response) => response,\n  async (error) => {\n    const originalRequest = error.config;\n\n    if (\n      error.response?.status === 401 &&\n      error.response?.data?.errorCode === 2 &&\n      !originalRequest._retry\n    ) {\n      originalRequest._retry = true;\n\n      if (isRefreshing) {\n        return new Promise((resolve) => {\n          addRefreshSubscriber((token) => {\n            originalRequest.headers[\"x-dtlx-auth\"] = token;\n            resolve(API(originalRequest));\n          });\n        });\n      }\n\n      isRefreshing = true;\n      try {\n        const { data } = await RefreshAPI.post(\"/auth/refetch-token\", {});\n        const newToken = data?.data?.accessToken;\n\n        if (newToken) {\n          localStorage.setItem(\"accessToken\", newToken);\n          API.defaults.headers[\"x-dtlx-auth\"] = newToken;\n\n          onRefreshed(newToken);\n          isRefreshing = false;\n\n          originalRequest.headers[\"x-dtlx-auth\"] = newToken;\n          return API(originalRequest);\n        }\n      } catch (refreshError) {\n        isRefreshing = false;\n        localStorage.removeItem(\"accessToken\");\n        localStorage.removeItem(\"refreshToken\");\n        window.location.href = \"/login\";\n        return Promise.reject(refreshError);\n      }\n    }\n\n    return Promise.reject(error);\n  }\n);\n\nexport default API;\n"}],"isError":false,"timestamp":1776131904887}}
{"type":"message","id":"99eef71c","parentId":"6cbd8284","timestamp":"2026-04-14T01:58:24.918Z","message":{"role":"toolResult","toolCallId":"call_function_bqefzr0lutse_2","toolName":"read","content":[{"type":"text","text":"import { defineConfig, loadEnv } from \"vite\";\nimport react from \"@vitejs/plugin-react\";\nimport path from \"path\";\nimport { fileURLToPath } from \"url\";\n\nconst __filename = fileURLToPath(import.meta.url);\nconst __dirname = path.dirname(__filename);\n\nexport default defineConfig(({ mode }) => {\n  const env = loadEnv(mode, \".\", \"\");\n  const PORT = env.VITE_PORT;\n  const allowedHosts =\n    env.VITE_ALLOWED_HOSTS?.split(\",\").map((h) => h.trim()) || [];\n  return {\n    plugins: [react()],\n    resolve: {\n      alias: {\n        bootstrap: path.resolve(__dirname, \"node_modules/bootstrap\"),\n      },\n    },\n    server: {\n      port: PORT,\n      host: \"0.0.0.0\",\n      allowedHosts: allowedHosts,\n    },\n  };\n});\n"}],"isError":false,"timestamp":1776131904905}}
{"type":"message","id":"7c62491b","parentId":"99eef71c","timestamp":"2026-04-14T01:58:24.931Z","message":{"role":"toolResult","toolCallId":"call_function_bqefzr0lutse_3","toolName":"read","content":[{"type":"text","text":"import { StrictMode } from \"react\";\nimport { createRoot } from \"react-dom/client\";\n\nimport \"./index.css\";\nimport \"./assets/css/icons.min.css\";\nimport \"./assets/css/app.min.css\";\nimport \"./assets/css/nouislider.min.css\";\n\nimport \"bootstrap/dist/js/bootstrap.bundle.min.js\";\n\nimport { ThemeProvider } from \"./configs/ThemeProvider.jsx\";\nimport App from \"./App.jsx\";\n\nconst NODE_ENV = import.meta.env.MODE;\n\nwindow.addEventListener(\"beforeunload\", () => {\n  sessionStorage.setItem(\"wasReloaded\", \"true\");\n});\n\nconst root = createRoot(document.getElementById(\"root\"));\n\nif (NODE_ENV === \"development\") {\n  root.render(\n    <ThemeProvider>\n      <App />\n    </ThemeProvider>\n  );\n} else {\n  root.render(\n    <StrictMode>\n      <ThemeProvider>\n        <App />\n      </ThemeProvider>\n    </StrictMode>\n  );\n}\n\n// createRoot(document.getElementById(\"root\")).render(\n\n//   <StrictMode>\n//     <ThemeProvider>\n//       <App />\n//     </ThemeProvider>\n//   </StrictMode>\n// );\n"}],"isError":false,"timestamp":1776131904918}}
