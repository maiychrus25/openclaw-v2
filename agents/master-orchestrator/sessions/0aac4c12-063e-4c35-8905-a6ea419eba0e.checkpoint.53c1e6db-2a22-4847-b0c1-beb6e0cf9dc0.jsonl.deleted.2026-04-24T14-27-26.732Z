{"type":"message","id":"0b0b24e8","parentId":"4fb8bced","timestamp":"2026-04-19T04:39:57.120Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me create more content and features. I'll add:\n\n1. Reading progress bar component\n2. Social sharing buttons\n3. 7 more articles (to have 15 total)\n4. Tags page\n5. Better 404 page\n6. Code syntax highlighting\n\nLet me write these in parallel.","thinkingSignature":"9ce468b2d25de3b949b05e7591a094eccc8257b99301eaf5b84b0d45ae2865df"},{"type":"toolCall","id":"call_function_kk016mswvrq5_1","name":"write","arguments":{"path":"/root/.openclaw/workspaces2/v4-ecosystem-review/maiy-tech-hub/components/blog/reading-progress.tsx","content":"'use client'\n\nimport { useState, useEffect, useRef } from 'react'\n\nexport function ReadingProgress() {\n  const [progress, setProgress] = useState(0)\n  const [visible, setVisible] = useState(false)\n  const articleRef = useRef<HTMLElement | null>(null)\n\n  useEffect(() => {\n    // Find the main article element\n    articleRef.current = document.querySelector('article') || \n      document.querySelector('[data-article-content]') ||\n      document.querySelector('.prose')\n\n    if (!articleRef.current) {\n      // Fallback: track scroll on entire page\n      articleRef.current = document.documentElement\n    }\n\n    const handleScroll = () => {\n      const el = articleRef.current\n      if (!el) return\n\n      const scrollTop = window.scrollY\n      const scrollHeight = el === document.documentElement \n        ? document.documentElement.scrollHeight - window.innerHeight\n        : el.scrollHeight - el.clientHeight\n\n      if (scrollHeight <= 0) return\n\n      const pct = Math.min(100, Math.max(0, (scrollTop / scrollHeight) * 100))\n      setProgress(pct)\n      setVisible(scrollTop > 200)\n    }\n\n    window.addEventListener('scroll', handleScroll, { passive: true })\n    handleScroll()\n    return () => window.removeEventListener('scroll', handleScroll)\n  }, [])\n\n  if (!visible) return null\n\n  return (\n    <div className=\"fixed top-0 left-0 right-0 z-[60] h-1 bg-border/40\">\n      <div\n        className=\"h-full bg-gradient-to-r from-indigo-500 to-purple-500 transition-all duration-75\"\n        style={{ width: `${progress}%` }}\n        role=\"progressbar\"\n        aria-valuenow={Math.round(progress)}\n        aria-valuemin={0}\n        aria-valuemax={100}\n        aria-label=\"Tiến độ đọc bài viết\"\n      />\n    </div>\n  )\n}\n"}},{"type":"toolCall","id":"call_function_kk016mswvrq5_2","name":"write","arguments":{"path":"/root/.openclaw/workspaces2/v4-ecosystem-review/maiy-tech-hub/components/blog/social-share.tsx","content":"'use client'\n\nimport { useState } from 'react'\nimport { Share2, Twitter, Facebook, Link2, Check } from 'lucide-react'\nimport { Button } from '@/components/ui/button'\nimport {\n  Dialog,\n  DialogContent,\n  DialogHeader,\n  DialogTitle,\n  DialogTrigger,\n} from '@/components/ui/dialog'\n\ninterface SocialShareProps {\n  title: string\n  url?: string\n}\n\nexport function SocialShare({ title, url }: SocialShareProps) {\n  const [copied, setCopied] = useState(false)\n\n  const shareUrl = url || (typeof window !== 'undefined' ? window.location.href : '')\n  const encodedUrl = encodeURIComponent(shareUrl)\n  const encodedTitle = encodeURIComponent(title)\n\n  const handleCopy = async () => {\n    try {\n      await navigator.clipboard.writeText(shareUrl)\n      setCopied(true)\n      setTimeout(() => setCopied(false), 2000)\n    } catch {\n      // Fallback\n    }\n  }\n\n  return (\n    <Dialog>\n      <DialogTrigger asChild>\n        <Button variant=\"outline\" size=\"sm\" className=\"gap-2\">\n          <Share2 className=\"h-4 w-4\" />\n          Chia sẻ\n        </Button>\n      </DialogTrigger>\n      <DialogContent className=\"sm:max-w-md\">\n        <DialogHeader>\n          <DialogTitle>Chia sẻ bài viết</DialogTitle>\n        </DialogHeader>\n        <div className=\"space-y-3\">\n          <a\n            href={`https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`}\n            target=\"_blank\"\n            rel=\"noopener noreferrer\"\n            className=\"flex items-center gap-3 p-3 rounded-lg border border-border hover:bg-accent transition-colors\"\n          >\n            <Twitter className=\"h-5 w-5 text-sky-500\" />\n            <span className=\"text-sm font-medium\">Chia sẻ lên Twitter</span>\n          </a>\n          <a\n            href={`https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`}\n            target=\"_blank\"\n            rel=\"noopener noreferrer\"\n            className=\"flex items-center gap-3 p-3 rounded-lg border border-border hover:bg-accent transition-colors\"\n          >\n            <Facebook className=\"h-5 w-5 text-blue-600\" />\n            <span className=\"text-sm font-medium\">Chia sẻ lên Facebook</span>\n          </a>\n          <button\n            onClick={handleCopy}\n            className=\"w-full flex items-center gap-3 p-3 rounded-lg border border-border hover:bg-accent transition-colors\"\n          >\n            {copied ? (\n              <Check className=\"h-5 w-5 text-green-500\" />\n            ) : (\n              <Link2 className=\"h-5 w-5 text-muted-foreground\" />\n            )}\n            <span className=\"text-sm font-medium\">\n              {copied ? 'Đã copy!' : 'Copy link'}\n            </span>\n          </button>\n        </div>\n      </DialogContent>\n    </Dialog>\n  )\n}\n"}},{"type":"toolCall","id":"call_function_kk016mswvrq5_3","name":"write","arguments":{"path":"/root/.openclaw/workspaces2/v4-ecosystem-review/maiy-tech-hub/components/blog/toc.tsx","content":"'use client'\n\nimport { useState, useEffect } from 'react'\nimport { List } from 'lucide-react'\nimport { cn } from '@/lib/utils'\n\ninterface Heading {\n  id: string\n  text: string\n  level: number\n}\n\ninterface TableOfContentsProps {\n  headings?: Heading[]\n}\n\nexport function TableOfContents({ headings = [] }: TableOfContentsProps) {\n  const [activeId, setActiveId] = useState<string>('')\n  const [tocHeadings, setTocHeadings] = useState<Heading[]>(headings)\n\n  // Auto-extract from article if not provided\n  useEffect(() => {\n    if (headings.length > 0) return\n\n    const article = document.querySelector('article') || document.querySelector('.prose')\n    if (!article) return\n\n    const elements = article.querySelectorAll('h2, h3')\n    const extracted: Heading[] = []\n    elements.forEach((el) => {\n      const text = el.textContent || ''\n      const id = el.id || text.toLowerCase().replace(/\\s+/g, '-').replace(/[^\\w-]/g, '')\n      if (!el.id) el.id = id\n      extracted.push({ id, text, level: parseInt(el.tagName[1]) })\n    })\n    setTocHeadings(extracted)\n  }, [headings])\n\n  useEffect(() => {\n    if (tocHeadings.length === 0) return\n\n    const observer = new IntersectionObserver(\n      (entries) => {\n        const visible = entries.filter((e) => e.isIntersecting)\n        if (visible.length > 0) {\n          setActiveId(visible[0].target.id)\n        }\n      },\n      { rootMargin: '-80px 0px -70% 0px', threshold: 0 }\n    )\n\n    tocHeadings.forEach(({ id }) => {\n      const el = document.getElementById(id)\n      if (el) observer.observe(el)\n    })\n\n    return () => observer.disconnect()\n  }, [tocHeadings])\n\n  if (tocHeadings.length < 3) return null\n\n  return (\n    <nav className=\"space-y-1\" aria-label=\"Mục lục bài viết\">\n      <div className=\"flex items-center gap-2 mb-3 text-xs font-semibold text-muted-foreground uppercase tracking-wider\">\n        <List className=\"h-3 w-3\" />\n        Mục lục\n      </div>\n      {tocHeadings.map((h) => (\n        <a\n          key={h.id}\n          href={`#${h.id}`}\n          className={cn(\n            'block text-sm py-1 transition-colors hover:text-primary',\n            h.level === 3 && 'pl-4',\n            activeId === h.id\n              ? 'text-primary font-medium'\n              : 'text-muted-foreground'\n          )}\n        >\n          {h.text}\n        </a>\n      ))}\n    </nav>\n  )\n}\n"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":141,"output":2010,"cacheRead":47678,"cacheWrite":714,"totalTokens":50543,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776573574636,"responseId":"06338f87c1c232c1e9ab1e69f5051d29"}}
