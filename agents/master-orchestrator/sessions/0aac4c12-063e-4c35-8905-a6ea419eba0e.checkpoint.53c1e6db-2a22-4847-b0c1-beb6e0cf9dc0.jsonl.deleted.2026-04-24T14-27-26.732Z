{"type":"message","id":"68b00efe","parentId":"0507deb9","timestamp":"2026-04-19T03:46:29.277Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me write the SEO components (breadcrumbs, article-schema), and then the music page, study page, and search page.","thinkingSignature":"37319793b971cffcc5f74096b4a6128e8e4a5a797b2cf60546093c3b74da3c2b"},{"type":"toolCall","id":"call_function_6y5nlm7zwc1t_1","name":"write","arguments":{"path":"/root/.openclaw/workspaces2/v4-ecosystem-review/maiy-tech-hub/components/seo/breadcrumbs.tsx","content":"import Link from 'next/link'\nimport { ChevronRight, Home } from 'lucide-react'\n\ninterface BreadcrumbItem {\n  label: string\n  href?: string\n}\n\ninterface BreadcrumbsProps {\n  items: BreadcrumbItem[]\n}\n\nexport function Breadcrumbs({ items }: BreadcrumbsProps) {\n  return (\n    <nav aria-label=\"Breadcrumb\" className=\"mb-6\">\n      <ol className=\"flex items-center gap-1 text-sm text-muted-foreground flex-wrap\">\n        <li>\n          <Link href=\"/\" className=\"hover:text-primary transition-colors\">\n            <Home className=\"h-4 w-4\" />\n          </Link>\n        </li>\n        {items.map((item, i) => (\n          <li key={i} className=\"flex items-center gap-1\">\n            <ChevronRight className=\"h-3 w-3\" />\n            {item.href ? (\n              <Link\n                href={item.href}\n                className=\"hover:text-primary transition-colors capitalize\"\n              >\n                {item.label}\n              </Link>\n            ) : (\n              <span className=\"text-foreground capitalize truncate max-w-[200px]\">\n                {item.label}\n              </span>\n            )}\n          </li>\n        ))}\n      </ol>\n    </nav>\n  )\n}\n"}},{"type":"toolCall","id":"call_function_6y5nlm7zwc1t_2","name":"write","arguments":{"path":"/root/.openclaw/workspaces2/v4-ecosystem-review/maiy-tech-hub/components/seo/article-schema.tsx","content":"import { SITE } from '@/config/site'\nimport type { ArticleSummary } from '@/components/blog/article-card'\n\nexport function ArticleSchema({ article }: { article: ArticleSummary & { content?: string } }) {\n  const schema = {\n    '@context': 'https://schema.org',\n    '@type': 'Article',\n    headline: article.title,\n    description: article.excerpt,\n    image: article.hero,\n    author: {\n      '@type': 'Person',\n      name: article.author,\n      url: `${SITE.url}/about`,\n    },\n    publisher: {\n      '@type': 'Organization',\n      name: SITE.name,\n      url: SITE.url,\n    },\n    datePublished: article.publishedAt,\n    mainEntityOfPage: {\n      '@type': 'WebPage',\n      '@id': `${SITE.url}/articles/${article.slug}`,\n    },\n    wordCount: article.readingTime * 200, // rough estimate\n    timeRequired: `PT${article.readingTime}M`,\n  }\n\n  return (\n    <script\n      type=\"application/ld+json\"\n      dangerouslySetInnerHTML={{ __html: JSON.stringify(schema) }}\n    />\n  )\n}\n"}},{"type":"toolCall","id":"call_function_6y5nlm7zwc1t_3","name":"write","arguments":{"path":"/root/.openclaw/workspaces2/v4-ecosystem-review/maiy-tech-hub/app/music/page.tsx","content":"'use client'\n\nimport { useState } from 'react'\nimport { Play, Pause, SkipForward, Volume2 } from 'lucide-react'\nimport { useMusic, type Track } from '@/providers/music-provider'\n\nconst MOODS = [\n  { id: 'focus', label: '🎯 Focus', description: 'Nhạc giúp tập trung làm việc' },\n  { id: 'sleep', label: '😴 Sleep', description: 'Thư giãn trước khi ngủ' },\n  { id: 'energize', label: '⚡ Energize', description: 'Cảm hứng và năng lượng' },\n  { id: 'study', label: '📚 Study', description: 'Nhạc nền khi học bài' },\n] as const\n\n// Sample playlists (replace with real data)\nconst PLAYLISTS: Record<string, Track[]> = {\n  focus: [\n    {\n      id: 'f1',\n      title: 'Lo-fi Beats to Study to',\n      artist: 'ChilledCow',\n      duration: 180,\n      mood: 'focus',\n      youtubeId: 'jfKfPfyJRdk',\n      coverUrl: 'https://picsum.photos/seed/focus1/300/300',\n    },\n    {\n      id: 'f2',\n      title: 'Deep Focus',\n      artist: 'Ambient Zone',\n      duration: 240,\n      mood: 'focus',\n      youtubeId: '5qap5aO4i9A',\n      coverUrl: 'https://picsum.photos/seed/focus2/300/300',\n    },\n  ],\n  sleep: [\n    {\n      id: 's1',\n      title: 'Rain Sounds',\n      artist: 'Nature Vibes',\n      duration: 3600,\n      mood: 'sleep',\n      youtubeId: 'pNThOQ-li0E',\n      coverUrl: 'https://picsum.photos/seed/sleep1/300/300',\n    },\n  ],\n  energize: [\n    {\n      id: 'e1',\n      title: 'Synthwave Mix',\n      artist: 'Retrowave FM',\n      duration: 300,\n      mood: 'energize',\n      youtubeId: '4xDzrJKXOOY',\n      coverUrl: 'https://picsum.photos/seed/energy1/300/300',\n    },\n  ],\n  study: [\n    {\n      id: 'st1',\n      title: 'Acoustic Study',\n      artist: 'Study Music',\n      duration: 2700,\n      mood: 'study',\n      youtubeId: 'DgPaCWJL7XI',\n      coverUrl: 'https://picsum.photos/seed/study1/300/300',\n    },\n  ],\n}\n\nexport default function MusicPage() {\n  const { currentTrack, isPlaying, play, pause, resume, skipNext } = useMusic()\n  const [activeMood, setActiveMood] = useState<string>('focus')\n\n  const playlist = PLAYLISTS[activeMood] || []\n\n  return (\n    <div className=\"container py-8\">\n      <div className=\"mb-10\">\n        <h1 className=\"text-3xl font-bold mb-2\">🎵 Relaxation Zone</h1>\n        <p className=\"text-muted-foreground\">\n          Âm nhạc giúp bạn tập trung và thư giãn. Mini-player hoạt động xuyên suốt mọi trang.\n        </p>\n      </div>\n\n      {/* Mood selector */}\n      <div className=\"grid grid-cols-2 md:grid-cols-4 gap-4 mb-10\">\n        {MOODS.map((mood) => (\n          <button\n            key={mood.id}\n            onClick={() => setActiveMood(mood.id)}\n            className={`p-4 rounded-xl border text-left transition-all ${\n              activeMood === mood.id\n                ? 'border-primary bg-primary/5 shadow-sm'\n                : 'border-border hover:border-primary/50 hover:bg-accent'\n            }`}\n          >\n            <div className=\"text-2xl mb-2\">{mood.label}</div>\n            <p className=\"text-xs text-muted-foreground\">{mood.description}</p>\n          </button>\n        ))}\n      </div>\n\n      <div className=\"grid md:grid-cols-3 gap-8\">\n        {/* Now playing */}\n        <div className=\"md:col-span-2\">\n          <h2 className=\"text-sm font-semibold text-muted-foreground uppercase tracking-wider mb-4\">\n            {MOODS.find((m) => m.id === activeMood)?.label} Playlist\n          </h2>\n\n          {currentTrack && (\n            <div className=\"rounded-xl border border-border bg-card p-6 mb-6\">\n              <div className=\"flex items-center gap-4 mb-4\">\n                {currentTrack.coverUrl && (\n                  // eslint-disable-next-line @next/next/no-img-element\n                  <img\n                    src={currentTrack.coverUrl}\n                    alt={currentTrack.title}\n                    className=\"w-20 h-20 rounded-lg object-cover\"\n                  />\n                )}\n                <div>\n                  <h3 className=\"font-semibold text-lg\">{currentTrack.title}</h3>\n                  <p className=\"text-sm text-muted-foreground\">{currentTrack.artist}</p>\n                </div>\n              </div>\n\n              {/* YouTube embed */}\n              {currentTrack.youtubeId && (\n                <div className=\"aspect-video rounded-lg overflow-hidden mb-4 bg-black\">\n                  <iframe\n                    src={`https://www.youtube.com/embed/${currentTrack.youtubeId}?autoplay=1&controls=1`}\n                    className=\"w-full h-full\"\n                    allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture\"\n                    allowFullScreen\n                    title={currentTrack.title}\n                  />\n                </div>\n              )}\n\n              <div className=\"flex items-center gap-3\">\n                <button\n                  onClick={isPlaying ? pause : resume}\n                  className=\"flex-1 inline-flex items-center justify-center gap-2 px-4 py-2.5 rounded-lg bg-primary text-primary-foreground font-medium hover:bg-primary/90 transition-colors\"\n                >\n                  {isPlaying ? (\n                    <>\n                      <Pause className=\"h-4 w-4\" /> Tạm dừng\n                    </>\n                  ) : (\n                    <>\n                      <Play className=\"h-4 w-4\" /> Phát\n                    </>\n                  )}\n                </button>\n                <button\n                  onClick={skipNext}\n                  className=\"px-4 py-2.5 rounded-lg border border-border hover:bg-accent transition-colors\"\n                >\n                  <SkipForward className=\"h-4 w-4\" />\n                </button>\n              </div>\n            </div>\n          )}\n\n          {/* Track list */}\n          <div className=\"space-y-1\">\n            {playlist.map((track, i) => (\n              <button\n                key={track.id}\n                onClick={() => play(track)}\n                className={`w-full flex items-center gap-3 p-3 rounded-lg text-left transition-all ${\n                  currentTrack?.id === track.id\n                    ? 'bg-primary/10 border border-primary/30'\n                    : 'hover:bg-accent'\n                }`}\n              >\n                <span className=\"w-6 text-center text-muted-foreground text-sm\">{i + 1}</span>\n                {track.coverUrl && (\n                  // eslint-disable-next-line @next/next/no-img-element\n                  <img\n                    src={track.coverUrl}\n                    alt=\"\"\n                    className=\"w-10 h-10 rounded object-cover\"\n                  />\n                )}\n                <div className=\"flex-1 min-w-0\">\n                  <p className=\"text-sm font-medium truncate\">{track.title}</p>\n                  <p className=\"text-xs text-muted-foreground truncate\">{track.artist}</p>\n                </div>\n                <span className=\"text-xs text-muted-foreground\">\n                  {Math.floor(track.duration / 60)}:{String(track.duration % 60).padStart(2, '0')}\n                </span>\n              </button>\n            ))}\n          </div>\n        </div>\n\n        {/* Sidebar */}\n        <div>\n          <h2 className=\"text-sm font-semibold text-muted-foreground uppercase tracking-wider mb-4\">\n            Tất cả playlists\n          </h2>\n          <div className=\"space-y-2\">\n            {MOODS.map((mood) => (\n              <button\n                key={mood.id}\n                onClick={() => setActiveMood(mood.id)}\n                className={`w-full flex items-center gap-3 p-3 rounded-lg text-left transition-all ${\n                  activeMood === mood.id\n                    ? 'bg-primary/10 border border-primary/30'\n                    : 'hover:bg-accent border border-transparent'\n                }`}\n              >\n                <span className=\"text-xl\">{mood.label.split(' ')[0]}</span>\n                <div>\n                  <p className=\"text-sm font-medium\">{mood.label.split(' ').slice(1).join(' ')}</p>\n                  <p className=\"text-xs text-muted-foreground\">\n                    {PLAYLISTS[mood.id]?.length || 0} tracks\n                  </p>\n                </div>\n              </button>\n            ))}\n          </div>\n        </div>\n      </div>\n    </div>\n  )\n}\n"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":146,"output":2804,"cacheRead":83725,"cacheWrite":4461,"totalTokens":91136,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776570359100,"responseId":"063382f82938428f98302a3f6f8bfedd"}}
