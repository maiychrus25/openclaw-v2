{"type":"message","id":"34fac855","parentId":"ddfea494","timestamp":"2026-04-19T05:05:25.066Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me create the admin login page and admin layout.","thinkingSignature":"1d894babf69c865e0e6aa5b83c42b4dcd5d4253ac23162348c2697e1ca0a8e72"},{"type":"toolCall","id":"call_function_n57dd9gmyls3_1","name":"write","arguments":{"path":"/root/.openclaw/workspaces2/v4-ecosystem-review/maiy-tech-hub/app/admin/login/page.tsx","content":"'use client'\n\nimport { useState } from 'react'\nimport { useRouter } from 'next/navigation'\nimport { Lock, Eye, EyeOff, Loader2 } from 'lucide-react'\n\nexport default function AdminLoginPage() {\n  const [password, setPassword] = useState('')\n  const [showPw, setShowPw] = useState(false)\n  const [loading, setLoading] = useState(false)\n  const [error, setError] = useState('')\n  const router = useRouter()\n\n  const handleLogin = async (e: React.FormEvent) => {\n    e.preventDefault()\n    if (!password.trim()) return\n\n    setLoading(true)\n    setError('')\n    try {\n      const res = await fetch('/api/auth/login', {\n        method: 'POST',\n        headers: { 'Content-Type': 'application/json' },\n        body: JSON.stringify({ password }),\n      })\n      if (res.ok) {\n        router.push('/admin')\n        router.refresh()\n      } else {\n        setError('Mật khẩu không đúng')\n      }\n    } catch {\n      setError('Có lỗi xảy ra')\n    } finally {\n      setLoading(false)\n    }\n  }\n\n  return (\n    <div className=\"min-h-screen flex items-center justify-center bg-muted/30 px-4\">\n      <div className=\"w-full max-w-sm\">\n        <div className=\"bg-background rounded-2xl border border-border p-8 shadow-sm\">\n          <div className=\"text-center mb-8\">\n            <div className=\"inline-flex items-center justify-center w-12 h-12 rounded-full bg-primary/10 mb-4\">\n              <Lock className=\"h-6 w-6 text-primary\" />\n            </div>\n            <h1 className=\"text-xl font-bold\">Admin Login</h1>\n            <p className=\"text-sm text-muted-foreground mt-1\">\n              MAIY Tech Hub Administration\n            </p>\n          </div>\n\n          <form onSubmit={handleLogin} className=\"space-y-4\">\n            <div className=\"relative\">\n              <input\n                type={showPw ? 'text' : 'password'}\n                value={password}\n                onChange={(e) => setPassword(e.target.value)}\n                placeholder=\"Enter admin password\"\n                className=\"w-full px-4 py-3 rounded-lg border border-border bg-background text-sm focus:outline-none focus:ring-2 focus:ring-ring pr-10\"\n                autoFocus\n              />\n              <button\n                type=\"button\"\n                onClick={() => setShowPw(!showPw)}\n                className=\"absolute right-3 top-1/2 -translate-y-1/2 text-muted-foreground hover:text-foreground\"\n                tabIndex={-1}\n              >\n                {showPw ? (\n                  <EyeOff className=\"h-4 w-4\" />\n                ) : (\n                  <Eye className=\"h-4 w-4\" />\n                )}\n              </button>\n            </div>\n\n            {error && (\n              <p className=\"text-sm text-red-500 text-center\">{error}</p>\n            )}\n\n            <button\n              type=\"submit\"\n              disabled={loading || !password.trim()}\n              className=\"w-full py-3 rounded-lg bg-primary text-primary-foreground font-medium hover:bg-primary/90 transition-colors disabled:opacity-50 flex items-center justify-center gap-2\"\n            >\n              {loading ? (\n                <Loader2 className=\"h-4 w-4 animate-spin\" />\n              ) : null}\n              {loading ? 'Đang đăng nhập...' : 'Đăng nhập'}\n            </button>\n          </form>\n\n          <p className=\"text-xs text-center text-muted-foreground mt-6\">\n            <a href=\"/\" className=\"hover:text-primary transition-colors\">\n              ← Quay về trang chủ\n            </a>\n          </p>\n        </div>\n      </div>\n    </div>\n  )\n}\n"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":111,"output":939,"cacheRead":100188,"cacheWrite":955,"totalTokens":102193,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776575112651,"responseId":"06339589997cf6166aa6fed0248ddea0"}}
