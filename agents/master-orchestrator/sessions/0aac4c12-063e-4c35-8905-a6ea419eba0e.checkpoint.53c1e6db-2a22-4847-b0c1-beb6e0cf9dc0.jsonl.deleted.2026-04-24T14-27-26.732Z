{"type":"message","id":"161444de","parentId":"625f749d","timestamp":"2026-04-19T05:06:02.131Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me create the admin dashboard page.","thinkingSignature":"c977fad6af7fb6d787e40ff8f0e51d0cbc49991084f216936b129d303efe88b7"},{"type":"toolCall","id":"call_function_plqu60e98l4q_1","name":"write","arguments":{"path":"/root/.openclaw/workspaces2/v4-ecosystem-review/maiy-tech-hub/app/admin/page.tsx","content":"import { Metadata } from 'next'\nimport Link from 'next/link'\nimport { FileText, Music, BookOpen, Eye, Calendar, Plus } from 'lucide-react'\nimport { getAllArticles } from '@/lib/content'\nimport { CATEGORIES } from '@/config/site'\n\nexport const metadata: Metadata = {\n  title: 'Dashboard — Admin',\n}\n\nexport default async function AdminDashboard() {\n  const articles = await getAllArticles()\n\n  const stats = [\n    {\n      label: 'Tổng bài viết',\n      value: articles.length,\n      icon: FileText,\n      color: 'text-indigo-500 bg-indigo-500/10',\n      href: '/admin/articles',\n    },\n    {\n      label: 'Chủ đề',\n      value: CATEGORIES.length,\n      icon: BookOpen,\n      color: 'text-purple-500 bg-purple-500/10',\n      href: '/admin/articles',\n    },\n    {\n      label: 'Music Zone',\n      value: 'Live',\n      icon: Music,\n      color: 'text-pink-500 bg-pink-500/10',\n      href: '/music',\n    },\n    {\n      label: 'Trang chủ',\n      value: 'Live',\n      icon: Eye,\n      color: 'text-green-500 bg-green-500/10',\n      href: '/',\n    },\n  ]\n\n  return (\n    <div className=\"space-y-8\">\n      <div className=\"flex items-center justify-between\">\n        <div>\n          <h1 className=\"text-2xl font-bold\">Dashboard</h1>\n          <p className=\"text-sm text-muted-foreground mt-1\">\n            Chào mừng đến MAIY Tech Hub Admin\n          </p>\n        </div>\n        <Link\n          href=\"/admin/articles/new\"\n          className=\"inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-primary text-primary-foreground font-medium text-sm hover:bg-primary/90 transition-colors\"\n        >\n          <Plus className=\"h-4 w-4\" />\n          Bài viết mới\n        </Link>\n      </div>\n\n      {/* Stats */}\n      <div className=\"grid grid-cols-2 md:grid-cols-4 gap-4\">\n        {stats.map((stat) => (\n          <div\n            key={stat.label}\n            className=\"rounded-xl border border-border bg-background p-5 hover:border-primary/30 transition-colors\"\n          >\n            <div className={`inline-flex p-2 rounded-lg ${stat.color} mb-3`}>\n              <stat.icon className=\"h-5 w-5\" />\n            </div>\n            <div className=\"text-2xl font-bold\">{stat.value}</div>\n            <div className=\"text-sm text-muted-foreground\">{stat.label}</div>\n          </div>\n        ))}\n      </div>\n\n      {/* Quick actions */}\n      <div>\n        <h2 className=\"text-sm font-semibold text-muted-foreground uppercase tracking-wider mb-4\">\n          Thao tác nhanh\n        </h2>\n        <div className=\"grid grid-cols-1 md:grid-cols-3 gap-4\">\n          <Link\n            href=\"/admin/articles\"\n            className=\"rounded-xl border border-border p-5 hover:border-primary/50 hover:bg-accent/30 transition-all group\"\n          >\n            <div className=\"flex items-center justify-between mb-3\">\n              <div className=\"p-2 rounded-lg bg-primary/10\">\n                <FileText className=\"h-4 w-4 text-primary\" />\n              </div>\n              <span className=\"text-xs text-muted-foreground group-hover:text-primary transition-colors\">\n                →\n              </span>\n            </div>\n            <h3 className=\"font-semibold mb-1\">Quản lý bài viết</h3>\n            <p className=\"text-sm text-muted-foreground\">\n              Xem, sửa, xóa bài viết\n            </p>\n          </Link>\n\n          <Link\n            href=\"/admin/music\"\n            className=\"rounded-xl border border-border p-5 hover:border-primary/50 hover:bg-accent/30 transition-all group\"\n          >\n            <div className=\"flex items-center justify-between mb-3\">\n              <div className=\"p-2 rounded-lg bg-pink-500/10\">\n                <Music className=\"h-4 w-4 text-pink-500\" />\n              </div>\n              <span className=\"text-xs text-muted-foreground group-hover:text-primary transition-colors\">\n                →\n              </span>\n            </div>\n            <h3 className=\"font-semibold mb-1\">Quản lý nhạc</h3>\n            <p className=\"text-sm text-muted-foreground\">\n              Thêm playlist, quản lý track\n            </p>\n          </Link>\n\n          <a\n            href=\"/\"\n            target=\"_blank\"\n            className=\"rounded-xl border border-border p-5 hover:border-primary/50 hover:bg-accent/30 transition-all group\"\n          >\n            <div className=\"flex items-center justify-between mb-3\">\n              <div className=\"p-2 rounded-lg bg-green-500/10\">\n                <Eye className=\"h-4 w-4 text-green-500\" />\n              </div>\n              <span className=\"text-xs text-muted-foreground group-hover:text-primary transition-colors\">\n                →\n              </span>\n            </div>\n            <h3 className=\"font-semibold mb-1\">Xem website</h3>\n            <p className=\"text-sm text-muted-foreground\">\n              Mở trang chủ trong tab mới\n            </p>\n          </a>\n        </div>\n      </div>\n\n      {/* Recent articles */}\n      <div>\n        <div className=\"flex items-center justify-between mb-4\">\n          <h2 className=\"text-sm font-semibold text-muted-foreground uppercase tracking-wider\">\n            Bài viết gần đây\n          </h2>\n          <Link\n            href=\"/admin/articles\"\n            className=\"text-sm text-primary hover:underline\"\n          >\n            Xem tất cả\n          </Link>\n        </div>\n\n        <div className=\"rounded-xl border border-border overflow-hidden\">\n          <table className=\"w-full text-sm\">\n            <thead className=\"border-b border-border bg-muted/30\">\n              <tr>\n                <th className=\"text-left px-4 py-3 font-medium text-muted-foreground\">\n                  Tiêu đề\n                </th>\n                <th className=\"text-left px-4 py-3 font-medium text-muted-foreground hidden md:table-cell\">\n                  Chủ đề\n                </th>\n                <th className=\"text-left px-4 py-3 font-medium text-muted-foreground hidden sm:table-cell\">\n                  <Calendar className=\"h-3.5 w-3.5 inline\" /> Ngày\n                </th>\n                <th className=\"text-right px-4 py-3 font-medium text-muted-foreground\">\n                  Thao tác\n                </th>\n              </tr>\n            </thead>\n            <tbody className=\"divide-y divide-border\">\n              {articles.slice(0, 5).map((article) => (\n                <tr key={article.slug} className=\"hover:bg-accent/30 transition-colors\">\n                  <td className=\"px-4 py-3\">\n                    <div className=\"font-medium line-clamp-1\">{article.title}</div>\n                    <div className=\"text-xs text-muted-foreground\">{article.readingTime} phút đọc</div>\n                  </td>\n                  <td className=\"px-4 py-3 hidden md:table-cell\">\n                    <span className=\"px-2 py-0.5 text-xs rounded-full bg-primary/10 text-primary\">\n                      {article.category}\n                    </span>\n                  </td>\n                  <td className=\"px-4 py-3 text-muted-foreground hidden sm:table-cell\">\n                    {new Date(article.publishedAt).toLocaleDateString('vi-VN')}\n                  </td>\n                  <td className=\"px-4 py-3 text-right\">\n                    <Link\n                      href={`/admin/articles/${article.slug}`}\n                      className=\"text-xs text-primary hover:underline\"\n                    >\n                      Sửa\n                    </Link>\n                  </td>\n                </tr>\n              ))}\n            </tbody>\n          </table>\n        </div>\n      </div>\n    </div>\n  )\n}\n"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":111,"output":1947,"cacheRead":102175,"cacheWrite":975,"totalTokens":105208,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776575140899,"responseId":"063395a673bd5b2db755ee595e01da1e"}}
