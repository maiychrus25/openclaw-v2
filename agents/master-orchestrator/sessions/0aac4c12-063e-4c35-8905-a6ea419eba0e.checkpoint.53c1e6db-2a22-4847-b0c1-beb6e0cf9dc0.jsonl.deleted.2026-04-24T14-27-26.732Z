{"type":"message","id":"e54230d6","parentId":"81ca594d","timestamp":"2026-04-19T05:06:18.599Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me create the admin articles list page and the article editor (simple).","thinkingSignature":"a22e4cf3bf9c9c7f8cfcb2a39f36c3f82e3cc6bcca2e2753472c75cae2db870d"},{"type":"toolCall","id":"call_function_hs8klls7nq4r_1","name":"write","arguments":{"path":"/root/.openclaw/workspaces2/v4-ecosystem-review/maiy-tech-hub/app/admin/articles/page.tsx","content":"import { Metadata } from 'next'\nimport Link from 'next/link'\nimport { Plus, FileText, Trash2, Edit, Eye } from 'lucide-react'\nimport { getAllArticles } from '@/lib/content'\nimport { CATEGORIES } from '@/config/site'\n\nexport const metadata: Metadata = {\n  title: 'Quản lý bài viết — Admin',\n}\n\nexport default async function AdminArticlesPage() {\n  const articles = await getAllArticles()\n\n  return (\n    <div className=\"space-y-6\">\n      <div className=\"flex items-center justify-between\">\n        <div>\n          <h1 className=\"text-2xl font-bold\">Quản lý bài viết</h1>\n          <p className=\"text-sm text-muted-foreground mt-1\">\n            {articles.length} bài viết\n          </p>\n        </div>\n        <Link\n          href=\"/admin/articles/new\"\n          className=\"inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-primary text-primary-foreground font-medium text-sm hover:bg-primary/90 transition-colors\"\n        >\n          <Plus className=\"h-4 w-4\" />\n          Bài viết mới\n        </Link>\n      </div>\n\n      {/* Category filter */}\n      <div className=\"flex flex-wrap gap-2\">\n        <Link\n          href=\"/admin/articles\"\n          className=\"px-3 py-1.5 rounded-full text-sm font-medium bg-primary text-primary-foreground\"\n        >\n          Tất cả ({articles.length})\n        </Link>\n        {CATEGORIES.map((cat) => {\n          const count = articles.filter((a) => a.category === cat.slug).length\n          return (\n            <Link\n              key={cat.slug}\n              href={`/admin/articles?category=${cat.slug}`}\n              className=\"px-3 py-1.5 rounded-full text-sm font-medium border border-border hover:border-primary/50 hover:bg-primary/5 transition-all\"\n            >\n              {cat.label} ({count})\n            </Link>\n          )\n        })}\n      </div>\n\n      {/* Articles table */}\n      <div className=\"rounded-xl border border-border overflow-hidden\">\n        <table className=\"w-full text-sm\">\n          <thead className=\"border-b border-border bg-muted/30\">\n            <tr>\n              <th className=\"text-left px-4 py-3 font-medium text-muted-foreground\">\n                Tiêu đề\n              </th>\n              <th className=\"text-left px-4 py-3 font-medium text-muted-foreground hidden md:table-cell\">\n                Chủ đề\n              </th>\n              <th className=\"text-left px-4 py-3 font-medium text-muted-foreground hidden lg:table-cell\">\n                Tags\n              </th>\n              <th className=\"text-right px-4 py-3 font-medium text-muted-foreground\">\n                Thao tác\n              </th>\n            </tr>\n          </thead>\n          <tbody className=\"divide-y divide-border\">\n            {articles.map((article) => (\n              <tr key={article.slug} className=\"hover:bg-accent/20 transition-colors\">\n                <td className=\"px-4 py-3\">\n                  <div className=\"font-medium\">{article.title}</div>\n                  <div className=\"flex items-center gap-3 mt-1\">\n                    <span className=\"text-xs text-muted-foreground\">\n                      {article.readingTime} phút\n                    </span>\n                    <span className=\"text-xs text-muted-foreground\">\n                      {new Date(article.publishedAt).toLocaleDateString('vi-VN')}\n                    </span>\n                  </div>\n                </td>\n                <td className=\"px-4 py-3 hidden md:table-cell\">\n                  <span className=\"px-2 py-0.5 text-xs rounded-full bg-primary/10 text-primary\">\n                    {article.category}\n                  </span>\n                </td>\n                <td className=\"px-4 py-3 hidden lg:table-cell\">\n                  <div className=\"flex flex-wrap gap-1\">\n                    {article.tags.slice(0, 3).map((tag) => (\n                      <span\n                        key={tag}\n                        className=\"px-1.5 py-0.5 text-xs rounded bg-muted text-muted-foreground\"\n                      >\n                        #{tag}\n                      </span>\n                    ))}\n                    {article.tags.length > 3 && (\n                      <span className=\"text-xs text-muted-foreground\">\n                        +{article.tags.length - 3}\n                      </span>\n                    )}\n                  </div>\n                </td>\n                <td className=\"px-4 py-3\">\n                  <div className=\"flex items-center justify-end gap-2\">\n                    <a\n                      href={`/articles/${article.slug}`}\n                      target=\"_blank\"\n                      className=\"p-1.5 rounded hover:bg-accent text-muted-foreground hover:text-foreground transition-colors\"\n                      title=\"Xem bài viết\"\n                    >\n                      <Eye className=\"h-3.5 w-3.5\" />\n                    </a>\n                    <Link\n                      href={`/admin/articles/${article.slug}`}\n                      className=\"p-1.5 rounded hover:bg-accent text-muted-foreground hover:text-foreground transition-colors\"\n                      title=\"Sửa bài viết\"\n                    >\n                      <Edit className=\"h-3.5 w-3.5\" />\n                    </Link>\n                    <button\n                      className=\"p-1.5 rounded hover:bg-red-500/10 text-muted-foreground hover:text-red-500 transition-colors\"\n                      title=\"Xóa bài viết\"\n                      onClick={() => {\n                        if (confirm(`Xóa bài \"${article.title}\"?`)) {\n                          // Would delete here\n                        }\n                      }}\n                    >\n                      <Trash2 className=\"h-3.5 w-3.5\" />\n                    </button>\n                  </div>\n                </td>\n              </tr>\n            ))}\n          </tbody>\n        </table>\n      </div>\n    </div>\n  )\n}\n"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":110,"output":1403,"cacheRead":102884,"cacheWrite":2262,"totalTokens":106659,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776575162240,"responseId":"063395bb966e5a93d765b00bb662020f"}}
