{"type":"message","id":"19ffab7c","parentId":"3e465ef3","timestamp":"2026-04-18T09:37:14.416Z","message":{"role":"toolResult","toolCallId":"call_function_2a7ofm4z4ss0_2","toolName":"exec","content":[{"type":"text","text":"src/infrastructure/database/models/exam.model.ts\nsrc/infrastructure/database/models/exam_batch.model.ts\nsrc/infrastructure/database/models/exam_schedule.model.ts\nsrc/domain/entities/exam_batch.entity.ts\nimport mongoose, { Schema, Document, Types } from 'mongoose';\n\nexport interface IExamSchedule extends Document {\n  exam_id: Types.ObjectId;\n  start_time: Date;\n  end_time: Date;\n  note?: string;\n  created_at: Date;\n  updated_at: Date;\n}\n\nconst ExamScheduleSchema = new Schema<IExamSchedule>({\n  exam_id: { type: Schema.Types.ObjectId, ref: 'Exams', required: true, index: true },\n  start_time: { type: Date, required: true },\n  end_time: { type: Date, required: true },\n  note: { type: String, default: '' },\n}, {\n  timestamps: { createdAt: 'created_at', updatedAt: 'updated_at' },\n  versionKey: false,\n  collection: 'examschedules'\n});\n\nExamScheduleSchema.index({ start_time: -1 });\nExamScheduleSchema.index({ start_time: 1, end_time: 1 });\n\nexport const ExamScheduleModel = mongoose.models.ExamSchedules || mongoose.model<IExamSchedule>('ExamSchedules', ExamScheduleSchema, 'examschedules');"}],"details":{"status":"completed","exitCode":0,"durationMs":164,"aggregated":"src/infrastructure/database/models/exam.model.ts\nsrc/infrastructure/database/models/exam_batch.model.ts\nsrc/infrastructure/database/models/exam_schedule.model.ts\nsrc/domain/entities/exam_batch.entity.ts\nimport mongoose, { Schema, Document, Types } from 'mongoose';\n\nexport interface IExamSchedule extends Document {\n  exam_id: Types.ObjectId;\n  start_time: Date;\n  end_time: Date;\n  note?: string;\n  created_at: Date;\n  updated_at: Date;\n}\n\nconst ExamScheduleSchema = new Schema<IExamSchedule>({\n  exam_id: { type: Schema.Types.ObjectId, ref: 'Exams', required: true, index: true },\n  start_time: { type: Date, required: true },\n  end_time: { type: Date, required: true },\n  note: { type: String, default: '' },\n}, {\n  timestamps: { createdAt: 'created_at', updatedAt: 'updated_at' },\n  versionKey: false,\n  collection: 'examschedules'\n});\n\nExamScheduleSchema.index({ start_time: -1 });\nExamScheduleSchema.index({ start_time: 1, end_time: 1 });\n\nexport const ExamScheduleModel = mongoose.models.ExamSchedules || mongoose.model<IExamSchedule>('ExamSchedules', ExamScheduleSchema, 'examschedules');","cwd":"/root/.openclaw/workspaces2/v4-ecosystem-review/master-orchestrator"},"isError":false,"timestamp":1776505034371}}
{"type":"message","id":"7bbff740","parentId":"19ffab7c","timestamp":"2026-04-18T09:37:18.981Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me look at the sat-hach page and ResultModal on the FE to understand what's currently implemented.","thinkingSignature":"1425e11e9c973dbff2608c678a6bf2c80e18620aa1b7ed799e1658c483fefd3f"},{"type":"toolCall","id":"call_function_8tszx5ikdpru_1","name":"exec","arguments":{"command":"cat /root/.openclaw/workspaces/teacher-driving-training-system.bootstrap-backup/ahv-qlhv-fe/src/app/sat-hach/page.tsx","timeout":10}},{"type":"toolCall","id":"call_function_8tszx5ikdpru_2","name":"exec","arguments":{"command":"cat /root/.openclaw/workspaces/teacher-driving-training-system.bootstrap-backup/ahv-qlhv-fe/src/components/sat-hach/ResultModal.tsx","timeout":10}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":1137,"output":151,"cacheRead":26008,"cacheWrite":1131,"totalTokens":28427,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776505034419,"responseId":"063283cbfdcfe7649ec6789b4274f7ea"}}
{"type":"message","id":"3b4d4e2a","parentId":"7bbff740","timestamp":"2026-04-18T09:37:19.357Z","message":{"role":"toolResult","toolCallId":"call_function_8tszx5ikdpru_1","toolName":"exec","content":[{"type":"text","text":"\"use client\";\n\nimport React, { useState, useEffect } from 'react';\nimport {\n  Trophy, Plus, Download, Search, ChevronDown, ChevronUp,\n  Edit2, Trash2, MapPin, CalendarDays, CheckCircle2,\n  Clock, X, Users, AlertCircle, UserMinus, ClipboardCheck\n} from 'lucide-react';\nimport { toast } from 'sonner';\nimport UnderDevelopment from '@/src/components/shared/UnderDevelopment';\nimport ExamModal, { ExamData } from '@/src/components/sat-hach/ExamModal';\nimport StudentDetailDrawer from '@/src/components/students/StudentDetailDrawer';\nimport AssignExamModal from '@/src/components/sat-hach/AssignExamModal';\nimport ResultModal from '@/src/components/sat-hach/ResultModal';\nimport { getExamBatches, getEligibleStudents, deleteExamBatch, updateExamBatch, getBatchById, exportExamBatchesToExcel } from '@/src/services/examService';\nimport { updateStudent, getLicenseCategories } from '@/src/services/studentService';\nimport { getCities, City } from '@/src/services/cityService';\nimport ConfirmModal from '@/src/components/shared/ConfirmModal';\nimport ViDateInput from '@/src/components/shared/ViDateInput';\nimport { useAuth } from '@/src/context/AuthContext';\n\n/* ─── Mock data remains as fallback if needed ──────── */\nconst EMPTY_EXAMS: any[] = [];\nconst EMPTY_STUDENTS: any[] = [];\n\n/* ─── helpers ───────────────────────────────────────── */\nconst examStatusMeta: Record<string, { label: string; cls: string }> = {\n  upcoming:  { label: 'Sắp diễn ra',          cls: 'bg-amber-50  text-amber-600  border-amber-200'  },\n  scheduled: { label: 'Đã lên lịch',          cls: 'bg-indigo-50 text-indigo-600 border-indigo-200' },\n  confirmed: { label: 'Đã xác nhận lịch',     cls: 'bg-blue-50   text-blue-600   border-blue-200'   },\n  completed: { label: 'Đã hoàn thành',         cls: 'bg-emerald-50 text-emerald-600 border-emerald-200' },\n  cancelled: { label: 'Đã hủy',               cls: 'bg-gray-100  text-gray-500   border-gray-200'   },\n};\n\nconst vehicleBadge = (v: string) =>\n  v === 'Xe máy'\n    ? 'bg-orange-50 text-orange-600 border-orange-200'\n    : 'bg-indigo-50 text-indigo-600 border-indigo-200';\n\n/* ─── page ───────────────────────────────────────────── */\nexport default function SatHachPage() {\n  const { user } = useAuth();\n  const [activeTab, setActiveTab]       = useState<'exams' | 'no-schedule'>('exams');\n  const [expandedId, setExpandedId]     = useState<string | null>(null);\n  const [modalOpen, setModalOpen]       = useState(false);\n  const [editData, setEditData]         = useState<ExamData | null>(null);\n  const [selectedStudent, setSelectedStudent] = useState<any>(null);\n  const [assignStudent, setAssignStudent]     = useState<any>(null);\n  \n  const [exams, setExams] = useState<any[]>([]);\n  const [studentsWithoutSchedule, setStudentsWithoutSchedule] = useState<any[]>([]);\n  const [deleteModalOpen, setDeleteModalOpen] = useState(false);\n  const [batchToDelete, setBatchToDelete] = useState<{ id: string, name: string } | null>(null);\n  const [loading, setLoading] = useState(true);\n  const [studentsLoading, setStudentsLoading] = useState(false);\n  const [isExporting, setIsExporting] = useState(false);\n  const [licenseCategories, setLicenseCategories] = useState<any[]>([]);\n\n  // Pagination for Students\n  const [studentsPage, setStudentsPage] = useState(1);\n  const [studentsTotal, setStudentsTotal] = useState(0);\n  const STUDENT_LIMIT = 20;\n\n  // Mapper helper\n  const mapStudentForDrawer = (s: any) => {\n    if (!s) return null;\n    // Case 1: Simple object from exam.studentResults\n    if (!s.user_id && s.name) {\n      return {\n        id: s.student_id || s._id || s.id,\n        name: s.name,\n        phone: '—', rank: '—', region: '—', status: '—'\n      };\n    }\n    // Case 2: Full student object from studentsWithoutSchedule\n    return {\n      id: s._id || s.id,\n      name: `${s.user_id?.last_name || ''} ${s.user_id?.first_name || ''}`.trim() || 'Học viên',\n      phone: s.user_id?.phone || '—',\n      rank: s.course_id?.level || '—',\n      region: s.region?.name || s.region || '—',\n      status: s.status_detail || s.status || '—'\n    };\n  };\n\n  // Result Modal State\n  const [resultModalOpen, setResultModalOpen] = useState(false);\n  const [targetStudentForResults, setTargetStudentForResults] = useState<any>(null);\n  const [targetBatchForResults, setTargetBatchForResults] = useState<any>(null);\n\n  // Removal Confirmation\n  const [removeConfirmOpen, setRemoveConfirmOpen] = useState(false);\n  const [studentToRemove, setStudentToRemove] = useState<{ id: string, name: string, batchId: string } | null>(null);\n\n  // filters\n  const [fromDate, setFromDate]         = useState('');\n  const [toDate, setToDate]             = useState('');\n  const [filterVehicle, setFilterVehicle] = useState('');\n  const [filterStatus, setFilterStatus] = useState('');\n  const [search, setSearch]             = useState('');\n\n  const fetchExams = async () => {\n    try {\n      setLoading(true);\n      const res = await getExamBatches(1, 50);\n      if (res.success) {\n        // Handle standardized API envelope { data: { data: [] } } or { data: [] }\n        const list = res.data?.data || res.data?.docs || (Array.isArray(res.data) ? res.data : []);\n        setExams(list);\n      }\n    } catch (error) {\n      toast.error('Không thể tải danh sách đợt thi');\n    } finally {\n      setLoading(false);\n    }\n  };\n  const fetchEligibleStudents = async (page = 1) => {\n    try {\n      setStudentsLoading(true);\n      const res = await getEligibleStudents(page, STUDENT_LIMIT);\n      if (res.success) {\n        const list = res.data?.data || res.data?.docs || (Array.isArray(res.data) ? res.data : []);\n        setStudentsWithoutSchedule(list);\n        setStudentsTotal(res.data?.meta?.total || list.length);\n        setStudentsPage(page);\n      }\n    } catch (error) {\n      toast.error('Không thể tải danh sách học viên');\n    } finally {\n      setStudentsLoading(false);\n    }\n  };\n\n\n  const fetchLicenseCategories = async () => {\n    try {\n      const res = await getLicenseCategories();\n      if (res.success) {\n        setLicenseCategories(res.data || []);\n      }\n    } catch (error) {\n       console.error('Failed to fetch categories', error);\n    }\n  };\n\n  useEffect(() => {\n    fetchExams();\n    fetchEligibleStudents();\n    fetchLicenseCategories();\n  }, []);\n\n  const clearFilters = () => {\n    setFromDate(''); setToDate('');\n    setFilterVehicle(''); setFilterStatus('');\n    setSearch('');\n  };\n\n  const openCreate = () => { setEditData(null); setModalOpen(true); };\n  const openEdit = (exam: any) => {\n    setEditData({\n      id: exam._id, \n      name: exam.name, \n      vehicleType: exam.vehicleType,\n      region: exam.region, \n      plannedDate: exam.examDate ? new Date(exam.examDate).toISOString().split('T')[0] : '',\n      officialDate: exam.officialDate ? new Date(exam.officialDate).toISOString().split('T')[0] : '',\n      venueId: exam.stadium_id || '', // Correctly pass stadium_id\n      venueName: exam.venue,\n      examStatus: exam.status === 'done' ? 'completed' : exam.status, \n      note: '',\n    });\n    setModalOpen(true);\n  };\n\n  const handleDeleteClick = (id: string, name: string) => {\n    setBatchToDelete({ id, name });\n    setDeleteModalOpen(true);\n  };\n\n  const confirmDelete = async () => {\n    if (!batchToDelete) return;\n    try {\n      await deleteExamBatch(batchToDelete.id);\n      toast.success(`Đã xóa đợt thi: ${batchToDelete.name}`);\n      fetchExams();\n      fetchEligibleStudents(); // Refresh unscheduled list\n    } catch (err) {\n      toast.error('Lỗi khi xóa đợt thi');\n    } finally {\n      setDeleteModalOpen(false);\n      setBatchToDelete(null);\n    }\n  };\n\n  const handleRemoveClick = (batchId: string, studentId: string, name: string) => {\n    setStudentToRemove({ id: studentId, name, batchId });\n    setRemoveConfirmOpen(true);\n  };\n\n  const confirmRemoveFromBatch = async () => {\n    if (!studentToRemove) return;\n    try {\n      // 1. Get latest batch info\n      const res = await getBatchById(studentToRemove.batchId);\n      if (!res.success) throw new Error('Không thể lấy thông tin đợt thi');\n      \n      const batch = res.data;\n      const updatedResults = (batch.studentResults || []).filter((s: any) => s.student_id !== studentToRemove.id);\n      \n      // 2. Update backend batch\n      await updateExamBatch(studentToRemove.batchId, { studentResults: updatedResults });\n      \n      // 3. Restore student status to 'Thi sát hạch'\n      if (studentToRemove.id) {\n        await updateStudent(studentToRemove.id, { status_detail: 'Thi sát hạch' });\n      }\n      \n      toast.success(`Đã xóa ${studentToRemove.name} khỏi đợt thi`);\n      fetchExams();\n      fetchEligibleStudents(studentsPage); // They will reappear in unscheduled list\n    } catch (err: any) {\n      toast.error(err.message || 'Lỗi khi xóa học viên khỏi đợt thi');\n    } finally {\n      setRemoveConfirmOpen(false);\n      setStudentToRemove(null);\n    }\n  };\n\n  const openResultModal = (batch: any, studentRes: any) => {\n    setTargetBatchForResults(batch);\n    setTargetStudentForResults({\n      id: studentRes.student_id,\n      name: studentRes.name,\n      licenseClass: batch.vehicleType === 'Xe máy' ? 'A1/A2' : 'Ô tô', // Fallback or improved mapping\n      currentResult: studentRes.result,\n      currentNote: studentRes.note\n    });\n    setResultModalOpen(true);\n  };\n\n  const handleSaveResult = async (result: string, note: string) => {\n    if (!targetBatchForResults || !targetStudentForResults) return;\n    \n    try {\n      // 1. Get latest batch\n      const res = await getBatchById(targetBatchForResults._id);\n      if (!res.success) throw new Error('Cập nhật thất bại');\n      \n      const batch = res.data;\n      const updatedResults = (batch.studentResults || []).map((s: any) => {\n        if (s.student_id === targetStudentForResults.id) {\n          return { ...s, result, note };\n        }\n        return s;\n      });\n\n      // 2. Update\n      await updateExamBatch(batch._id || batch.id, { studentResults: updatedResults });\n      \n      toast.success(`Đã cập nhật kết quả cho ${targetStudentForResults.name}`);\n      fetchExams();\n    } catch (err: any) {\n      toast.error(err.message || 'Lỗi khi lưu kết quả');\n    }\n  };\n\n  const displayed = (Array.isArray(exams) ? exams : []).filter(e => {\n    if (filterVehicle && e.vehicleType !== filterVehicle) return false;\n    if (filterStatus  && e.status !== filterStatus)   return false;\n    const pDate = e.examDate ? new Date(e.examDate).toISOString().split('T')[0] : '';\n    if (fromDate && pDate < fromDate)             return false;\n    if (toDate   && pDate > toDate)               return false;\n    if (search && typeof search === 'string') {\n      const trimmedSearch = search.trim().toLowerCase();\n      if (trimmedSearch && !e.name.toLowerCase().includes(trimmedSearch)) return false;\n    }\n    return true;\n  });\n\n  const examList = Array.isArray(exams) ? exams : [];\n  const stats = [\n    { icon: <Trophy className=\"w-5 h-5 text-indigo-600\" />,  bg: 'bg-indigo-50',  label: 'Tổng đợt thi',    value: examList.length },\n    { icon: <Clock className=\"w-5 h-5 text-amber-600\" />,    bg: 'bg-amber-50',   label: 'Sắp diễn ra',     value: examList.filter(e => e.status === 'upcoming').length },\n    { icon: <CheckCircle2 className=\"w-5 h-5 text-blue-600\" />, bg: 'bg-blue-50', label: 'Đã xác nhận',     value: examList.filter(e => e.status === 'confirmed').length },\n    { icon: <CheckCircle2 className=\"w-5 h-5 text-emerald-600\" />, bg: 'bg-emerald-50', label: 'Đã hoàn thành', value: examList.filter(e => e.status === 'completed').length },\n    { icon: <Users className=\"w-5 h-5 text-rose-500\" />,     bg: 'bg-rose-50',    label: 'HV chưa có lịch', value: studentsTotal },\n  ];\n\n  return (\n    <div className=\"flex flex-col gap-6 animate-in fade-in slide-in-from-bottom-2 duration-700\">\n\n      {/* Header */}\n      <div className=\"flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4\">\n        <div>\n          <h2 className=\"text-2xl sm:text-3xl font-extrabold text-gray-900 tracking-tight leading-tight\">Thi sát hạch</h2>\n          <p className=\"text-gray-500 font-medium mt-1 text-sm\">Quản lý đợt thi sát hạch, gắn học viên và theo dõi kết quả</p>\n        </div>\n        <div className=\"flex items-center gap-3\">\n          <button \n            onClick={async () => {\n              try {\n                setIsExporting(true);\n                await exportExamBatchesToExcel();\n                toast.success('Xuất Excel thành công!');\n              } catch (err) {\n                toast.error('Lỗi khi xuất Excel');\n              } finally {\n                setIsExporting(false);\n              }\n            }}\n            disabled={isExporting}\n            className=\"flex items-center gap-2 px-4 py-2 bg-white border border-gray-200 text-gray-700 font-bold rounded-xl hover:bg-gray-50 transition-colors shadow-sm text-sm disabled:opacity-60\"\n          >\n            {isExporting\n              ? <div className=\"w-4 h-4 border-2 border-gray-400 border-t-indigo-600 rounded-full animate-spin\" />\n              : <Download className=\"w-4 h-4\" />}\n            {isExporting ? 'Đang xuất...' : 'Xuất Excel'}\n          </button>\n          <button\n            onClick={openCreate}\n            className=\"flex items-center gap-2 px-4 py-2 bg-indigo-600 text-white font-bold rounded-xl shadow-lg shadow-indigo-600/20 hover:bg-indigo-700 transition-all active:scale-95 text-sm\"\n          >\n            <Plus className=\"w-4 h-4\" /> Tạo đợt thi\n          </button>\n        </div>\n      </div>\n\n      {/* Stat cards */}\n      <div className=\"grid grid-cols-2 sm:grid-cols-3 xl:grid-cols-5 gap-3\">\n        {stats.map((s, i) => (\n          <div key={i} className=\"bg-white border border-gray-100 rounded-2xl p-4 flex items-center gap-3 shadow-sm hover:shadow-md transition-shadow\">\n            <div className={`w-10 h-10 rounded-xl flex items-center justify-center shrink-0 ${s.bg}`}>{s.icon}</div>\n            <div className=\"flex flex-col\">\n              <span className=\"text-xl font-black text-gray-900\">{s.value}</span>\n              <span className=\"text-[11px] font-semibold text-gray-500 leading-tight\">{s.label}</span>\n            </div>\n          </div>\n        ))}\n      </div>\n\n      {/* Tabs */}\n      <div className=\"flex items-center gap-1\">\n        <button\n          onClick={() => setActiveTab('exams')}\n          className={`flex items-center gap-2 px-4 py-2 rounded-xl text-sm font-bold transition-all ${\n            activeTab === 'exams' ? 'bg-indigo-600 text-white shadow-md shadow-indigo-600/20' : 'text-gray-500 hover:bg-gray-100'\n          }`}\n        >\n          <Trophy className=\"w-4 h-4\" /> Đợt thi\n        </button>\n        <button\n          onClick={() => setActiveTab('no-schedule')}\n          className={`flex items-center gap-2 px-4 py-2 rounded-xl text-sm font-bold transition-all ${\n            activeTab === 'no-schedule' ? 'bg-rose-500 text-white shadow-md shadow-rose-500/20' : 'text-gray-500 hover:bg-gray-100'\n          }`}\n        >\n          <Users className=\"w-4 h-4\" /> HV chưa có lịch\n          <span className={`text-[11px] font-black px-1.5 py-0.5 rounded-full ${activeTab === 'no-schedule' ? 'bg-white/25 text-white' : 'bg-rose-100 text-rose-600'}`}>\n            {studentsTotal}\n          </span>\n        </button>\n      </div>\n\n      {/* ── TAB: Đợt thi ── */}\n      {activeTab === 'exams' && (\n        <>\n          {/* Filter bar */}\n          <div className=\"bg-white border border-gray-100 rounded-2xl shadow-sm p-4 flex flex-wrap gap-3 items-center\">\n            <div className=\"flex flex-col gap-0.5\">\n              <span className=\"text-[10px] text-gray-400 font-bold uppercase\">Từ ngày</span>\n              <ViDateInput value={fromDate} onChange={val => setFromDate(val)}\n                className=\"px-3 py-1.5 border border-gray-200 rounded-lg text-sm bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500/20 w-36\" />\n            </div>\n            <div className=\"flex flex-col gap-0.5\">\n              <span className=\"text-[10px] text-gray-400 font-bold uppercase\">Đến ngày</span>\n              <ViDateInput value={toDate} onChange={val => setToDate(val)}\n                className=\"px-3 py-1.5 border border-gray-200 rounded-lg text-sm bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500/20 w-36\" />\n            </div>\n            <div className=\"flex flex-col gap-0.5\">\n              <span className=\"text-[10px] text-gray-400 font-bold uppercase\">Hạng bằng</span>\n              <select value={filterVehicle} onChange={e => setFilterVehicle(e.target.value)}\n                className=\"px-3 py-1.5 border border-gray-200 rounded-lg text-sm bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500/20 cursor-pointer w-36\">\n                <option value=\"\">Tất cả</option>\n                {licenseCategories.map(cat => (\n                  <option key={cat._id} value={cat.name}>{cat.name}</option>\n                ))}\n              </select>\n            </div>\n            <div className=\"flex flex-col gap-0.5\">\n              <span className=\"text-[10px] text-gray-400 font-bold uppercase\">Trạng thái</span>\n              <select value={filterStatus} onChange={e => setFilterStatus(e.target.value)}\n                className=\"px-3 py-1.5 border border-gray-200 rounded-lg text-sm bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500/20 cursor-pointer w-36\">\n                <option value=\"\">Tất cả</option>\n                <option value=\"upcoming\">Sắp diễn ra</option>\n                <option value=\"confirmed\">Đã xác nhận</option>\n                <option value=\"completed\">Đã hoàn thành</option>\n                <option value=\"cancelled\">Đã hủy</option>\n              </select>\n            </div>\n            <button onClick={clearFilters}\n              className=\"self-end mb-0.5 flex items-center gap-1.5 px-3 py-1.5 bg-gray-100 hover:bg-gray-200 text-gray-600 font-bold text-xs rounded-lg transition-colors\">\n              <X className=\"w-3.5 h-3.5\" /> Xóa lọc\n            </button>\n          </div>\n\n          {/* Exam list */}\n          <div className=\"flex flex-col gap-4\">\n            {loading ? (\n              [...Array(3)].map((_, i) => (\n                <div key={i} className=\"bg-white border border-gray-100 rounded-2xl p-6 animate-pulse\">\n                  <div className=\"h-4 bg-gray-100 rounded w-1/4 mb-4\"></div>\n                  <div className=\"h-3 bg-gray-50 rounded w-1/2\"></div>\n                </div>\n              ))\n            ) : displayed.length === 0 ? (\n              <div className=\"bg-white border border-gray-100 rounded-2xl p-14 flex flex-col items-center gap-3 text-gray-400 shadow-sm\">\n                <Trophy className=\"w-10 h-10 opacity-20\" />\n                <p className=\"font-semibold\">Không có đợt thi nào phù hợp.</p>\n              </div>\n            ) : displayed.map(exam => {\n              const meta   = examStatusMeta[exam.status] || examStatusMeta.upcoming;\n              const isOpen = expandedId === exam._id;\n              const pDate = exam.examDate ? new Date(exam.examDate).toLocaleDateString('vi-VN') : '--';\n              const studentsCount = exam.studentResults?.length || 0;\n              const passedCount = exam.studentResults?.filter((r: any) => r.result === 'pass').length || 0;\n              const failedCount = exam.studentResults?.filter((r: any) => r.result === 'fail').length || 0;\n\n              return (\n                <div key={exam._id} className=\"bg-white border border-gray-100 rounded-2xl shadow-sm overflow-hidden hover:shadow-md transition-all duration-300\">\n                  \n                  {/* Row */}\n                  <div className=\"px-7 py-5 flex flex-col sm:flex-row sm:items-center gap-6\">\n\n                    {/* Left info */}\n                    <div className=\"flex-1 min-w-0 space-y-3\">\n                      <div className=\"flex flex-wrap items-center gap-3\">\n                        <span className=\"font-extrabold text-gray-900 text-lg tracking-tight\">{exam.name}</span>\n                        <div className=\"flex items-center gap-1.5\">\n                          <span className={`px-2 py-0.5 rounded-md text-[10px] font-black border uppercase tracking-wider ${meta.cls}`}>{meta.label}</span>\n                          <span className={`px-2 py-0.5 rounded-md text-[10px] font-black border uppercase tracking-wider ${vehicleBadge(exam.vehicleType)}`}>{exam.vehicleType}</span>\n                        </div>\n                      </div>\n\n                      <div className=\"flex flex-wrap items-center gap-5 text-[12px] text-gray-500 font-medium\">\n                        <div className=\"flex items-center gap-4\">\n                          <div className=\"flex items-center gap-1.5\">\n                            <CalendarDays className=\"w-3.5 h-3.5 text-gray-300\" />\n                            <span>Dự kiến: <strong className=\"text-gray-700 ml-0.5 font-bold\">{pDate}</strong></span>\n                          </div>\n                          <div className=\"w-px h-3 bg-gray-100\" />\n                          <div className=\"flex items-center gap-1.5\">\n                            <CalendarDays className=\"w-3.5 h-3.5 text-indigo-300\" />\n                            <span>Chính thức: <strong className=\"text-indigo-600 ml-0.5 font-black\">{exam.officialDate ? new Date(exam.officialDate).toLocaleDateString('vi-VN') : '—'}</strong></span>\n                          </div>\n                        </div>\n                        \n                        <div className=\"flex items-center gap-1.5\">\n                          <MapPin className=\"w-3.5 h-3.5 text-gray-300\" />\n                          <span className=\"font-bold text-gray-600\">{exam.venue}</span>\n                        </div>\n                      </div>\n                    </div>\n\n                    {/* Right stats + actions */}\n                    <div className=\"flex items-center gap-6 shrink-0\">\n                      {/* Student counts */}\n                      <div className=\"flex items-center gap-4 text-center px-4 py-2 bg-gray-50/50 rounded-2xl border border-gray-50\">\n                        <div className=\"flex flex-col\">\n                          <span className=\"text-lg font-black text-gray-800 leading-none\">{studentsCount}</span>\n                          <span className=\"text-[9px] font-bold text-gray-400 uppercase tracking-widest mt-1\">Học viên</span>\n                        </div>\n                        <div className=\"flex flex-col border-l border-gray-100 pl-4\">\n                          <span className=\"text-lg font-black text-emerald-600 leading-none\">{passedCount}</span>\n                          <span className=\"text-[9px] font-bold text-emerald-400 uppercase tracking-widest mt-1\">Đậu</span>\n                        </div>\n                        <div className=\"flex flex-col border-l border-gray-100 pl-4\">\n                          <span className=\"text-lg font-black text-rose-500 leading-none\">{failedCount}</span>\n                          <span className=\"text-[9px] font-bold text-rose-400 uppercase tracking-widest mt-1\">Trượt</span>\n                        </div>\n                      </div>\n\n                      {/* Action buttons */}\n                      <div className=\"flex items-center gap-1 pl-4 border-l border-gray-100\">\n                        <button onClick={() => openEdit(exam)}\n                          title=\"Sửa đợt thi\"\n                          className=\"p-2 text-gray-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-xl transition-all active:scale-95\">\n                          <Edit2 className=\"w-4.5 h-4.5\" />\n                        </button>\n                        <button \n                          onClick={() => handleDeleteClick(exam._id, exam.name)}\n                          title=\"Xóa đợt thi\"\n                          className=\"p-2 text-gray-400 hover:text-rose-600 hover:bg-rose-50 rounded-xl transition-all active:scale-95\"\n                        >\n                          <Trash2 className=\"w-4.5 h-4.5\" />\n                        </button>\n                        <button onClick={() => setExpandedId(isOpen ? null : exam._id)}\n                          title=\"Mở rộng\"\n                          className={`p-2 rounded-xl transition-all active:scale-95 ${isOpen ? 'bg-indigo-600 text-white shadow-lg shadow-indigo-600/20' : 'text-gray-400 hover:bg-gray-100 hover:text-gray-700'}`}>\n                          {isOpen ? <ChevronUp className=\"w-4.5 h-4.5\" /> : <ChevronDown className=\"w-4.5 h-4.5\" />}\n                        </button>\n                      </div>\n                    </div>\n                  </div>\n\n                  {/* Expanded panel */}\n                  {isOpen && (\n                    <div className=\"border-t border-gray-100 bg-gray-50/50 px-5 py-4 animate-in slide-in-from-top-2 duration-200\">\n                      <p className=\"text-[11px] font-bold text-gray-400 uppercase tracking-wider mb-3\">Học viên trong đợt thi</p>\n                      {studentsCount === 0 ? (\n                        <div className=\"flex items-center gap-2 text-gray-400 font-medium text-sm py-4\">\n                          <AlertCircle className=\"w-4 h-4\" /> Chưa có học viên nào được gắn vào đợt thi này.\n                        </div>\n                      ) : (\n                        <div className=\"flex flex-col gap-2\">\n                          {exam.studentResults.map((result: any, i: number) => (\n                            <div key={i} className=\"flex items-center justify-between bg-white border border-gray-100 rounded-xl px-4 py-3 text-sm group/item\">\n                              <div className=\"flex items-center gap-3\">\n                                <span className=\"w-8 h-8 rounded-full bg-indigo-50 text-indigo-600 flex items-center justify-center text-[11px] font-black group-hover/item:bg-indigo-600 group-hover/item:text-white transition-all\">\n                                  {i + 1}\n                                </span>\n                                <div className=\"flex flex-col\">\n                                  <span \n                                    className=\"font-extrabold text-gray-700 hover:text-indigo-600 cursor-pointer transition-colors\"\n                                    onClick={() => setSelectedStudent({ _id: result.student_id, user_id: { first_name: result.name } })}\n                                  >\n                                    {result.name || `Học viên #${i + 1}`}\n                                  </span>\n                                  <span className=\"text-gray-400 text-[10px] font-medium\">{result.student_id ? `Mã HV: ${result.student_id.slice(-6).toUpperCase()}` : '—'}</span>\n                                </div>\n                              </div>\n                              \n                              <div className=\"flex items-center gap-3\">\n                                <span className={`text-[10px] font-bold px-2 py-1 rounded border transition-all ${\n                                  result.result === 'pass' ? 'bg-emerald-50 text-emerald-600 border-emerald-100' : \n                                  result.result === 'fail' ? 'bg-rose-50 text-rose-600 border-rose-100' : \n                                  'bg-gray-50 text-gray-400 border-gray-200'\n                                }`}>\n                                  {result.result === 'pass' ? 'Đã đậu' : result.result === 'fail' ? 'Trượt' : 'Chờ kết quả'}\n                                </span>\n                                \n                                <div className=\"flex items-center gap-1 opacity-0 group-hover/item:opacity-100 transition-opacity\">\n                                  <button\n                                    onClick={() => openResultModal(exam, result)}\n                                    title=\"Nhập kết quả\"\n                                    className=\"p-1.5 text-indigo-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-lg transition-all\"\n                                  >\n                                    <ClipboardCheck className=\"w-4 h-4\" />\n                                  </button>\n                                  <button\n                                    onClick={() => handleRemoveClick(exam._id, result.student_id, result.name)}\n                                    title=\"Xóa khỏi đợt thi\"\n                                    className=\"p-1.5 text-gray-400 hover:text-rose-500 hover:bg-rose-50 rounded-lg transition-all\"\n                                  >\n                                    <UserMinus className=\"w-4 h-4\" />\n                                  </button>\n                                </div>\n                              </div>\n                            </div>\n                          ))}\n                        </div>\n                      )}\n                    </div>\n                  )}\n                </div>\n              );\n            })}\n          </div>\n        </>\n      )}\n\n      {/* ── TAB: HV chưa có lịch ── */}\n      {activeTab === 'no-schedule' && (\n        <div className=\"bg-white border border-gray-100 rounded-2xl shadow-sm overflow-hidden\">\n          <div className=\"px-5 py-4 border-b border-gray-100 flex items-center justify-between\">\n            <h3 className=\"font-extrabold text-gray-800\">Học viên chưa được xếp lịch thi</h3>\n            <div className=\"relative\">\n              <Search className=\"w-4 h-4 text-gray-400 absolute left-3 top-1/2 -translate-y-1/2\" />\n              <input type=\"text\" value={search} onChange={e => setSearch(e.target.value)}\n                placeholder=\"Tìm tên, SĐT...\"\n                className=\"pl-9 pr-4 py-1.5 text-sm bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500/20 w-48 transition-all\" />\n            </div>\n          </div>\n          <table className=\"w-full text-left\">\n            <thead>\n              <tr className=\"bg-gray-50/60 border-b border-gray-100 text-[11px] uppercase tracking-wider text-gray-500 font-extrabold\">\n                <th className=\"px-6 py-3\">Học viên</th>\n                <th className=\"px-6 py-3\">Hạng</th>\n                <th className=\"px-6 py-3 text-right\">Thao tác</th>\n              </tr>\n            </thead>\n            <tbody className=\"divide-y divide-gray-50 text-sm\">\n              {studentsLoading ? (\n                <tr>\n                  <td colSpan={3} className=\"px-6 py-10 text-center text-gray-400\">Đang tải danh sách học viên...</td>\n                </tr>\n              ) : studentsWithoutSchedule.length === 0 ? (\n                <tr>\n                  <td colSpan={3} className=\"px-6 py-10 text-center text-gray-400 italic\">Không có học viên nào đang chờ lịch thi sát hạch.</td>\n                </tr>\n              ) : studentsWithoutSchedule\n                .filter(s => {\n                  // FILTER: Exclude students already assigned to an active exam batch\n                  const isAssigned = exams.some(exam => \n                    (exam.status === 'upcoming' || exam.status === 'confirmed') && \n                    (exam.studentResults || []).some((sr: any) => sr.student_id === s._id)\n                  );\n                  if (isAssigned) return false;\n\n                  const fullName = `${s.user_id?.last_name || ''} ${s.user_id?.first_name || ''}`.toLowerCase();\n                  return !search || fullName.includes(search.toLowerCase()) || s.user_id?.phone?.includes(search);\n                })\n                .map(s => {\n                  const firstName = s.user_id?.first_name || '';\n                  const lastName = s.user_id?.last_name || '';\n                  const fullName = firstName || lastName ? `${lastName} ${firstName}`.trim() : 'Học viên ẩn danh';\n                  const phone = s.user_id?.phone || '—';\n                  const region = s.region_id?.name || '—';\n                  \n                  return (\n                    <tr key={s._id} className=\"hover:bg-indigo-50/20 transition-colors\">\n                      <td className=\"px-6 py-4\">\n                        <div\n                          className=\"flex flex-col cursor-pointer group\"\n                          onClick={() => setSelectedStudent(s)}\n                        >\n                          <span className=\"font-extrabold text-indigo-700 transition-colors group-hover:text-indigo-900\">\n                            {fullName}\n                          </span>\n                          <span className=\"text-[11px] text-gray-400 group-hover:text-gray-500\">{phone}</span>\n                        </div>\n                      </td>\n                      <td className=\"px-6 py-4\">\n                        <span className=\"px-1.5 py-0.5 bg-blue-50 text-blue-700 text-[10px] font-black border border-blue-100 rounded\">{s.license_category_id || '—'}</span>\n                      </td>\n                      <td className=\"px-6 py-4 text-right\">\n                        <button\n                          onClick={() => setAssignStudent({\n                            id: s._id,\n                            name: fullName\n                          })}\n                          className=\"inline-flex items-center gap-1.5 px-3 py-1.5 bg-indigo-600 text-white hover:bg-indigo-700 transition-colors rounded-lg font-bold text-xs shadow-sm shadow-indigo-600/20\"\n                        >\n                          <Plus className=\"w-3.5 h-3.5\" /> Gắn vào đợt thi\n                        </button>\n                      </td>\n                    </tr>\n                  );\n                })}\n            </tbody>\n          </table>\n\n          {/* Pagination Controls */}\n          {studentsTotal > STUDENT_LIMIT && (\n            <div className=\"px-6 py-4 bg-gray-50/50 border-t border-gray-100 flex items-center justify-between\">\n              <span className=\"text-xs font-bold text-gray-500 uppercase tracking-widest\">\n                Trang {studentsPage} / {Math.ceil(studentsTotal / STUDENT_LIMIT)}\n              </span>\n              <div className=\"flex items-center gap-2\">\n                <button\n                  disabled={studentsPage <= 1}\n                  onClick={() => fetchEligibleStudents(studentsPage - 1)}\n                  className=\"px-3 py-1.5 bg-white border border-gray-200 rounded-lg text-xs font-black text-gray-700 hover:bg-gray-50 disabled:opacity-40 transition-colors uppercase\"\n                >\n                  Trước\n                </button>\n                <div className=\"flex items-center gap-1\">\n                   {[...Array(Math.min(5, Math.ceil(studentsTotal / STUDENT_LIMIT)))].map((_, i) => {\n                     const pNum = i + 1; // Simplistic pagination for now\n                     return (\n                       <button\n                         key={pNum}\n                         onClick={() => fetchEligibleStudents(pNum)}\n                         className={`w-8 h-8 rounded-lg text-xs font-black transition-all ${\n                           studentsPage === pNum ? 'bg-rose-500 text-white shadow-md shadow-rose-500/20' : 'text-gray-500 hover:bg-gray-100'\n                         }`}\n                       >\n                         {pNum}\n                       </button>\n                     );\n                   })}\n                </div>\n                <button\n                  disabled={studentsPage >= Math.ceil(studentsTotal / STUDENT_LIMIT)}\n                  onClick={() => fetchEligibleStudents(studentsPage + 1)}\n                  className=\"px-3 py-1.5 bg-white border border-gray-200 rounded-lg text-xs font-black text-gray-700 hover:bg-gray-50 disabled:opacity-40 transition-colors uppercase\"\n                >\n                  Sau\n                </button>\n              </div>\n            </div>\n          )}\n        </div>\n      )}\n\n      {/* Modal */}\n      <ExamModal \n        isOpen={modalOpen} \n        onClose={() => setModalOpen(false)} \n        onSuccess={() => fetchExams()}\n        initial={editData} \n      />\n\n      {/* Student Detail Drawer */}\n      <StudentDetailDrawer\n        isOpen={!!selectedStudent}\n        student={mapStudentForDrawer(selectedStudent)}\n        onClose={() => setSelectedStudent(null)}\n      />\n\n      {/* Assign to exam modal */}\n      <AssignExamModal\n        isOpen={!!assignStudent}\n        student={assignStudent}\n        onClose={() => setAssignStudent(null)}\n        onSuccess={() => {\n          fetchExams();\n          fetchEligibleStudents();\n        }}\n      />\n      {/* Result Entry Modal */}\n      <ResultModal\n        isOpen={resultModalOpen}\n        onClose={() => { setResultModalOpen(false); setTargetStudentForResults(null); }}\n        onSave={handleSaveResult}\n        student={targetStudentForResults}\n        examBatch={targetBatchForResults}\n      />\n\n      {/* Remove from Batch Confirmation */}\n      <ConfirmModal\n        isOpen={removeConfirmOpen}\n        onClose={() => setRemoveConfirmOpen(false)}\n        onConfirm={confirmRemoveFromBatch}\n        title=\"Xóa khỏi đợt thi\"\n        message={`Bạn có chắc chắn muốn gỡ học viên \"${studentToRemove?.name}\" khỏi đợt thi này? Học viên sẽ quay lại danh sách chờ xếp lịch.`}\n        confirmText=\"Xác nhận gỡ\"\n        cancelText=\"Quay lại\"\n        type=\"warning\"\n      />\n\n      {/* Confirm Delete Batch */}\n      <ConfirmModal\n        isOpen={deleteModalOpen}\n        onClose={() => setDeleteModalOpen(false)}\n        onConfirm={confirmDelete}\n        title=\"Xóa đợt thi\"\n        message={`Bạn có chắc chắn muốn xóa đợt thi \"${batchToDelete?.name}\"? Hành động này không thể hoàn tác.`}\n        confirmText=\"Xác nhận xóa\"\n        cancelText=\"Quay lại\"\n        type=\"danger\"\n      />\n    </div>\n  );\n}"}],"details":{"status":"completed","exitCode":0,"durationMs":188,"aggregated":"\"use client\";\n\nimport React, { useState, useEffect } from 'react';\nimport {\n  Trophy, Plus, Download, Search, ChevronDown, ChevronUp,\n  Edit2, Trash2, MapPin, CalendarDays, CheckCircle2,\n  Clock, X, Users, AlertCircle, UserMinus, ClipboardCheck\n} from 'lucide-react';\nimport { toast } from 'sonner';\nimport UnderDevelopment from '@/src/components/shared/UnderDevelopment';\nimport ExamModal, { ExamData } from '@/src/components/sat-hach/ExamModal';\nimport StudentDetailDrawer from '@/src/components/students/StudentDetailDrawer';\nimport AssignExamModal from '@/src/components/sat-hach/AssignExamModal';\nimport ResultModal from '@/src/components/sat-hach/ResultModal';\nimport { getExamBatches, getEligibleStudents, deleteExamBatch, updateExamBatch, getBatchById, exportExamBatchesToExcel } from '@/src/services/examService';\nimport { updateStudent, getLicenseCategories } from '@/src/services/studentService';\nimport { getCities, City } from '@/src/services/cityService';\nimport ConfirmModal from '@/src/components/shared/ConfirmModal';\nimport ViDateInput from '@/src/components/shared/ViDateInput';\nimport { useAuth } from '@/src/context/AuthContext';\n\n/* ─── Mock data remains as fallback if needed ──────── */\nconst EMPTY_EXAMS: any[] = [];\nconst EMPTY_STUDENTS: any[] = [];\n\n/* ─── helpers ───────────────────────────────────────── */\nconst examStatusMeta: Record<string, { label: string; cls: string }> = {\n  upcoming:  { label: 'Sắp diễn ra',          cls: 'bg-amber-50  text-amber-600  border-amber-200'  },\n  scheduled: { label: 'Đã lên lịch',          cls: 'bg-indigo-50 text-indigo-600 border-indigo-200' },\n  confirmed: { label: 'Đã xác nhận lịch',     cls: 'bg-blue-50   text-blue-600   border-blue-200'   },\n  completed: { label: 'Đã hoàn thành',         cls: 'bg-emerald-50 text-emerald-600 border-emerald-200' },\n  cancelled: { label: 'Đã hủy',               cls: 'bg-gray-100  text-gray-500   border-gray-200'   },\n};\n\nconst vehicleBadge = (v: string) =>\n  v === 'Xe máy'\n    ? 'bg-orange-50 text-orange-600 border-orange-200'\n    : 'bg-indigo-50 text-indigo-600 border-indigo-200';\n\n/* ─── page ───────────────────────────────────────────── */\nexport default function SatHachPage() {\n  const { user } = useAuth();\n  const [activeTab, setActiveTab]       = useState<'exams' | 'no-schedule'>('exams');\n  const [expandedId, setExpandedId]     = useState<string | null>(null);\n  const [modalOpen, setModalOpen]       = useState(false);\n  const [editData, setEditData]         = useState<ExamData | null>(null);\n  const [selectedStudent, setSelectedStudent] = useState<any>(null);\n  const [assignStudent, setAssignStudent]     = useState<any>(null);\n  \n  const [exams, setExams] = useState<any[]>([]);\n  const [studentsWithoutSchedule, setStudentsWithoutSchedule] = useState<any[]>([]);\n  const [deleteModalOpen, setDeleteModalOpen] = useState(false);\n  const [batchToDelete, setBatchToDelete] = useState<{ id: string, name: string } | null>(null);\n  const [loading, setLoading] = useState(true);\n  const [studentsLoading, setStudentsLoading] = useState(false);\n  const [isExporting, setIsExporting] = useState(false);\n  const [licenseCategories, setLicenseCategories] = useState<any[]>([]);\n\n  // Pagination for Students\n  const [studentsPage, setStudentsPage] = useState(1);\n  const [studentsTotal, setStudentsTotal] = useState(0);\n  const STUDENT_LIMIT = 20;\n\n  // Mapper helper\n  const mapStudentForDrawer = (s: any) => {\n    if (!s) return null;\n    // Case 1: Simple object from exam.studentResults\n    if (!s.user_id && s.name) {\n      return {\n        id: s.student_id || s._id || s.id,\n        name: s.name,\n        phone: '—', rank: '—', region: '—', status: '—'\n      };\n    }\n    // Case 2: Full student object from studentsWithoutSchedule\n    return {\n      id: s._id || s.id,\n      name: `${s.user_id?.last_name || ''} ${s.user_id?.first_name || ''}`.trim() || 'Học viên',\n      phone: s.user_id?.phone || '—',\n      rank: s.course_id?.level || '—',\n      region: s.region?.name || s.region || '—',\n      status: s.status_detail || s.status || '—'\n    };\n  };\n\n  // Result Modal State\n  const [resultModalOpen, setResultModalOpen] = useState(false);\n  const [targetStudentForResults, setTargetStudentForResults] = useState<any>(null);\n  const [targetBatchForResults, setTargetBatchForResults] = useState<any>(null);\n\n  // Removal Confirmation\n  const [removeConfirmOpen, setRemoveConfirmOpen] = useState(false);\n  const [studentToRemove, setStudentToRemove] = useState<{ id: string, name: string, batchId: string } | null>(null);\n\n  // filters\n  const [fromDate, setFromDate]         = useState('');\n  const [toDate, setToDate]             = useState('');\n  const [filterVehicle, setFilterVehicle] = useState('');\n  const [filterStatus, setFilterStatus] = useState('');\n  const [search, setSearch]             = useState('');\n\n  const fetchExams = async () => {\n    try {\n      setLoading(true);\n      const res = await getExamBatches(1, 50);\n      if (res.success) {\n        // Handle standardized API envelope { data: { data: [] } } or { data: [] }\n        const list = res.data?.data || res.data?.docs || (Array.isArray(res.data) ? res.data : []);\n        setExams(list);\n      }\n    } catch (error) {\n      toast.error('Không thể tải danh sách đợt thi');\n    } finally {\n      setLoading(false);\n    }\n  };\n  const fetchEligibleStudents = async (page = 1) => {\n    try {\n      setStudentsLoading(true);\n      const res = await getEligibleStudents(page, STUDENT_LIMIT);\n      if (res.success) {\n        const list = res.data?.data || res.data?.docs || (Array.isArray(res.data) ? res.data : []);\n        setStudentsWithoutSchedule(list);\n        setStudentsTotal(res.data?.meta?.total || list.length);\n        setStudentsPage(page);\n      }\n    } catch (error) {\n      toast.error('Không thể tải danh sách học viên');\n    } finally {\n      setStudentsLoading(false);\n    }\n  };\n\n\n  const fetchLicenseCategories = async () => {\n    try {\n      const res = await getLicenseCategories();\n      if (res.success) {\n        setLicenseCategories(res.data || []);\n      }\n    } catch (error) {\n       console.error('Failed to fetch categories', error);\n    }\n  };\n\n  useEffect(() => {\n    fetchExams();\n    fetchEligibleStudents();\n    fetchLicenseCategories();\n  }, []);\n\n  const clearFilters = () => {\n    setFromDate(''); setToDate('');\n    setFilterVehicle(''); setFilterStatus('');\n    setSearch('');\n  };\n\n  const openCreate = () => { setEditData(null); setModalOpen(true); };\n  const openEdit = (exam: any) => {\n    setEditData({\n      id: exam._id, \n      name: exam.name, \n      vehicleType: exam.vehicleType,\n      region: exam.region, \n      plannedDate: exam.examDate ? new Date(exam.examDate).toISOString().split('T')[0] : '',\n      officialDate: exam.officialDate ? new Date(exam.officialDate).toISOString().split('T')[0] : '',\n      venueId: exam.stadium_id || '', // Correctly pass stadium_id\n      venueName: exam.venue,\n      examStatus: exam.status === 'done' ? 'completed' : exam.status, \n      note: '',\n    });\n    setModalOpen(true);\n  };\n\n  const handleDeleteClick = (id: string, name: string) => {\n    setBatchToDelete({ id, name });\n    setDeleteModalOpen(true);\n  };\n\n  const confirmDelete = async () => {\n    if (!batchToDelete) return;\n    try {\n      await deleteExamBatch(batchToDelete.id);\n      toast.success(`Đã xóa đợt thi: ${batchToDelete.name}`);\n      fetchExams();\n      fetchEligibleStudents(); // Refresh unscheduled list\n    } catch (err) {\n      toast.error('Lỗi khi xóa đợt thi');\n    } finally {\n      setDeleteModalOpen(false);\n      setBatchToDelete(null);\n    }\n  };\n\n  const handleRemoveClick = (batchId: string, studentId: string, name: string) => {\n    setStudentToRemove({ id: studentId, name, batchId });\n    setRemoveConfirmOpen(true);\n  };\n\n  const confirmRemoveFromBatch = async () => {\n    if (!studentToRemove) return;\n    try {\n      // 1. Get latest batch info\n      const res = await getBatchById(studentToRemove.batchId);\n      if (!res.success) throw new Error('Không thể lấy thông tin đợt thi');\n      \n      const batch = res.data;\n      const updatedResults = (batch.studentResults || []).filter((s: any) => s.student_id !== studentToRemove.id);\n      \n      // 2. Update backend batch\n      await updateExamBatch(studentToRemove.batchId, { studentResults: updatedResults });\n      \n      // 3. Restore student status to 'Thi sát hạch'\n      if (studentToRemove.id) {\n        await updateStudent(studentToRemove.id, { status_detail: 'Thi sát hạch' });\n      }\n      \n      toast.success(`Đã xóa ${studentToRemove.name} khỏi đợt thi`);\n      fetchExams();\n      fetchEligibleStudents(studentsPage); // They will reappear in unscheduled list\n    } catch (err: any) {\n      toast.error(err.message || 'Lỗi khi xóa học viên khỏi đợt thi');\n    } finally {\n      setRemoveConfirmOpen(false);\n      setStudentToRemove(null);\n    }\n  };\n\n  const openResultModal = (batch: any, studentRes: any) => {\n    setTargetBatchForResults(batch);\n    setTargetStudentForResults({\n      id: studentRes.student_id,\n      name: studentRes.name,\n      licenseClass: batch.vehicleType === 'Xe máy' ? 'A1/A2' : 'Ô tô', // Fallback or improved mapping\n      currentResult: studentRes.result,\n      currentNote: studentRes.note\n    });\n    setResultModalOpen(true);\n  };\n\n  const handleSaveResult = async (result: string, note: string) => {\n    if (!targetBatchForResults || !targetStudentForResults) return;\n    \n    try {\n      // 1. Get latest batch\n      const res = await getBatchById(targetBatchForResults._id);\n      if (!res.success) throw new Error('Cập nhật thất bại');\n      \n      const batch = res.data;\n      const updatedResults = (batch.studentResults || []).map((s: any) => {\n        if (s.student_id === targetStudentForResults.id) {\n          return { ...s, result, note };\n        }\n        return s;\n      });\n\n      // 2. Update\n      await updateExamBatch(batch._id || batch.id, { studentResults: updatedResults });\n      \n      toast.success(`Đã cập nhật kết quả cho ${targetStudentForResults.name}`);\n      fetchExams();\n    } catch (err: any) {\n      toast.error(err.message || 'Lỗi khi lưu kết quả');\n    }\n  };\n\n  const displayed = (Array.isArray(exams) ? exams : []).filter(e => {\n    if (filterVehicle && e.vehicleType !== filterVehicle) return false;\n    if (filterStatus  && e.status !== filterStatus)   return false;\n    const pDate = e.examDate ? new Date(e.examDate).toISOString().split('T')[0] : '';\n    if (fromDate && pDate < fromDate)             return false;\n    if (toDate   && pDate > toDate)               return false;\n    if (search && typeof search === 'string') {\n      const trimmedSearch = search.trim().toLowerCase();\n      if (trimmedSearch && !e.name.toLowerCase().includes(trimmedSearch)) return false;\n    }\n    return true;\n  });\n\n  const examList = Array.isArray(exams) ? exams : [];\n  const stats = [\n    { icon: <Trophy className=\"w-5 h-5 text-indigo-600\" />,  bg: 'bg-indigo-50',  label: 'Tổng đợt thi',    value: examList.length },\n    { icon: <Clock className=\"w-5 h-5 text-amber-600\" />,    bg: 'bg-amber-50',   label: 'Sắp diễn ra',     value: examList.filter(e => e.status === 'upcoming').length },\n    { icon: <CheckCircle2 className=\"w-5 h-5 text-blue-600\" />, bg: 'bg-blue-50', label: 'Đã xác nhận',     value: examList.filter(e => e.status === 'confirmed').length },\n    { icon: <CheckCircle2 className=\"w-5 h-5 text-emerald-600\" />, bg: 'bg-emerald-50', label: 'Đã hoàn thành', value: examList.filter(e => e.status === 'completed').length },\n    { icon: <Users className=\"w-5 h-5 text-rose-500\" />,     bg: 'bg-rose-50',    label: 'HV chưa có lịch', value: studentsTotal },\n  ];\n\n  return (\n    <div className=\"flex flex-col gap-6 animate-in fade-in slide-in-from-bottom-2 duration-700\">\n\n      {/* Header */}\n      <div className=\"flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4\">\n        <div>\n          <h2 className=\"text-2xl sm:text-3xl font-extrabold text-gray-900 tracking-tight leading-tight\">Thi sát hạch</h2>\n          <p className=\"text-gray-500 font-medium mt-1 text-sm\">Quản lý đợt thi sát hạch, gắn học viên và theo dõi kết quả</p>\n        </div>\n        <div className=\"flex items-center gap-3\">\n          <button \n            onClick={async () => {\n              try {\n                setIsExporting(true);\n                await exportExamBatchesToExcel();\n                toast.success('Xuất Excel thành công!');\n              } catch (err) {\n                toast.error('Lỗi khi xuất Excel');\n              } finally {\n                setIsExporting(false);\n              }\n            }}\n            disabled={isExporting}\n            className=\"flex items-center gap-2 px-4 py-2 bg-white border border-gray-200 text-gray-700 font-bold rounded-xl hover:bg-gray-50 transition-colors shadow-sm text-sm disabled:opacity-60\"\n          >\n            {isExporting\n              ? <div className=\"w-4 h-4 border-2 border-gray-400 border-t-indigo-600 rounded-full animate-spin\" />\n              : <Download className=\"w-4 h-4\" />}\n            {isExporting ? 'Đang xuất...' : 'Xuất Excel'}\n          </button>\n          <button\n            onClick={openCreate}\n            className=\"flex items-center gap-2 px-4 py-2 bg-indigo-600 text-white font-bold rounded-xl shadow-lg shadow-indigo-600/20 hover:bg-indigo-700 transition-all active:scale-95 text-sm\"\n          >\n            <Plus className=\"w-4 h-4\" /> Tạo đợt thi\n          </button>\n        </div>\n      </div>\n\n      {/* Stat cards */}\n      <div className=\"grid grid-cols-2 sm:grid-cols-3 xl:grid-cols-5 gap-3\">\n        {stats.map((s, i) => (\n          <div key={i} className=\"bg-white border border-gray-100 rounded-2xl p-4 flex items-center gap-3 shadow-sm hover:shadow-md transition-shadow\">\n            <div className={`w-10 h-10 rounded-xl flex items-center justify-center shrink-0 ${s.bg}`}>{s.icon}</div>\n            <div className=\"flex flex-col\">\n              <span className=\"text-xl font-black text-gray-900\">{s.value}</span>\n              <span className=\"text-[11px] font-semibold text-gray-500 leading-tight\">{s.label}</span>\n            </div>\n          </div>\n        ))}\n      </div>\n\n      {/* Tabs */}\n      <div className=\"flex items-center gap-1\">\n        <button\n          onClick={() => setActiveTab('exams')}\n          className={`flex items-center gap-2 px-4 py-2 rounded-xl text-sm font-bold transition-all ${\n            activeTab === 'exams' ? 'bg-indigo-600 text-white shadow-md shadow-indigo-600/20' : 'text-gray-500 hover:bg-gray-100'\n          }`}\n        >\n          <Trophy className=\"w-4 h-4\" /> Đợt thi\n        </button>\n        <button\n          onClick={() => setActiveTab('no-schedule')}\n          className={`flex items-center gap-2 px-4 py-2 rounded-xl text-sm font-bold transition-all ${\n            activeTab === 'no-schedule' ? 'bg-rose-500 text-white shadow-md shadow-rose-500/20' : 'text-gray-500 hover:bg-gray-100'\n          }`}\n        >\n          <Users className=\"w-4 h-4\" /> HV chưa có lịch\n          <span className={`text-[11px] font-black px-1.5 py-0.5 rounded-full ${activeTab === 'no-schedule' ? 'bg-white/25 text-white' : 'bg-rose-100 text-rose-600'}`}>\n            {studentsTotal}\n          </span>\n        </button>\n      </div>\n\n      {/* ── TAB: Đợt thi ── */}\n      {activeTab === 'exams' && (\n        <>\n          {/* Filter bar */}\n          <div className=\"bg-white border border-gray-100 rounded-2xl shadow-sm p-4 flex flex-wrap gap-3 items-center\">\n            <div className=\"flex flex-col gap-0.5\">\n              <span className=\"text-[10px] text-gray-400 font-bold uppercase\">Từ ngày</span>\n              <ViDateInput value={fromDate} onChange={val => setFromDate(val)}\n                className=\"px-3 py-1.5 border border-gray-200 rounded-lg text-sm bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500/20 w-36\" />\n            </div>\n            <div className=\"flex flex-col gap-0.5\">\n              <span className=\"text-[10px] text-gray-400 font-bold uppercase\">Đến ngày</span>\n              <ViDateInput value={toDate} onChange={val => setToDate(val)}\n                className=\"px-3 py-1.5 border border-gray-200 rounded-lg text-sm bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500/20 w-36\" />\n            </div>\n            <div className=\"flex flex-col gap-0.5\">\n              <span className=\"text-[10px] text-gray-400 font-bold uppercase\">Hạng bằng</span>\n              <select value={filterVehicle} onChange={e => setFilterVehicle(e.target.value)}\n                className=\"px-3 py-1.5 border border-gray-200 rounded-lg text-sm bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500/20 cursor-pointer w-36\">\n                <option value=\"\">Tất cả</option>\n                {licenseCategories.map(cat => (\n                  <option key={cat._id} value={cat.name}>{cat.name}</option>\n                ))}\n              </select>\n            </div>\n            <div className=\"flex flex-col gap-0.5\">\n              <span className=\"text-[10px] text-gray-400 font-bold uppercase\">Trạng thái</span>\n              <select value={filterStatus} onChange={e => setFilterStatus(e.target.value)}\n                className=\"px-3 py-1.5 border border-gray-200 rounded-lg text-sm bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500/20 cursor-pointer w-36\">\n                <option value=\"\">Tất cả</option>\n                <option value=\"upcoming\">Sắp diễn ra</option>\n                <option value=\"confirmed\">Đã xác nhận</option>\n                <option value=\"completed\">Đã hoàn thành</option>\n                <option value=\"cancelled\">Đã hủy</option>\n              </select>\n            </div>\n            <button onClick={clearFilters}\n              className=\"self-end mb-0.5 flex items-center gap-1.5 px-3 py-1.5 bg-gray-100 hover:bg-gray-200 text-gray-600 font-bold text-xs rounded-lg transition-colors\">\n              <X className=\"w-3.5 h-3.5\" /> Xóa lọc\n            </button>\n          </div>\n\n          {/* Exam list */}\n          <div className=\"flex flex-col gap-4\">\n            {loading ? (\n              [...Array(3)].map((_, i) => (\n                <div key={i} className=\"bg-white border border-gray-100 rounded-2xl p-6 animate-pulse\">\n                  <div className=\"h-4 bg-gray-100 rounded w-1/4 mb-4\"></div>\n                  <div className=\"h-3 bg-gray-50 rounded w-1/2\"></div>\n                </div>\n              ))\n            ) : displayed.length === 0 ? (\n              <div className=\"bg-white border border-gray-100 rounded-2xl p-14 flex flex-col items-center gap-3 text-gray-400 shadow-sm\">\n                <Trophy className=\"w-10 h-10 opacity-20\" />\n                <p className=\"font-semibold\">Không có đợt thi nào phù hợp.</p>\n              </div>\n            ) : displayed.map(exam => {\n              const meta   = examStatusMeta[exam.status] || examStatusMeta.upcoming;\n              const isOpen = expandedId === exam._id;\n              const pDate = exam.examDate ? new Date(exam.examDate).toLocaleDateString('vi-VN') : '--';\n              const studentsCount = exam.studentResults?.length || 0;\n              const passedCount = exam.studentResults?.filter((r: any) => r.result === 'pass').length || 0;\n              const failedCount = exam.studentResults?.filter((r: any) => r.result === 'fail').length || 0;\n\n              return (\n                <div key={exam._id} className=\"bg-white border border-gray-100 rounded-2xl shadow-sm overflow-hidden hover:shadow-md transition-all duration-300\">\n                  \n                  {/* Row */}\n                  <div className=\"px-7 py-5 flex flex-col sm:flex-row sm:items-center gap-6\">\n\n                    {/* Left info */}\n                    <div className=\"flex-1 min-w-0 space-y-3\">\n                      <div className=\"flex flex-wrap items-center gap-3\">\n                        <span className=\"font-extrabold text-gray-900 text-lg tracking-tight\">{exam.name}</span>\n                        <div className=\"flex items-center gap-1.5\">\n                          <span className={`px-2 py-0.5 rounded-md text-[10px] font-black border uppercase tracking-wider ${meta.cls}`}>{meta.label}</span>\n                          <span className={`px-2 py-0.5 rounded-md text-[10px] font-black border uppercase tracking-wider ${vehicleBadge(exam.vehicleType)}`}>{exam.vehicleType}</span>\n                        </div>\n                      </div>\n\n                      <div className=\"flex flex-wrap items-center gap-5 text-[12px] text-gray-500 font-medium\">\n                        <div className=\"flex items-center gap-4\">\n                          <div className=\"flex items-center gap-1.5\">\n                            <CalendarDays className=\"w-3.5 h-3.5 text-gray-300\" />\n                            <span>Dự kiến: <strong className=\"text-gray-700 ml-0.5 font-bold\">{pDate}</strong></span>\n                          </div>\n                          <div className=\"w-px h-3 bg-gray-100\" />\n                          <div className=\"flex items-center gap-1.5\">\n                            <CalendarDays className=\"w-3.5 h-3.5 text-indigo-300\" />\n                            <span>Chính thức: <strong className=\"text-indigo-600 ml-0.5 font-black\">{exam.officialDate ? new Date(exam.officialDate).toLocaleDateString('vi-VN') : '—'}</strong></span>\n                          </div>\n                        </div>\n                        \n                        <div className=\"flex items-center gap-1.5\">\n                          <MapPin className=\"w-3.5 h-3.5 text-gray-300\" />\n                          <span className=\"font-bold text-gray-600\">{exam.venue}</span>\n                        </div>\n                      </div>\n                    </div>\n\n                    {/* Right stats + actions */}\n                    <div className=\"flex items-center gap-6 shrink-0\">\n                      {/* Student counts */}\n                      <div className=\"flex items-center gap-4 text-center px-4 py-2 bg-gray-50/50 rounded-2xl border border-gray-50\">\n                        <div className=\"flex flex-col\">\n                          <span className=\"text-lg font-black text-gray-800 leading-none\">{studentsCount}</span>\n                          <span className=\"text-[9px] font-bold text-gray-400 uppercase tracking-widest mt-1\">Học viên</span>\n                        </div>\n                        <div className=\"flex flex-col border-l border-gray-100 pl-4\">\n                          <span className=\"text-lg font-black text-emerald-600 leading-none\">{passedCount}</span>\n                          <span className=\"text-[9px] font-bold text-emerald-400 uppercase tracking-widest mt-1\">Đậu</span>\n                        </div>\n                        <div className=\"flex flex-col border-l border-gray-100 pl-4\">\n                          <span className=\"text-lg font-black text-rose-500 leading-none\">{failedCount}</span>\n                          <span className=\"text-[9px] font-bold text-rose-400 uppercase tracking-widest mt-1\">Trượt</span>\n                        </div>\n                      </div>\n\n                      {/* Action buttons */}\n                      <div className=\"flex items-center gap-1 pl-4 border-l border-gray-100\">\n                        <button onClick={() => openEdit(exam)}\n                          title=\"Sửa đợt thi\"\n                          className=\"p-2 text-gray-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-xl transition-all active:scale-95\">\n                          <Edit2 className=\"w-4.5 h-4.5\" />\n                        </button>\n                        <button \n                          onClick={() => handleDeleteClick(exam._id, exam.name)}\n                          title=\"Xóa đợt thi\"\n                          className=\"p-2 text-gray-400 hover:text-rose-600 hover:bg-rose-50 rounded-xl transition-all active:scale-95\"\n                        >\n                          <Trash2 className=\"w-4.5 h-4.5\" />\n                        </button>\n                        <button onClick={() => setExpandedId(isOpen ? null : exam._id)}\n                          title=\"Mở rộng\"\n                          className={`p-2 rounded-xl transition-all active:scale-95 ${isOpen ? 'bg-indigo-600 text-white shadow-lg shadow-indigo-600/20' : 'text-gray-400 hover:bg-gray-100 hover:text-gray-700'}`}>\n                          {isOpen ? <ChevronUp className=\"w-4.5 h-4.5\" /> : <ChevronDown className=\"w-4.5 h-4.5\" />}\n                        </button>\n                      </div>\n                    </div>\n                  </div>\n\n                  {/* Expanded panel */}\n                  {isOpen && (\n                    <div className=\"border-t border-gray-100 bg-gray-50/50 px-5 py-4 animate-in slide-in-from-top-2 duration-200\">\n                      <p className=\"text-[11px] font-bold text-gray-400 uppercase tracking-wider mb-3\">Học viên trong đợt thi</p>\n                      {studentsCount === 0 ? (\n                        <div className=\"flex items-center gap-2 text-gray-400 font-medium text-sm py-4\">\n                          <AlertCircle className=\"w-4 h-4\" /> Chưa có học viên nào được gắn vào đợt thi này.\n                        </div>\n                      ) : (\n                        <div className=\"flex flex-col gap-2\">\n                          {exam.studentResults.map((result: any, i: number) => (\n                            <div key={i} className=\"flex items-center justify-between bg-white border border-gray-100 rounded-xl px-4 py-3 text-sm group/item\">\n                              <div className=\"flex items-center gap-3\">\n                                <span className=\"w-8 h-8 rounded-full bg-indigo-50 text-indigo-600 flex items-center justify-center text-[11px] font-black group-hover/item:bg-indigo-600 group-hover/item:text-white transition-all\">\n                                  {i + 1}\n                                </span>\n                                <div className=\"flex flex-col\">\n                                  <span \n                                    className=\"font-extrabold text-gray-700 hover:text-indigo-600 cursor-pointer transition-colors\"\n                                    onClick={() => setSelectedStudent({ _id: result.student_id, user_id: { first_name: result.name } })}\n                                  >\n                                    {result.name || `Học viên #${i + 1}`}\n                                  </span>\n                                  <span className=\"text-gray-400 text-[10px] font-medium\">{result.student_id ? `Mã HV: ${result.student_id.slice(-6).toUpperCase()}` : '—'}</span>\n                                </div>\n                              </div>\n                              \n                              <div className=\"flex items-center gap-3\">\n                                <span className={`text-[10px] font-bold px-2 py-1 rounded border transition-all ${\n                                  result.result === 'pass' ? 'bg-emerald-50 text-emerald-600 border-emerald-100' : \n                                  result.result === 'fail' ? 'bg-rose-50 text-rose-600 border-rose-100' : \n                                  'bg-gray-50 text-gray-400 border-gray-200'\n                                }`}>\n                                  {result.result === 'pass' ? 'Đã đậu' : result.result === 'fail' ? 'Trượt' : 'Chờ kết quả'}\n                                </span>\n                                \n                                <div className=\"flex items-center gap-1 opacity-0 group-hover/item:opacity-100 transition-opacity\">\n                                  <button\n                                    onClick={() => openResultModal(exam, result)}\n                                    title=\"Nhập kết quả\"\n                                    className=\"p-1.5 text-indigo-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-lg transition-all\"\n                                  >\n                                    <ClipboardCheck className=\"w-4 h-4\" />\n                                  </button>\n                                  <button\n                                    onClick={() => handleRemoveClick(exam._id, result.student_id, result.name)}\n                                    title=\"Xóa khỏi đợt thi\"\n                                    className=\"p-1.5 text-gray-400 hover:text-rose-500 hover:bg-rose-50 rounded-lg transition-all\"\n                                  >\n                                    <UserMinus className=\"w-4 h-4\" />\n                                  </button>\n                                </div>\n                              </div>\n                            </div>\n                          ))}\n                        </div>\n                      )}\n                    </div>\n                  )}\n                </div>\n              );\n            })}\n          </div>\n        </>\n      )}\n\n      {/* ── TAB: HV chưa có lịch ── */}\n      {activeTab === 'no-schedule' && (\n        <div className=\"bg-white border border-gray-100 rounded-2xl shadow-sm overflow-hidden\">\n          <div className=\"px-5 py-4 border-b border-gray-100 flex items-center justify-between\">\n            <h3 className=\"font-extrabold text-gray-800\">Học viên chưa được xếp lịch thi</h3>\n            <div className=\"relative\">\n              <Search className=\"w-4 h-4 text-gray-400 absolute left-3 top-1/2 -translate-y-1/2\" />\n              <input type=\"text\" value={search} onChange={e => setSearch(e.target.value)}\n                placeholder=\"Tìm tên, SĐT...\"\n                className=\"pl-9 pr-4 py-1.5 text-sm bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500/20 w-48 transition-all\" />\n            </div>\n          </div>\n          <table className=\"w-full text-left\">\n            <thead>\n              <tr className=\"bg-gray-50/60 border-b border-gray-100 text-[11px] uppercase tracking-wider text-gray-500 font-extrabold\">\n                <th className=\"px-6 py-3\">Học viên</th>\n                <th className=\"px-6 py-3\">Hạng</th>\n                <th className=\"px-6 py-3 text-right\">Thao tác</th>\n              </tr>\n            </thead>\n            <tbody className=\"divide-y divide-gray-50 text-sm\">\n              {studentsLoading ? (\n                <tr>\n                  <td colSpan={3} className=\"px-6 py-10 text-center text-gray-400\">Đang tải danh sách học viên...</td>\n                </tr>\n              ) : studentsWithoutSchedule.length === 0 ? (\n                <tr>\n                  <td colSpan={3} className=\"px-6 py-10 text-center text-gray-400 italic\">Không có học viên nào đang chờ lịch thi sát hạch.</td>\n                </tr>\n              ) : studentsWithoutSchedule\n                .filter(s => {\n                  // FILTER: Exclude students already assigned to an active exam batch\n                  const isAssigned = exams.some(exam => \n                    (exam.status === 'upcoming' || exam.status === 'confirmed') && \n                    (exam.studentResults || []).some((sr: any) => sr.student_id === s._id)\n                  );\n                  if (isAssigned) return false;\n\n                  const fullName = `${s.user_id?.last_name || ''} ${s.user_id?.first_name || ''}`.toLowerCase();\n                  return !search || fullName.includes(search.toLowerCase()) || s.user_id?.phone?.includes(search);\n                })\n                .map(s => {\n                  const firstName = s.user_id?.first_name || '';\n                  const lastName = s.user_id?.last_name || '';\n                  const fullName = firstName || lastName ? `${lastName} ${firstName}`.trim() : 'Học viên ẩn danh';\n                  const phone = s.user_id?.phone || '—';\n                  const region = s.region_id?.name || '—';\n                  \n                  return (\n                    <tr key={s._id} className=\"hover:bg-indigo-50/20 transition-colors\">\n                      <td className=\"px-6 py-4\">\n                        <div\n                          className=\"flex flex-col cursor-pointer group\"\n                          onClick={() => setSelectedStudent(s)}\n                        >\n                          <span className=\"font-extrabold text-indigo-700 transition-colors group-hover:text-indigo-900\">\n                            {fullName}\n                          </span>\n                          <span className=\"text-[11px] text-gray-400 group-hover:text-gray-500\">{phone}</span>\n                        </div>\n                      </td>\n                      <td className=\"px-6 py-4\">\n                        <span className=\"px-1.5 py-0.5 bg-blue-50 text-blue-700 text-[10px] font-black border border-blue-100 rounded\">{s.license_category_id || '—'}</span>\n                      </td>\n                      <td className=\"px-6 py-4 text-right\">\n                        <button\n                          onClick={() => setAssignStudent({\n                            id: s._id,\n                            name: fullName\n                          })}\n                          className=\"inline-flex items-center gap-1.5 px-3 py-1.5 bg-indigo-600 text-white hover:bg-indigo-700 transition-colors rounded-lg font-bold text-xs shadow-sm shadow-indigo-600/20\"\n                        >\n                          <Plus className=\"w-3.5 h-3.5\" /> Gắn vào đợt thi\n                        </button>\n                      </td>\n                    </tr>\n                  );\n                })}\n            </tbody>\n          </table>\n\n          {/* Pagination Controls */}\n          {studentsTotal > STUDENT_LIMIT && (\n            <div className=\"px-6 py-4 bg-gray-50/50 border-t border-gray-100 flex items-center justify-between\">\n              <span className=\"text-xs font-bold text-gray-500 uppercase tracking-widest\">\n                Trang {studentsPage} / {Math.ceil(studentsTotal / STUDENT_LIMIT)}\n              </span>\n              <div className=\"flex items-center gap-2\">\n                <button\n                  disabled={studentsPage <= 1}\n                  onClick={() => fetchEligibleStudents(studentsPage - 1)}\n                  className=\"px-3 py-1.5 bg-white border border-gray-200 rounded-lg text-xs font-black text-gray-700 hover:bg-gray-50 disabled:opacity-40 transition-colors uppercase\"\n                >\n                  Trước\n                </button>\n                <div className=\"flex items-center gap-1\">\n                   {[...Array(Math.min(5, Math.ceil(studentsTotal / STUDENT_LIMIT)))].map((_, i) => {\n                     const pNum = i + 1; // Simplistic pagination for now\n                     return (\n                       <button\n                         key={pNum}\n                         onClick={() => fetchEligibleStudents(pNum)}\n                         className={`w-8 h-8 rounded-lg text-xs font-black transition-all ${\n                           studentsPage === pNum ? 'bg-rose-500 text-white shadow-md shadow-rose-500/20' : 'text-gray-500 hover:bg-gray-100'\n                         }`}\n                       >\n                         {pNum}\n                       </button>\n                     );\n                   })}\n                </div>\n                <button\n                  disabled={studentsPage >= Math.ceil(studentsTotal / STUDENT_LIMIT)}\n                  onClick={() => fetchEligibleStudents(studentsPage + 1)}\n                  className=\"px-3 py-1.5 bg-white border border-gray-200 rounded-lg text-xs font-black text-gray-700 hover:bg-gray-50 disabled:opacity-40 transition-colors uppercase\"\n                >\n                  Sau\n                </button>\n              </div>\n            </div>\n          )}\n        </div>\n      )}\n\n      {/* Modal */}\n      <ExamModal \n        isOpen={modalOpen} \n        onClose={() => setModalOpen(false)} \n        onSuccess={() => fetchExams()}\n        initial={editData} \n      />\n\n      {/* Student Detail Drawer */}\n      <StudentDetailDrawer\n        isOpen={!!selectedStudent}\n        student={mapStudentForDrawer(selectedStudent)}\n        onClose={() => setSelectedStudent(null)}\n      />\n\n      {/* Assign to exam modal */}\n      <AssignExamModal\n        isOpen={!!assignStudent}\n        student={assignStudent}\n        onClose={() => setAssignStudent(null)}\n        onSuccess={() => {\n          fetchExams();\n          fetchEligibleStudents();\n        }}\n      />\n      {/* Result Entry Modal */}\n      <ResultModal\n        isOpen={resultModalOpen}\n        onClose={() => { setResultModalOpen(false); setTargetStudentForResults(null); }}\n        onSave={handleSaveResult}\n        student={targetStudentForResults}\n        examBatch={targetBatchForResults}\n      />\n\n      {/* Remove from Batch Confirmation */}\n      <ConfirmModal\n        isOpen={removeConfirmOpen}\n        onClose={() => setRemoveConfirmOpen(false)}\n        onConfirm={confirmRemoveFromBatch}\n        title=\"Xóa khỏi đợt thi\"\n        message={`Bạn có chắc chắn muốn gỡ học viên \"${studentToRemove?.name}\" khỏi đợt thi này? Học viên sẽ quay lại danh sách chờ xếp lịch.`}\n        confirmText=\"Xác nhận gỡ\"\n        cancelText=\"Quay lại\"\n        type=\"warning\"\n      />\n\n      {/* Confirm Delete Batch */}\n      <ConfirmModal\n        isOpen={deleteModalOpen}\n        onClose={() => setDeleteModalOpen(false)}\n        onConfirm={confirmDelete}\n        title=\"Xóa đợt thi\"\n        message={`Bạn có chắc chắn muốn xóa đợt thi \"${batchToDelete?.name}\"? Hành động này không thể hoàn tác.`}\n        confirmText=\"Xác nhận xóa\"\n        cancelText=\"Quay lại\"\n        type=\"danger\"\n      />\n    </div>\n  );\n}","cwd":"/root/.openclaw/workspaces2/v4-ecosystem-review/master-orchestrator"},"isError":false,"timestamp":1776505039289}}
{"type":"message","id":"20623c7d","parentId":"3b4d4e2a","timestamp":"2026-04-18T09:37:19.508Z","message":{"role":"toolResult","toolCallId":"call_function_8tszx5ikdpru_2","toolName":"exec","content":[{"type":"text","text":"\"use client\";\n\nimport React, { useState, useEffect } from 'react';\nimport { X, Trophy, AlertCircle, HelpCircle, Save, Loader2, BookOpen } from 'lucide-react';\n\ninterface ResultModalProps {\n  isOpen: boolean;\n  onClose: () => void;\n  onSave: (result: string, note: string) => Promise<void>;\n  student: { id: string; name: string; licenseClass: string; currentResult?: string; currentNote?: string } | null;\n  examBatch: { name: string; officialDate: string | null } | null;\n}\n\nexport default function ResultModal({ isOpen, onClose, onSave, student, examBatch }: ResultModalProps) {\n  const [result, setResult] = useState('no_result');\n  const [note, setNote] = useState('');\n  const [touched, setTouched] = useState<Record<string, boolean>>({});\n  const [errors, setErrors] = useState<Record<string, string>>({});\n  const [isSubmitting, setIsSubmitting] = useState(false);\n\n  const validate = (r: string, n: string) => {\n    const errs: Record<string, string> = {};\n    if (r === 'fail' && !n.trim()) {\n      errs.note = \"Vui lòng nhập lý do nếu kết quả là 'Trượt'\";\n    }\n    return errs;\n  };\n\n  useEffect(() => {\n    if (isOpen && student) {\n      setResult(student.currentResult || 'no_result');\n      setNote(student.currentNote || '');\n      setTouched({});\n      setErrors({});\n    }\n  }, [isOpen, student]);\n\n  const touch = (field: string) => {\n    setTouched(prev => ({ ...prev, [field]: true }));\n    setErrors(validate(result, note));\n  };\n\n  const updateResult = (val: string) => {\n    setResult(val);\n    setErrors(validate(val, note));\n  };\n\n  const updateNote = (val: string) => {\n    setNote(val);\n    setErrors(validate(result, val));\n  };\n\n  if (!isOpen || !student || !examBatch) return null;\n\n  const handleSave = async () => {\n    const errs = validate(result, note);\n    setErrors(errs);\n    setTouched({ result: true, note: true });\n    \n    if (Object.keys(errs).length > 0) return;\n\n    try {\n      setIsSubmitting(true);\n      await onSave(result, note);\n      onClose();\n    } catch (err: any) {\n      if (err.response?.data?.errors) {\n        const serverErrs: any = {};\n        err.response.data.errors.forEach((e: any) => {\n          const path = e.path.split('.').pop();\n          serverErrs[path] = e.message;\n        });\n        setErrors(prev => ({ ...prev, ...serverErrs }));\n      }\n    } finally {\n      setIsSubmitting(false);\n    }\n  };\n\n  const FieldWrapper = ({ label, children, field }: { label: string, children: React.ReactNode, field: string }) => (\n    <div className=\"flex flex-col gap-2\">\n      <label className={`text-[11px] font-black uppercase tracking-widest ml-1 transition-colors ${touched[field] && errors[field] ? 'text-rose-500' : 'text-gray-400'}`}>\n        {label}\n      </label>\n      <div className=\"relative group\">\n        {children}\n      </div>\n      {touched[field] && errors[field] && (\n        <p className=\"text-[10px] font-bold text-rose-500 ml-1 mt-0.5 animate-in fade-in slide-in-from-top-1\">\n          {errors[field]}\n        </p>\n      )}\n    </div>\n  );\n\n  const results = [\n    { value: 'no_result', label: 'Chờ kết quả', icon: <HelpCircle className=\"w-4 h-4\" />, cls: 'bg-gray-50 text-gray-600 border-gray-200' },\n    { value: 'pass', label: 'Đạt', icon: <Trophy className=\"w-4 h-4\" />, cls: 'bg-emerald-50 text-emerald-600 border-emerald-100' },\n    { value: 'fail', label: 'Trượt', icon: <AlertCircle className=\"w-4 h-4\" />, cls: 'bg-rose-50 text-rose-600 border-rose-100' },\n  ];\n\n  return (\n    <div className=\"fixed inset-0 z-[100] flex items-center justify-center p-4 bg-gray-900/40 backdrop-blur-sm animate-in fade-in duration-200\">\n      <div className=\"bg-white rounded-[2rem] w-full max-w-md shadow-2xl animate-in zoom-in-95 duration-200 overflow-hidden border border-gray-100\">\n        \n        {/* Header */}\n        <div className=\"px-8 py-6 border-b border-gray-100 flex items-center justify-between\">\n          <div>\n            <h2 className=\"text-xl font-black text-gray-900 tracking-tight\">Nhập kết quả thi</h2>\n            <div className=\"flex items-center gap-2 mt-1\">\n              <span className=\"text-sm font-bold text-gray-500\">{student.name}</span>\n              <span className=\"w-1 h-1 rounded-full bg-gray-300\"></span>\n              <span className=\"px-1.5 py-0.5 bg-indigo-50 text-indigo-600 rounded text-[10px] font-black uppercase border border-indigo-100\">\n                {student.licenseClass}\n              </span>\n            </div>\n          </div>\n          <button onClick={onClose} className=\"p-2 text-gray-400 hover:text-gray-900 hover:bg-gray-100 rounded-xl transition-all\">\n            <X className=\"w-5 h-5\" />\n          </button>\n        </div>\n\n        {/* Body */}\n        <div className=\"p-8 flex flex-col gap-6\">\n          \n          {/* Exam Context */}\n          <div className=\"p-4 bg-gray-50/80 border border-gray-100 rounded-2xl flex items-start gap-3\">\n             <div className=\"w-8 h-8 rounded-lg bg-white shadow-sm flex items-center justify-center shrink-0\">\n                <BookOpen className=\"w-4 h-4 text-indigo-500\" />\n             </div>\n             <div className=\"flex flex-col\">\n                <span className=\"text-[13px] font-bold text-gray-700\">{examBatch.name}</span>\n                <span className=\"text-[11px] text-gray-400 font-medium\">\n                  Chính thức: {examBatch.officialDate ? new Date(examBatch.officialDate).toLocaleDateString('vi-VN') : 'Chưa cập nhật'}\n                </span>\n             </div>\n          </div>\n\n          {/* Result Select */}\n          <FieldWrapper label=\"KẾT QUẢ TỔNG\" field=\"result\">\n              <select\n                value={result}\n                onChange={(e) => updateResult(e.target.value)}\n                onBlur={() => touch('result')}\n                className={`w-full px-5 py-4 bg-gray-50 border rounded-2xl text-sm font-black tracking-tight focus:outline-none focus:ring-4 transition-all cursor-pointer appearance-none ${\n                    touched.result && errors.result \n                    ? 'border-rose-300 bg-rose-50 focus:ring-rose-500/10 focus:border-rose-500 text-rose-900' \n                    : 'border-gray-200 focus:ring-indigo-500/10 focus:border-indigo-500'\n                }`}\n              >\n                {results.map((r) => (\n                  <option key={r.value} value={r.value}>{r.label}</option>\n                ))}\n              </select>\n              <div className=\"absolute right-5 top-1/2 -translate-y-1/2 pointer-events-none text-gray-400\">\n                <HelpCircle className=\"w-4 h-4\" />\n              </div>\n          </FieldWrapper>\n\n          {/* Note Input */}\n          <FieldWrapper label=\"GHI CHÚ\" field=\"note\">\n            <textarea\n              value={note}\n              onChange={(e) => updateNote(e.target.value)}\n              onBlur={() => touch('note')}\n              placeholder=\"Ghi chú thêm...\"\n              rows={3}\n              className={`w-full px-5 py-4 bg-gray-50 border rounded-2xl text-sm font-medium focus:outline-none focus:ring-4 transition-all resize-none ${\n                  touched.note && errors.note \n                  ? 'border-rose-300 bg-rose-50 focus:ring-rose-500/10 focus:border-rose-500 text-rose-900' \n                  : 'border-gray-200 focus:ring-indigo-500/10 focus:border-indigo-500'\n              }`}\n            />\n          </FieldWrapper>\n        </div>\n\n        {/* Footer */}\n        <div className=\"px-8 py-6 border-t border-gray-100 bg-gray-50/50 flex items-center justify-end gap-3\">\n          <button\n            onClick={onClose}\n            className=\"px-6 py-3 text-sm font-black text-gray-500 hover:text-gray-900 transition-colors uppercase tracking-widest text-[11px]\"\n          >\n            Hủy\n          </button>\n          <button\n            onClick={handleSave}\n            disabled={isSubmitting}\n            className=\"flex items-center gap-2 px-8 py-3.5 bg-indigo-600 hover:bg-indigo-700 text-white rounded-2xl font-black shadow-xl shadow-indigo-600/20 transition-all hover:scale-105 active:scale-95 disabled:opacity-50 disabled:cursor-not-allowed uppercase tracking-widest text-[11px]\"\n          >\n            {isSubmitting ? <Loader2 className=\"w-4 h-4 animate-spin\" /> : <Save className=\"w-4 h-4\" />}\n            Lưu kết quả\n          </button>\n        </div>\n\n      </div>\n    </div>\n  );\n}"}],"details":{"status":"completed","exitCode":0,"durationMs":363,"aggregated":"\"use client\";\n\nimport React, { useState, useEffect } from 'react';\nimport { X, Trophy, AlertCircle, HelpCircle, Save, Loader2, BookOpen } from 'lucide-react';\n\ninterface ResultModalProps {\n  isOpen: boolean;\n  onClose: () => void;\n  onSave: (result: string, note: string) => Promise<void>;\n  student: { id: string; name: string; licenseClass: string; currentResult?: string; currentNote?: string } | null;\n  examBatch: { name: string; officialDate: string | null } | null;\n}\n\nexport default function ResultModal({ isOpen, onClose, onSave, student, examBatch }: ResultModalProps) {\n  const [result, setResult] = useState('no_result');\n  const [note, setNote] = useState('');\n  const [touched, setTouched] = useState<Record<string, boolean>>({});\n  const [errors, setErrors] = useState<Record<string, string>>({});\n  const [isSubmitting, setIsSubmitting] = useState(false);\n\n  const validate = (r: string, n: string) => {\n    const errs: Record<string, string> = {};\n    if (r === 'fail' && !n.trim()) {\n      errs.note = \"Vui lòng nhập lý do nếu kết quả là 'Trượt'\";\n    }\n    return errs;\n  };\n\n  useEffect(() => {\n    if (isOpen && student) {\n      setResult(student.currentResult || 'no_result');\n      setNote(student.currentNote || '');\n      setTouched({});\n      setErrors({});\n    }\n  }, [isOpen, student]);\n\n  const touch = (field: string) => {\n    setTouched(prev => ({ ...prev, [field]: true }));\n    setErrors(validate(result, note));\n  };\n\n  const updateResult = (val: string) => {\n    setResult(val);\n    setErrors(validate(val, note));\n  };\n\n  const updateNote = (val: string) => {\n    setNote(val);\n    setErrors(validate(result, val));\n  };\n\n  if (!isOpen || !student || !examBatch) return null;\n\n  const handleSave = async () => {\n    const errs = validate(result, note);\n    setErrors(errs);\n    setTouched({ result: true, note: true });\n    \n    if (Object.keys(errs).length > 0) return;\n\n    try {\n      setIsSubmitting(true);\n      await onSave(result, note);\n      onClose();\n    } catch (err: any) {\n      if (err.response?.data?.errors) {\n        const serverErrs: any = {};\n        err.response.data.errors.forEach((e: any) => {\n          const path = e.path.split('.').pop();\n          serverErrs[path] = e.message;\n        });\n        setErrors(prev => ({ ...prev, ...serverErrs }));\n      }\n    } finally {\n      setIsSubmitting(false);\n    }\n  };\n\n  const FieldWrapper = ({ label, children, field }: { label: string, children: React.ReactNode, field: string }) => (\n    <div className=\"flex flex-col gap-2\">\n      <label className={`text-[11px] font-black uppercase tracking-widest ml-1 transition-colors ${touched[field] && errors[field] ? 'text-rose-500' : 'text-gray-400'}`}>\n        {label}\n      </label>\n      <div className=\"relative group\">\n        {children}\n      </div>\n      {touched[field] && errors[field] && (\n        <p className=\"text-[10px] font-bold text-rose-500 ml-1 mt-0.5 animate-in fade-in slide-in-from-top-1\">\n          {errors[field]}\n        </p>\n      )}\n    </div>\n  );\n\n  const results = [\n    { value: 'no_result', label: 'Chờ kết quả', icon: <HelpCircle className=\"w-4 h-4\" />, cls: 'bg-gray-50 text-gray-600 border-gray-200' },\n    { value: 'pass', label: 'Đạt', icon: <Trophy className=\"w-4 h-4\" />, cls: 'bg-emerald-50 text-emerald-600 border-emerald-100' },\n    { value: 'fail', label: 'Trượt', icon: <AlertCircle className=\"w-4 h-4\" />, cls: 'bg-rose-50 text-rose-600 border-rose-100' },\n  ];\n\n  return (\n    <div className=\"fixed inset-0 z-[100] flex items-center justify-center p-4 bg-gray-900/40 backdrop-blur-sm animate-in fade-in duration-200\">\n      <div className=\"bg-white rounded-[2rem] w-full max-w-md shadow-2xl animate-in zoom-in-95 duration-200 overflow-hidden border border-gray-100\">\n        \n        {/* Header */}\n        <div className=\"px-8 py-6 border-b border-gray-100 flex items-center justify-between\">\n          <div>\n            <h2 className=\"text-xl font-black text-gray-900 tracking-tight\">Nhập kết quả thi</h2>\n            <div className=\"flex items-center gap-2 mt-1\">\n              <span className=\"text-sm font-bold text-gray-500\">{student.name}</span>\n              <span className=\"w-1 h-1 rounded-full bg-gray-300\"></span>\n              <span className=\"px-1.5 py-0.5 bg-indigo-50 text-indigo-600 rounded text-[10px] font-black uppercase border border-indigo-100\">\n                {student.licenseClass}\n              </span>\n            </div>\n          </div>\n          <button onClick={onClose} className=\"p-2 text-gray-400 hover:text-gray-900 hover:bg-gray-100 rounded-xl transition-all\">\n            <X className=\"w-5 h-5\" />\n          </button>\n        </div>\n\n        {/* Body */}\n        <div className=\"p-8 flex flex-col gap-6\">\n          \n          {/* Exam Context */}\n          <div className=\"p-4 bg-gray-50/80 border border-gray-100 rounded-2xl flex items-start gap-3\">\n             <div className=\"w-8 h-8 rounded-lg bg-white shadow-sm flex items-center justify-center shrink-0\">\n                <BookOpen className=\"w-4 h-4 text-indigo-500\" />\n             </div>\n             <div className=\"flex flex-col\">\n                <span className=\"text-[13px] font-bold text-gray-700\">{examBatch.name}</span>\n                <span className=\"text-[11px] text-gray-400 font-medium\">\n                  Chính thức: {examBatch.officialDate ? new Date(examBatch.officialDate).toLocaleDateString('vi-VN') : 'Chưa cập nhật'}\n                </span>\n             </div>\n          </div>\n\n          {/* Result Select */}\n          <FieldWrapper label=\"KẾT QUẢ TỔNG\" field=\"result\">\n              <select\n                value={result}\n                onChange={(e) => updateResult(e.target.value)}\n                onBlur={() => touch('result')}\n                className={`w-full px-5 py-4 bg-gray-50 border rounded-2xl text-sm font-black tracking-tight focus:outline-none focus:ring-4 transition-all cursor-pointer appearance-none ${\n                    touched.result && errors.result \n                    ? 'border-rose-300 bg-rose-50 focus:ring-rose-500/10 focus:border-rose-500 text-rose-900' \n                    : 'border-gray-200 focus:ring-indigo-500/10 focus:border-indigo-500'\n                }`}\n              >\n                {results.map((r) => (\n                  <option key={r.value} value={r.value}>{r.label}</option>\n                ))}\n              </select>\n              <div className=\"absolute right-5 top-1/2 -translate-y-1/2 pointer-events-none text-gray-400\">\n                <HelpCircle className=\"w-4 h-4\" />\n              </div>\n          </FieldWrapper>\n\n          {/* Note Input */}\n          <FieldWrapper label=\"GHI CHÚ\" field=\"note\">\n            <textarea\n              value={note}\n              onChange={(e) => updateNote(e.target.value)}\n              onBlur={() => touch('note')}\n              placeholder=\"Ghi chú thêm...\"\n              rows={3}\n              className={`w-full px-5 py-4 bg-gray-50 border rounded-2xl text-sm font-medium focus:outline-none focus:ring-4 transition-all resize-none ${\n                  touched.note && errors.note \n                  ? 'border-rose-300 bg-rose-50 focus:ring-rose-500/10 focus:border-rose-500 text-rose-900' \n                  : 'border-gray-200 focus:ring-indigo-500/10 focus:border-indigo-500'\n              }`}\n            />\n          </FieldWrapper>\n        </div>\n\n        {/* Footer */}\n        <div className=\"px-8 py-6 border-t border-gray-100 bg-gray-50/50 flex items-center justify-end gap-3\">\n          <button\n            onClick={onClose}\n            className=\"px-6 py-3 text-sm font-black text-gray-500 hover:text-gray-900 transition-colors uppercase tracking-widest text-[11px]\"\n          >\n            Hủy\n          </button>\n          <button\n            onClick={handleSave}\n            disabled={isSubmitting}\n            className=\"flex items-center gap-2 px-8 py-3.5 bg-indigo-600 hover:bg-indigo-700 text-white rounded-2xl font-black shadow-xl shadow-indigo-600/20 transition-all hover:scale-105 active:scale-95 disabled:opacity-50 disabled:cursor-not-allowed uppercase tracking-widest text-[11px]\"\n          >\n            {isSubmitting ? <Loader2 className=\"w-4 h-4 animate-spin\" /> : <Save className=\"w-4 h-4\" />}\n            Lưu kết quả\n          </button>\n        </div>\n\n      </div>\n    </div>\n  );\n}","cwd":"/root/.openclaw/workspaces2/v4-ecosystem-review/master-orchestrator"},"isError":false,"timestamp":1776505039462}}
