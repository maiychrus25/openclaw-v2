{"type":"message","id":"56a905f8","parentId":"2038420b","timestamp":"2026-04-18T09:37:08.893Z","message":{"role":"toolResult","toolCallId":"call_function_7bg7dktu51cm_1","toolName":"exec","content":[{"type":"text","text":"import { Request, Response } from 'express';\nimport { ExamScheduleService } from '@/application/services/exam_schedule.service';\nimport { catchAsync } from '@/interface/middlewares/catchAsync.middleware';\n\nconst examScheduleService = new ExamScheduleService();\n\nexport const createExamSchedule = catchAsync(async (req: Request, res: Response) => {\n  const schedule = await examScheduleService.createExamSchedule(req.body);\n  res.statusSuccess(schedule, 'Exam schedule created successfully');\n});\n\nexport const getExamSchedules = catchAsync(async (req: Request, res: Response) => {\n  const schedules = await examScheduleService.getAllSchedules(req.pagination);\n  res.statusSuccess(schedules, 'Exam schedules retrieved successfully');\n});\n\nexport const getById = catchAsync(async (req: Request, res: Response) => {\n  const idStr = typeof req.params.id === 'string' ? req.params.id : req.params.id[0];\n  const schedule = await examScheduleService.getExamScheduleById(idStr);\n  res.statusSuccess(schedule, 'Exam schedule retrieved successfully');\n});\n\nexport const getByExam = catchAsync(async (req: Request, res: Response) => {\n  const examId = typeof req.params.examId === 'string' ? req.params.examId : req.params.examId[0];\n  const schedules = await examScheduleService.getByExamId(examId, req.pagination);\n  res.statusSuccess(schedules, 'Exam schedules retrieved successfully');\n});\n\nexport const updateExamSchedule = catchAsync(async (req: Request, res: Response) => {\n  const idStr = typeof req.params.id === 'string' ? req.params.id : req.params.id[0];\n  const schedule = await examScheduleService.updateExamSchedule(idStr, req.body);\n  res.statusSuccess(schedule, 'Exam schedule updated successfully');\n});\n\nexport const deleteExamSchedule = catchAsync(async (req: Request, res: Response) => {\n  const idStr = typeof req.params.id === 'string' ? req.params.id : req.params.id[0];\n  await examScheduleService.deleteExamSchedule(idStr);\n  res.statusSuccess(null, 'Exam schedule deleted successfully');\n});"}],"details":{"status":"completed","exitCode":0,"durationMs":96,"aggregated":"import { Request, Response } from 'express';\nimport { ExamScheduleService } from '@/application/services/exam_schedule.service';\nimport { catchAsync } from '@/interface/middlewares/catchAsync.middleware';\n\nconst examScheduleService = new ExamScheduleService();\n\nexport const createExamSchedule = catchAsync(async (req: Request, res: Response) => {\n  const schedule = await examScheduleService.createExamSchedule(req.body);\n  res.statusSuccess(schedule, 'Exam schedule created successfully');\n});\n\nexport const getExamSchedules = catchAsync(async (req: Request, res: Response) => {\n  const schedules = await examScheduleService.getAllSchedules(req.pagination);\n  res.statusSuccess(schedules, 'Exam schedules retrieved successfully');\n});\n\nexport const getById = catchAsync(async (req: Request, res: Response) => {\n  const idStr = typeof req.params.id === 'string' ? req.params.id : req.params.id[0];\n  const schedule = await examScheduleService.getExamScheduleById(idStr);\n  res.statusSuccess(schedule, 'Exam schedule retrieved successfully');\n});\n\nexport const getByExam = catchAsync(async (req: Request, res: Response) => {\n  const examId = typeof req.params.examId === 'string' ? req.params.examId : req.params.examId[0];\n  const schedules = await examScheduleService.getByExamId(examId, req.pagination);\n  res.statusSuccess(schedules, 'Exam schedules retrieved successfully');\n});\n\nexport const updateExamSchedule = catchAsync(async (req: Request, res: Response) => {\n  const idStr = typeof req.params.id === 'string' ? req.params.id : req.params.id[0];\n  const schedule = await examScheduleService.updateExamSchedule(idStr, req.body);\n  res.statusSuccess(schedule, 'Exam schedule updated successfully');\n});\n\nexport const deleteExamSchedule = catchAsync(async (req: Request, res: Response) => {\n  const idStr = typeof req.params.id === 'string' ? req.params.id : req.params.id[0];\n  await examScheduleService.deleteExamSchedule(idStr);\n  res.statusSuccess(null, 'Exam schedule deleted successfully');\n});","cwd":"/root/.openclaw/workspaces2/v4-ecosystem-review/master-orchestrator"},"isError":false,"timestamp":1776505028835}}
{"type":"message","id":"46f786b7","parentId":"56a905f8","timestamp":"2026-04-18T09:37:08.946Z","message":{"role":"toolResult","toolCallId":"call_function_7bg7dktu51cm_2","toolName":"exec","content":[{"type":"text","text":"import { IExamScheduleRepository } from '@/domain/repositories/exam_schedule.repository.interface';\nimport { ExamScheduleRepository } from '@/infrastructure/repositories/exam_schedule.repository';\nimport { IExamSchedule } from '@/infrastructure/database/models/exam_schedule.model';\nimport { PaginationOptions, PaginatedResult } from '@/domain/types/pagination.types';\n\nexport class ExamScheduleService {\n  private examScheduleRepository: IExamScheduleRepository;\n\n  constructor(examScheduleRepository: IExamScheduleRepository = new ExamScheduleRepository()) {\n    this.examScheduleRepository = examScheduleRepository;\n  }\n\n  async createExamSchedule(data: Partial<IExamSchedule>): Promise<IExamSchedule> {\n    return await this.examScheduleRepository.create(data);\n  }\n\n  async getExamScheduleById(id: string): Promise<IExamSchedule | null> {\n    return await this.examScheduleRepository.findById(id);\n  }\n\n  async getByExamId(examId: string, options?: PaginationOptions): Promise<PaginatedResult<IExamSchedule>> {\n    return await this.examScheduleRepository.findByExam(examId, options);\n  }\n\n  async getAllSchedules(options?: PaginationOptions): Promise<PaginatedResult<IExamSchedule>> {\n    return await this.examScheduleRepository.findAll(options);\n  }\n\n  async updateExamSchedule(id: string, data: Partial<IExamSchedule>): Promise<IExamSchedule | null> {\n    return await this.examScheduleRepository.update(id, data);\n  }\n\n  async deleteExamSchedule(id: string): Promise<IExamSchedule | null> {\n    return await this.examScheduleRepository.delete(id);\n  }\n}"}],"details":{"status":"completed","exitCode":0,"durationMs":161,"aggregated":"import { IExamScheduleRepository } from '@/domain/repositories/exam_schedule.repository.interface';\nimport { ExamScheduleRepository } from '@/infrastructure/repositories/exam_schedule.repository';\nimport { IExamSchedule } from '@/infrastructure/database/models/exam_schedule.model';\nimport { PaginationOptions, PaginatedResult } from '@/domain/types/pagination.types';\n\nexport class ExamScheduleService {\n  private examScheduleRepository: IExamScheduleRepository;\n\n  constructor(examScheduleRepository: IExamScheduleRepository = new ExamScheduleRepository()) {\n    this.examScheduleRepository = examScheduleRepository;\n  }\n\n  async createExamSchedule(data: Partial<IExamSchedule>): Promise<IExamSchedule> {\n    return await this.examScheduleRepository.create(data);\n  }\n\n  async getExamScheduleById(id: string): Promise<IExamSchedule | null> {\n    return await this.examScheduleRepository.findById(id);\n  }\n\n  async getByExamId(examId: string, options?: PaginationOptions): Promise<PaginatedResult<IExamSchedule>> {\n    return await this.examScheduleRepository.findByExam(examId, options);\n  }\n\n  async getAllSchedules(options?: PaginationOptions): Promise<PaginatedResult<IExamSchedule>> {\n    return await this.examScheduleRepository.findAll(options);\n  }\n\n  async updateExamSchedule(id: string, data: Partial<IExamSchedule>): Promise<IExamSchedule | null> {\n    return await this.examScheduleRepository.update(id, data);\n  }\n\n  async deleteExamSchedule(id: string): Promise<IExamSchedule | null> {\n    return await this.examScheduleRepository.delete(id);\n  }\n}","cwd":"/root/.openclaw/workspaces2/v4-ecosystem-review/master-orchestrator"},"isError":false,"timestamp":1776505028901}}
