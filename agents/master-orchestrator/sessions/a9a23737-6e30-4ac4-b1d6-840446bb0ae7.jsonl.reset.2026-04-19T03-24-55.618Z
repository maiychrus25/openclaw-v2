{"type":"message","id":"70bebdbb","parentId":"e51807d9","timestamp":"2026-04-18T10:32:40.796Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Chart.js is available. Let me create a chart component and add it to the sat-hach page. I'll add:1. A chart component showing pass/fail/absent distribution (pie chart)\n2. A bar chart showing failed by section (theory, simulation, parking, road)Let me create the component and integrate it into the sat-hach page.","thinkingSignature":"74f55c3ce61f847df31bc9286db1d325c9be16f623c39a8073bb9e42863241b2"},{"type":"text","text":"Chart.js đã có. Tạo component biểu đồ:\n"},{"type":"toolCall","id":"call_function_208p7zkk3ciy_1","name":"exec","arguments":{"command":"cat > /root/.openclaw/workspaces/teacher-driving-training-system.bootstrap-backup/ahv-qlhv-fe/src/components/sat-hach/ExamStatsChart.tsx << 'EOF'\n\"use client\";\n\nimport React from 'react';\nimport {\n  Chart as ChartJS,\n  ArcElement,\n  CategoryScale,\n  LinearScale,\n  BarElement,\n  Title,\n  Tooltip,\n  Legend,\n} from 'chart.js';\nimport { Pie, Bar } from 'react-chartjs-2';\n\nChartJS.register(ArcElement, CategoryScale, LinearScale, BarElement, Title, Tooltip, Legend);\n\ninterface ExamStatsChartProps {\n  total: number;\n  passed: number;\n  failed: number;\n  absent: number;\n  noResult: number;\n  failedBySection: {\n    theory: number;\n    simulation: number;\n    parking: number;\n    road: number;\n  };\n  batchName: string;\n}\n\nexport default function ExamStatsChart({\n  total,\n  passed,\n  failed,\n  absent,\n  noResult,\n  failedBySection,\n  batchName,\n}: ExamStatsChartProps) {\n  if (total === 0) {\n    return (\n      <div className=\"flex items-center justify-center h-48 text-gray-400 text-sm font-medium\">\n        Chưa có dữ liệu học viên trong đợt thi này\n      </div>\n    );\n  }\n\n  // Pie chart data\n  const pieData = {\n    labels: ['Đậu', 'Trượt', 'Vắng thi', 'Chưa có kết quả'],\n    datasets: [\n      {\n        data: [passed, failed, absent, noResult],\n        backgroundColor: ['#22c55e', '#ef4444', '#6b7280', '#e5e7eb'],\n        borderColor: ['#16a34a', '#dc2626', '#4b5563', '#d1d5db'],\n        borderWidth: 2,\n        hoverOffset: 8,\n      },\n    ],\n  };\n\n  const pieOptions = {\n    responsive: true,\n    maintainAspectRatio: false,\n    plugins: {\n      legend: {\n        position: 'bottom' as const,\n        labels: {\n          padding: 16,\n          usePointStyle: true,\n          pointStyle: 'circle',\n          font: { size: 12, weight: '600' as const },\n          color: '#374151',\n        },\n      },\n      tooltip: {\n        callbacks: {\n          label: (ctx: any) => {\n            const val = ctx.parsed;\n            const pct = total > 0 ? ((val / total) * 100).toFixed(1) : 0;\n            return ` ${ctx.label}: ${val} (${pct}%)`;\n          },\n        },\n      },\n    },\n  };\n\n  // Bar chart data - failed by section\n  const sectionLabels = ['Lý thuyết', 'Mô phỏng', 'Sa hình', 'Đường trường'];\n  const sectionData = [\n    failedBySection.theory,\n    failedBySection.simulation,\n    failedBySection.parking,\n    failedBySection.road,\n  ];\n  const maxFailed = Math.max(...sectionData, 1);\n\n  const barData = {\n    labels: sectionLabels,\n    datasets: [\n      {\n        label: 'Số học viên trượt',\n        data: sectionData,\n        backgroundColor: sectionData.map(v =>\n          v === 0 ? '#d1d5db' : v > maxFailed * 0.6 ? '#ef4444' : v > maxFailed * 0.3 ? '#f59e0b' : '#fbbf24'\n        ),\n        borderColor: sectionData.map(v =>\n          v === 0 ? '#9ca3af' : '#dc2626'\n        ),\n        borderWidth: 1.5,\n        borderRadius: 8,\n        barThickness: 40,\n      },\n    ],\n  };\n\n  const barOptions = {\n    responsive: true,\n    maintainAspectRatio: false,\n    plugins: {\n      legend: { display: false },\n      tooltip: {\n        callbacks: {\n          label: (ctx: any) => ` ${ctx.parsed.y} học viên trượt`,\n        },\n      },\n    },\n    scales: {\n      y: {\n        beginAtZero: true,\n        max: Math.max(maxFailed + 1, 5),\n        ticks: {\n          stepSize: 1,\n          font: { size: 11, weight: '600' as const },\n          color: '#9ca3af',\n        },\n        grid: { color: '#f3f4f6' },\n      },\n      x: {\n        ticks: {\n          font: { size: 12, weight: '700' as const },\n          color: '#374151',\n        },\n        grid: { display: false },\n      },\n    },\n  };\n\n  return (\n    <div className=\"flex flex-col gap-6 p-6 bg-white border border-gray-100 rounded-2xl shadow-sm\">\n      <div className=\"flex items-center justify-between\">\n        <div>\n          <h3 className=\"text-base font-extrabold text-gray-900\">📊 Thống kê kết quả thi</h3>\n          <p className=\"text-xs text-gray-400 font-medium mt-0.5\">{batchName}</p>\n        </div>\n        <div className=\"flex items-center gap-3 text-xs font-bold\">\n          <span className=\"text-emerald-600\">● Đậu {passed}</span>\n          <span className=\"text-rose-500\">● Trượt {failed}</span>\n          <span className=\"text-gray-400\">● Vắng {absent}</span>\n        </div>\n      </div>\n\n      <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n        {/* Pie chart */}\n        <div className=\"flex flex-col\">\n          <p className=\"text-[11px] font-black text-gray-400 uppercase tracking-widest mb-3 text-center\">\n            Tỷ lệ kết quả chung\n          </p>\n          <div className=\"h-52\">\n            <Pie data={pieData} options={pieOptions} />\n          </div>\n        </div>\n\n        {/* Bar chart */}\n        <div className=\"flex flex-col\">\n          <p className=\"text-[11px] font-black text-gray-400 uppercase tracking-widest mb-3 text-center\">\n            Số học viên trượt theo phần thi\n          </p>\n          <div className=\"h-52\">\n            <Bar data={barData} options={barOptions} />\n          </div>\n        </div>\n      </div>\n\n      {/* Summary row */}\n      <div className=\"grid grid-cols-4 gap-3 pt-2 border-t border-gray-100\">\n        {[\n          { label: 'Tổng dự thi', value: total, cls: 'text-gray-700 bg-gray-50' },\n          { label: 'Tỷ lệ đậu', value: total > 0 ? ((passed / total) * 100).toFixed(1) + '%' : '0%', cls: 'text-emerald-600 bg-emerald-50' },\n          { label: 'Tỷ lệ trượt', value: total > 0 ? ((failed / total) * 100).toFixed(1) + '%' : '0%', cls: 'text-rose-500 bg-rose-50' },\n          { label: 'Vắng thi', value: absent, cls: 'text-gray-500 bg-gray-100' },\n        ].map((stat, i) => (\n          <div key={i} className={`flex flex-col items-center gap-1 p-3 rounded-xl ${stat.cls}`}>\n            <span className=\"text-lg font-black\">{stat.value}</span>\n            <span className=\"text-[10px] font-bold uppercase tracking-wider opacity-70\">{stat.label}</span>\n          </div>\n        ))}\n      </div>\n    </div>\n  );\n}\nEOF\necho \"✅ Created ExamStatsChart.tsx\"","timeout":5}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":0,"output":1917,"cacheRead":122393,"cacheWrite":0,"totalTokens":124310,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776508337988,"responseId":"063290b3ad576903301c416c4fba3871"}}
