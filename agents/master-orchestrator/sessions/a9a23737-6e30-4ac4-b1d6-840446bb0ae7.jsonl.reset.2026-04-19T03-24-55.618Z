<span className=\"w-8 h-8 rounded-full bg-indigo-50 text-indigo-600 flex items-center justify-center text-[11px] font-black group-hover/item:bg-indigo-600 group-hover/item:text-white transition-all\">\n                                  {i + 1}\n                                </span>\n                                <div className=\"flex flex-col\">\n                                  <span \n                                    className=\"font-extrabold text-gray-700 hover:text-indigo-600 cursor-pointer transition-colors\"\n                                    onClick={() => setSelectedStudent({ _id: result.student_id, user_id: { first_name: result.name } })}\n                                  >\n                                    {result.name || `Học viên #${i + 1}`}\n                                  </span>\n                                  <span className=\"text-gray-400 text-[10px] font-medium\">{result.student_id ? `Mã HV: ${result.student_id.slice(-6).toUpperCase()}` : '—'}</span>\n                                </div>\n                              </div>\n                              \n                              <div className=\"flex items-center gap-3\">\n                                <span className={`text-[10px] font-bold px-2 py-1 rounded border transition-all ${\n                                  result.result === 'pass' ? 'bg-emerald-50 text-emerald-600 border-emerald-100' : \n                                  result.result === 'fail' ? 'bg-rose-50 text-rose-600 border-rose-100' : \n                                  'bg-gray-50 text-gray-400 border-gray-200'\n                                }`}>\n                                  {result.result === 'pass' ? 'Đã đậu' : result.result === 'fail' ? 'Trượt' : 'Chờ kết quả'}\n                                </span>\n                                \n                                <div className=\"flex items-center gap-1 opacity-0 group-hover/item:opacity-100 transition-opacity\">\n                                  <button\n\n[226 more lines in file. Use offset=575 to continue.]"}],"isError":false,"timestamp":1776508413067}}
