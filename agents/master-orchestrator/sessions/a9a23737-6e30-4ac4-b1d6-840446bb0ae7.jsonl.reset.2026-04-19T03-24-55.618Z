{"type":"message","id":"8488bcde","parentId":"e32dbe08","timestamp":"2026-04-18T10:53:05.731Z","message":{"role":"toolResult","toolCallId":"call_function_iicm6qtfja3u_1","toolName":"read","content":[{"type":"text","text":"import { Request, Response } from 'express';\nimport { ExamBatchService } from '@/application/services/exam_batch.service';\nimport { ExamBatchRepository } from '@/infrastructure/database/repositories/exam_batch.repository';\nimport { catchAsync } from '@/interface/middlewares/catchAsync.middleware';\nimport multer from 'multer';\nimport * as fs from 'fs';\nimport * as path from 'path';\nimport XLSX from 'xlsx';\n\nconst examBatchRepository = new ExamBatchRepository();\nconst examBatchService = new ExamBatchService(examBatchRepository);\nconst upload = multer({ storage: multer.memoryStorage() });\n\nexport const importExamResults = catchAsync(async (req: Request, res: Response) => {\n  const file = (req as any).file;\n  const { batchId } = req.body;\n\n  if (!file) return res.statusError('No file uploaded', 400);\n  if (!batchId) return res.statusError('batchId is required', 400);\n\n  const XLSX = require('xlsx');\n  const workbook = XLSX.read(file.buffer, { type: 'buffer' });\n  const sheet = workbook.Sheets[workbook.SheetNames[0]];\n  const rows: any[] = XLSX.utils.sheet_to_json(sheet);\n\n  if (rows.length === 0) return res.statusError('File is empty', 400);\n\n  const batch = await examBatchService.getBatchById(batchId);\n  if (!batch) return res.statusError('Exam batch not found', 404);\n\n  const existingMap = new Map(\n    (batch.studentResults || []).map((r: any) => [r.student_id, r])\n  );\n\n  for (const row of rows) {\n    existingMap.set(String(row.student_id), {\n      student_id: String(row.student_id),\n      name: String(row.name || row.student_id),\n      result: ['pass', 'fail', 'absent', 'no_result'].includes(row.result) ? row.result : 'no_result',\n      theory_result: ['pass', 'fail', 'absent'].includes(row.theory_result) ? row.theory_result : undefined,\n      simulation_result: ['pass', 'fail', 'absent'].includes(row.simulation_result) ? row.simulation_result : undefined,\n      parking_result: ['pass', 'fail', 'absent'].includes(row.parking_result) ? row.parking_result : undefined,\n      road_result: ['pass', 'fail', 'absent'].includes(row.road_result) ? row.road_result : undefined,\n      note: String(row.note || ''),\n    });\n  }\n\n  await examBatchService.updateBatch(batchId, {\n    studentResults: Array.from(existingMap.values())\n  });\n\n  res.statusSuccess({ imported: rows.length }, 'Import thành công');\n});\n\nexport const getBatchStats = catchAsync(async (req: Request, res: Response) => {\n  const idStr = typeof req.params.id === 'string' ? req.params.id : req.params.id[0];\n  const stats = await examBatchService.getBatchStats(idStr);\n  res.statusSuccess(stats, 'Batch stats retrieved');\n});\n\n\n[15 more lines in file. Use offset=61 to continue.]"}],"isError":false,"timestamp":1776509585685}}
