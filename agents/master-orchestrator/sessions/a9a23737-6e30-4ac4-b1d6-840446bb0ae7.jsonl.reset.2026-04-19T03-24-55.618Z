{"type":"message","id":"8c9e5d5f","parentId":"260e01d5","timestamp":"2026-04-18T09:37:02.239Z","message":{"role":"toolResult","toolCallId":"call_function_z2d1h1wzoyx0_1","toolName":"exec","content":[{"type":"text","text":"import { Request, Response } from 'express';\nimport { ExamBatchService } from '@/application/services/exam_batch.service';\nimport { ExamBatchRepository } from '@/infrastructure/database/repositories/exam_batch.repository';\nimport { catchAsync } from '@/interface/middlewares/catchAsync.middleware';\n\nconst examBatchRepository = new ExamBatchRepository();\nconst examBatchService = new ExamBatchService(examBatchRepository);\n\nexport const createBatch = catchAsync(async (req: Request, res: Response) => {\n  const batch = await examBatchService.createBatch(req.body);\n  res.statusSuccess(batch, 'Exam batch created successfully');\n});\n\nexport const getAllBatches = catchAsync(async (req: Request, res: Response) => {\n  const batches = await examBatchService.getAllBatches(req.pagination);\n  res.statusSuccess(batches, 'Exam batches retrieved successfully');\n});\n\nexport const getBatchById = catchAsync(async (req: Request, res: Response) => {\n  const batch = await examBatchService.getBatchById((typeof req.params.id === 'string' ? req.params.id : req.params.id[0]));\n  if (!batch) {\n    return res.statusError('Exam batch not found', 404);\n  }\n  res.statusSuccess(batch, 'Exam batch retrieved successfully');\n});\n\nexport const updateBatch = catchAsync(async (req: Request, res: Response) => {\n  const batch = await examBatchService.updateBatch((typeof req.params.id === 'string' ? req.params.id : req.params.id[0]), req.body);\n  if (!batch) {\n    return res.statusError('Exam batch not found', 404);\n  }\n  res.statusSuccess(batch, 'Exam batch updated successfully');\n});\n\nexport const deleteBatch = catchAsync(async (req: Request, res: Response) => {\n  const idStr = typeof req.params.id === 'string' ? req.params.id : req.params.id[0];\n  await examBatchService.deleteBatch(idStr);\n  res.statusSuccess(null, 'Exam batch deleted successfully');\n});\n\nexport const exportBatches = catchAsync(async (req: Request, res: Response) => {\n  await examBatchService.exportBatchesToExcel(res, req.query);\n});"}],"details":{"status":"completed","exitCode":0,"durationMs":66,"aggregated":"import { Request, Response } from 'express';\nimport { ExamBatchService } from '@/application/services/exam_batch.service';\nimport { ExamBatchRepository } from '@/infrastructure/database/repositories/exam_batch.repository';\nimport { catchAsync } from '@/interface/middlewares/catchAsync.middleware';\n\nconst examBatchRepository = new ExamBatchRepository();\nconst examBatchService = new ExamBatchService(examBatchRepository);\n\nexport const createBatch = catchAsync(async (req: Request, res: Response) => {\n  const batch = await examBatchService.createBatch(req.body);\n  res.statusSuccess(batch, 'Exam batch created successfully');\n});\n\nexport const getAllBatches = catchAsync(async (req: Request, res: Response) => {\n  const batches = await examBatchService.getAllBatches(req.pagination);\n  res.statusSuccess(batches, 'Exam batches retrieved successfully');\n});\n\nexport const getBatchById = catchAsync(async (req: Request, res: Response) => {\n  const batch = await examBatchService.getBatchById((typeof req.params.id === 'string' ? req.params.id : req.params.id[0]));\n  if (!batch) {\n    return res.statusError('Exam batch not found', 404);\n  }\n  res.statusSuccess(batch, 'Exam batch retrieved successfully');\n});\n\nexport const updateBatch = catchAsync(async (req: Request, res: Response) => {\n  const batch = await examBatchService.updateBatch((typeof req.params.id === 'string' ? req.params.id : req.params.id[0]), req.body);\n  if (!batch) {\n    return res.statusError('Exam batch not found', 404);\n  }\n  res.statusSuccess(batch, 'Exam batch updated successfully');\n});\n\nexport const deleteBatch = catchAsync(async (req: Request, res: Response) => {\n  const idStr = typeof req.params.id === 'string' ? req.params.id : req.params.id[0];\n  await examBatchService.deleteBatch(idStr);\n  res.statusSuccess(null, 'Exam batch deleted successfully');\n});\n\nexport const exportBatches = catchAsync(async (req: Request, res: Response) => {\n  await examBatchService.exportBatchesToExcel(res, req.query);\n});","cwd":"/root/.openclaw/workspaces2/v4-ecosystem-review/master-orchestrator"},"isError":false,"timestamp":1776505022191}}
{"type":"message","id":"0b50bbef","parentId":"8c9e5d5f","timestamp":"2026-04-18T09:37:02.330Z","message":{"role":"toolResult","toolCallId":"call_function_z2d1h1wzoyx0_2","toolName":"exec","content":[{"type":"text","text":"import type {} from \"../types/express.d\";\nimport { Request, Response } from \"express\";\nimport mongoose from \"mongoose\";\nimport { StudentModel } from \"@/infrastructure/database/models/student.model\";\nimport { CourseStudentModel } from \"@/infrastructure/database/models/course_student.model\";\nimport { NotificationModel } from \"@/infrastructure/database/models/notification.model\";\nimport { ExamScheduleModel } from \"@/infrastructure/database/models/exam_schedule.model\";\nimport { catchAsync } from \"@/interface/middlewares/catchAsync.middleware\";\nimport { ctrlLogger } from \"@/infrastructure/logging/controller-logger\";\nimport { ExcelHelper } from \"@/infrastructure/utils/excel.helper\";\nimport { NotifyService } from \"@/application/services/notify.service\";\n\nconst notifyService = new NotifyService();\n\nexport const getDashboardStats = catchAsync(\n  async (req: Request, res: Response) => {\n    const log = ctrlLogger(\"dashboard.get_stats\", req);\n    log.start({ userId: (req.user as any)?.id ?? (req.user as any)?._id });\n    const today = new Date();\n    today.setHours(0, 0, 0, 0);\n\n    // --- MONTH BOUNDARIES ---\n    const startOfThisMonth = new Date(today.getFullYear(), today.getMonth(), 1);\n    const startOfLastMonth = new Date(\n      today.getFullYear(),\n      today.getMonth() - 1,\n      1,\n    );\n    const endOfLastMonth = new Date(\n      today.getFullYear(),\n      today.getMonth(),\n      0,\n      23,\n      59,\n      59,\n      999,\n    );\n\n    const sevenDaysLater = new Date(today);\n    sevenDaysLater.setDate(today.getDate() + 7);\n    sevenDaysLater.setHours(23, 59, 59, 999);\n\n    const thirtyDaysLater = new Date(today);\n    thirtyDaysLater.setDate(today.getDate() + 30);\n    thirtyDaysLater.setHours(23, 59, 59, 999);\n\n    const fortyEightHoursLater = new Date();\n    fortyEightHoursLater.setHours(fortyEightHoursLater.getHours() + 48);\n\n    // --- DATA ISOLATION ---\n    const studentMatch: any = { is_deleted: false };\n    const enrollmentMatch: any = {};\n    const userId = (req.user as any)?.id || (req.user as any)?._id;\n\n    if (req.user?.role === \"teacher\") {\n      const assignedStudentIds = await CourseStudentModel.find({\n        teacher_id: userId,\n      })\n        .distinct(\"student_id\")\n        .exec();\n      studentMatch._id = { $in: assignedStudentIds };\n      enrollmentMatch.teacher_id = new mongoose.Types.ObjectId(userId);\n    }\n\n    // 1. Core counts (Filtered by teacher if necessary)\n    const [totalStudents, thisMonthCount, lastMonthCount] = await Promise.all([\n      StudentModel.countDocuments(studentMatch),\n      StudentModel.countDocuments({\n        ...studentMatch,\n        created_at: { $gte: startOfThisMonth },\n      }),\n      StudentModel.countDocuments({\n        ...studentMatch,\n        created_at: { $gte: startOfLastMonth, $lte: endOfLastMonth },\n      }),\n    ]);\n\n    // 2. Monthly growth %\n    const monthlyGrowthPercent =\n      lastMonthCount > 0\n        ? Math.round(((thisMonthCount - lastMonthCount) / lastMonthCount) * 100)\n        : thisMonthCount > 0\n          ? 100\n          : 0;\n\n    // 3. Status distribution (Aggregating from StudentModel for consistency with list)\n    const statusCounts = await StudentModel.aggregate([\n      { $match: studentMatch },\n      {\n        $group: {\n          _id: { $ifNull: [\"$status_detail\", \"Chờ KSK\"] },\n          count: { $sum: 1 },\n        },\n      },\n    ]);\n\n    // 4. Total tuition debt\n    const debtAgg = await CourseStudentModel.aggregate([\n      { $match: { ...enrollmentMatch, $expr: { $lt: [\"$paid_fee\", \"$fee\"] } } },\n      {"}],"details":{"status":"completed","exitCode":0,"durationMs":157,"aggregated":"import type {} fr