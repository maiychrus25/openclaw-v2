  const enrollmentMatch: any = {};\n    const userId = (req.user as any)?.id || (req.user as any)?._id;\n\n    if (req.user?.role === \"teacher\") {\n      const assignedStudentIds = await CourseStudentModel.find({\n        teacher_id: userId,\n      })\n        .distinct(\"student_id\")\n        .exec();\n      studentMatch._id = { $in: assignedStudentIds };\n      enrollmentMatch.teacher_id = new mongoose.Types.ObjectId(userId);\n    }\n\n    // 1. Core counts (Filtered by teacher if necessary)\n    const [totalStudents, thisMonthCount, lastMonthCount] = await Promise.all([\n      StudentModel.countDocuments(studentMatch),\n      StudentModel.countDocuments({\n        ...studentMatch,\n        created_at: { $gte: startOfThisMonth },\n      }),\n      StudentModel.countDocuments({\n        ...studentMatch,\n        created_at: { $gte: startOfLastMonth, $lte: endOfLastMonth },\n      }),\n    ]);\n\n    // 2. Monthly growth %\n    const monthlyGrowthPercent =\n      lastMonthCount > 0\n        ? Math.round(((thisMonthCount - lastMonthCount) / lastMonthCount) * 100)\n        : thisMonthCount > 0\n          ? 100\n          : 0;\n\n    // 3. Status distribution (Aggregating from StudentModel for consistency with list)\n    const statusCounts = await StudentModel.aggregate([\n      { $match: studentMatch },\n      {\n        $group: {\n          _id: { $ifNull: [\"$status_detail\", \"Chờ KSK\"] },\n          count: { $sum: 1 },\n        },\n      },\n    ]);\n\n    // 4. Total tuition debt\n    const debtAgg = await CourseStudentModel.aggregate([\n      { $match: { ...enrollmentMatch, $expr: { $lt: [\"$paid_fee\", \"$fee\"] } } },\n      {","cwd":"/root/.openclaw/workspaces2/v4-ecosystem-review/master-orchestrator"},"isError":false,"timestamp":1776505022282}}
