{"type":"message","id":"48f5ab5a","parentId":"679898d5","timestamp":"2026-04-13T01:47:12.256Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Let me read the key auth files to understand the registration and login flow.","thinkingSignature":"4e25e5dc87f971017152fe2b4e6c05353f642677a611b9ffc5f0ae868c9aeea0"},{"type":"toolCall","id":"call_function_rh9id3n03un2_1","name":"read","arguments":{"path":"/root/.openclaw/workspaces/teacher-driving-training-system.bootstrap-backup/ahv-qlhv-be/src/interface/controllers/auth.controller.ts"}},{"type":"toolCall","id":"call_function_rh9id3n03un2_2","name":"read","arguments":{"path":"/root/.openclaw/workspaces/teacher-driving-training-system.bootstrap-backup/ahv-qlhv-be/src/interface/routes/auth.routes.ts"}},{"type":"toolCall","id":"call_function_rh9id3n03un2_3","name":"read","arguments":{"path":"/root/.openclaw/workspaces/teacher-driving-training-system.bootstrap-backup/ahv-qlhv-fe/src/app/(auth)/register/page.tsx"}},{"type":"toolCall","id":"call_function_rh9id3n03un2_4","name":"read","arguments":{"path":"/root/.openclaw/workspaces/teacher-driving-training-system.bootstrap-backup/ahv-qlhv-fe/src/app/(auth)/login/page.tsx"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":1272,"output":214,"cacheRead":100165,"cacheWrite":514,"totalTokens":102165,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776044822719,"responseId":"062b7e1806d754a99dd9bc7c9be5fae7"}}
{"type":"message","id":"94c8a59b","parentId":"48f5ab5a","timestamp":"2026-04-13T01:47:12.659Z","message":{"role":"toolResult","toolCallId":"call_function_rh9id3n03un2_1","toolName":"read","content":[{"type":"text","text":"import type {} from \"../types/express.d\";\nimport { Request, Response } from \"express\";\nimport bcrypt from \"bcrypt\";\nimport jwt from \"jsonwebtoken\";\nimport { UserModel as User } from \"@/infrastructure/database/models/user.model\";\nimport { catchAsync } from \"@/interface/middlewares/catchAsync.middleware\";\nimport { ctrlLogger } from \"@/infrastructure/logging/controller-logger\";\nimport { tokenBlacklist } from \"@/infrastructure/security/token-blacklist.service\";\nimport {\n  SystemLogModel,\n  ActionType,\n} from \"@/infrastructure/database/models/system_log.model\";\nimport { UserAgentModel } from \"@/infrastructure/database/models/user_agent.model\";\nimport { UserRoleModel } from \"@/infrastructure/database/models/user_role.model\";\nimport { RoleModel } from \"@/infrastructure/database/models/role.model\";\nimport logger from '@/infrastructure/logging/logger';\n\n/**\n * Helper to fetch all of a user's role names relationally\n */\nasync function getUserRoles(userId: any): Promise<string[]> {\n  const userRoles = await UserRoleModel.find({ user_id: userId }).populate(\"role_id\");\n  const roles = userRoles\n    .map((ur) => (ur.role_id as any)?.role_name)\n    .filter((name) => !!name);\n  \n  return roles.length > 0 ? roles : [\"student\"]; // Default fallback\n}\n\nexport const register = catchAsync(async (req: Request, res: Response) => {\n  const log = ctrlLogger('auth.register', req);\n  const {\n    username,\n    password,\n    role,\n    first_name,\n    last_name,\n    email,\n    phone,\n    address,\n    identity_card,\n  } = req.body;\n\n  log.start({ username });\n\n  const passwordHash = await bcrypt.hash(password, 10);\n\n  const user = await User.create({\n    username,\n    password: passwordHash,\n    first_name,\n    last_name,\n    email,\n    phone,\n    address: address || \"N/A\",\n    identity_card: identity_card || \"N/A\",\n  });\n\n  // Assign roles in userroles collection\n  if (role) {\n    const rolesToAssign = Array.isArray(role) ? role : [role];\n    for (const r of rolesToAssign) {\n      const roleDoc = await RoleModel.findOne({ role_name: r.toLowerCase() });\n      if (roleDoc) {\n        await UserRoleModel.create({\n          user_id: user._id,\n          role_id: roleDoc._id\n        });\n      }\n    }\n  }\n\n  log.success(\n    res,\n    { id: user._id, username: user.username, roles: Array.isArray(role) ? role : [role] },\n    \"User registered successfully\",\n  );\n});\n\nexport const login = catchAsync(async (req: Request, res: Response) => {\n  const log = ctrlLogger('auth.login', req);\n  const { username, password } = req.body;\n\n  log.start({ username });\n\n  const user = await User.findOne({ username });\n  if (!user || !(await bcrypt.compare(password, user.password))) {\n    return log.fail('invalid_credentials', res, 401, 'Invalid credentials', { username });\n  }\n\n  // Fetch agent_id and roles relationally\n  const [userAgent, roles] = await Promise.all([\n    UserAgentModel.findOne({ user_id: user._id }),\n    getUserRoles(user._id)\n  ]);\n  \n  const agentId = userAgent?.agent_id || null;\n  const primaryRole = roles[0];\n\n  const accessToken = jwt.sign(\n    { id: user._id, role: primaryRole, roles: roles, agent_id: agentId },\n    process.env.JWT_SECRET!,\n    { expiresIn: \"24h\" },\n  );\n\n  const refreshToken = jwt.sign(\n    { id: user._id },\n    process.env.JWT_REFRESH_SECRET!,\n    { expiresIn: \"7d\" },\n  );\n\n  // Save refresh token to user\n  user.refresh_token = refreshToken;\n  await user.save();\n\n  // Cross-domain cookie config: Render (BE) <-> Vercel (FE)\n  // SameSite=None + Secure=true is required for cross-site cookies over HTTPS\n  const isProduction =\n    process.env.RENDER === \"true\" || process.env.NODE_ENV === \"production\";\n  res.cookie(\"refreshToken\", refreshToken, {\n    httpOnly: true,\n    secure: isProduction, // true trên Render (HTTPS), false trên localhost\n    sameSite: isProduction ? \"none\" : \"lax\", // 'none' cho phép cross-domain trên HTTPS\n    maxAge: 7 * 24 * 60 * 60 * 1000, // 7 days\n  });\n\n  // Log successful login to system audit log (non-critical — fires after response)\n  const loginResponse = {\n    token: accessToken,\n    user: {\n      id: user._id,\n      username: user.username,\n      role: primaryRole,\n      roles: roles,\n      first_name: user.first_name,\n      last_name: user.last_name,\n      agent_id: agentId,\n    },\n  };\n\n  log.success(res, loginResponse, \"Login successful\");\n\n  try {\n    await SystemLogModel.create({\n      user_id: user._id,\n      title: \"Đăng nhập hệ thống\",\n      action: ActionType.LOGIN,\n      entity_type: \"AUTH\",\n      entity_id: user._id.toString(),\n      ip_address: req.ip,\n      user_agent: req.headers[\"user-agent\"],\n    });\n  } catch (error) {\n    logger.error(\"Failed to log login:\", error);\n  }\n});\n\nexport const refreshToken = catchAsync(async (req: Request, res: Response) => {\n  const log = ctrlLogger('auth.refresh_token', req);\n  const tokenFromCookie = req.cookies.refreshToken;\n\n  log.start({});\n\n  if (!tokenFromCookie) {\n    return log.fail('no_refresh_token', res, 401, 'No refresh token provided');\n  }\n\n  const user = await User.findOne({ refresh_token: tokenFromCookie });\n  if (!user) {\n    return log.fail('invalid_refresh_token', res, 403, 'Invalid refresh token');\n  }\n\n  try {\n    const roles = await getUserRoles(user._id);\n\n    const newAccessToken = jwt.sign(\n      { id: user._id, role: roles[0], roles: roles },\n      process.env.JWT_SECRET!,\n      { expiresIn: \"24h\" },\n    );\n\n    log.success(\n      res,\n      { token: newAccessToken },\n      \"Token refreshed successfully\",\n    );\n  } catch (error) {\n    log.error('jwt_sign_failed', error);\n    return res.statusError(\"Refresh token expired\", 403);\n  }\n});\n\nexport const getMe = catchAsync(async (req: any, res: Response) => {\n  const log = ctrlLogger('auth.get_me', req);\n  log.start({ userId: req.user.id });\n\n  const user = await User.findById(req.user.id).select(\"-password\");\n  if (!user) {\n    return log.fail('user_not_found', res, 404, 'User not found');\n  }\n\n  // Fetch agent_id and roles\n  const [userAgent, roles] = await Promise.all([\n    UserAgentModel.findOne({ user_id: user._id }),\n    getUserRoles(user._id)\n  ]);\n\n  // Normalize user object for frontend\n  const userProfile = {\n    id: user._id,\n    username: user.username,\n    role: roles[0],\n    roles: roles,\n    first_name: user.first_name,\n    last_name: user.last_name,\n    email: user.email,\n    phone: user.phone,\n    address: user.address,\n    image: user.image,\n    bio: (user as any).bio,\n    agent_id: userAgent?.agent_id || null,\n  };\n\n  log.success(res, userProfile, 'Profile retrieved successfully');\n});\n\nexport const updateMe = catchAsync(async (req: any, res: Response) => {\n  const log = ctrlLogger('auth.update_me', req);\n  const { first_name, last_name, email, phone, address, image, bio } = req.body;\n\n  log.start({ userId: req.user.id });\n\n  const user = await User.findById(req.user.id);\n  if (!user) {\n    return log.fail('user_not_found', res, 404, 'User not found');\n  }\n\n  // Update only allowed fields\n  if (first_name) user.first_name = first_name;\n  if (last_name) user.last_name = last_name;\n  if (email) user.email = email;\n  if (phone) user.phone = phone;\n  if (address) user.address = address;\n  if (image) user.image = image;\n  if (bio !== undefined) (user as any).bio = bio;\n\n  await user.save();\n\n  const roles = await getUserRoles(user._id);\n\n  const updatedProfile = {\n    id: user._id,\n    username: user.username,\n    role: roles[0],\n    roles: roles,\n    first_name: user.first_name,\n    last_name: user.last_name,\n    email: user.email,\n    phone: user.phone,\n    address: user.address,\n    image: user.image,\n    bio: (user as any).bio,\n  };\n\n  log.success(res, updatedProfile, 'Profile updated successfully');\n});\n\nexport const changePassword = catchAsync(async (req: any, res: Response) => {\n  const log = ctrlLogger('auth.change_password', req);\n  const { old_password, new_password } = req.body;\n\n  log.start({ userId: req.user.id });\n\n  const user = await User.findById(req.user.id);\n  if (!user) {\n    return log.fail('user_not_found', res, 404, 'User not found');\n  }\n\n  // Verify old password\n  const isMatch = await bcrypt.compare(old_password, user.password);\n  if (!isMatch) {\n    return log.fail('wrong_old_password', res, 400, 'Mật khẩu cũ không chính xác');\n  }\n\n  // Hash new password\n  const salt = await bcrypt.genSalt(10);\n  user.password = await bcrypt.hash(new_password, salt);\n\n  // Clear refresh token for security (forces re-login)\n  user.refresh_token = undefined;\n\n  await user.save();\n\n  log.success(res, null, 'Đổi mật khẩu thành công. Vui lòng đăng nhập lại.');\n});\n\nexport const logout = catchAsync(async (req: Request, res: Response) => {\n  const log = ctrlLogger('auth.logout', req);\n  const { refreshToken } = req.cookies;\n  const authHeader = req.headers.authorization;\n\n  log.start({});\n\n  // Blacklist the current access token\n  if (authHeader && authHeader.startsWith(\"Bearer \")) {\n    const accessToken = authHeader.split(\" \")[1];\n    tokenBlacklist.add(accessToken);\n  }\n\n  if (refreshToken) {\n    await User.findOneAndUpdate(\n      { refresh_token: refreshToken },\n      { refresh_token: null },\n    );\n  }\n  const isProduction =\n    process.env.RENDER === \"true\" || process.env.NODE_ENV === \"production\";\n  res.clearCookie(\"refreshToken\", {\n    httpOnly: true,\n    secure: isProduction,\n    sameSite: isProduction ? \"none\" : \"lax\",\n  });\n  // Log logout to system audit log\n  try {\n    const user = await User.findOne({ refresh_token: refreshToken });\n    if (user) {\n      await SystemLogModel.create({\n        user_id: user._id,\n        action: ActionType.LOGOUT,\n        entity_type: \"AUTH\",\n        entity_id: user._id.toString(),\n        ip_address: req.ip,\n        user_agent: req.headers[\"user-agent\"],\n      });\n    }\n  } catch (error) {\n    logger.error(\"Failed to log logout:\", error);\n  }\n\n  log.success(res, null, 'Logged out successfully');\n});\n\nexport const getLoginHistory = catchAsync(async (req: any, res: Response) => {\n  const log = ctrlLogger('auth.get_login_history', req);\n  log.start({ userId: req.user.id });\n\n  const history = await SystemLogModel.find({\n    user_id: req.user.id,\n    action: { $in: [ActionType.LOGIN, ActionType.LOGOUT] },\n  })\n    .sort({ created_at: -1 })\n    .limit(10)\n    .lean();\n\n  log.success(res, history, 'Login history retrieved successfully', { count: history.length });\n});\n"}],"isError":false,"timestamp":1776044832591}}
{"type":"message","id":"3e848515","parentId":"94c8a59b","timestamp":"2026-04-13T01:47:12.733Z","message":{"role":"toolResult","toolCallId":"call_function_rh9id3n03un2_2","toolName":"read","content":[{"type":"text","text":"import express from 'express';\nimport * as authController from '@/interface/controllers/auth.controller';\nimport { validate } from '@/interface/middlewares/validation.middleware';\nimport { loginSchema, registerSchema, changePasswordSchema } from '@/interface/dtos/auth.dto';\nimport { authenticateJWT } from '@/interface/middlewares/auth.middleware';\n\nconst router = express.Router();\n\nrouter.post('/register', validate(registerSchema), authController.register);\nrouter.post('/login', validate(loginSchema), authController.login);\nrouter.post('/refresh', authController.refreshToken);\nrouter.get('/me', authenticateJWT, authController.getMe);\nrouter.patch('/me', authenticateJWT, authController.updateMe);\nrouter.patch('/change-password', authenticateJWT, validate(changePasswordSchema), authController.changePassword);\nrouter.get('/login-history', authenticateJWT, authController.getLoginHistory);\nrouter.post('/logout', authController.logout);\n\nexport default router;\n"}],"isError":false,"timestamp":1776044832660}}
{"type":"message","id":"2e210605","parentId":"3e848515","timestamp":"2026-04-13T01:47:12.814Z","message":{"role":"toolResult","toolCallId":"call_function_rh9id3n03un2_3","toolName":"read","content":[{"type":"text","text":"'use client';\n\nimport React, { useState } from 'react';\nimport Link from 'next/link';\nimport { User, Phone, Mail, Lock, ChevronRight, GraduationCap, AlertCircle, Fingerprint } from 'lucide-react';\nimport Button from '@/src/components/ui/Button';\nimport * as authService from '@/src/services/authService';\nimport { useRouter } from 'next/navigation';\n\nexport default function RegisterPage() {\n  const [fullName, setFullName] = useState('');\n  const [username, setUsername] = useState('');\n  const [phone, setPhone] = useState('');\n  const [email, setEmail] = useState('');\n  const [password, setPassword] = useState('');\n  const [error, setError] = useState<string | null>(null);\n  const [loading, setLoading] = useState(false);\n  const router = useRouter();\n\n  const handleSubmit = async (e: React.FormEvent) => {\n    e.preventDefault();\n    setLoading(true);\n    setError(null);\n\n    // Split Full Name into First and Last Name\n    const nameParts = fullName.trim().split(' ');\n    const first_name = nameParts.length > 1 ? nameParts.pop() || '' : nameParts[0];\n    const last_name = nameParts.join(' ') || first_name;\n\n    try {\n      const response = await authService.register({\n        username,\n        password,\n        first_name,\n        last_name,\n        email,\n        phone,\n      });\n\n      if (response.success) {\n        router.push('/login');\n      } else {\n        setError(response.message || 'Đăng ký thất bại. Vui lòng thử lại.');\n      }\n    } catch (err: any) {\n      setError(err.message || 'Đăng ký thất bại. Vui lòng thử lại.');\n    } finally {\n      setLoading(false);\n    }\n  };\n\n  return (\n    <div className=\"bg-white rounded-3xl shadow-2xl p-10 flex flex-col gap-8 relative overflow-hidden\">\n      {/* Header Section */}\n      <div className=\"flex flex-col gap-2\">\n        <div className=\"w-12 h-12 bg-primary-soft rounded-xl flex items-center justify-center text-primary mb-4\">\n          <GraduationCap className=\"w-6 h-6\" />\n        </div>\n        <h2 className=\"text-3xl font-extrabold text-gray-900 tracking-tight\">Đăng ký</h2>\n        <p className=\"text-gray-500 font-medium\">Bắt đầu hành trình của bạn ngay hôm nay!</p>\n      </div>\n\n      {error && (\n        <div className=\"bg-red-50 border border-red-100 text-red-600 px-4 py-3 rounded-xl flex items-center gap-3 text-sm font-medium animate-in fade-in slide-in-from-top-2\">\n          <AlertCircle className=\"w-5 h-5 flex-shrink-0\" />\n          {error}\n        </div>\n      )}\n\n      {/* Form Section */}\n      <form className=\"space-y-4\" onSubmit={handleSubmit}>\n        <div className=\"grid grid-cols-1 gap-4\">\n          <div className=\"space-y-1.5 relative group\">\n            <label className=\"text-[10px] font-bold text-gray-400 uppercase tracking-widest pl-1\">Họ và tên</label>\n            <div className=\"relative\">\n              <User className=\"absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400 group-focus-within:text-primary transition-colors\" />\n                <input \n                  type=\"text\" \n                  placeholder=\"Nguyễn Văn An\" \n                  value={fullName}\n                  onChange={(e) => setFullName(e.target.value)}\n                  required\n                  className=\"w-full pl-12 pr-4 py-4 bg-gray-50 border border-gray-100 rounded-2xl font-medium outline-none focus:border-primary/20 focus:bg-white transition-all text-gray-900\"\n                />\n            </div>\n          </div>\n\n          <div className=\"space-y-1.5 relative group\">\n            <label className=\"text-[10px] font-bold text-gray-400 uppercase tracking-widest pl-1\">Tên đăng nhập</label>\n            <div className=\"relative\">\n              <Fingerprint className=\"absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400 group-focus-within:text-primary transition-colors\" />\n                <input \n                  type=\"text\" \n                  placeholder=\"username123\" \n                  value={username}\n                  onChange={(e) => setUsername(e.target.value)}\n                  required\n                  className=\"w-full pl-12 pr-4 py-4 bg-gray-50 border border-gray-100 rounded-2xl font-medium outline-none focus:border-primary/20 focus:bg-white transition-all text-gray-900\"\n                />\n            </div>\n          </div>\n\n          <div className=\"space-y-1.5 relative group\">\n            <label className=\"text-[10px] font-bold text-gray-400 uppercase tracking-widest pl-1\">Số điện thoại</label>\n            <div className=\"relative\">\n              <Phone className=\"absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400 group-focus-within:text-primary transition-colors\" />\n                <input \n                  type=\"tel\" \n                  placeholder=\"0912 345 678\" \n                  value={phone}\n                  onChange={(e) => setPhone(e.target.value)}\n                  required\n                  className=\"w-full pl-12 pr-4 py-4 bg-gray-50 border border-gray-100 rounded-2xl font-medium outline-none focus:border-primary/20 focus:bg-white transition-all text-gray-900\"\n                />\n            </div>\n          </div>\n\n          <div className=\"space-y-1.5 relative group\">\n            <label className=\"text-[10px] font-bold text-gray-400 uppercase tracking-widest pl-1\">Email liên lạc</label>\n            <div className=\"relative\">\n              <Mail className=\"absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400 group-focus-within:text-primary transition-colors\" />\n                <input \n                  type=\"email\" \n                  placeholder=\"an.nguyenv@gmail.com\" \n                  value={email}\n                  onChange={(e) => setEmail(e.target.value)}\n                  required\n                  className=\"w-full pl-12 pr-4 py-4 bg-gray-50 border border-gray-100 rounded-2xl font-medium outline-none focus:border-primary/20 focus:bg-white transition-all text-gray-900\"\n                />\n            </div>\n          </div>\n\n          <div className=\"space-y-1.5 relative group\">\n            <label className=\"text-[10px] font-bold text-gray-400 uppercase tracking-widest pl-1\">Mật khẩu</label>\n            <div className=\"relative\">\n              <Lock className=\"absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400 group-focus-within:text-primary transition-colors\" />\n                <input \n                  type=\"password\" \n                  placeholder=\"••••••••\" \n                  value={password}\n                  onChange={(e) => setPassword(e.target.value)}\n                  required\n                  className=\"w-full pl-12 pr-4 py-4 bg-gray-50 border border-gray-100 rounded-2xl font-medium outline-none focus:border-primary/20 focus:bg-white transition-all text-gray-900\"\n                />\n            </div>\n          </div>\n        </div>\n\n        <Button \n          fullWidth \n          size=\"lg\" \n          type=\"submit\"\n          disabled={loading}\n          className=\"rounded-2xl mt-6 py-4 flex items-center gap-2 group justify-center\"\n        >\n          {loading ? 'Đang tạo tài khoản...' : (\n            <>\n              Tạo tài khoản <ChevronRight className=\"w-4 h-4 group-hover:translate-x-1 transition-transform\" />\n            </>\n          )}\n        </Button>\n      </form>\n\n      {/* Footer */}\n      <div className=\"text-center pt-4\">\n        <p className=\"text-sm text-gray-500 font-medium\">\n          Đã có tài khoản?{' '}\n          <Link href=\"/login\" className=\"text-primary font-bold hover:underline\">Đăng nhập ngay</Link>\n        </p>\n      </div>\n\n      <div className=\"absolute top-0 right-0 w-32 h-32 bg-primary/5 rounded-full -mr-16 -mt-16\"></div>\n      <div className=\"absolute bottom-0 left-0 w-24 h-24 bg-primary/5 rounded-full -ml-12 -mb-12\"></div>\n    </div>\n  );\n}\n"}],"isError":false,"timestamp":1776044832734}}
{"type":"message","id":"3bea7e66","parentId":"2e210605","timestamp":"2026-04-13T01:47:12.885Z","message":{"role":"toolResult","toolCallId":"call_function_rh9id3n03un2_4","toolName":"read","content":[{"type":"text","text":"'use client';\n\nimport React, { useState } from 'react';\nimport Link from 'next/link';\nimport { Mail, Lock, ChevronRight, User, AlertCircle } from 'lucide-react';\nimport Button from '@/src/components/ui/Button';\nimport * as authService from '@/src/services/authService';\nimport { useAuth } from '@/src/context/AuthContext';\nimport { useRouter } from 'next/navigation';\n\nexport default function LoginPage() {\n  const [username, setUsername] = useState('');\n  const [password, setPassword] = useState('');\n  const [error, setError] = useState<string | null>(null);\n  const [loading, setLoading] = useState(false);\n  const { setToken } = useAuth();\n  const router = useRouter();\n\n  const handleSubmit = async (e: React.FormEvent) => {\n    e.preventDefault();\n    setLoading(true);\n    setError(null);\n\n    try {\n      const response = await authService.login(username, password);\n      if (response.success && response.data?.token) {\n        // Pass user data to context to avoid redundant /auth/me call\n        const user = response.data.user;\n        setToken(response.data.token, user);\n        router.push('/dashboard');\n      } else {\n        setError(response.message || 'Đăng nhập thất bại. Vui lòng thử lại.');\n      }\n    } catch (err: any) {\n      setError(err.message || 'Đăng nhập thất bại. Vui lòng thử lại.');\n    } finally {\n      setLoading(false);\n    }\n  };\n\n  return (\n    <div className=\"bg-white rounded-3xl shadow-2xl p-10 flex flex-col gap-8 relative overflow-hidden\">\n      {/* Login Header */}\n      <div className=\"flex flex-col gap-2\">\n        <div className=\"w-12 h-12 bg-primary-soft rounded-xl flex items-center justify-center text-primary mb-4\">\n          <User className=\"w-6 h-6\" />\n        </div>\n        <h2 className=\"text-3xl font-extrabold text-gray-900 tracking-tight\">Đăng nhập</h2>\n        <p className=\"text-gray-500 font-medium\">Chào mừng bạn quay trở lại!</p>\n      </div>\n\n      {error && (\n        <div className=\"bg-red-50 border border-red-100 text-red-600 px-4 py-3 rounded-xl flex items-center gap-3 text-sm font-medium animate-in fade-in slide-in-from-top-2\">\n          <AlertCircle className=\"w-5 h-5 flex-shrink-0\" />\n          {error}\n        </div>\n      )}\n\n      {/* Form Fields */}\n      <form className=\"space-y-4\" onSubmit={handleSubmit}>\n        <div className=\"space-y-1.5 focus-within:z-10 relative\">\n          <label className=\"text-[10px] font-bold text-gray-400 uppercase tracking-widest pl-1\">Tên đăng nhập</label>\n          <div className=\"relative group\">\n            <Mail className=\"absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400 group-focus-within:text-primary transition-colors\" />\n            <input \n              type=\"text\" \n              placeholder=\"admin\" \n              value={username}\n              onChange={(e) => setUsername(e.target.value)}\n              required\n              className=\"w-full pl-12 pr-4 py-4 bg-gray-50 border border-gray-100 rounded-2xl font-medium outline-none focus:border-primary/20 focus:bg-white transition-all text-gray-900\"\n            />\n          </div>\n        </div>\n\n        <div className=\"space-y-1.5 relative\">\n          <div className=\"flex items-center justify-between pl-1\">\n            <label className=\"text-[10px] font-bold text-gray-400 uppercase tracking-widest\">Mật khẩu</label>\n            <Link href=\"#\" className=\"text-[10px] font-bold text-primary uppercase tracking-widest hover:underline\">Quên mật khẩu?</Link>\n          </div>\n          <div className=\"relative group\">\n            <Lock className=\"absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400 group-focus-within:text-primary transition-colors\" />\n            <input \n              type=\"password\" \n              placeholder=\"••••••••\" \n              value={password}\n              onChange={(e) => setPassword(e.target.value)}\n              required\n              className=\"w-full pl-12 pr-4 py-4 bg-gray-50 border border-gray-100 rounded-2xl font-medium outline-none focus:border-primary/20 focus:bg-white transition-all text-gray-900\"\n            />\n          </div>\n        </div>\n\n        <Button \n          fullWidth \n          size=\"lg\" \n          type=\"submit\"\n          disabled={loading}\n          className=\"rounded-2xl mt-6 py-4 flex items-center gap-2 group justify-center\"\n        >\n          {loading ? 'Đang xử lý...' : (\n            <>\n              Tiếp tục <ChevronRight className=\"w-4 h-4 group-hover:translate-x-1 transition-transform\" />\n            </>\n          )}\n        </Button>\n      </form>\n\n      {/* Footer */}\n      <div className=\"text-center pt-4\">\n        <p className=\"text-sm text-gray-500 font-medium\">\n          Bạn chưa có tài khoản?{' '}\n          <Link href=\"/register\" className=\"text-primary font-bold hover:underline\">Đăng ký ngay</Link>\n        </p>\n      </div>\n\n      <div className=\"absolute top-0 right-0 w-32 h-32 bg-primary/5 rounded-full -mr-16 -mt-16\"></div>\n      <div className=\"absolute bottom-0 left-0 w-24 h-24 bg-primary/5 rounded-full -ml-12 -mb-12\"></div>\n    </div>\n  );\n}\n"}],"isError":false,"timestamp":1776044832815}}
