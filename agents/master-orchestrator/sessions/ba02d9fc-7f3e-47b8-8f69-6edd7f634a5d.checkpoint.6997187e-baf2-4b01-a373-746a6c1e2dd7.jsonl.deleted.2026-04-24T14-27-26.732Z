{"type":"message","id":"24488b93","parentId":"063a359b","timestamp":"2026-04-13T03:22:19.642Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"There's a `license_category.model.ts`. Let me read it, then check if there's an API route for it, and also check the FE settings page more thoroughly.","thinkingSignature":"f52fe3e0bd76d619ae8cc673099a05a57bfc952ae296032e65bb2150c5c3aee0"},{"type":"toolCall","id":"call_function_udf3guzrdnfq_1","name":"read","arguments":{"path":"/root/.openclaw/workspaces/teacher-driving-training-system.bootstrap-backup/ahv-qlhv-be/src/infrastructure/database/models/license_category.model.ts"}},{"type":"toolCall","id":"call_function_udf3guzrdnfq_2","name":"read","arguments":{"path":"/root/.openclaw/workspaces/teacher-driving-training-system.bootstrap-backup/ahv-qlhv-fe/src/app/settings/page.tsx"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":362,"output":135,"cacheRead":139848,"cacheWrite":666,"totalTokens":141011,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776050534165,"responseId":"062b9467cfbef377f7583a172c107340"}}
{"type":"message","id":"38cf848d","parentId":"24488b93","timestamp":"2026-04-13T03:22:19.893Z","message":{"role":"toolResult","toolCallId":"call_function_udf3guzrdnfq_1","toolName":"read","content":[{"type":"text","text":"import mongoose, { Schema, Document } from 'mongoose';\n\nexport interface ILicenseCategory extends Document {\n  name: string;\n  code: string;\n  description?: string;\n}\n\nconst LicenseCategorySchema = new Schema<ILicenseCategory>({\n  name: { type: String, required: true },\n  code: { type: String, required: true, unique: true },\n  description: { type: String },\n}, {\n  timestamps: { createdAt: 'created_at', updatedAt: 'updated_at' },\n  versionKey: false,\n  collection: 'licensecategories'\n});\n\nif (mongoose.models.LicenseCategories) {\n  mongoose.deleteModel('LicenseCategories');\n}\nexport const LicenseCategoryModel = mongoose.model<ILicenseCategory>('LicenseCategories', LicenseCategorySchema, 'licensecategories');\n"}],"isError":false,"timestamp":1776050539819}}
{"type":"message","id":"071c96a0","parentId":"38cf848d","timestamp":"2026-04-13T03:22:20.005Z","message":{"role":"toolResult","toolCallId":"call_function_udf3guzrdnfq_2","toolName":"read","content":[{"type":"text","text":"'use client';\n\nimport React, { useState, useEffect } from 'react';\nimport {\n  Settings, Save, Shield, Bell, User, Sliders, Crown, FileText, Cloud, Database,\n  MapPin, CreditCard, Banknote, Stethoscope, Car, Flag, Building2, Plus, Edit2, Trash2,\n  CheckCircle2, AlertTriangle, Download, Upload, Trash, Info, Send, Phone, Mail, Globe, Map,\n  ClipboardList, ArrowUp, ArrowDown, ExternalLink, Monitor, Navigation, Lock, Key, Eye, EyeOff,\n  Smartphone, History, Loader2, AlertCircle\n} from 'lucide-react';\nimport { useAuth } from '@/src/context/AuthContext';\nimport { updateProfile, changePassword, getLoginHistory } from '@/src/services/authService';\nimport UnderDevelopment from '@/src/components/shared/UnderDevelopment';\nimport { toast } from 'sonner';\nimport { ConfirmDeleteModal, LicenseModal, ClinicModal, ExamCenterModal, RegionModal, FeeBatchModal } from './SettingsModals';\nimport { getSystemSettings, updateSystemSettings, SystemSettings, LicenseCategory, Clinic as ClinicType } from '@/src/services/settingsService';\nimport { getCities, createCity, updateCity, deleteCity, City } from '@/src/services/cityService';\nimport { getStadiums, createStadium, updateStadium, deleteStadium, Stadium } from '@/src/services/stadiumService';\n\n/* ─── Level 1 Tabs (Top) ─────────────────────────────── */\nconst TOP_TABS = [\n  { id: 'chung',     label: 'Chung',      icon: Sliders },\n  { id: 'tai-khoan', label: 'Tài khoản',   icon: User },\n  { id: 'vip-qr',    label: 'VIP QR',     icon: Crown },\n  { id: 'form-hv',   label: 'Form học viên', icon: ClipboardList },\n  { id: 'data',      label: 'Dữ liệu',     icon: Database },\n];\n\n/* ─── Level 2 Tabs (under Chung) ─────────────────────── */\nconst CHUNG_SUBTABS = [\n  { id: 'khu-vuc',    label: 'Khu vực',    icon: MapPin },\n  { id: 'hang-bang',  label: 'Hạng bằng',  icon: CreditCard },\n  { id: 'dot-thu',    label: 'Đợt thu phí', icon: Banknote },\n  { id: 'phong-ksk',  label: 'Phòng KSK', icon: Stethoscope },\n  { id: 'dao-tao',    label: 'Đào tạo ô tô', icon: Car },\n  { id: 'san-thi',    label: 'Sân thi',    icon: Map },\n  { id: 'trung-tam',  label: 'Trung tâm',  icon: Building2 },\n];\n\nexport default function SettingsPage() {\n  const [activeTopTab, setActiveTopTab] = useState('chung');\n  const [activeSubTab, setActiveSubTab] = useState('khu-vuc');\n\n  // Data States\n  const [systemSettings, setSystemSettings] = useState<SystemSettings | null>(null);\n  const [regions, setRegions] = useState<City[]>([]);\n  const [stadiums, setStadiums] = useState<Stadium[]>([]);\n  const [loading, setLoading] = useState(true);\n\n  // Modal States\n  const [isDeleteOpen, setIsDeleteOpen] = useState(false);\n  const [deleteConfig, setDeleteConfig] = useState<{ id: string, type: 'city' | 'license' | 'clinic' | 'stadium' | 'fee', message: string } | null>(null);\n  \n  const [isLicenseOpen, setIsLicenseOpen] = useState(false);\n  const [editingLicense, setEditingLicense] = useState<LicenseCategory | null>(null);\n  \n  const [isClinicOpen, setIsClinicOpen] = useState(false);\n  const [editingClinic, setEditingClinic] = useState<ClinicType | null>(null);\n  \n  const [isCenterOpen, setIsCenterOpen] = useState(false);\n  const [editingStadium, setEditingStadium] = useState<Stadium | null>(null);\n  \n  const [isRegionOpen, setIsRegionOpen] = useState(false);\n  const [editingRegion, setEditingRegion] = useState<City | null>(null);\n  \n  const [isFeeBatchOpen, setIsFeeBatchOpen] = useState(false);\n\n  useEffect(() => {\n    fetchAllData();\n  }, []);\n\n  const fetchAllData = async () => {\n    setLoading(true);\n    try {\n      const [settingsRes, citiesRes, stadiumsRes] = await Promise.all([\n        getSystemSettings(),\n        getCities(),\n        getStadiums()\n      ]);\n\n      if (settingsRes.success) {\n        setSystemSettings(settingsRes.data || {\n          license_categories: [],\n          fee_stages: [],\n          clinic_list: [],\n          requiredFields: ['name', 'rank', 'region'],\n          practiceTargetMinutes: 420\n        });\n      }\n      if (citiesRes.success) {\n        const citiesData = citiesRes.data;\n        setRegions(Array.isArray(citiesData) ? citiesData : (citiesData as any).items || (citiesData as any).docs || []);\n      }\n      if (stadiumsRes.success) {\n        const stadiumsData = stadiumsRes.data;\n        setStadiums(Array.isArray(stadiumsData) ? stadiumsData : (stadiumsData as any).items || (stadiumsData as any).docs || []);\n      }\n    } catch (error) {\n      toast.error('Lỗi khi tải dữ liệu hệ thống');\n    } finally {\n      setLoading(false);\n    }\n  };\n\n  // --- Student Form Handlers ---\n  const handleSaveStudentForm = async (requiredFields: string[]) => {\n    if (!systemSettings) return;\n    try {\n      const res = await updateSystemSettings({ requiredFields });\n      if (res.success) {\n        toast.success('Đã lưu cấu hình trường bắt buộc');\n        setSystemSettings({ ...systemSettings, requiredFields });\n      } else {\n        toast.error('Lỗi khi lưu cấu hình');\n      }\n    } catch (error) {\n      toast.error('Lỗi kết nối máy chủ');\n    }\n  };\n\n  // --- Center Config Handlers ---\n  const handleSaveRegion = async (data: Partial<City>) => {\n    try {\n      const res = editingRegion \n        ? await updateCity(editingRegion._id, data)\n        : await createCity(data as City);\n      \n      if (res.success) {\n        toast.success(editingRegion ? 'Đã cập nhật khu vực' : 'Đã thêm khu vực mới');\n        const citiesRes = await getCities();\n        if (citiesRes.success) setRegions(Array.isArray(citiesRes.data) ? citiesRes.data : (citiesRes.data as any).items || []);\n        setIsRegionOpen(false);\n      } else {\n        toast.error(res.message || 'Thao tác thất bại');\n      }\n    } catch (error) {\n      toast.error('Lỗi kết nối máy chủ');\n    }\n  };\n\n  const handleDeleteCity = async (id: string) => {\n    try {\n      const res = await deleteCity(id);\n      if (res.success) {\n        toast.success('Đã xóa khu vực');\n        setRegions(prev => prev.filter(r => r._id !== id));\n      }\n    } catch (error) {\n      toast.error('Lỗi khi xóa khu vực');\n    }\n  };\n\n  // --- License Handlers ---\n  const handleSaveLicense = async (data: LicenseCategory) => {\n    try {\n      const currentSettings = systemSettings || { license_categories: [] };\n      let updatedLicenses = [...(currentSettings.license_categories || [])];\n      if (editingLicense) {\n        updatedLicenses = updatedLicenses.map(l => l.id === editingLicense.id ? data : l);\n      } else {\n        if (updatedLicenses.find(l => l.id === data.id)) {\n          toast.error('Mã hạng bằng đã tồn tại');\n          return;\n        }\n        updatedLicenses.push(data);\n      }\n\n      const res = await updateSystemSettings({ license_categories: updatedLicenses });\n      if (res.success) {\n        toast.success('Đã lưu hạng bằng');\n        setSystemSettings(prev => prev ? { ...prev, license_categories: updatedLicenses } : { license_categories: updatedLicenses } as any);\n        setIsLicenseOpen(false);\n      } else {\n        toast.error(res.message || 'Lỗi khi lưu hạng bằng');\n      }\n    } catch (error) {\n      toast.error('Lỗi khi lưu hạng bằng');\n    }\n  };\n\n  // --- Clinic Handlers ---\n  const handleSaveClinic = async (data: ClinicType) => {\n    try {\n      const currentSettings = systemSettings || { clinic_list: [] };\n      let updatedClinics = [...(currentSettings.clinic_list || [])];\n      if (editingClinic) {\n        updatedClinics = updatedClinics.map(c => c.name === editingClinic.name ? data : c);\n      } else {\n        updatedClinics.push(data);\n      }\n\n      const res = await updateSystemSettings({ clinic_list: updatedClinics });\n      if (res.success) {\n        toast.success('Đã lưu phòng khám');\n        setSystemSettings(prev => prev ? { ...prev, clinic_list: updatedClinics } : { clinic_list: updatedClinics } as any);\n        setIsClinicOpen(false);\n      } else {\n        toast.error(res.message || 'Lỗi khi lưu phòng khám');\n      }\n    } catch (error) {\n      toast.error('Lỗi khi lưu phòng khám');\n    }\n  };\n\n  // --- Stadium Handlers ---\n  const handleSaveStadium = async (data: Stadium) => {\n    try {\n      const res = editingStadium \n        ? await updateStadium(editingStadium._id, data)\n        : await createStadium(data);\n      \n      if (res.success) {\n        toast.success(editingStadium ? 'Đã cập nhật sân thi' : 'Đã thêm sân thi mới');\n        const sRes = await getStadiums();\n        if (sRes.success) setStadiums(Array.isArray(sRes.data) ? sRes.data : (sRes.data as any).items || []);\n        setIsCenterOpen(false);\n      }\n    } catch (error) {\n      toast.error('Lỗi khi lưu sân thi');\n    }\n  };\n\n  const handleDeleteStadium = async (id: string) => {\n    try {\n      const res = await deleteStadium(id);\n      if (res.success) {\n        toast.success('Đã xóa sân thi');\n        setStadiums(prev => prev.filter(s => s._id !== id));\n      }\n    } catch (error) {\n      toast.error('Lỗi khi xóa sân thi');\n    }\n  };\n\n  // --- Fee Handlers ---\n  const handleSaveFeeBatch = async (name: string) => {\n    try {\n      const currentSettings = systemSettings || { fee_stages: [] };\n      const updatedFees = [...(currentSettings.fee_stages || []), name];\n      const res = await updateSystemSettings({ fee_stages: updatedFees });\n      if (res.success) {\n        toast.success('Đã thêm đợt thu phí');\n        setSystemSettings(prev => prev ? { ...prev, fee_stages: updatedFees } : { fee_stages: updatedFees } as any);\n      } else {\n        toast.error(res.message || 'Lỗi khi thêm đợt thu phí');\n      }\n    } catch (error) {\n      toast.error('Lỗi khi thêm đợt thu phí');\n    }\n  };\n\n  // --- Training Handler ---\n  const handleSaveTrainingConfig = async (val: number) => {\n    try {\n      const res = await updateSystemSettings({ practiceTargetMinutes: val });\n      if (res.success) {\n        toast.success('Đã cập nhật cấu hình đào tạo');\n        if (systemSettings) setSystemSettings({ ...systemSettings, practiceTargetMinutes: val });\n      }\n    } catch (error) {\n      toast.error('Lỗi khi lưu cấu hình');\n    }\n  };\n\n  const confirmDelete = (id: string, type: any, message: string) => {\n    setDeleteConfig({ id, type, message });\n    setIsDeleteOpen(true);\n  };\n\n  const executeDelete = async () => {\n    if (!deleteConfig) return;\n    const { id, type } = deleteConfig;\n\n    if (type === 'city') await handleDeleteCity(id);\n    if (type === 'stadium') await handleDeleteStadium(id);\n    if (type === 'license' && systemSettings) {\n      const updated = (systemSettings.license_categories || []).filter(l => l.id !== id);\n      const res = await updateSystemSettings({ license_categories: updated });\n      if (res.success) {\n        setSystemSettings({ ...systemSettings, license_categories: updated });\n        toast.success('Đã xóa hạng bằng');\n      }\n    }\n\n    if (type === 'clinic' && systemSettings) {\n      const updated = (systemSettings.clinic_list || []).filter((_, idx) => idx.toString() !== id);\n      const res = await updateSystemSettings({ clinic_list: updated });\n\n      if (res.success) {\n        setSystemSettings({ ...systemSettings, clinic_list: updated });\n        toast.success('Đã xóa phòng khám');\n      }\n    }\n\n    if (type === 'fee' && systemSettings) {\n      const updated = (systemSettings.fee_stages || []).filter((_, idx) => idx.toString() !== id);\n      const res = await updateSystemSettings({ fee_stages: updated });\n      \n      if (res.success) {\n        setSystemSettings({ ...systemSettings, fee_stages: updated });\n        toast.success('Đã xóa đợt thu phí');\n      }\n    }\n    setIsDeleteOpen(false);\n  };\n\n  if (loading) {\n    return (\n      <div className=\"flex flex-col items-center justify-center min-h-[60vh] gap-4\">\n        <div className=\"w-12 h-12 border-4 border-indigo-100 border-t-indigo-600 rounded-full animate-spin\" />\n        <p className=\"text-gray-400 font-black uppercase tracking-widest text-xs\">Đang tải cấu hình hệ thống...</p>\n      </div>\n    );\n  }\n\n  return (\n    <div className=\"flex flex-col gap-6 animate-in fade-in slide-in-from-bottom-2 duration-700 pb-10\">\n      {/* Page Header */}\n      <div className=\"flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 px-2\">\n        <div>\n          <h2 className=\"text-2xl sm:text-3xl font-extrabold text-gray-900 tracking-tight leading-tight uppercase\">Cài đặt hệ thống</h2>\n          <p className=\"text-gray-500 font-medium mt-1 text-sm opacity-70\">Cấu hình các tham số hệ thống và quản lý dữ liệu toàn cục</p>\n        </div>\n      </div>\n\n      {/* Level 1 Navigation */}\n      <div className=\"flex flex-wrap items-center gap-2 px-1\">\n        {TOP_TABS.map(tab => {\n          const Icon = tab.icon;\n          const isActive = activeTopTab === tab.id;\n          return (\n            <button\n              key={tab.id}\n              onClick={() => setActiveTopTab(tab.id)}\n              className={`flex items-center gap-2 px-4 py-2 rounded-xl text-sm font-bold transition-all border ${\n                isActive\n                  ? 'bg-indigo-600 text-white border-indigo-600 shadow-md shadow-indigo-600/20'\n                  : 'text-gray-500 bg-white border-gray-100 hover:bg-gray-50 hover:text-indigo-600'\n              }`}\n            >\n              <Icon className=\"w-4 h-4\" />\n              {tab.label}\n            </button>\n          );\n        })}\n      </div>\n\n      {/* Level 2 Sub-Nav (only for 'Chung') */}\n      {activeTopTab === 'chung' && (\n        <div className=\"flex items-center gap-1 overflow-x-auto pb-1 -mt-2 no-scrollbar px-1\">\n          {CHUNG_SUBTABS.map(tab => {\n            const Icon = tab.icon;\n            const isActive = activeSubTab === tab.id;\n            return (\n              <button\n                key={tab.id}\n                onClick={() => setActiveSubTab(tab.id)}\n                className={`flex items-center gap-2 px-4 py-3 text-sm font-bold transition-all relative shrink-0 ${\n                  isActive ? 'text-indigo-600' : 'text-gray-400 hover:text-gray-600'\n                }`}\n              >\n                <Icon className=\"w-4 h-4\" />\n                {tab.label}\n                {isActive && (\n                  <div className=\"absolute bottom-0 left-4 right-4 h-0.5 bg-indigo-600 rounded-full\" />\n                )}\n              </button>\n            );\n          })}\n        </div>\n      )}\n\n      {/* Content Area */}\n      <div className=\"min-h-[400px]\">\n        {activeTopTab === 'chung' ? (\n          <GeneralSettingsView \n            activeSubTab={activeSubTab} \n            regions={regions}\n            categories={systemSettings?.license_categories || []}\n            stages={systemSettings?.fee_stages || []}\n            clinics={systemSettings?.clinic_list || []}\n            stadiums={stadiums}\n            practiceTargetMinutes={systemSettings?.practiceTargetMinutes || 0}\n            onRegionAdd={() => { setEditingRegion(null); setIsRegionOpen(true); }}\n            onRegionEdit={(r) => { setEditingRegion(r); setIsRegionOpen(true); }}\n            onRegionDelete={(id) => confirmDelete(id, 'city', 'Xóa khu vực này?')}\n            onLicenseAdd={() => { setEditingLicense(null); setIsLicenseOpen(true); }}\n            onLicenseEdit={(l) => { setEditingLicense(l); setIsLicenseOpen(true); }}\n            onLicenseDelete={(id) => confirmDelete(id, 'license', 'Xóa hạng bằng này?')}\n            onClinicAdd={() => { setEditingClinic(null); setIsClinicOpen(true); }}\n            onClinicEdit={(c) => { setEditingClinic(c); setIsClinicOpen(true); }}\n            onClinicDelete={(idx) => confirmDelete(idx.toString(), 'clinic', 'Xóa phòng khám này?')}\n            onFeeBatchAdd={() => setIsFeeBatchOpen(true)}\n            onFeeBatchDelete={(idx) => confirmDelete(idx.toString(), 'fee', 'Xóa đợt thu phí này?')}\n            onCenterAdd={() => { setEditingStadium(null); setIsCenterOpen(true); }}\n            onCenterEdit={(s) => { setEditingStadium(s); setIsCenterOpen(true); }}\n            onCenterDelete={(id) => confirmDelete(id, 'stadium', 'Xóa sân thi này?')}\n            onTrainingSave={handleSaveTrainingConfig}\n          />\n        ) : activeTopTab === 'tai-khoan' ? (\n          <AccountSettingsView />\n        ) : activeTopTab === 'vip-qr' ? (\n          <VipQrSettingsView />\n        ) : activeTopTab === 'form-hv' ? (\n          <StudentFormSettingsView \n            requiredFields={systemSettings?.requiredFields || ['name', 'rank', 'region']} \n            onSave={handleSaveStudentForm}\n          />\n        ) : activeTopTab === 'data' ? (\n          <DataManagementView />\n        ) : (\n          <div className=\"flex flex-col items-center justify-center p-20 text-gray-400 gap-3 bg-white border border-gray-50 rounded-3xl\">\n            <Info className=\"w-12 h-12 opacity-20\" />\n            <p className=\"font-semibold\">{TOP_TABS.find(t => t.id === activeTopTab)?.label} - Module đang phát triển</p>\n          </div>\n        )}\n      </div>\n\n      {/* Modals */}\n      <ConfirmDeleteModal \n        isOpen={isDeleteOpen} \n        onClose={() => setIsDeleteOpen(false)} \n        onConfirm={executeDelete} \n        message={deleteConfig?.message || 'Xác nhận xóa?'}\n        item={deleteConfig?.id}\n      />\n      <LicenseModal \n        isOpen={isLicenseOpen} \n        onClose={() => setIsLicenseOpen(false)} \n        item={editingLicense}\n        onSave={handleSaveLicense}\n      />\n      <ClinicModal \n        isOpen={isClinicOpen} \n        onClose={() => setIsClinicOpen(false)} \n        item={editingClinic}\n        onSave={handleSaveClinic}\n      />\n      <ExamCenterModal \n        isOpen={isCenterOpen} \n        onClose={() => setIsCenterOpen(false)} \n        item={editingStadium}\n        onSave={handleSaveStadium}\n        regions={regions}\n      />\n      <RegionModal \n        isOpen={isRegionOpen} \n        onClose={() => setIsRegionOpen(false)} \n        item={editingRegion}\n        onSave={handleSaveRegion}\n      />\n      <FeeBatchModal \n        isOpen={isFeeBatchOpen} \n        onClose={() => setIsFeeBatchOpen(false)} \n        onSave={handleSaveFeeBatch}\n      />\n    </div>\n  );\n}\n\n/* ─── Level 2: Account View ─────────────────────────── */\nfunction AccountSettingsView() {\n  const { user, refreshUser } = useAuth();\n  \n  // Profile State\n  const [profileName, setProfileName] = useState('');\n  const [isUpdatingProfile, setIsUpdatingProfile] = useState(false);\n  \n  // Password State\n  const [passwords, setPasswords] = useState({\n    old_password: '',\n    new_password: '',\n    confirm_password: ''\n  });\n  const [showPassword, setShowPassword] = useState(false);\n  const [isChangingPassword, setIsChangingPassword] = useState(false);\n\n  // History State\n  const [loginHistory, setLoginHistory] = useState<any[]>([]);\n  const [isLoadingHistory, setIsLoadingHistory] = useState(false);\n\n  useEffect(() => {\n    if (user) {\n      setProfileName(`${user.first_name || ''} ${user.last_name || ''}`.trim());\n      fetchHistory();\n    }\n  }, [user]);\n\n  const fetchHistory = async () => {\n    setIsLoadingHistory(true);\n    try {\n      const res = await getLoginHistory();\n      if (res.success) {\n        setLoginHistory(res.data);\n      }\n    } catch (error) {\n      console.error('Failed to fetch history:', error);\n    } finally {\n      setIsLoadingHistory(false);\n    }\n  };\n\n  const parseUA = (ua: string) => {\n    if (!ua) return 'Thiết bị lạ';\n    if (ua.includes('Windows')) return 'Máy tính Windows';\n    if (ua.includes('Macintosh')) return 'Máy tính Mac';\n    if (ua.includes('iPhone')) return 'iPhone';\n    if (ua.includes('Android')) return 'Điện thoại Android';\n    if (ua.includes('Linux')) return 'Máy tính Linux';\n    return 'Web Browser';\n  };\n\n  const formatRelativeTime = (dateStr: string) => {\n    const date = new Date(dateStr);\n    const now = new Date();\n    const diffInMs = now.getTime() - date.getTime();\n    const diffInMinutes = Math.floor(diffInMs / (1000 * 60));\n    const diffInHours = Math.floor(diffInMinutes / 60);\n    const diffInDays = Math.floor(diffInHours / 24);\n\n    if (diffInMinutes < 5) return 'Đang hoạt động';\n    if (diffInMinutes < 60) return `${diffInMinutes} phút trước`;\n    if (diffInHours < 24) return `${diffInHours} giờ trước`;\n    return `${diffInDays} ngày trước`;\n  };\n\n  const handleUpdateProfile = async (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!profileName.trim()) {\n      toast.error('Vui lòng nhập tên hiển thị!');\n      return;\n    }\n\n    setIsUpdatingProfile(true);\n    try {\n      const parts = profileName.trim().split(' ');\n      const last_name = parts.length > 1 ? parts.pop() : '';\n      const first_name = parts.join(' ');\n\n      const res = await updateProfile({ first_name, last_name });\n      if (res.success) {\n        toast.success('Cập nhật thông tin thành công!');\n        await refreshUser();\n      } else {\n        toast.error(res.message || 'Lỗi khi cập nhật profile');\n      }\n    } catch (error) {\n      toast.error('Lỗi kết nối máy chủ');\n    } finally {\n      setIsUpdatingProfile(false);\n    }\n  };\n\n  const handlePasswordChange = async (e: React.FormEvent) => {\n    e.preventDefault();\n    \n    if (!passwords.old_password || !passwords.new_password) {\n      toast.error('Vui lòng điền đầy đủ các trường mật khẩu!');\n      return;\n    }\n\n    if (passwords.new_password !== passwords.confirm_password) {\n      toast.error('Mật khẩu mới không khớp!');\n      return;\n    }\n\n    setIsChangingPassword(true);\n    try {\n      const res = await changePassword({\n        old_password: passwords.old_password,\n        new_password: passwords.new_password,\n        confirm_password: passwords.confirm_password\n      });\n\n      if (res.success) {\n        toast.success('Đổi mật khẩu thành công!');\n        setPasswords({ old_password: '', new_password: '', confirm_password: '' });\n      } else {\n        toast.error(res.message || 'Mật khẩu hiện tại không chính xác');\n      }\n    } catch (error) {\n      toast.error('Lỗi kết nối khi đổi mật khẩu');\n    } finally {\n      setIsChangingPassword(false);\n    }\n  };\n\n  return (\n    <div className=\"flex flex-col gap-8 animate-in fade-in slide-in-from-bottom-4 duration-700\">\n      <div className=\"grid grid-cols-1 lg:grid-cols-2 gap-8 items-start\">\n        {/* Account Info Form */}\n        <div className=\"bg-white border border-gray-100 rounded-[2.5rem] p-8 shadow-sm flex flex-col gap-8 transition-all hover:shadow-md duration-300\">\n           <div className=\"flex items-center justify-between\">\n              <div className=\"flex items-center gap-3\">\n                 <div className=\"w-12 h-12 bg-indigo-50 rounded-2xl flex items-center justify-center\">\n                    <User className=\"w-6 h-6 text-indigo-600\" />\n                 </div>\n                 <div>\n                    <h3 className=\"text-lg font-black text-gray-800 tracking-tight uppercase\">Thông tin cơ bản</h3>\n                    <p className=\"text-xs text-gray-400 font-bold uppercase tracking-widest\">Profile Identity</p>\n                 </div>\n              </div>\n           </div>\n\n           <form onSubmit={handleUpdateProfile} className=\"flex flex-col gap-6\">\n              <div className=\"flex flex-col gap-1.5 px-1\">\n                 <label className=\"text-[10px] font-black text-gray-400 uppercase tracking-widest ml-1\">TÊN HIỂN THỊ *</label>\n                 <div className=\"relative group\">\n                    <input \n                      type=\"text\" \n                      value={profileName}\n                      onChange={(e) => setProfileName(e.target.value)}\n                      placeholder=\"Nhập tên của bạn...\"\n                      className=\"w-full px-5 py-3.5 bg-gray-50 border border-transparent rounded-2xl focus:bg-white focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500/30 transition-all outline-none font-bold text-gray-800\" \n                    />\n                    <User className=\"absolute right-4 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-300 group-focus-within:text-indigo-500 transition-colors\" />\n                 </div>\n              </div>\n\n              <div className=\"flex flex-col gap-1.5 px-1\">\n                 <label className=\"text-[10px] font-black text-gray-400 uppercase tracking-widest ml-1\">EMAIL LIÊN KẾT</label>\n                 <div className=\"relative group opacity-60\">\n                    <input \n                      type=\"email\" \n                      value={user?.email || ''}\n                      disabled\n                      className=\"w-full px-5 py-3.5 bg-gray-100 border border-transparent rounded-2xl cursor-not-allowed font-bold text-gray-500\" \n                    />\n                    <CheckCircle2 className=\"absolute right-4 top-1/2 -translate-y-1/2 w-4 h-4 text-emerald-500\" />\n                 </div>\n                  <p className=\"text-[10px] text-gray-400 font-medium ml-1 flex items-center gap-1.5 mt-1\">\n                    <AlertCircle className=\"w-3 h-3\" /> Email đã được xác thực, không thể thay đổi lúc này.\n                  </p>\n              </div>\n\n              <button \n                type=\"submit\"\n                disabled={isUpdatingProfile}\n                className=\"mt-2 flex items-center justify-center gap-2 w-full py-4 bg-indigo-600 text-white font-black rounded-2xl shadow-xl shadow-indigo-600/20 hover:scale-[1.02] active:scale-[0.98] transition-all uppercase tracking-widest text-sm disabled:opacity-50\"\n              >\n                 {isUpdatingProfile ? <Loader2 className=\"w-5 h-5 animate-spin\" /> : <Save className=\"w-5 h-5\" />}\n                 Cập nhật profile\n              </button>\n           </form>\n        </div>\n\n        {/* Change Password Form */}\n        <div className=\"bg-white border border-gray-100 rounded-[2.5rem] p-8 shadow-sm flex flex-col gap-8 transition-all hover:shadow-md duration-300\">\n           <div className=\"flex items-center justify-between\">\n              <div className=\"flex items-center gap-3\">\n                 <div className=\"w-12 h-12 bg-rose-50 rounded-2xl flex items-center justify-center\">\n                    <Key className=\"w-6 h-6 text-rose-600\" />\n                 </div>\n                 <div>\n                    <h3 className=\"text-lg font-black text-gray-800 tracking-tight uppercase\">Đổi mật khẩu</h3>\n                    <p className=\"text-xs text-gray-400 font-bold uppercase tracking-widest\">Update Credentials</p>\n                 </div>\n              </div>\n           </div>\n\n           <form onSubmit={handlePasswordChange} className=\"flex flex-col gap-5\">\n              <div className=\"flex flex-col gap-1.5 px-1\">\n                 <label className=\"text-[10px] font-black text-gray-400 uppercase tracking-widest ml-1\">MẬT KHẨU HIỆN TẠI</label>\n                 <div className=\"relative group font-black tracking-widest\">\n                    <input \n                      type={showPassword ? \"text\" : \"password\"} \n                      value={passwords.old_password}\n                      onChange={(e) => setPasswords({...passwords, old_password: e.target.value})}\n                      placeholder=\"••••••••\"\n                      className=\"w-full px-5 py-3.5 bg-gray-50 border border-transparent rounded-2xl focus:bg-white focus:ring-4 focus:ring-rose-500/10 focus:border-rose-500/30 transition-all outline-none text-gray-800 font-black tracking-widest placeholder:tracking-widest\" \n                    />\n                    <button \n                      type=\"button\"\n                      onClick={() => setShowPassword(!showPassword)}\n                      className=\"absolute right-4 top-1/2 -translate-y-1/2 w-10 h-10 flex items-center justify-center text-gray-300 hover:text-rose-500 transition-colors\"\n                    >\n                      {showPassword ? <EyeOff className=\"w-5 h-5\" /> : <Eye className=\"w-5 h-5\" />}\n                    </button>\n                 </div>\n              </div>\n\n              <div className=\"flex flex-col gap-1.5 px-1\">\n                 <label className=\"text-[10px] font-black text-gray-400 uppercase tracking-widest ml-1\">MẬT KHẨU MỚI</label>\n                 <input \n                   type=\"password\" \n                   value={passwords.new_password}\n                   onChange={(e) => setPasswords({...passwords, new_password: e.target.value})}\n                   placeholder=\"Nhập mật khẩu mới...\"\n                   className=\"w-full px-5 py-3.5 bg-gray-50 border border-transparent rounded-2xl focus:bg-white focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500/30 transition-all outline-none font-black tracking-widest placeholder:tracking-tight placeholder:font-bold\" \n                 />\n              </div>\n\n              <div className=\"flex flex-col gap-1.5 px-1\">\n                 <label className=\"text-[10px] font-black text-gray-400 uppercase tracking-widest ml-1\">XÁC NHẬN MẬT KHẨU MỚI</label>\n                 <input \n                   type=\"password\" \n                   value={passwords.confirm_password}\n                   onChange={(e) => setPasswords({...passwords, confirm_password: e.target.value})}\n                   placeholder=\"Lặp lại mật khẩu mới...\"\n                   className=\"w-full px-5 py-3.5 bg-gray-50 border border-transparent rounded-2xl focus:bg-white focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500/30 transition-all outline-none font-black tracking-widest placeholder:tracking-tight placeholder:font-bold\" \n                 />\n              </div>\n\n              <button \n                type=\"submit\"\n                disabled={isChangingPassword}\n                className=\"mt-3 flex items-center justify-center gap-2 w-full py-4 bg-gray-900 text-white font-black rounded-2xl shadow-xl shadow-gray-900/20 hover:scale-[1.02] active:scale-[0.98] transition-all uppercase tracking-widest text-sm disabled:opacity-50\"\n              >\n                 {isChangingPassword ? <Loader2 className=\"w-5 h-5 animate-spin\" /> : <Lock className=\"w-5 h-5\" />}\n                 Thay đổi mật khẩu\n              </button>\n           </form>\n        </div>\n\n        {/* Additional Security Section */}\n        <div className=\"lg:col-span-2 bg-gradient-to-br from-indigo-900 to-slate-900 border border-indigo-800 rounded-[2.5rem] p-10 shadow-2xl flex flex-col md:flex-row items-center gap-10\">\n           <div className=\"flex-1 flex flex-col gap-4\">\n              <div className=\"inline-flex items-center gap-2 px-3 py-1 bg-white/10 backdrop-blur-md rounded-full w-fit\">\n                 <div className=\"w-2 h-2 rounded-full bg-emerald-500 animate-pulse\" />\n                 <span className=\"text-[10px] text-emerald-400 font-bold uppercase tracking-widest\">Enhanced Security</span>\n              </div>\n              <h2 className=\"text-2xl font-black text-white uppercase tracking-tight\">Kích hoạt bảo vệ 2 lớp (2FA)</h2>\n              <p className=\"text-sm text-indigo-100/60 font-semibold leading-relaxed tracking-tight\">\n                 Tăng cường bảo vệ tài khoản bằng cách yêu cầu mã xác thực từ điện thoại mỗi khi bạn đăng nhập. \n                 Đây là biện pháp bảo mật mạnh nhất hiện nay.\n              </p>\n              <button className=\"mt-4 px-8 py-3.5 bg-white text-indigo-900 font-black rounded-2xl hover:bg-indigo-50 transition-all w-fit uppercase tracking-widest text-xs flex items-center gap-2 hover:scale-[1.05] active:scale-[0.95]\">\n                 <Smartphone className=\"w-4 h-4\" /> Bắt đầu thiết lập\n              </button>\n           </div>\n           \n           <div className=\"w-full md:w-80 flex flex-col gap-4 bg-white/5 backdrop-blur-xl border border-white/10 rounded-3xl p-6 min-h-[220px]\">\n              <div className=\"flex items-center justify-between pb-3 border-b border-white/5\">\n                 <div className=\"flex items-center gap-2 text-white/80 font-black text-xs uppercase\">\n                    <History className=\"w-3.5 h-3.5\" /> Lịch sử đăng nhập\n                 </div>\n                 <button onClick={fetchHistory} className=\"text-[10px] text-indigo-400 font-bold hover:underline\">Làm mới</button>\n              </div>\n              \n              {isLoadingHistory ? (\n                 <div className=\"flex-1 flex flex-col items-center justify-center gap-2 py-4\">\n                    <Loader2 className=\"w-5 h-5 text-indigo-400 animate-spin\" />\n                    <span className=\"text-[10px] text-indigo-300 font-bold uppercase tracking-widest\">Đang tải...</span>\n                 </div>\n              ) : loginHistory.length === 0 ? (\n                 <div className=\"flex-1 flex flex-col items-center justify-center opacity-40 py-4\">\n                    <span className=\"text-[10px] text-white font-bold uppercase\">Chưa có dữ liệu</span>\n                 </div>\n              ) : (\n                <div className=\"flex flex-col gap-3\">\n                  {loginHistory.map((h, i) => {\n                    const isOnline = i === 0 && h.action === 'LOGIN';\n                    return (\n                      <div key={h._id} className=\"flex items-center justify-between py-1 group\">\n                        <div className=\"flex flex-col gap-0.5\">\n                          <span className=\"text-xs font-bold text-white/90 group-hover:text-white transition-colors\">{parseUA(h.user_agent)}</span>\n                          <div className=\"flex items-center gap-2\">\n                             <span className={`text-[9px] font-black uppercase ${isOnline ? 'text-emerald-400' : 'text-white/30'}`}>\n                                {isOnline ? 'Đang hoạt động' : formatRelativeTime(h.created_at)}\n                             </span>\n                             {h.ip_address && (\n                                <span className=\"text-[8px] text-white/20 font-medium\">({h.ip_address})</span>\n                             )}\n                          </div>\n                        </div>\n                        <div className={`w-1.5 h-1.5 rounded-full transition-all duration-500 ${isOnline ? 'bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.5)]' : 'bg-white/10'}`} />\n                      </div>\n                    );\n                  })}\n                </div>\n              )}\n           </div>\n        </div>\n      </div>\n    </div>\n  );\n}\n\n/* ─── Level 2: General Views ─────────────────────────── */\nfunction GeneralSettingsView({ \n  activeSubTab, \n  regions,\n  categories,\n  stages,\n  clinics,\n  stadiums,\n  practiceTargetMinutes,\n  onRegionAdd,\n  onRegionEdit,\n  onRegionDelete,\n  onLicenseAdd,\n  onLicenseEdit,\n  onLicenseDelete,\n  onClinicAdd,\n  onClinicEdit,\n  onClinicDelete,\n  onFeeBatchAdd,\n  onFeeBatchDelete,\n  onCenterAdd,\n  onCenterEdit,\n  onCenterDelete,\n  onTrainingSave\n}: { \n  activeSubTab: string, \n  regions: City[],\n  categories: LicenseCategory[],\n  stages: string[],\n  clinics: ClinicType[],\n  stadiums: Stadium[],\n  practiceTargetMinutes: number,\n  onRegionAdd: () => void,\n  onRegionEdit: (r: City) => void,\n  onRegionDelete: (id: string) => void,\n  onLicenseAdd: () => void,\n  onLicenseEdit: (l: LicenseCategory) => void,\n  onLicenseDelete: (id: string) => void,\n  onClinicAdd: () => void,\n  onClinicEdit: (c: ClinicType) => void,\n  onClinicDelete: (idx: number) => void,\n  onFeeBatchAdd: () => void,\n  onFeeBatchDelete: (idx: number) => void,\n  onCenterAdd: () => void,\n  onCenterEdit: (s: Stadium) => void,\n  onCenterDelete: (id: string) => void,\n  onTrainingSave: (val: number) => Promise<void>\n}) {\n  switch (activeSubTab) {\n    case 'khu-vuc': return <RegionManagement regions={regions} onAdd={onRegionAdd} onEdit={onRegionEdit} onDelete={onRegionDelete} />;\n    case 'hang-bang': return <LicenseCategoryManagement categories={categories} onAdd={onLicenseAdd} onEdit={onLicenseEdit} onDelete={onLicenseDelete} />;\n    case 'dot-thu': return <FeeBatchManagement stages={stages} onAdd={onFeeBatchAdd} onDelete={onFeeBatchDelete} />;\n    case 'phong-ksk': return <ClinicManagement clinics={clinics} onAdd={onClinicAdd} onEdit={onClinicEdit} onDelete={onClinicDelete} />;\n\n⚠️ [... middle content omitted — showing head and tail ...]\n\n                    Khôi phục từ file JSON backup đã xuất. Dữ liệu trùng sẽ được cập nhật, không xóa.\n                  </span>\n                </div>\n              </div>\n              <button\n                onClick={() => fileInputRef.current?.click()}\n                disabled={isImporting}\n                className=\"shrink-0 flex items-center gap-2 px-5 py-2.5 bg-indigo-600 text-white font-black rounded-xl hover:bg-indigo-700 shadow-lg shadow-indigo-600/20 transition-all text-[11px] uppercase tracking-widest active:scale-95 disabled:opacity-60 disabled:cursor-not-allowed\"\n              >\n                {isImporting ? <Loader2 className=\"w-4 h-4 animate-spin\" /> : <Upload className=\"w-4 h-4\" />}\n                {isImporting ? 'Đang nhập...' : 'Nhập dữ liệu'}\n              </button>\n              <input\n                ref={fileInputRef}\n                type=\"file\"\n                accept=\".json\"\n                className=\"hidden\"\n                onChange={handleImportFile}\n              />\n            </div>\n\n            {/* Import Result */}\n            {importResult && (\n              <div className=\"bg-gray-50 border border-gray-100 rounded-2xl p-5 flex flex-col gap-3 animate-in fade-in\">\n                <div className=\"flex items-center gap-2\">\n                  <CheckCircle2 className=\"w-4 h-4 text-emerald-600\" />\n                  <p className=\"text-[11px] font-black uppercase tracking-widest text-gray-600\">Kết quả phục hồi</p>\n                </div>\n                <div className=\"grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-2\">\n                  {Object.entries(importResult.results).map(([col, count]) => (\n                    <div key={col} className=\"bg-white border border-gray-100 rounded-xl px-4 py-2.5 flex flex-col\">\n                      <span className=\"text-[10px] font-black uppercase text-gray-400 tracking-wider\">{col}</span>\n                      <span className=\"text-xl font-black text-indigo-600\">{count}</span>\n                      <span className=\"text-[9px] font-bold text-gray-400 uppercase\">records</span>\n                    </div>\n                  ))}\n                </div>\n                {importResult.errors.length > 0 && (\n                  <div className=\"flex flex-col gap-1 bg-rose-50 border border-rose-100 rounded-xl p-3\">\n                    <p className=\"text-[10px] font-black text-rose-600 uppercase tracking-widest\">Lỗi phát sinh:</p>\n                    {importResult.errors.map((err, i) => (\n                      <p key={i} className=\"text-[11px] text-rose-500 font-bold\">{err}</p>\n                    ))}\n                  </div>\n                )}\n              </div>\n            )}\n          </div>\n\n          {/* Danger: Delete All */}\n          <div className=\"py-6 flex items-center justify-between gap-4\">\n            <div className=\"flex items-start gap-4\">\n              <div className=\"w-10 h-10 bg-rose-50 rounded-xl flex items-center justify-center shrink-0\">\n                <Trash className=\"w-5 h-5 text-rose-400\" />\n              </div>\n              <div className=\"flex flex-col\">\n                <span className=\"font-black text-rose-400 text-sm tracking-tight uppercase\">Xóa toàn bộ dữ liệu</span>\n                <span className=\"text-[11px] text-rose-300 font-black tracking-tight flex items-center gap-1 mt-0.5\">\n                  <AlertTriangle className=\"w-3 h-3\" /> Cảnh báo: Không thể hoàn tác! Tính năng đang tạm khóa để đảm bảo an toàn.\n                </span>\n              </div>\n            </div>\n            <button\n              disabled\n              title=\"Tính năng đang tạm khóa\"\n              className=\"shrink-0 flex items-center gap-2 px-5 py-2.5 bg-rose-100 text-rose-300 font-black rounded-xl cursor-not-allowed text-[11px] uppercase tracking-widest\"\n            >\n              <Trash className=\"w-4 h-4\" /> Xóa sạch\n            </button>\n          </div>\n        </div>\n      </div>\n    </div>\n  );\n}\n[... 54453 more characters truncated]"}],"isError":false,"timestamp":1776050539907}}
{"type":"custom","customType":"openclaw:bootstrap-context:full","data":{"timestamp":1776050540100,"runId":"2d8b89a3-e7c7-410c-8620-93a48433398b","sessionId":"ba02d9fc-7f3e-47b8-8f69-6edd7f634a5d"},"id":"bd0035f0","parentId":"071c96a0","timestamp":"2026-04-13T03:22:20.100Z"}
