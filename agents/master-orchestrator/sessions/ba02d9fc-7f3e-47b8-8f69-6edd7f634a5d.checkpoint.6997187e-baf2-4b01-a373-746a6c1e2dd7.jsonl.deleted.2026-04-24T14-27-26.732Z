{"type":"message","id":"7f2a2a88","parentId":"6c7625a0","timestamp":"2026-04-13T03:19:53.259Z","message":{"role":"toolResult","toolCallId":"call_function_fip7hrxe9dm7_1","toolName":"read","content":[{"type":"text","text":"import { apiClient } from './api';\n\nexport interface SystemSettings {\n  id?: string;\n  regions: string[];\n  license_categories?: any[];\n  fee_stages?: string[];\n  clinic_list?: any[];\n  requiredFields?: string[];\n  examVenues: string[];\n  practiceTargetMinutes: number;\n  center_name: string;\n  center_website: string;\n  center_address: string;\n  center_phone: string;\n  center_email: string;\n  center_fax?: string;\n}\n\nexport interface LicenseCategory {\n  id: string;\n  type: string;\n  name: string;\n  fee: string;\n  tags: string[];\n  inactive: string[];\n  dat?: string | null;\n}\n\nexport interface Clinic {\n  name: string;\n  info?: string;\n  address?: string;\n  phone?: string;\n  price?: string;\n}\n\nexport const getSystemSettings = async () => {\n  return apiClient('/settings');\n};\n\nexport const updateSystemSettings = async (data: Partial<SystemSettings>) => {\n  return apiClient('/settings', {\n    method: 'PATCH',\n    body: JSON.stringify(data),\n  });\n};\n"}],"isError":false,"timestamp":1776050393177}}
{"type":"message","id":"e4677116","parentId":"7f2a2a88","timestamp":"2026-04-13T03:19:53.352Z","message":{"role":"toolResult","toolCallId":"call_function_fip7hrxe9dm7_2","toolName":"read","content":[{"type":"text","text":"import { Request, Response } from 'express';\nimport { catchAsync } from '@/interface/middlewares/catchAsync.middleware';\nimport mongoose from 'mongoose';\n\n// All collections to export/import\nconst COLLECTIONS = [\n  'students',\n  'courses',\n  'coursestudents',\n  'exams',\n  'exambatches',\n  'payments',\n  'cities',\n  'stadiums',\n  'systemsettings',\n  'licensecategories',\n  'lessons',\n  'dats',\n];\n\nexport const exportAllData = catchAsync(async (req: Request, res: Response) => {\n  const db = mongoose.connection.db;\n  if (!db) {\n    res.status(503).json({ success: false, message: 'Database not connected' });\n    return;\n  }\n\n  const exportData: Record<string, any[]> = {};\n  const meta = {\n    exportedAt: new Date().toISOString(),\n    version: '1.0',\n    collections: [] as string[],\n  };\n\n  for (const collection of COLLECTIONS) {\n    try {\n      const docs = await db.collection(collection).find({}).toArray();\n      exportData[collection] = docs;\n      meta.collections.push(collection);\n    } catch {\n      // Collection may not exist, skip\n    }\n  }\n\n  const payload = { meta, data: exportData };\n\n  res.setHeader('Content-Type', 'application/json');\n  res.setHeader(\n    'Content-Disposition',\n    `attachment; filename=\"dtms-backup-${new Date().toISOString().split('T')[0]}.json\"`,\n  );\n  res.json(payload);\n});\n\nexport const importAllData = catchAsync(async (req: Request, res: Response) => {\n  const db = mongoose.connection.db;\n  if (!db) {\n    res.status(503).json({ success: false, message: 'Database not connected' });\n    return;\n  }\n\n  const { data, meta } = req.body;\n\n  if (!data || typeof data !== 'object') {\n    res.status(400).json({ success: false, message: 'Dữ liệu import không hợp lệ. Cần trường \"data\".' });\n    return;\n  }\n\n  const results: Record<string, number> = {};\n  const errors: string[] = [];\n\n  for (const [collectionName, docs] of Object.entries(data)) {\n    if (!Array.isArray(docs) || docs.length === 0) continue;\n\n    try {\n      const col = db.collection(collectionName);\n\n      // Convert string _id back to ObjectId where applicable\n      const sanitized = (docs as any[]).map((doc: any) => {\n        if (doc._id && typeof doc._id === 'string') {\n          try {\n            doc._id = new mongoose.Types.ObjectId(doc._id);\n          } catch {\n            // keep as-is\n          }\n        }\n        return doc;\n      });\n\n      // Use bulkWrite with upsert to avoid duplicates\n      const ops = sanitized.map((doc: any) => ({\n        replaceOne: {\n          filter: { _id: doc._id },\n          replacement: doc,\n          upsert: true,\n        },\n      }));\n\n      const result = await col.bulkWrite(ops);\n      results[collectionName] = result.upsertedCount + result.modifiedCount;\n    } catch (err: any) {\n      errors.push(`${collectionName}: ${err.message}`);\n    }\n  }\n\n  res.json({\n    success: true,\n    message: `Import hoàn tất. ${errors.length > 0 ? 'Một số lỗi xảy ra.' : 'Tất cả thành công.'}`,\n    data: { results, errors },\n  });\n});\n"}],"isError":false,"timestamp":1776050393260}}
