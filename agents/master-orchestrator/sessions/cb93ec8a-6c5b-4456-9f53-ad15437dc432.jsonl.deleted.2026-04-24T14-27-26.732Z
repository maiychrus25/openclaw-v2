essionKey\": \"agent:master-orchestrator:telegram:direct:6053576134\",\n      \"deliveryContext\": {\n        \"channel\": \"webchat\"\n      },\n      \"updatedAt\": 1776149948353,\n      \"sessionId\": \"209e1e2a-1435-42a2-bfce-6aa8571414e2\",\n      \"model\": \"AHV-Holding-TroLy\",\n      \"contextTokens\": 200000,\n      \"totalTokens\": 35632,\n      \"estimatedCostUsd\": 0,\n      \"status\": \"failed\",\n      \"startedAt\": 1776149027599,\n      \"endedAt\": 1776149401234,\n      \"runtimeMs\": 5977,\n      \"thinkingLevel\": \"medium\",\n      \"abortedLastRun\": false,\n      \"lastChannel\": \"webchat\",\n      \"transcriptPath\": \"/root/.openclaw/agents/master-orchestrator/sessions/209e1e2a-1435-42a2-bfce-6aa8571414e2.jsonl\",\n      \"messages\": [\n        {\n          \"role\": \"assistant\",\n          \"content\": [],\n          \"api\": \"anthropic-messages\",\n          \"provider\": \"ahvholding\",\n          \"model\": \"AHV-Holding-TroLy\",\n          \"usage\": {\n            \"input\": 0,\n            \"output\": 0,\n            \"totalTokens\": 0,\n            \"cacheRead\": 0,\n            \"cacheWrite\": 0,\n            \"cost\": {\n              \"total\": 0\n            }\n          },\n          \"stopReason\": \"error\",\n          \"timestamp\": 1776149395467,\n          \"errorMessage\": \"500 {\\\"error\\\":{\\\"message\\\":\\\"Cannot read properties of undefined (reading 'providerSpecificData')\\\"}}\",\n          \"__openclaw\": {\n            \"id\": \"c3562531\",\n            \"seq\": 61\n          }\n        }\n      ]\n    },\n    {\n      \"key\": \"agent:master-orchestrator:telegram:group:-5168104492\",\n      \"kind\": \"group\",\n      \"channel\": \"telegram\",\n      \"origin\": {\n        \"provider\": \"telegram\",\n        \"accountId\": \"main_bot\"\n      },\n      \"displayName\": \"telegram:g-ahv-dtlx-ecosystem\",\n      \"deliveryContext\": {\n        \"channel\": \"telegram\",\n        \"to\": \"telegram:-5168