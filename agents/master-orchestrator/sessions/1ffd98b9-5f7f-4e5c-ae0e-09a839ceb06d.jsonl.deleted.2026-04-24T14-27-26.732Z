ealth closely.\n\n━━━━━━━━━━━━━━━━━━━━━\n\n**Pipeline Status:** 🟢 HEALTHY\n**Active Agents:** 34 (v4 ecosystem)\n**Active Session:** telegram:group:-5212380728\n\n━━━━━━━━━━━━━━━━━━━━━\nOrbis 🌐 — Global Orchestrator"}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":328,"output":570,"totalTokens":17958,"cacheRead":14121,"cacheWrite":2939,"cost":{"total":0}},"stopReason":"stop","timestamp":1776117671474,"responseId":"062c9aa87844c59bbd285766e62b966f","__openclaw":{"id":"faf39631","seq":7}}]},{"key":"agent:master-orchestrator:subagent:8d8e1952-016d-4c2d-819c-c3b32e3b45b2","kind":"other","channel":"telegram","spawnedBy":"agent:master-orchestrator:telegram:direct:6053576134","label":"QLHV monitor run","displayName":"telegram:g-agent-master-orchestrator-subagent-8d8e1952-016d-4c2d-819c-c3b32e3b45b2","parentSessionKey":"agent:master-orchestrator:telegram:direct:6053576134","deliveryContext":{"channel":"telegram"},"updatedAt":1776070165477,"sessionId":"c1e8da7a-5b7a-475f-a9d1-fb81f43fe127","model":"AHV-Holding-DEV","contextTokens":200000,"totalTokens":12228,"estimatedCostUsd":0,"status":"failed","startedAt":1776069883487,"endedAt":1776070040118,"runtimeMs":0,"thinkingLevel":"medium","abortedLastRun":false,"lastChannel":"telegram","transcriptPath":"/root/.openclaw/agents/master-orchestrator/sessions/c1e8da7a-5b7a-475f-a9d1-fb81f43fe127.jsonl","messages":[]},{"key":"agent:master-orchestrator:subagent:fe86b902-0203-46af-83a0-60a211aa4976","kind":"other","channel":"unknown","updatedAt":1776069898582,"sessionId":"b909e1f7-79a7-4556-bdc4-cba37d46adfa","model":"AHV-Holding-DEV","contextTokens":200000,"thinkingLevel":"medium","transcriptPath":"/root/.openclaw/agents/master-orchestrator/sessions/b909e1f7-79a7-4556-bdc4-cba37d46adfa.jsonl","messages":[]},{"key":"agent:ui-ux-pro-max:subagent:ae038bd3-76fe-45b5-a5d7-b8797a299b2d","kind":"other","channel":"telegram","spawnedBy":"agent:master-orchestrator:telegram:group:-5163901258","label":