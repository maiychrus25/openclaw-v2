{"type":"message","id":"9d48db8a","parentId":"26a9f379","timestamp":"2026-04-14T04:29:18.745Z","message":{"role":"toolResult","toolCallId":"call_function_r9elppp4j8k4_1","toolName":"read","content":[{"type":"text","text":"import dotenv from 'dotenv';\ndotenv.config();\n\nimport { env } from '@common/helpers/env.helper';\nimport { DatabaseAdapter } from '@common/infrastructure/database.adapter';\nimport logger from '@common/logger';\nimport { SocketServer } from './socketServer';\nimport { getNotifiesSchedule } from './modules/notifies/notifies.helper';\nimport { CronJobManager } from './modules/cronJobs/cronJobs.manager';\n\n// CATCH UNCAUGHT EXCEPTION\nprocess.on('uncaughtException', (err) => {\n    logger.error('UNCAUGHT EXCEPTION: Shutting down...', { error: err.message, stack: err.stack });\n    logger.end();\n\n    logger.on('finish', () => {\n        process.exit(1);\n    });\n\n    setTimeout(() => {\n        process.exit(1);\n    }, 3000);\n});\n\n// CONNECT DATABASE\nconst databaseAdapter = new DatabaseAdapter();\ndatabaseAdapter.connect();\n\n// SERVER SOCKET IO\nconst socketServer = new SocketServer();\nsocketServer.setupSocket(env.SOCKET_PORT);\n\n// INITIALIZE CronJobManager\ngetNotifiesSchedule();\n\nimport app from './app';\n\nconst port = process.env.PORT || 5000;\nconst server = app.listen(port, () => {\n    logger.info(`Server is running on port ${port}!`);\n    (global as any).cronManager = new CronJobManager();\n    logger.info('The api was started successfully!');\n});\n\n// CATCH UNHANDLED REJECTIONS\nprocess.on('unhandledRejection', (err: Error) => {\n    logger.info(err.name, err.message);\n    logger.info('UNHANDLED REJECTION: Shutting down...');\n\n    // THUC HIEN VIEC DONG SERVER NHE NHANG DE XU LY NOT NHUNG YEU CAU DANG THUC HIEN\n    server.close(() => {\n        process.exit(1);\n    });\n});\n\nprocess.on('SIGINT', () => {\n    logger.info('Caught SIGINT, exitting!');\n\n    server.close(() => {\n        process.exit(1);\n    });\n});\n\nprocess.on('SIGTERM', () => {\n    logger.info('Caught SIGTERM, exitting');\n\n    server.close(() => {\n        process.exit(1);\n    });\n});\n\nprocess.on('exit', () => {\n    logger.info('Exiting process...');\n\n    server.close(() => {\n        process.exit(1);\n    });\n});\n"}],"isError":false,"timestamp":1776140958589}}
