te\": \"/api/v1/sales/*\", \"method\": \"PUT\" }\n    ],\n    \"student\": [\n        { \"route\": \"/api/v1/students/*\", \"method\": \"GET\" },\n        { \"route\": \"/api/v1/students/*\", \"method\": \"POST\" }\n    ],\n    \"teacher\": [\n        { \"route\": \"/api/v1/teachers/*\", \"method\": \"GET\" },\n        { \"route\": \"/api/v1/teachers/*\", \"method\": \"POST\" },\n        { \"route\": \"/api/v1/teachers/*\", \"method\": \"PUT\" }\n    ],\n    \"lead\": [\n        { \"route\": \"/api/v1/leads/*\", \"method\": \"GET\" },\n        { \"route\": \"/api/v1/leads/*\", \"method\": \"POST\" },\n        { \"route\": \"/api/v1/leads/*\", \"method\": \"PUT\" },\n        { \"route\": \"/api/v1/leads/*\", \"method\": \"DELETE\" }\n    ],\n    \"user\": [\n        { \"route\": \"/api/v1/users/*\", \"method\": \"GET\" }\n    ],\n    \"staff\": [\n        { \"route\": \"/api/v1/staff/*\", \"method\": \"GET\" },\n        { \"route\": \"/api/v1/staff/*\", \"method\": \"POST\" },\n        { \"route\": \"/api/v1/staff/*\", \"method\": \"PUT\" }\n    ]\n}\n"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":898,"output":743,"cacheRead":20966,"cacheWrite":539,"totalTokens":23146,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776140794889,"responseId":"062cf4fb88b26d8ea685b0292442f218"}}
