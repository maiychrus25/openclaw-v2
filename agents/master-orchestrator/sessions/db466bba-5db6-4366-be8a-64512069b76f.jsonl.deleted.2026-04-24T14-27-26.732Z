{"type":"message","id":"1c21e7db","parentId":"f4fa3139","timestamp":"2026-04-14T04:33:14.352Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"The Firebase service still crashes. Let me check the fcm.config.ts more carefully and make the FCM initialization conditional.","thinkingSignature":"a87d91fd84510399fac55759efddf84ccc0846b7d5d11a5026bbb50c9da57e42"},{"type":"toolCall","id":"call_function_6yua1fph6on3_1","name":"write","arguments":{"path":"/root/.openclaw/workspaces2/v4-ecosystem-review/ahv-dtlx-backend/src/common/notifications/fcm/fcm.config.ts","content":"import admin from 'firebase-admin';\nimport path from 'path';\nimport fs from 'fs';\n\nconst serviceAccountPath = path.resolve(__dirname, '../../../config/serviceAccount.json');\n\nlet adminInstance: admin.app.App | null = null;\n\ntry {\n    if (fs.existsSync(serviceAccountPath)) {\n        adminInstance = admin.initializeApp({\n            credential: admin.credential.cert(serviceAccountPath),\n        });\n    } else {\n        console.warn('FCM serviceAccount.json not found, FCM disabled');\n    }\n} catch (error) {\n    console.warn('FCM initialization failed, FCM disabled:', error);\n}\n\nexport default adminInstance;\n"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":1061,"output":220,"cacheRead":45835,"cacheWrite":191,"totalTokens":47307,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776141185555,"responseId":"062cf682c300a5d823b6aa923c40d61d"}}
