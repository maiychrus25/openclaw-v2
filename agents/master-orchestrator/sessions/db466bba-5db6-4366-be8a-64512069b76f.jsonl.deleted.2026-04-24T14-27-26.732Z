{"type":"message","id":"5173d8d1","parentId":"814efd56","timestamp":"2026-04-14T04:34:26.207Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"There's a TypeScript error because `admin` is now `admin.app.App | null` instead of just `admin`. Let me fix the type annotations.","thinkingSignature":"30b440d5e2841da58428c09bce8e9e135b59b87a540b8b2e9386e41bedc8a9d7"},{"type":"toolCall","id":"call_function_so6ybesqkjj0_1","name":"write","arguments":{"path":"/root/.openclaw/workspaces2/v4-ecosystem-review/ahv-dtlx-backend/src/common/notifications/fcm/fcm.service.ts","content":"import admin from './fcm.config';\n\nexport interface FcmPayload {\n    token: string;\n    title: string;\n    description: string;\n    data?: Record<string, string>;\n}\n\nexport class FcmService {\n    static async sendNotification(payload: FcmPayload) {\n        if (!admin) {\n            console.warn('FCM not initialized, skipping notification');\n            return null;\n        }\n\n        const message = {\n            token: payload.token,\n            notification: {\n                title: payload.title,\n                body: payload.description,\n            },\n            data: payload.data,\n        };\n\n        try {\n            const response = await admin.messaging().send(message as any);\n            return response;\n        } catch (error) {\n            console.error('FCM send error:', error);\n            throw error;\n        }\n    }\n\n    static async sendToMany(tokens: string[], title: string, body: string) {\n        if (!admin) {\n            console.warn('FCM not initialized, skipping multicast notification');\n            return null;\n        }\n\n        const message = {\n            tokens,\n            notification: { title, body },\n        };\n\n        return admin.messaging().sendMulticast(message as any);\n    }\n}\n"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":189,"output":338,"cacheRead":47934,"cacheWrite":203,"totalTokens":48664,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776141259485,"responseId":"062cf6cc3c4c448b307359eff4146b6a"}}
