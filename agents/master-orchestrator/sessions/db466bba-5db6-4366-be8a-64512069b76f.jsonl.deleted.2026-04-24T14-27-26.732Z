{"type":"message","id":"e4cf8fb4","parentId":"9b8bcdf0","timestamp":"2026-04-14T04:26:01.403Z","message":{"role":"toolResult","toolCallId":"call_function_7lbwlx97ydye_1","toolName":"read","content":[{"type":"text","text":"import logger from '@common/logger';\nimport permissionsConfig from '../../config/permissions.json';\nimport apiDetail from '../../config/routeDetailForPermissions.json';\n\nexport function getPermissionsByRoleNames(roles: string[]): string[] {\n    try {\n        const permissions: string[] = [];\n        roles.forEach((role) => {\n            const rolePermissions = permissionsConfig.find((r) => r.role === role)?.permissions;\n            permissions.push(...(rolePermissions || []));\n        });\n        return permissions;\n    } catch (error) {\n        logger.info('Error getting permissions from request:', error);\n        return [];\n    }\n}\n\nexport function getApisByPermissions(permissions: string[]): any[] {\n    try {\n        const apis = [];\n        permissions.forEach((perm) => {\n            const api = apiDetail[perm];\n            if (api) {\n                apis.push(api);\n            }\n        });\n        return apis;\n    } catch (error) {\n        logger.info('Error getting permissions from request:', error);\n        return [];\n    }\n}\n\nexport function replaceRouteParam(paramKey: string, paramValue: string, path: string): string {\n    try {\n        const resolvedPath = path.replace(paramKey, paramValue);\n        return resolvedPath ?? path;\n    } catch (error) {\n        logger.info('Error getting permissions from request:', error);\n        return path;\n    }\n}\n\nexport function checkPermissionsPath(apis: any[], fullPath: string, method: string, userId: string): boolean {\n    try {\n        return apis.some((api) => {\n            if (api.method !== method) return false;\n\n            let permissionRoute = api.route;\n\n            if (api.route.includes('/:id')) {\n                permissionRoute = api.route.replace('/:id', `/${userId}`);\n                return fullPath === permissionRoute;\n            }\n            const routeRegex = new RegExp(\n                '^' + api.route.replace(/\\//g, '\\\\/').replace(/:[^/]+/g, '([^/]+)') + '\\\\/?$',\n            );\n\n            return routeRegex.test(fullPath);\n        });\n    } catch (error) {\n        logger.info('Error in checkPermissionsPath:', error);\n        return false;\n    }\n}\n"}],"isError":false,"timestamp":1776140758520}}
