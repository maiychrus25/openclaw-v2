{"type":"message","id":"a680313f","parentId":"cf552274","timestamp":"2026-04-14T07:05:41.717Z","message":{"role":"toolResult","toolCallId":"call_function_6fywgmo2oefl_1","toolName":"exec","content":[{"type":"text","text":"import { Types, Document } from 'mongoose';\n\nexport interface IUserRole extends Document {\n    user_id: Types.ObjectId;\n    role_id: Types.ObjectId;\n    created_at: Date;\n    updated_at: Date;\n}\n\nexport interface IUserRoleResponse {\n    id: string;\n    user_id: string;\n    role_id: string;\n    role_name?: string;\n    created_at?: Date;\n    updated_at?: Date;\n}\n\nexport enum UserRoleDefined {\n    Admin = 'admin',\n    Sale = 'sale',\n    Student = 'student',\n    Teacher = 'teacher',\n    Lead = 'lead',\n    User = 'user',\n    Staff = 'staff',\n}\n\nexport interface IUserRoleCreateRequest {\n    user_id: string;\n    role_id: string;\n}\nexport interface IUserRoleUpdateRequest {\n    role_id?: string;\n}\n\nexport interface IUserRoleByIdRequest {\n    id: string;\n}\nexport interface IUserRoleByUserIdRequest {\n    id: string;\n}\n\nexport interface IUserRoleListRequest {\n    user_id?: string;\n    role_id?: string;\n    page?: number;\n    limit?: number;\n}\n\nexport interface IFilterUserRole {\n    user_id?: string;\n}\n==="}],"details":{"status":"completed","exitCode":0,"durationMs":199,"aggregated":"import { Types, Document } from 'mongoose';\n\nexport interface IUserRole extends Document {\n    user_id: Types.ObjectId;\n    role_id: Types.ObjectId;\n    created_at: Date;\n    updated_at: Date;\n}\n\nexport interface IUserRoleResponse {\n    id: string;\n    user_id: string;\n    role_id: string;\n    role_name?: string;\n    created_at?: Date;\n    updated_at?: Date;\n}\n\nexport enum UserRoleDefined {\n    Admin = 'admin',\n    Sale = 'sale',\n    Student = 'student',\n    Teacher = 'teacher',\n    Lead = 'lead',\n    User = 'user',\n    Staff = 'staff',\n}\n\nexport interface IUserRoleCreateRequest {\n    user_id: string;