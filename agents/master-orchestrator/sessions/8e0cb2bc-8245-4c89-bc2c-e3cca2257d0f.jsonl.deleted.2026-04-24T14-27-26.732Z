rname: 'admin2',\n            first_name: 'system',\n            last_name: 'admin2',\n            phone: '030000000001',\n            image: null,\n            gender: IUserGender.Male,\n            dob: new Date('1900-01-01'),\n            address: '',\n            identity_card: '00000000001',\n            status: IUserStatus.Active,\n            email: ADMIN2_EMAIL,\n            password: ADMIN2_PASSWORD,\n        };\n        const admin2User = await userService.createUser(recordData);\n        await userRolesService.createUserRole({\n            user_id: admin2User.id,\n            role_id: adminRoleId,\n        });\n        logger.info('[initAdmin2Account] Created admin2@gmail.com with admin role');\n        return admin2User;\n    } catch (error) {\n        logger.error('[initAdmin2Account] Error:', error);\n        return null;\n    }\n}\n\nexport async function initMotorbikeCourse(): Promise<ICourseResponse> {"}]}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":486,"output":661,"cacheRead":83626,"cacheWrite":591,"totalTokens":85364,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776150380651,"responseId":"062d1a6e267ed7dac7a94c87cfddecb8"}}
