{"type":"message","id":"1d08aee3","parentId":"42883fe6","timestamp":"2026-04-13T05:04:30.335Z","message":{"role":"toolResult","toolCallId":"call_function_xolx5a03x6gs_1","toolName":"exec","content":[{"type":"text","text":"image: node:20-alpine\n\nvariables:\n  PRJ_PATH: \"/root/qlhv/ahv-qlhv-fe\"\n  DOCKER_BUILDKIT: 1\n\ndefault:\n  timeout: 30m\n\nstages:\n  - lint\n  - test\n  - deploy\n\ncache:\n  key:\n    files:\n      - yarn.lock\n  paths:\n    - .yarn-cache/\n    \n# Lint\nfrontend_lint:\n  stage: lint\n  tags:\n    - ahv-dtlx\n  script:\n    - yarn install --frozen-lockfile --cache-folder .yarn-cache --prefer-offline\n    - yarn lint\n  rules:\n    - if: $CI_PIPELINE_SOURCE == \"merge_request_event\"\n\n# Test\nfrontend_test:\n  stage: test\n  tags:\n    - ahv-dtlx\n  script:\n    - yarn install --frozen-lockfile --cache-folder .yarn-cache --prefer-offline\n    - yarn test --passWithNoTests\n  rules:\n    - if: $CI_PIPELINE_SOURCE == \"merge_request_event\"\n\n# Deploy\nfrontend_deploy:\n  stage: deploy\n  image: docker:24.0.5\n  tags:\n    - ahv-dtlx\n  script:\n    - apk add --no-cache git\n    - git config --global --add safe.directory $PRJ_PATH\n    - cd $PRJ_PATH\n    - git reset --hard HEAD\n    - git clean -fd\n    - git pull https://gitlab-ci-token:${CI_JOB_TOKEN}@${CI_SERVER_HOST}/${CI_PROJECT_PATH}.git develop\n    - docker compose down --remove-orphans\n    - docker compose up -d --build\n    - docker image prune -f\n  rules:\n    - if: $CI_COMMIT_BRANCH == \"develop\""}],"details":{"status":"completed","exitCode":0,"durationMs":41,"aggregated":"image: node:20-alpine\n\nvariables:\n  PRJ_PATH: \"/root/qlhv/ahv-qlhv-fe\"\n  DOCKER_BUILDKIT: 1\n\ndefault:\n  timeout: 30m\n\nstages:\n  - lint\n  - test\n  - deploy\n\ncache:\n  key:\n    files:\n      - yarn.lock\n  paths:\n    - .yarn-cache/\n    \n# Lint\nfrontend_lint:\n  stage: lint\n  tags:\n    - ahv-dtlx\n  script:\n    - yarn install --frozen-lockfile --cache-folder .yarn-cache --prefer-offline\n    - yarn lint\n  rules:\n    - if: $CI_PIPELINE_SOURCE == \"merge_request_event\"\n\n# Test\nfrontend_test:\n  stage: test\n  tags:\n    - ahv-dtlx\n  script:\n    - yarn install --frozen-lockfile --cache-folder .yarn-cache --prefer-offline\n    - yarn test --passWithNoTests\n  rules:\n    - if: $CI_PIPELINE_SOURCE == \"merge_request_event\"\n\n# Deploy\nfrontend_deploy:\n  stage: deploy\n  image: docker:24.0.5\n  tags:\n    - ahv-dtlx\n  script:\n    - apk add --no-cache git\n    - git config --global --add safe.directory $PRJ_PATH\n    - cd $PRJ_PATH\n    - git reset --hard HEAD\n    - git clean -fd\n    - git pull https://gitlab-ci-token:${CI_JOB_TOKEN}@${CI_SERVER_HOST}/${CI_PROJECT_PATH}.git develop\n    - docker compose down --remove-orphans\n    - docker compose up -d --build\n    - docker image prune -f\n  rules:\n    - if: $CI_COMMIT_BRANCH == \"develop\"","cwd":"/root/.openclaw/workspaces/teacher-driving-training-system.bootstrap-backup/ahv-qlhv-fe"},"isError":false,"timestamp":1776056670212}}
