{"type":"message","id":"c55615aa","parentId":"78f3c249","timestamp":"2026-04-13T04:55:42.052Z","message":{"role":"toolResult","toolCallId":"call_function_x8rrrub3k05c_1","toolName":"exec","content":[{"type":"text","text":"diff --git a/src/application/services/exam.service.ts b/src/application/services/exam.service.ts\nindex 5105394..c599469 100644\n--- a/src/application/services/exam.service.ts\n+++ b/src/application/services/exam.service.ts\n@@ -42,8 +42,8 @@ export class ExamService {\n     return await this.examRepository.findByType(type, options);\n   }\n \n-  async getExamStudents(id: string, options: PaginationOptions = { page: 1, limit: 10 }) {\n-    return await this.examRepository.getStudents(id, options);\n+  async getExamStudents(id: string, options: PaginationOptions = { page: 1, limit: 10 }, teacherId?: string) {\n+    return await this.examRepository.getStudents(id, options, teacherId);\n   }\n \n   async updateStudentResult(examId: string, studentId: string, result: string) {\ndiff --git a/src/application/services/lesson.service.ts b/src/application/services/lesson.service.ts\nindex d892d73..89fdec0 100644\n--- a/src/application/services/lesson.service.ts\n+++ b/src/application/services/lesson.service.ts\n@@ -37,4 +37,9 @@ export class LessonService {\n   async deleteLesson(id: string): Promise<ILesson | null> {\n     return await this.lessonRepository.delete(id);\n   }\n+\n+  async isLessonAssignedToTeacher(lessonId: string, teacherId: string): Promise<boolean> {\n+    const lesson = await this.lessonRepository.findById(lessonId);\n+    return lesson?.teacher_id?.toString() === teacherId;\n+  }\n }\ndiff --git a/src/application/services/student.service.ts b/src/application/services/student.service.ts\nindex b7657a8..046ec49 100644\n--- a/src/application/services/student.service.ts\n+++ b/src/application/services/student.service.ts\n@@ -265,4 +265,12 @@ export class StudentService {\n       }\n     };\n   }\n+\n+  async isStudentAssignedToTeacher(studentId: string, teacherId: string): Promise<boolean> {\n+    const count = await CourseStudentModel.countDocuments({\n+      student_id: studentId,\n+      teacher_id: teacherId\n+    });\n+    return count > 0;\n+  }\n }\ndiff --git a/src/infrastructure/repositories/exam.repository.ts b/src/infrastructure/repositories/exam.repository.ts\nindex 5b284d1..d9cb0cf 100644\n--- a/src/infrastructure/repositories/exam.repository.ts\n+++ b/src/infrastructure/repositories/exam.repository.ts\n@@ -28,9 +28,15 @@ export class ExamRepository {\n     const { page, limit } = options;\n     const skip = (page - 1) * limit;\n \n-    const { exam_type, search, status, start_date, end_date } = filters;\n+    const { exam_type, search, status, start_date, end_date, teacher_id } = filters;\n     const mongoFilters: any = {};\n \n+    if (teacher_id) {\n+      const { CourseStudentModel } = require('../database/models/course_student.model');\n+      const assignedStudentIds = await CourseStudentModel.find({ teacher_id }).distinct('student_id').exec();\n+      mongoFilters['studentResults.student_id'] = { $in: assignedStudentIds };\n+    }\n+\n     if (exam_type && exam_type !== 'Tất cả') {\n       mongoFilters.exam_type = exam_type;\n     }\n@@ -133,11 +139,19 @@ export class ExamRepository {\n     return await ExamModel.findByIdAndDelete(id).exec();\n   }\n \n-  async getStudents(id: string, options: PaginationOptions = { page: 1, limit: 10 }): Promise<PaginatedResult<any>> {\n+  async getStudents(id: string, options: PaginationOptions = { page: 1, limit: 10 }, teacherId?: string): Promise<PaginatedResult<any>> {\n     const exam = await ExamModel.findById(id).lean().exec();\n     if (!exam) throw new Error('Exam not found');\n \n-    const results = (exam as any).studentResults || [];\n+    let results = (exam as any).studentResults || [];\n+\n+    if (teacherId) {\n+      const { CourseStudentModel } = require('../database/models/course_student.model');\n+      const assignedStudentIds