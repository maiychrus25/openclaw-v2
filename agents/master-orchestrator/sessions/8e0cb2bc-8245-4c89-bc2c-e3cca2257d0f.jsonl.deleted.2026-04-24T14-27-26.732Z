] = useState(false);\nsrc/app/settings/page.tsx:561:  const handlePasswordChange = async (e: React.FormEvent) => {\nsrc/app/settings/page.tsx:574:    setIsChangingPassword(true);\nsrc/app/settings/page.tsx:576:      const res = await changePassword({\nsrc/app/settings/page.tsx:591:      setIsChangingPassword(false);\nsrc/app/settings/page.tsx:619:                      onChange={(e) => setProfileName(e.target.value)}","cwd":"/root/.openclaw/workspaces/teacher-driving-training-system.bootstrap-backup/ahv-qlhv-fe"},"isError":false,"timestamp":1776054486142}}
{"type":"message","id":"50fe5b0f","parentId":"517cf5e0","timestamp":"2026-04-13T04:28:11.022Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"The settings page at `src/app/settings/page.tsx` has the license class management (hạng bằng). Let me read this file to understand the current modal for adding license classes.","thinkingSignature":"0b95020c5d30d51c3b0f41e14037db6495db18cbf03d0f105a2c1ba1edf3d63d"},{"type":"toolCall","id":"call_function_38dgwkx8qbbu_1","name":"read","arguments":{"path":"/root/.openclaw/workspaces/teacher-driving-training-system.bootstrap-backup/ahv-qlhv-fe/src/app/settings/page.tsx","offset":1,"limit":100}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":1224,"output":114,"cacheRead":22092,"cacheWrite":574,"totalTokens":24004,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776054486275,"responseId":"062ba3d726067a4fa08c9de2057aced3"}}
{"type":"message","id":"caf76639","parentId":"50fe5b0f","timestamp":"2026-04-13T04:28:11.322Z","message":{"role":"toolResult","toolCallId":"call_function_38dgwkx8qbbu_1","toolName":"read","content":[{"type":"text","text":"'use client';\n\nimport React, { useState, useEffect } from 'react';\nimport {\n  Settings, Save, Shield, Bell, User, Sliders, Crown, FileText, Cloud, Database,\n  MapPin, CreditCard, Banknote, Stethoscope, Car, Flag, Building2, Plus, Edit2, Trash2,\n  CheckCircle2, AlertTriangle, Download, Upload, Trash, Info, Send, Phone, Mail, Globe, Map,\n  ClipboardList, ArrowUp, ArrowDown, ExternalLink, Monitor, Navigation, Lock, Key, Eye, EyeOff,\n  Smartphone, History, Loader2, AlertCircle\n} from 'lucide-react';\nimport { useAuth } from '@/src/context/AuthContext';\nimport { updateProfile, changePassword, getLoginHistory } from '@/src/services/authService';\nimport UnderDevelopment from '@/src/components/shared/UnderDevelopment';\nimport { toast } from 'sonner';\nimport { ConfirmDeleteModal, LicenseModal, ClinicModal, ExamCenterModal, RegionModal, FeeBatchModal } from './SettingsModals';\nimport { getSystemSettings, updateSystemSettings, SystemSettings, Clinic as ClinicType } from '@/src/services/settingsService';\nimport { getLicenseCategories, LicenseCategory } from '@/src/services/licenseCategoryService';\nimport { getCities, createCity, updateCity, deleteCity, City } from '@/src/services/cityService';\nimport { createLicenseCategory, updateLicenseCategory, deleteLicenseCategory } from '@/src/services/licenseCategoryService';\nimport { getStadiums, createStadium, updateStadium, deleteStadium, Stadium } from '@/src/services/stadiumService';\n\n/* ─── Level 1 Tabs (Top) ─────────────────────────────── */\nconst TOP_TABS = [\n  { id: 'chung',     label: 'Chung',      icon: Sliders },\n  { id: 'tai-khoan', label: 'Tài khoản',   icon: User },\n  { id: 'vip-qr',    label: 'VIP QR',     icon: Crown },\n  { id: 'form-hv',   label: 'Form học viên', icon: ClipboardList },\n  { id: 'data',      label: 'Dữ liệu',     icon: Database },\n];\n\n/* ─── Level 2 Tabs (under Chung) ─────────────────────── */\nconst CHUNG_SUBTABS = [\n  { id: 'khu-vuc',    label: 'Khu vực',    icon: MapPin },\n  { id: 'hang-bang',  label: 'Hạng bằng',  icon: CreditCard },\n  { id: 'dot-thu',    label: 'Đợt thu phí', icon: Banknote },\n  { id: 'phong-ksk',  label: 'Phòng KSK', icon: Stethoscope },\n  { id: 'dao-tao',    label: 'Đào tạo ô tô', icon: Car },\n  { id: 'san-thi',    label: 'Sân thi',    icon: Map },\n  { id: 'trung-tam',  label: 'Trung tâm',  icon: Building2 },\n];\n\nexport default function SettingsPage() {\n  const [activeTopTab, setActiveTopTab] = useState('chung');\n  const [activeSubTab, setActiveSubTab] = useState('khu-vuc');\n\n  // Data States\n  const [systemSettings, setSystemSettings] = useState<SystemSettings | null>(null);\n  const [regions, setRegions] = useState<City[]>([]);\n  const [stadiums, setStadiums] = useState<Stadium[]>([]);\n  const [licenseCategories, setLicenseCategories] = useState<LicenseCategory[]>([]);\n  const [loading, setLoading] = useState(true);\n\n  // Modal States\n  const [isDeleteOpen, setIsDeleteOpen] = useState(false);\n  const [deleteConfig, setDeleteConfig] = useState<{ id: string, type: 'city' | 'license' | 'clinic' | 'stadium' | 'fee', message: string } | null>(null);\n  \n  const [isLicenseOpen, setIsLicenseOpen] = useState(false);\n  const [editingLicense, setEditingLicense] = useState<LicenseCategory | null>(null);\n  \n  const [isClinicOpen, setIsClinicOpen] = useState(false);\n  const [editingClinic, setEditingClinic] = useState<ClinicType | null>(null);\n  \n  const [isCenterOpen, setIsCenterOpen] = useState(false);\n  const [editingStadium, setEditingStadium] = useState<Stadium | null>(null);\n  \n  const [isRegionOpen, setIsRegionOpen] = useState(false);\n  const [editingRegion, setEditingRegion] = useState<City | null>(null);\n  \n  const [isFeeBatchOpen, setIsFeeBatchOpen] = useState(false);\n\n  useEffect(() => {\n    fetchAllData();\n  }, []);\n\n  const fetchAllData = async () => {\n    setLoading(true);\n    try {\n      const [settingsRes, citiesRes, stadiumsRes, lcRes] = await Promise.all([\n        getSystemSettings(),\n        getCities(),\n        getStadiums(),\n        getLicenseCategories()\n      ]);\n\n      if (settingsRes.success) {\n        setSystemSettings(settingsRes.data || {\n          license_categories: [],\n          fee_stages: [],\n          clinic_list: [],\n          requiredFields: ['name', 'rank', 'region'],\n          practiceTargetMinutes: 420\n        });\n      }\n      if (citiesRes.success) {\n        const citiesData = citiesRes.data;\n        setRegions(Array.isArray(citiesData) ? citiesData : (citiesData as any).items || (citiesData as any).docs || []);\n      }\n      if (stadiumsRes.success) {\n        const stadiumsData = stadiumsRes.data;\n        setStadiums(Array.isArray(stadiumsData) ? stadiumsData : (stadiumsData as any).items || (stadiumsData as any).docs || []);\n\n[1812 more lines in file. Use offset=101 to continue.]"}],"isError":false,"timestamp":1776054491189}}
{"type":"message","id":"53c44870","parentId":"caf76639","timestamp":"2026-04-13T04:28:21.427Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Let me look at the LicenseModal component to see how it currently works.","thinkingSignature":"352bb058020f8298109bcb436bd1e88060e56230a581675c0066dd29f9e6d1f5"},{"type":"toolCall","id":"call_function_lg4xcoukvjdb_1","name":"read","arguments":{"path":"/root/.openclaw/workspaces/teacher-driving-training-system.bootstrap-backup/ahv-qlhv-fe/src/app/settings/SettingsModals.tsx"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":1464,"output":71,"cacheRead":22519,"cacheWrite":1380,"totalTokens":25434,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776054491329,"responseId":"062ba3dc88006591fbb6e76a956a97af"}}
{"type":"message","id":"bc36768f","parentId":"53c44870","timestamp":"2026-04-13T04:28:21.613Z","message":{"role":"toolResult","toolCallId":"call_function_lg4xcoukvjdb_1","toolName":"read","content":[{"type":"text","text":"'use client';\n\nimport React from 'react';\nimport { \n  X, Car, Flag, AlertTriangle, CreditCard, Stethoscope, MapPin, Save, \n  Trash2, CheckCircle2, Banknote, FileText, Monitor, Navigation, Info, Activity\n} from 'lucide-react';\nimport { toast } from 'sonner';\n\nimport { City } from '@/src/services/cityService';\nimport { Stadium } from '@/src/services/stadiumService';\nimport { \n  LicenseCategory, Clinic as ClinicType, SystemSettings \n} from '@/src/services/settingsService';\n\ninterface ModalProps {\n  isOpen: boolean;\n  onClose: () => void;\n  title: string;\n  icon: React.ElementType;\n  children: React.ReactNode;\n  footer?: React.ReactNode;\n}\n\nconst Modal: React.FC<ModalProps> = ({ isOpen, onClose, title, icon: Icon, children, footer }) => {\n  if (!isOpen) return null;\n\n  return (\n    <div className=\"fixed inset-0 z-[100] flex items-center justify-center p-4 animate-in fade-in duration-200\">\n      <div className=\"absolute inset-0 bg-gray-900/40 backdrop-blur-sm\" onClick={onClose} />\n      <div className=\"relative w-full max-w-lg bg-white rounded-[2rem] shadow-2xl overflow-hidden flex flex-col animate-in zoom-in-95 duration-200\">\n        <div className=\"flex items-center justify-between px-6 py-4 border-b border-gray-100 font-black text-gray-800\">\n          <div className=\"flex items-center gap-2\">\n            <Icon className=\"w-5 h-5 text-indigo-600\" />\n            <span>{title}</span>\n          </div>\n          <button onClick={onClose} className=\"p-2 text-gray-400 hover:text-rose-500 hover:bg-rose-50 rounded-xl transition-colors\">\n            <X className=\"w-5 h-5\" />\n          </button>\n        </div>\n        <div className=\"p-6 overflow-y-auto max-h-[80vh] no-scrollbar\">\n          {children}\n        </div>\n        {footer && (\n          <div className=\"flex items-center justify-end gap-3 px-6 py-4 border-t border-gray-100 bg-gray-50/50\">\n            {footer}\n          </div>\n        )}\n      </div>\n    </div>\n  );\n};\n\n/* 1. Confirm Delete Modal */\nexport const ConfirmDeleteModal = ({ \n  isOpen, \n  onClose, \n  onConfirm, \n  message, \n  item \n}: { \n  isOpen: boolean, \n  onClose: () => void, \n  onConfirm: (item: any) => Promise<void>, \n  message: string, \n  item: any \n}) => {\n  const [isDeleting, setIsDeleting] = React.useState(false);\n\n  const handleConfirm = async () => {\n    setIsDeleting(true);\n    try {\n      await onConfirm(item);\n      onClose();\n    } finally {\n      setIsDeleting(false);\n    }\n  };\n\n  return (\n    <Modal isOpen={isOpen} onClose={onClose} title=\"Xác nhận xóa\" icon={AlertTriangle}>\n      <div className=\"flex flex-col gap-4 py-2\">\n        <p className=\"text-gray-600 font-bold leading-relaxed tracking-tight text-center\">\n          {message}\n        </p>\n        <p className=\"text-[11px] text-rose-500 font-black text-center uppercase tracking-widest border-t border-rose-50 border-dashed pt-4 opacity-70\">\n          Hành động này không thể hoàn tác!\n        </p>\n      </div>\n      <div className=\"flex items-center justify-end gap-3 mt-6\">\n         <button onClick={onClose} className=\"px-5 py-2.5 text-sm font-black text-gray-400 hover:text-gray-600\">Hủy</button>\n         <button \n           onClick={handleConfirm}\n           disabled={isDeleting}\n           className=\"px-8 py-2.5 bg-rose-500 text-white font-black rounded-2xl shadow-lg shadow-rose-500/20 hover:bg-rose-600 transition-all text-sm uppercase tracking-widest flex items-center gap-2\"\n          >\n           {isDeleting && <div className=\"w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin\" />}\n           {isDeleting ? 'Đang xóa...' : 'Xác nhận xóa'}\n         </button>\n      </div>\n    </Modal>\n  );\n};\n\n/* 2. License Category Modal (Add/Edit) */\nexport const LicenseModal = ({ isOpen, onClose, item, onSave }: { isOpen: boolean, onClose: () => void, item?: LicenseCategory | null, onSave: (data: LicenseCategory) => Promise<void> }) => {\n  const [selectedTags, setSelectedTags] = React.useState<string[]>([]);\n  const [formData, setFormData] = React.useState({\n    id: '',\n    name: '',\n    type: 'Ô tô' as 'Ô tô' | 'Xe máy',\n    fee: '0',\n    dat: ''\n  });\n  const [touched, setTouched] = React.useState(false);\n  const [isSaving, setIsSaving] = React.useState(false);\n\n  React.useEffect(() => {\n    if (item) {\n      setFormData({\n        id: item.id,\n        name: item.name,\n        type: item.type as 'Ô tô' | 'Xe máy',\n        fee: item.fee.replace(/[^0-9]/g, ''),\n        dat: item.dat || ''\n      });\n      setSelectedTags(item.tags);\n    } else {\n      setFormData({ id: '', name: '', type: 'Ô tô', fee: '0', dat: '' });\n      setSelectedTags(['Lý thuyết', 'Thực hành']);\n    }\n  }, [item, isOpen]);\n\n  const errors = {\n    id: touched && !formData.id.trim() ? 'Mã hạng không được để trống' : '',\n    name: touched && !formData.name.trim() ? 'Tên hạng không được để trống' : '',\n  };\n\n  const subjects = [\n    { id: 'Lý thuyết', label: 'Học lý thuyết', desc: 'Luật GTĐB + kỹ thuật lái xe', icon: FileText },\n    { id: 'Thực hành', label: 'Học thực hành', desc: 'Sử dụng cho xe máy', icon: Car },\n    { id: 'Cabin',     label: 'Học kỹ năng cabin', desc: 'Làm quen xe, điều chỉnh gương, ga phanh', icon: Car },\n    { id: 'Sa hình',   label: 'Học sa hình', desc: 'Thực hành các bài thi sa hình', icon: Flag },\n    { id: 'Mô phỏng',  label: 'Học mô phỏng', desc: 'Phần mềm mô phỏng tình huống lái xe', icon: Monitor },\n    { id: 'Đường trường', label: 'Học lái đường trường', desc: 'Lái xe thực tế trên đường', icon: Navigation },\n  ];\n\n  const handleSave = async () => {\n    setTouched(true);\n    if (errors.id || errors.name) return;\n\n    setIsSaving(true);\n    try {\n      const formattedFee = new Intl.NumberFormat('vi-VN').format(Number(formData.fee)) + 'đ';\n      const inactive = subjects.map(s => s.id).filter(tag => !selectedTags.includes(tag));\n      \n      await onSave({\n        ...formData,\n        fee: formattedFee,\n        tags: selectedTags,\n        inactive,\n        dat: formData.dat || null\n      });\n      onClose();\n    } finally {\n      setIsSaving(false);\n    }\n  };\n\n  const toggleTag = (id: string) => {\n    setSelectedTags(prev => prev.includes(id) ? prev.filter(m => m !== id) : [...prev, id]);\n  };\n\n  return (\n    <Modal isOpen={isOpen} onClose={onClose} title={item ? 'Sửa hạng bằng' : 'Thêm hạng bằng mới'} icon={CreditCard}>\n      <div className=\"flex flex-col gap-5\">\n        <div className=\"grid grid-cols-2 gap-4\">\n           <div className=\"flex flex-col gap-1.5\">\n              <label className=\"text-[10px] font-black text-gray-400 uppercase tracking-widest\">MÃ HẠNG *</label>\n              <input \n                type=\"text\" \n                placeholder=\"B2, A1, C...\" \n                value={formData.id}\n                onChange={(e) => setFormData({...formData, id: e.target.value.toUpperCase()})}\n                disabled={!!item}\n                className={`w-full px-4 py-2.5 bg-gray-50 border rounded-xl focus:outline-none focus:ring-2 transition-all text-sm font-black disabled:opacity-50 ${\n                  errors.id ? 'border-rose-500 focus:ring-rose-500/20' : 'border-gray-200 focus:ring-indigo-500/20'\n                }`} \n              />\n              {errors.id && <span className=\"text-[10px] font-bold text-rose-500 pl-1\">{errors.id}</span>}\n           </div>\n           <div className=\"flex flex-col gap-1.5\">\n              <label className=\"text-[10px] font-black text-gray-400 uppercase tracking-widest\">TÊN HIỂN THỊ *</label>\n              <input \n                type=\"text\" \n                placeholder=\"VD: Ô tô phổ thông\" \n                value={formData.name}\n                onChange={(e) => setFormData({...formData, name: e.target.value})}\n                className={`w-full px-4 py-2.5 bg-gray-50 border rounded-xl focus:outline-none focus:ring-2 transition-all text-sm font-black ${\n                    errors.name ? 'border-rose-500 focus:ring-rose-500/20' : 'border-gray-200 focus:ring-indigo-500/20'\n                }`} \n              />\n              {errors.name && <span className=\"text-[10px] font-bold text-rose-500 pl-1\">{errors.name}</span>}\n           </div>\n           <div className=\"flex flex-col gap-1.5\">\n              <label className=\"text-[10px] font-black text-gray-400 uppercase tracking-widest\">LOẠI XE</label>\n              <select \n                value={formData.type}\n                onChange={(e) => setFormData({...formData, type: e.target.value as any})}\n                className=\"w-full px-4 py-2.5 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500/20 text-sm font-black\"\n              >\n                 <option>Ô tô</option>\n                 <option>Xe máy</option>\n              </select>\n           </div>\n           <div className=\"flex flex-col gap-1.5\">\n              <label className=\"text-[10px] font-black text-gray-400 uppercase tracking-widest\">HỌC PHÍ MẶC ĐỊNH (Đ)</label>\n              <input \n                type=\"number\" \n                value={formData.fee}\n                onChange={(e) => setFormData({...formData, fee: e.target.value})}\n                className=\"w-full px-4 py-2.5 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500/20 text-sm font-black text-indigo-600\" \n              />\n           </div>\n        </div>\n\n        <div className=\"p-4 bg-indigo-50/50 border border-indigo-100 rounded-2xl flex flex-col gap-3\">\n            <div className=\"flex items-center gap-2 text-indigo-600\">\n                <Flag className=\"w-4 h-4\" />\n                <span className=\"text-xs font-black uppercase tracking-tight\">Cấu hình DAT (nếu có)</span>\n            </div>\n            <div className=\"flex flex-col gap-1\">\n                <label className=\"text-[10px] font-bold text-gray-500 uppercase tracking-tight\">MÔ TẢ DAT (VD: 8h - 840 km)</label>\n                <input \n                  type=\"text\" \n                  placeholder=\"VD: 8h - 840 km\" \n                  value={formData.dat}\n                  onChange={(e) => setFormData({...formData, dat: e.target.value})}\n                  className=\"w-full px-3 py-2 bg-white border border-gray-100 rounded-xl text-xs font-bold\" \n                />\n            </div>\n            <p className=\"text-[10px] text-gray-400 font-medium\">Hiển thị cho học viên biết ngưỡng cần đạt</p>\n        </div>\n\n        <div className=\"flex flex-col gap-3\">\n           <h4 className=\"text-sm font-black text-gray-800 tracking-tight\">Môn học & Nội dung đào tạo</h4>\n           <div className=\"flex flex-col gap-2\">\n              {subjects.map(s => (\n                 <label key={s.id} onClick={() => toggleTag(s.id)} className={`flex items-start gap-3 p-3 border rounded-2xl transition-all cursor-pointer ${\n                    selectedTags.includes(s.id) ? 'bg-indigo-50 border-indigo-200' : 'bg-white border-gray-50 hover:bg-gray-50'\n                 }`}>\n                    <div className={`mt-0.5 w-5 h-5 rounded-lg border-2 flex items-center justify-center shrink-0 transition-all ${\n                       selectedTags.includes(s.id) ? 'bg-indigo-600 border-indigo-600 shadow-lg shadow-indigo-500/30' : 'border-gray-200'\n                    }`}>\n                       {selectedTags.includes(s.id) && <CheckCircle2 className=\"w-3 h-3 text-white\" />}\n                    </div>\n                    <div className=\"flex items-center gap-3\">\n                       <div className={`p-2 rounded-xl border ${selectedTags.includes(s.id) ? 'border-indigo-100 bg-white text-indigo-600' : 'border-gray-50 text-gray-300'}`}>\n                          {React.createElement(s.icon, { className: 'w-4 h-4' })}\n                       </div>\n                       <div className=\"flex flex-col\">\n                          <span className={`text-sm font-black tracking-tight ${selectedTags.includes(s.id) ? 'text-indigo-900 font-black' : 'text-gray-400 font-bold'}`}>{s.label}</span>\n                          <span className=\"text-[10px] text-gray-400 font-medium\">{s.desc}</span>\n                       </div>\n                    </div>\n                 </label>\n              ))}\n           </div>\n        </div>\n\n        <div className=\"flex items-center justify-end gap-3 mt-2\">\n           <button onClick={onClose} className=\"px-5 py-2.5 text-sm font-black text-gray-400 hover:text-gray-600\">Hủy</button>\n           <button \n             onClick={handleSave}\n             disabled={isSaving}\n             className=\"px-8 py-2.5 bg-indigo-600 text-white font-black rounded-2xl shadow-lg shadow-indigo-600/20 hover:bg-indigo-700 transition-all text-sm flex items-center gap-2 uppercase tracking-widest disabled:opacity-50\"\n           >\n              {isSaving ? <div className=\"w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin\" /> : <Save className=\"w-4 h-4\" />} \n              {isSaving ? (item ? 'Đang lưu...' : 'Đang thêm...') : (item ? 'Lưu thay đổi' : 'Thêm mới')}\n           </button>\n        </div>\n      </div>\n    </Modal>\n  );\n};\n\n/* 3. Region Modal */\nexport const RegionModal = ({ isOpen, onClose, item, onSave }: { isOpen: boolean, onClose: () => void, item?: City | null, onSave: (data: Partial<City>) => Promise<void> }) => {\n  const [formData, setFormData] = React.useState({\n    name: '',\n    code: ''\n  });\n  const [touched, setTouched] = React.useState(false);\n  const [isSaving, setIsSaving] = React.useState(false);\n\n  React.useEffect(() => {\n    if (item) {\n      setFormData({\n        name: item.name,\n        code: item.code || ''\n      });\n    } else {\n      setFormData({ name: '', code: '' });\n    }\n  }, [item, isOpen]);\n\n  const errors = {\n    name: touched && !formData.name.trim() ? 'Tên khu vực không được để trống' : '',\n    code: touched && !formData.code.trim() ? 'Mã khu vực không được để trống' : '',\n  };\n\n  const handleSave = async () => {\n    setTouched(true);\n    if (errors.name || errors.code) return;\n    setIsSaving(true);\n    try {\n      await onSave(formData);\n      onClose();\n    } finally {\n      setIsSaving(false);\n    }\n  };\n\n  return (\n    <Modal isOpen={isOpen} onClose={onClose} title={item ? 'Sửa khu vực' : 'Thêm khu vực mới'} icon={MapPin}>\n      <div className=\"flex flex-col gap-5\">\n         <div className=\"flex flex-col gap-1.5\">\n            <label className=\"text-[10px] font-black text-gray-400 uppercase tracking-widest\">MÃ KHU VỰC *</label>\n            <input \n              type=\"text\" \n              placeholder=\"VD: NT, OT, BN...\" \n              value={formData.code}\n              onChange={(e) => setFormData({...formData, code: e.target.value.toUpperCase()})}\n              className={`w-full px-4 py-2.5 bg-gray-50 border rounded-xl focus:outline-none focus:ring-2 transition-all text-sm font-black ${\n                errors.code ? 'border-rose-500 focus:ring-rose-500/20' : 'border-gray-200 focus:ring-indigo-500/20'\n              }`} \n            />\n            {errors.code && <span className=\"text-[10px] font-bold text-rose-500 pl-1\">{errors.code}</span>}\n         </div>\n         <div className=\"flex flex-col gap-1.5\">\n            <label className=\"text-[10px] font-black text-gray-400 uppercase tracking-widest\">TÊN KHU VỰC *</label>\n            <input \n              type=\"text\" \n              placeholder=\"VD: Nội thành, Ngoại thành...\" \n              value={formData.name}\n              onChange={(e) => setFormData({...formData, name: e.target.value})}\n              className={`w-full px-4 py-2.5 bg-gray-50 border rounded-xl focus:outline-none focus:ring-2 transition-all text-sm font-black ${\n                errors.name ? 'border-rose-500 focus:ring-rose-500/20' : 'border-gray-200 focus:ring-indigo-500/20'\n              }`} \n            />\n            {errors.name && <span className=\"text-[10px] font-bold text-rose-500 pl-1\">{errors.name}</span>}\n         </div>\n         <div className=\"flex items-center justify-end gap-3 mt-2\">\n             <button onClick={onClose} className=\"px-5 py-2.5 text-sm font-black text-gray-400 hover:text-gray-600\">Hủy</button>\n             <button \n               onClick={handleSave}\n               disabled={isSaving}\n               className=\"px-8 py-2.5 bg-indigo-600 text-white font-black rounded-2xl shadow-lg shadow-indigo-600/20 hover:bg-indigo-700 transition-all text-sm flex items-center gap-2 uppercase tracking-widest disabled:opacity-50\"\n             >\n                {isSaving ? <div className=\"w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin\" /> : <Save className=\"w-4 h-4\" />}\n                {isSaving ? 'Đang lưu...' : 'Lưu'}\n             </button>\n          </div>\n      </div>\n    </Modal>\n  );\n};\n\n/* 4. Fee Batch Modal */\nexport const FeeBatchModal = ({ isOpen, onClose, onSave }: { isOpen: boolean, onClose: () => void, onSave: (name: string) => Promise<void> }) => {\n  const [name, setName] = React.useState('');\n  const [touched, setTouched] = React.useState(false);\n  const [isSaving, setIsSaving] = React.useState(false);\n\n  React.useEffect(() => {\n    if (isOpen) setName('');\n  }, [isOpen]);\n\n  const error = touched && !name.trim() ? 'Tên giai đoạn không được để trống' : '';\n\n  const handleSave = async () => {\n    setTouched(true);\n    if (error || !name.trim()) return;\n    setIsSaving(true);\n    try {\n      await onSave(name);\n      onClose();\n    } finally {\n      setIsSaving(false);\n    }\n  };\n\n  return (\n    <Modal isOpen={isOpen} onClose={onClose} title=\"Thêm giai đoạn thu học phí\" icon={Banknote}>\n      <div className=\"flex flex-col gap-5\">\n         <div className=\"flex flex-col gap-1.5\">\n            <label className=\"text-[10px] font-black text-gray-400 uppercase tracking-widest\">TÊN GIAI ĐOẠN / ĐỢT THU *</label>\n            <input \n              type=\"text\" \n              placeholder=\"VD: Đợt 1 - Hồ sơ, Đợt 2 - Thực hành...\" \n              value={name}\n              onChange={(e) => setName(e.target.value)}\n              className={`w-full px-4 py-2.5 bg-gray-50 border rounded-xl focus:outline-none focus:ring-2 transition-all text-sm font-black ${\n                error ? 'border-rose-500 focus:ring-rose-500/20' : 'border-gray-200 focus:ring-indigo-500/20'\n              }`} \n            />\n            {error && <span className=\"text-[10px] font-bold text-rose-500 pl-1\">{error}</span>}\n         </div>\n         <div className=\"flex items-center justify-end gap-3 mt-2\">\n             <button onClick={onClose} className=\"px-5 py-2.5 text-sm font-black text-gray-400 hover:text-gray-600\">Hủy</button>\n             <button \n               onClick={handleSave}\n               disabled={isSaving}\n               className=\"px-8 py-2.5 bg-indigo-600 text-white font-black rounded-2xl shadow-lg shadow-indigo-600/20 hover:bg-indigo-700 transition-all text-sm flex items-center gap-2 uppercase tracking-widest disabled:opacity-50\"\n             >\n                {isSaving ? <div className=\"w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin\" /> : <Save className=\"w-4 h-4\" />}\n                {isSaving ? 'Đang lưu...' : 'Lưu giai đoạn'}\n             </button>\n          </div>\n      </div>\n    </Modal>\n  );\n};\n\n/* 5. Clinic Management Modal (Add/Edit) */\nexport const ClinicModal = ({ isOpen, onClose, item, onSave }: { isOpen: boolean, onClose: () => void, item?: ClinicType | null, onSave: (data: ClinicType) => Promise<void> }) => {\n  const [formData, setFormData] = React.useState({\n    name: '',\n    address: '',\n    phone: '',\n    price: '0'\n  });\n  const [touched, setTouched] = React.useState(false);\n  const [isSaving, setIsSaving] = React.useState(false);\n\n  React.useEffect(() => {\n    if (item) {\n      setFormData({\n        name: item.name,\n        address: item.address ?? '',\n        phone: item.phone ?? '',\n        price: (item.price ?? '0').replace(/[^0-9]/g, '')\n      });\n    } else {\n      setFormData({ name: '', address: '', phone: '', price: '0' });\n    }\n  }, [item, isOpen]);\n\n  const errors = {\n    name: touched && !formData.name.trim() ? 'Tên phòng khám không được để trống' : '',\n    address: touched && !formData.address.trim() ? 'Địa chỉ không được để trống' : '',\n  };\n\n  const handleSave = async () => {\n    setTouched(true);\n    if (errors.name || errors.address) return;\n\n    setIsSaving(true);\n    try {\n      const formattedPrice = new Intl.NumberFormat('vi-VN').format(Number(formData.price)) + 'đ';\n      await onSave({\n        ...formData,\n        price: formattedPrice\n      });\n      onClose();\n    } finally {\n      setIsSaving(false);\n    }\n  };\n\n  return (\n    <Modal isOpen={isOpen} onClose={onClose} title={item ? 'Sửa thông tin phòng khám' : 'Thêm phòng khám mới'} icon={Activity}>\n      <div className=\"flex flex-col gap-5\">\n         <div className=\"flex flex-col gap-1.5\">\n            <label className=\"text-[10px] font-black text-gray-400 uppercase tracking-widest\">TÊN PHÒNG KHÁM *</label>\n            <input \n              type=\"text\" \n              placeholder=\"VD: Bệnh viện Đa khoa Tâm Anh\" \n              value={formData.name}\n              onChange={(e) => setFormData({...formData, name: e.target.value})}\n              className={`w-full px-4 py-3 bg-gray-50 border rounded-2xl focus:outline-none focus:ring-2 transition-all text-sm font-black ${\n                errors.name ? 'border-rose-500 focus:ring-rose-500/20' : 'border-gray-200 focus:ring-indigo-500/20'\n              }`} \n            />\n            {errors.name && <span className=\"text-[10px] font-bold text-rose-500 pl-1\">{errors.name}</span>}\n         </div>\n\n         <div className=\"flex flex-col gap-1.5\">\n            <label className=\"text-[10px] font-black text-gray-400 uppercase tracking-widest\">ĐỊA CHỈ *</label>\n            <div className=\"relative\">\n               <MapPin className=\"absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400\" />\n               <input \n                 type=\"text\" \n                 placeholder=\"VD: 108 Hoàng Như Tiếp, Bồ Đề, Long Biên...\" \n                 value={formData.address}\n                 onChange={(e) => setFormData({...formData, address: e.target.value})}\n                 className={`w-full pl-11 pr-4 py-3 bg-gray-50 border rounded-2xl focus:outline-none focus:ring-2 transition-all text-sm font-black ${\n                    errors.address ? 'border-rose-500 focus:ring-rose-500/20' : 'border-gray-200 focus:ring-indigo-500/20'\n                 }`} \n               />\n            </div>\n            {errors.address && <span className=\"text-[10px] font-bold text-rose-500 pl-1\">{errors.address}</span>}\n         </div>\n\n         <div className=\"grid grid-cols-2 gap-4\">\n            <div className=\"flex flex-col gap-1.5\">\n               <label className=\"text-[10px] font-black text-gray-400 uppercase tracking-widest\">SỐ ĐIỆN THOẠI</label>\n               <input \n                 type=\"text\" \n                 placeholder=\"024 xxxx xxxx\" \n                 value={formData.phone}\n                 onChange={(e) => setFormData({...formData, phone: e.target.value})}\n                 className=\"w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-2xl focus:outline-none focus:ring-2 focus:ring-indigo-500/20 text-sm font-black\" \n               />\n            </div>\n            <div className=\"flex flex-col gap-1.5\">\n               <label className=\"text-[10px] font-black text-gray-400 uppercase tracking-widest\">GIÁ KHÁM (VNĐ)</label>\n               <input \n                 type=\"number\" \n                 value={formData.price}\n                 onChange={(e) => setFormData({...formData, price: e.target.value})}\n                 className=\"w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-2xl focus:outline-none focus:ring-2 focus:ring-indigo-500/20 text-sm font-black text-emerald-600\" \n               />\n            </div>\n         </div>\n\n         <div className=\"flex items-center justify-end gap-3 mt-4\">\n            <button onClick={onClose} className=\"px-5 py-2.5 text-sm font-black text-gray-400 hover:text-gray-600\">Hủy</button>\n            <button \n              onClick={handleSave}\n              disabled={isSaving}\n              className=\"px-8 py-2.5 bg-indigo-600 text-white font-black rounded-2xl shadow-lg shadow-indigo-600/20 hover:bg-indigo-700 transition-all text-sm flex items-center gap-2 uppercase tracking-widest disabled:opacity-50\"\n            >\n               {isSaving ? <div className=\"w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin\" /> : <Save className=\"w-4 h-4\" />} \n               {isSaving ? 'Đang lưu...' : 'Xác nhận'}\n            </button>\n         </div>\n      </div>\n    </Modal>\n  );\n};\n\n/* 6. Exam Center Modal (Add/Edit) */\nexport const ExamCenterModal = ({ isOpen, onClose, item, onSave, regions = [] }: { isOpen: boolean, onClose: () => void, item?: Stadium | null, onSave: (data: Stadium) => Promise<void>, regions?: City[] }) => {\n  const [formData, setFormData] = React.useState({\n    name: '',\n    locate: '',\n    address: '', // Keep for sync\n    mapsLink: '',\n    city: '',\n    region_id: '',\n    note: ''\n  });\n  const [touched, setTouched] = React.useState(false);\n  const [isSaving, setIsSaving] = React.useState(false);\n\n  React.useEffect(() => {\n    if (item) {\n      setFormData({\n        name: item.name,\n        locate: item.locate || (item as any).address || '',\n        address: item.locate || (item as any).address || '',\n        mapsLink: item.mapsLink || '',\n        city: item.city || '',\n        region_id: typeof item.region_id === 'string' ? item.region_id : (item.region_id as any)?._id || '',\n        note: item.note || ''\n      });\n    } else {\n      setFormData({ name: '', locate: '', address: '', mapsLink: '', city: '', region_id: '', note: '' });\n    }\n  }, [item, isOpen]);\n\n  const errors = {\n    name: touched && !formData.name.trim() ? 'Tên trung tâm không được để trống' : '',\n    city: touched && !formData.city ? 'Vui lòng chọn khu vực/tỉnh thành' : ''\n  };\n\n  const handleSave = async () => {\n    setTouched(true);\n    if (errors.name || errors.city) return;\n\n    setIsSaving(true);\n    try {\n      await onSave({\n        ...formData,\n        address: formData.locate || formData.address // Ensure address is populated for UI\n      } as Stadium);\n      onClose();\n    } finally {\n      setIsSaving(false);\n    }\n  };\n\n  return (\n    <Modal isOpen={isOpen} onClose={onClose} title={item ? 'Sửa sân thi' : 'Thêm sân / trung tâm sát hạch'} icon={MapPin}>\n      <div className=\"flex flex-col gap-5\">\n         <p className=\"text-[11px] text-gray-400 font-medium px-1 leading-relaxed italic pr-4\">\n           Khai báo một lần trong danh sách; khi tạo đợt thi chỉ cần chọn sân.\n         </p>\n         \n         <div className=\"flex flex-col gap-1.5\">\n            <label className=\"text-[10px] font-black text-gray-400 uppercase tracking-widest\">TỈNH THÀNH / KHU VỰC *</label>\n            <select \n              value={formData.region_id}\n              onChange={(e) => {\n                const reg = regions.find(r => r._id === e.target.value);\n                setFormData({\n                  ...formData, \n                  region_id: e.target.value,\n                  city: reg ? reg.name : ''\n                });\n              }}\n              className={`w-full px-4 py-2.5 bg-gray-50 border rounded-xl focus:outline-none focus:ring-2 transition-all text-sm font-black ${\n                errors.city ? 'border-rose-500 focus:ring-rose-500/20' : 'border-gray-200 focus:ring-indigo-500/20'\n              }`}\n            >\n               <option value=\"\">Chọn khu vực...</option>\n               {regions.map(r => (\n                 <option key={r._id} value={r._id}>{r.name}</option>\n               ))}\n            </select>\n            {errors.city && <span className=\"text-[10px] font-bold text-rose-500 pl-1\">{errors.city}</span>}\n         </div>\n\n         <div className=\"flex flex-col gap-1.5\">\n            <label className=\"text-[10px] font-black text-gray-400 uppercase tracking-widest\">TÊN TRUNG TÂM / SÂN *</label>\n            <input \n              type=\"text\" \n              placeholder=\"VD: TT Sát hạch lái xe Bình Minh\" \n              value={formData.name}\n              onChange={(e) => setFormData({...formData, name: e.target.value})}\n              className={`w-full px-4 py-2.5 bg-gray-50 border rounded-xl focus:outline-none focus:ring-2 transition-all text-sm font-black ${\n                errors.name ? 'border-rose-500 focus:ring-rose-500/20' : 'border-gray-200 focus:ring-indigo-500/20'\n              }`} \n            />\n            {errors.name && <span className=\"text-[10px] font-bold text-rose-500 pl-1\">{errors.name}</span>}\n         </div>\n         <div className=\"flex flex-col gap-1.5\">\n            <label className=\"text-[10px] font-black text-gray-400 uppercase tracking-widest\">GHI CHÚ / MÔ TẢ</label>\n            <input \n              type=\"text\" \n              placeholder=\"Ghi chú thêm về sân thi...\" \n              value={formData.note}\n              onChange={(e) => setFormData({...formData, note: e.target.value})}\n              className=\"w-full px-4 py-2.5 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500/20 text-xs font-bold\" \n            />\n         </div>\n         <div className=\"flex flex-col gap-1.5\">\n            <label className=\"text-[10px] font-black text-gray-400 uppercase tracking-widest\">LINK GOOGLE MAPS <span className=\"text-gray-300\">(TÙY CHỌN)</span></label>\n            <input \n              type=\"text\" \n              placeholder=\"Dán link Chia sẻ từ Google Maps\" \n              value={formData.mapsLink}\n              onChange={(e) => setFormData({...formData, mapsLink: e.target.value})}\n              className=\"w-full px-4 py-2.5 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500/20 text-xs font-bold\" \n            />\n         </div>\n         <div className=\"flex flex-col gap-1.5\">\n            <label className=\"text-[10px] font-black text-gray-400 uppercase tracking-widest\">ĐỊA CHỈ CHI TIẾT</label>\n            <textarea \n              placeholder=\"Số nhà, đường...\" \n              rows={3} \n              value={formData.locate}\n              onChange={(e) => setFormData({...formData, locate: e.target.value})}\n              className=\"w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-2xl focus:outline-none focus:ring-2 focus:ring-indigo-500/20 text-xs font-bold resize-none\" \n            />\n         </div>\n         <div className=\"flex items-center justify-end gap-3 mt-2\">\n             <button onClick={onClose} className=\"px-5 py-2.5 text-sm font-black text-gray-400 hover:text-gray-600\">Hủy</button>\n             <button \n               onClick={handleSave}\n               disabled={isSaving}\n               className=\"px-8 py-2.5 bg-indigo-600 text-white font-black rounded-2xl shadow-lg shadow-indigo-600/20 hover:bg-indigo-700 transition-all text-sm flex items-center gap-2 uppercase tracking-widest disabled:opacity-50\"\n             >\n                {isSaving ? <div className=\"w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin\" /> : <Save className=\"w-4 h-4\" />}\n                {isSaving ? 'Đang lưu...' : (item ? 'Lưu thay đổi' : 'Thêm sân thi')}\n             </button>\n          </div>\n      </div>\n    </Modal>\n  );\n};\n"}],"isError":false,"timestamp":1776054501535}}
