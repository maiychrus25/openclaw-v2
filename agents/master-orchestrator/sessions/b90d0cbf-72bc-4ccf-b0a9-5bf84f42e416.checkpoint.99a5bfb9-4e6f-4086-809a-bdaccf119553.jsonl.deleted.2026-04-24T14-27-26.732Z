com\",\n      \"committed_date\": \"2026-03-23T03:13:37.000+00:00\",\n      \"trailers\": {},\n      \"extended_trailers\": {},\n      \"web_url\": \"https://gitlab.com/ahv-dtlx/ahv-dtlx-backend/-/commit/3fce0dddbd624fb605fc812b878a3e1ee5dee28d\"\n    },\n    \"merged\": false,\n    \"protected\": true,\n    \"developers_can_push\": false,\n    \"developers_can_merge\": false,\n    \"can_push\": false,\n    \"default\": false,\n    \"web_url\": \"https://gitlab.com/ahv-dtlx/ahv-dtlx-backend/-/tree/production\"\n  },\n  {\n    \"name\": \"refactor/antigravity\",\n    \"commit\": {\n      \"id\": \"82e115a3fc2d949a15355514408efbf621affd9d\",\n      \"short_id\": \"82e115a3\",\n      \"created_at\": \"2026-03-02T17:07:23.000+07:00\",\n      \"parent_ids\": [\n        \"cbaaf97ce98837b1f3042a77e7719874faf7e38b\"\n      ],\n      \"title\": \"fix: resolve model overwrite errors, standardize mongoose imports, and fix startup order\",\n      \"message\": \"fix: resolve model overwrite errors, standardize mongoose imports, and fix startup order\\n\",\n      \"author_name\": \"hieupm\",\n      \"author_email\": \"hieupm.98.tn@gmail.com\",\n      \"authored_date\": \"2026-03-02T17:07:23.000+07:00\",\n      \"committer_name\": \"hieupm\",\n      \"committer_email\": \"hieupm.98.tn@gmail.com\",\n      \"committed_date\": \"2026-03-02T17:07:23.000+07:00\",\n      \"trailers\": {},\n      \"extended_trailers\": {},\n      \"web_url\": \"https://gitlab.com/ahv-dtlx/ahv-dtlx-backend/-/commit/82e115a3fc2d949a15355514408efbf621affd9d\"\n    },\n    \"merged\": false,\n    \"protected\": false,\n    \"developers_can_push\": false,\n    \"developers_can_merge\": false,\n    \"can_push\": true,\n    \"default\": false,\n    \"web_url\": \"https://gitlab.com/ahv-dtlx/ahv-dtlx-backend/-/tree/refactor/antigravity\"\n  },\n  {\n    \"name\": \"refactor/code-cleanup-phase-2\",\n    \"commit\": {\n      \"id\": \"7c29ccd70361826701c056b395e4f6183d86e503\",\n      \"short_id\": \"7c29ccd7\",\n      \"created_at\": \"2026-03-09T14:48:26.000+07:00\",\n      \"parent_ids\": [\n        \"1b5c4e12f486d639d89ead0bc33208c4c617b116\"\n      ],\n      \"title\": \"refactor: standardize Vehicles and WorkCalendars modules with unified architecture\\\" -m \\\"Comprehensive update across two core modules to implement clean code standards:\",\n      \"message\": \"refactor: standardize Vehicles and WorkCalendars modules with unified architecture\\\" -m \\\"Comprehensive update across two core modules to implement clean code standards:\\n\\n- Architecture: Replaced manual try-catch blocks with catchAsync middleware and standardized API outputs using responseHandler.\\n- Services: Refactored Vehicles and WorkCalendars logic with optimized MongoDB queries ($or logic, .populate(), and .reduce() for time aggregation).\\n- Validation: Implemented localized Joi validation messages (Vietnamese) and strict schema constraints.\\n- Models: Updated Mongoose schemas with auto-transform logic, specialized indexing for performance, and audit logging.\\n- Consistency: Unified method naming and established clear JSON request/response patterns for frontend integration.\\n\",\n      \"author_name\": \"Ninh Thanh Khuong\",\n      \"author_email\": \"ninhem575@gmail.com\",\n      \"authored_date\": \"2026-03-09T14:48:26.000+07:00\",\n      \"committer_name\": \"Ninh Thanh Khuong\",\n      \"committer_email\": \"ninhem575@gmail.com\",\n      \"committed_date\": \"2026-03-09T14:48:26.000+07:00\",\n      \"trailers\": {},\n      \"extended_trailers\": {},\n      \"web_url\": \"https://gitlab.com/ahv-dtlx/ahv-dtlx-backend/-/commit/7c29ccd70361826701c056b395e4f6183d86e503\"\n    },\n    \"merged\": true,\n    \"protected\": false,\n    \"developers_can_push\": false,\n    \"developers_can_merge\": false,\n    \"can_push\": true,\n    \"default\": false,\n    \"web_url\": \"https://gitlab.com/ahv-dtlx/ahv-dtlx-backend/-/tree/refactor/code-cleanup-phase-2\"\n  },\n  {\n    \"name\": \"refactor/m