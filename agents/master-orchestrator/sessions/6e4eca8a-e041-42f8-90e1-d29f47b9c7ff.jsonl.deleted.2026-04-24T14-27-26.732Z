inking","thinking":"Duplicate heartbeat. Nothing needs attention."},{"type":"text","text":"HEARTBEAT_OK"}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":288,"output":16,"totalTokens":96101,"cacheRead":7778,"cacheWrite":88019,"cost":{"total":0}},"stopReason":"stop","timestamp":1776178669339,"responseId":"062d88ef92ab7e1dc4aa888a6bf1609a","__openclaw":{"id":"475eee34","seq":1143}}]},{"key":"agent:master-orchestrator:cron:b653a6c0-143b-4b53-a242-034bc5fd9fca","kind":"other","channel":"unknown","label":"Cron: Orbis QLHV Report 11:53 UTC","displayName":"Cron: Orbis QLHV Report 11:53 UTC","updatedAt":1776167853466,"sessionId":"2f8d61ea-217f-4a52-8c6b-32e142e69caf","model":"AHV-Holding-DEV","contextTokens":200000,"systemSent":true,"transcriptPath":"/root/.openclaw/agents/master-orchestrator/sessions/2f8d61ea-217f-4a52-8c6b-32e142e69caf.jsonl","messages":[]},{"key":"agent:master-orchestrator:cron:ac986a8d-2425-40c7-835b-ed9b101b0bff","kind":"other","channel":"unknown","label":"Cron: Send this exact message to Telegram group -5163901258:","displayName":"Cron: Send this exact message to Telegram group -5163901258:","updatedAt":1776156272410,"sessionId":"d6d5ae17-2a68-46a3-beb9-a2a98cf2f1b5","model":"AHV-Holding-DEV","contextTokens":200000,"totalTokens":15116,"estimatedCostUsd":0,"status":"running","startedAt":1776156271891,"systemSent":true,"abortedLastRun":false,"transcriptPath":"/root/.openclaw/agents/master-orchestrator/sessions/d6d5ae17-2a68-46a3-beb9-a2a98cf2f1b5.jsonl","messages":[{"role":"assistant","content":[{"type":"thinking","thinking":"The OpenClaw CLI commands seem to be aborted. Let me try with sessions_send directly to the Telegram session."},{"type":"toolCall","id":"call_function_6p6s89cpkzn1_1","name":"sessions_list","arguments":{"limit":20,"activeMinutes":60,"messageLimit":1}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":123,"output":72,"totalTokens":15188,"cach