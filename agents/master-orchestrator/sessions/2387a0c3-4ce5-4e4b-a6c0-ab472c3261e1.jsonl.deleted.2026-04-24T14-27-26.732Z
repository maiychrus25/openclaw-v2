a\":{\"runtime\":\"node\",\"runtimeVersion\":\"22.22.2\",\"hostname\":\"unknown\",\"name\":\"{\\\"subsystem\\\":\\\"gateway\\\"}\",\"parentNames\":[\"openclaw\"],\"date\":\"2026-04-22T04:35:42.375Z\",\"logLevelId\":3,\"logLevelName\":\"INFO\",\"path\":{\"fullFilePath\":\"file:///usr/lib/node_modules/openclaw/dist/subsystem-C1arrdPy.js:328:14\",\"fileName\":\"subsystem-C1arrdPy.js\",\"fileNameWithLine\":\"subsystem-C1arrdPy.js:328\",\"fileColumn\":\"14\",\"fileLine\":\"328\",\"filePath\":\"/usr/lib/node_modules/openclaw/dist/subsystem-C1arrdPy.js\",\"filePathWithLine\":\"/usr/lib/node_modules/openclaw/dist/subsystem-C1arrdPy.js:328\",\"method\":\"logToFile\"}},\"time\":\"2026-04-22T04:35:42.375+00:00\"}\n{\"0\":\"{\\\"subsystem\\\":\\\"gateway\\\"}\",\"1\":\"MCP loopback server listening on http://127.0.0.1:35325/mcp\",\"_meta\":{\"runtime\":\"node\",\"runtimeVersion\":\"22.22.2\",\"hostname\":\"unknown\",\"name\":\"{\\\"subsystem\\\":\\\"gateway\\\"}\",\"parentNames\":[\"openclaw\"],\"date\":\"2026-04-22T04:38:15.768Z\",\"logLevelId\":3,\"logLevelName\":\"INFO\",\"path\":{\"fullFilePath\":\"file:///usr/lib/node_modules/openclaw/dist/subsystem-C1arrdPy.js:328:14\",\"fileName\":\"subsystem-C1arrdPy.js\",\"fileNameWithLine\":\"subsystem-C1arrdPy.js:328\",\"fileColumn\":\"14\",\"fileLine\":\"328\",\"filePath\":\"usr/lib/node_modules/openclaw/dist/subsystem-C1arrdPy.js\",\"filePathWithLine\":\"usr/lib/node_modules/openclaw/dist/subsystem-C1arrdPy.js:328\",\"method\":\"logToFile\"}},\"time\":\"2026-04-22T04:38:15.769+00:00\"}\n{\"0\":\"{\\\"subsystem\\\":\\\"gateway\\\"}\",\"1\":\"MCP loopback server listening on http://127.0.0.1:39253/mcp\",\"_meta\":{\"runtime\":\"node\",\"runtimeVersion\":\"22.22.2\",\"hostname\":\"unknown\",\"name\":\"{\\\"subsystem\\\":\\\"gateway\\\"}\",\"parentNames\":[\"openclaw\"],\"date\":\"2026-04-22T04:38:28.344Z\",\"logLevelId\":3,\"logLevelName\":\"INFO\",\"path\":{\"fullFilePath\":\"file:///usr/lib/node_modules/openclaw/dist/subsystem-C1arr