{"type":"message","id":"4596164e","parentId":"a6d2e8d5","timestamp":"2026-04-22T05:17:15.487Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Let me create the data models documentation.","thinkingSignature":"c2897df02e0b5d185ba90ab15226571c04bebaf1d7a81a6543683e38344017fb"},{"type":"toolCall","id":"call_function_oe77cp831mfc_1","name":"write","arguments":{"path":"/tmp/ahvteacher-docs/4-DATA-MODELS.md","content":"---\nconfluence:\n  id: \"130744323\"\ntitle: 4. Data Models\n---\n\nh1. 4. Data Models\n\n{toc:printable=true|style=disc|maxLevel=2}\n\nh1. 1. User Model\n\n{panel:title=Collection: users}\nMongoDB Document Schema\n{panel}\n\nh2. 1.1 Fields\n\n||Field||Type||Required||Description||\n|_id|ObjectId|Yes|Auto-generated ID|\n|username|string|Yes|Unique, lowercase|\n|first_name|string|Yes|First name|\n|last_name|string|Yes|Last name|\n|email|string|Yes|Unique, lowercase|\n|phone|string|Yes|Phone number|\n|gender|enum|Yes|male, female, another|\n|dob|Date|No|Date of birth|\n|address|string|Yes|Full address|\n|identity_card|string|Yes|CCCD 12 digits|\n|status|enum|Yes|active, inactive, deleted|\n|password|string|Yes|Hashed password|\n|role|string|Yes|User role|\n|refresh_token|string|No|JWT refresh token|\n|image|string|No|Avatar URL|\n|bio|string|No|Biography|\n|zalo_user_id|string|No|Zalo ID|\n|fcm_token|string|No|Firebase token|\n|created_at|Date|Auto|Timestamp|\n|updated_at|Date|Auto|Timestamp|\n\nh2. 1.2 Indexes\n\n{code}\nusername: unique\nemail: unique\nphone: index\nidentity_card: index\ncreated_at: index (descending)\nSearchIndex: text(first_name, last_name, phone, identity_card)\n{code}\n\nh1. 2. Course Model\n\n{panel:title=Collection: courses}\nMongoDB Document Schema\n{panel}\n\nh2. 2.1 Fields\n\n||Field||Type||Required||Description||\n|_id|ObjectId|Yes|Auto-generated ID|\n|title|string|Yes|Course name|\n|description|string|No|Course description|\n|duration|number|Yes|Total hours|\n|price|number|Yes|Tuition fee (VND)|\n|status|enum|Yes|active, inactive, draft|\n|teacher_id|ObjectId|Yes|Assigned teacher|\n|lessons|array|No|List of lessons|\n|requirements|string|No|Entry requirements|\n|max_students|number|No|Max enrollment|\n|enrolled_count|number|Auto|Current enrollment|\n|created_at|Date|Auto|Timestamp|\n|updated_at|Date|Auto|Timestamp|\n\nh2. 2.2 Lesson Subdocument\n\n||Field||Type||Description||\n|title|string|Lesson name|\n|content|string|Lesson content|\n|order|number|Sequence|\n|duration|number|Hours|\n|type|enum|theory, practice, exam|\n\nh1. 3. Student Model\n\n{panel:title=Collection: students}\nExtended user profile\n{panel}\n\nh2. 3.1 Fields\n\n||Field||Type||Required||Description||\n|user_id|ObjectId|Yes|Reference to users|\n|enrolled_courses|array|No|List of enrollments|\n|progress|object|No|Course progress tracking|\n|completed_courses|array|No|List of completed course IDs|\n|failed_exams|array|No|Failed exam attempts|\n|balance|number|No|Account balance|\n|emergency_contact|string|No|Emergency contact|\n|created_at|Date|Auto|Timestamp|\n\nh1. 4. ExamSchedule Model\n\n{panel:title=Collection: exam_schedules}\nMongoDB Document Schema\n{panel}\n\nh2. 4.1 Fields\n\n||Field||Type||Required||Description||\n|_id|ObjectId|Yes|Auto-generated ID|\n|course_id|ObjectId|Yes|Related course|\n|exam_date|datetime|Yes|Exam date/time|\n|duration|number|Yes|Minutes|\n|location|string|Yes|Exam venue|\n|stadium_id|ObjectId|No|Exam stadium|\n|max_students|number|Yes|Max participants|\n|enrolled_students|array|No|Registered students|\n|status|enum|Yes|scheduled, in_progress, completed, cancelled|\n|result_published|boolean|No|Published flag|\n|created_by|ObjectId|Yes|Admin who created|\n|created_at|Date|Auto|Timestamp|\n\nh1. 5. Payment Model\n\n{panel:title=Collection: payments}\nMongoDB Document Schema\n{panel}\n\nh2. 5.1 Fields\n\n||Field||Type||Required||Description||\n|_id|ObjectId|Yes|Auto-generated ID|\n|student_id|ObjectId|Yes|Student reference|\n|course_id|ObjectId|No|Course (for tuition)|\n|amount|number|Yes|Amount (VND)|\n|type|enum|Yes|tuition, exam_fee, certificate, other|\n|method|enum|Yes|cash, bank_transfer, zalopay, momo|\n|status|enum|Yes|pending, completed, failed, refunded|\n|transaction_id|string|No|External transaction|\n|paid_at|Date|No|Payment timestamp|\n|notes|string|No|Additional notes|\n|created_by|ObjectId|Yes|Processed by|\n|created_at|Date|Auto|Timestamp|\n\nh1. 6. Notification Model\n\n{panel:title=Collection: notifications}\nMongoDB Document Schema\n{panel}\n\nh2. 6.1 Fields\n\n||Field||Type||Required||Description||\n|_id|ObjectId|Yes|Auto-generated ID|\n|user_id|ObjectId|Yes|Recipient|\n|title|string|Yes|Notification title|\n|message|string|Yes|Notification content|\n|type|enum|Yes|exam, payment, course, system, announcement|\n|is_read|boolean|No|Read status|\n|data|object|No|Additional payload|\n|created_at|Date|Auto|Timestamp|\n\nh1. 7. SupportRequest Model\n\n{panel:title=Collection: support_requests}\nMongoDB Document Schema\n{panel}\n\nh2. 7.1 Fields\n\n||Field||Type||Required||Description||\n|_id|ObjectId|Yes|Auto-generated ID|\n|student_id|ObjectId|Yes|Requester|\n|subject|string|Yes|Request subject|\n|description|string|Yes|Detailed description|\n|priority|enum|Yes|low, medium, high, urgent|\n|status|enum|Yes|open, in_progress, resolved, closed|\n|assigned_to|ObjectId|No|Assigned staff|\n|responses|array|No|Conversation history|\n|created_at|Date|Auto|Timestamp|\n|updated_at|Date|Auto|Timestamp|\n\nh1. 8. Enum Values\n\nh2. 8.1 UserGender\n\n{code}\nmale, female, another\n{code}\n\nh2. 8.2 UserStatus\n\n{code}\nactive, inactive, deleted\n{code}\n\nh2. 8.3 UserRole\n\n{code}\nsuperadmin, admin, staff, teacher, student\n{code}\n\nh2. 8.4 PaymentType\n\n{code}\ntuition, exam_fee, certificate, other\n{code}\n\nh2. 8.5 PaymentMethod\n\n{code}\ncash, bank_transfer, zalopay, momo\n{code}\n\nh2. 8.6 SupportPriority\n\n{code}\nlow, medium, high, urgent\n{code}\n\nh2. 8.7 SupportStatus\n\n{code}\nopen, in_progress, resolved, closed\n{code}\n\n----\n_Last updated: {date}_\n"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":93,"output":1606,"cacheRead":114020,"cacheWrite":2207,"totalTokens":117926,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776835010725,"responseId":"06378cc4430ed91663d2b2a8cb1bc1e5"}}
