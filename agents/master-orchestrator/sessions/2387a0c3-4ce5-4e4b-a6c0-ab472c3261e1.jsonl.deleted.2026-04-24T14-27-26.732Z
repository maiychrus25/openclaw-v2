{"type":"message","id":"2d25bc0d","parentId":"7780f009","timestamp":"2026-04-22T04:41:14.723Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"The MCP server keeps restarting (new ports each time). This means the confluence MCP server is crashing and restarting. The issue might be that the server.js is using ES modules but the package.json might not have \"type\": \"module\".\n\nLet me check the MCP server more carefully and maybe restart it properly.","thinkingSignature":"1b41f05cbc55d5ff5242bb0430cc2dbdf59e01dc52ae803856341a3fab1247ea"},{"type":"toolCall","id":"call_function_a57fxnripedz_1","name":"exec","arguments":{"command":"cat /root/.openclaw/mcp-servers/confluence/package.json"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":3539,"output":100,"cacheRead":70209,"cacheWrite":155,"totalTokens":74003,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776832867883,"responseId":"063784652460e731306633ddaa8356b9"}}
