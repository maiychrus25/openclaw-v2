{"type":"message","id":"424ab9b9","parentId":"a9d5486d","timestamp":"2026-04-22T04:49:04.400Z","message":{"role":"toolResult","toolCallId":"call_function_lt276y6nin1y_1","toolName":"exec","content":[{"type":"text","text":"import mongoose, { Schema, Document } from 'mongoose';\n\nexport enum UserGender {\n  Male = 'male',\n  Female = 'female',\n  Another = 'another',\n}\n\nexport enum UserStatus {\n  Active = 'active',\n  InActive = 'inactive',\n  Deleted = 'deleted',\n}\n\nexport enum UserRole {\n  Admin = 'admin',\n  SuperAdmin = 'superadmin',\n  Staff = 'staff',\n  Teacher = 'teacher',\n  Student = 'student',\n}\n\nexport interface IUser extends Document {\n  username: string;\n  first_name: string;\n  last_name: string;\n  email: string;\n  phone: string;\n  image?: string;\n  bio?: string;\n  gender: UserGender;\n  dob?: Date;\n  address: string;\n  identity_card: string;\n  status: UserStatus;\n  // NOTE: 'role' is removed — use UserRoleModel (userroles collection) instead\n  password: string;\n  refresh_token?: string;\n  existing_license_num?: string;\n  existing_license_rank?: string;\n  zalo_user_id?: string;\n  fcm_token?: string;\n  created_at: Date;\n  updated_at: Date;\n}\n\nconst UserSchema = new Schema<IUser>(\n  {\n    username: { type: String, required: true, unique: true, lowercase: true, trim: true },\n    first_name: { type: String, required: true },\n    last_name: { type: String, required: true },\n    email: { type: String, required: true, unique: true, lowercase: true, trim: true },\n    phone: { type: String, required: true },\n    image: { type: String },\n    bio: { type: String },\n    gender: { type: String, enum: Object.values(UserGender), default: UserGender.Male },\n    dob: { type: Date },\n    address: { type: String, required: true },\n    identity_card: {\n      type: String,\n      required: true,\n      validate: {\n        validator: function (v: string) {\n          return /^\\d{12}$/.test(v);\n        },\n        message: (props: any) => `${props.value} không phải là số CCCD hợp lệ (phải có đúng 12 chữ số)!`,\n      },\n    },\n    status: { type: String, enum: Object.values(UserStatus), default: UserStatus.Active },\n    password: { type: String, required: true },\n    refresh_token: { type: String },\n    existing_license_num: { type: String, default: null },\n    existing_license_rank: { type: String, default: null },\n    zalo_user_id: { type: String, default: null },\n    fcm_token: { type: String, default: null },\n  },\n  {\n    timestamps: { createdAt: 'created_at', updatedAt: 'updated_at' },\n    versionKey: false,\n  },\n);\n\nUserSchema.index(\n  {\n    first_name: 'text',\n    last_name: 'text',\n    phone: 'text',\n    identity_card: 'text',\n  },\n  {\n    name: 'SearchIndex',\n    weights: { first_name: 10, last_name: 5, phone: 5, identity_card: 3 },\n  },\n);\nUserSchema.index({ phone: 1 });\nUserSchema.index({ identity_card: 1 });\nUserSchema.index({ created_at: -1 });\n\nexport const UserModel = mongoose.models.Users || mongoose.model<IUser>('Users', UserSchema);"}],"details":{"status":"completed","exitCode":0,"durationMs":12,"aggregated":"import mongoose, { Schema, Document } from 'mongoose';\n\nexport enum UserGender {\n  Male = 'male',\n  Female = 'female',\n  Another = 'another',\n}\n\nexport enum UserStatus {\n  Active = 'active',\n  InActive = 'inactive',\n  Deleted = 'deleted',\n}\n\nexport enum UserRole {\n  Admin = 'admin',\n  SuperAdmin = 'superadmin',\n  Staff = 'staff',\n  Teacher = 'teacher',\n  Student = 'student',\n}\n\nexport interface IUser extends Document {\n  username: string;\n  first_name: string;\n  last_name: string;\n  email: string;\n  phone: string;\n  image?: string;\n  bio?: string;\n  gender: UserGender;\n  dob?: Date;\n  address: string;\n  identity_card: string;\n  status: UserStatus;\n  // NOTE: 'role' is removed — use UserRoleModel (userroles collection) instead\n  password: string;\n  refresh_token?: string;\n  existing_license_num?: string;\n  existing_license_rank?: string;\n  zalo_user_id?: string;\n  fcm_token?: string;\n  created_at: Date;\n  updated_at: Date;\n}\n\nconst UserSchema = new Schema<IUser>(\n  {\n    username: { type: String, required: true, unique: true, lowercase: true, trim: true },\n    first_name: { type: String, required: true },\n    last_name: { type: String, required: true },\n    email: { type: String, required: true, unique: true, lowercase: true, trim: true },\n    phone: { type: String, required: true },\n    image: { type: String },\n    bio: { type: String },\n    gender: { type: String, enum: Object.values(UserGender), default: UserGender.Male },\n    dob: { type: Date },\n    address: { type: String, required: true },\n    identity_card: {\n      type: String,\n      required: true,\n      validate: {\n        validator: function (v: string) {\n          return /^\\d{12}$/.test(v);\n        },\n        message: (props: any) => `${props.value} không phải là số CCCD hợp lệ (phải có đúng 12 chữ số)!`,\n      },\n    },\n    status: { type: String, enum: Object.values(UserStatus), default: UserStatus.Active },\n    password: { type: String, required: true },\n    refresh_token: { type: String },\n    existing_license_num: { type: String, default: null },\n    existing_license_rank: { type: String, default: null },\n    zalo_user_id: { type: String, default: null },\n    fcm_token: { type: String, default: null },\n  },\n  {\n    timestamps: { createdAt: 'created_at', updatedAt: 'updated_at' },\n    versionKey: false,\n  },\n);\n\nUserSchema.index(\n  {\n    first_name: 'text',\n    last_name: 'text',\n    phone: 'text',\n    identity_card: 'text',\n  },\n  {\n    name: 'SearchIndex',\n    weights: { first_name: 10, last_name: 5, phone: 5, identity_card: 3 },\n  },\n);\nUserSchema.index({ phone: 1 });\nUserSchema.index({ identity_card: 1 });\nUserSchema.index({ created_at: -1 });\n\nexport const UserModel = mongoose.models.Users || mongoose.model<IUser>('Users', UserSchema);","cwd":"/root/.openclaw/workspaces2/v4-ecosystem-review/master-orchestrator"},"isError":false,"timestamp":1776833344393}}
