{"type":"message","id":"2c303994","parentId":"b5c872ad","timestamp":"2026-04-23T09:50:27.194Z","message":{"role":"toolResult","toolCallId":"call_5lYhTAOAqYu4mpt6sFxfqeQH","toolName":"read","content":[{"type":"text","text":"import mongoose from 'mongoose';\nimport logger from '@/infrastructure/logging/logger';\nimport './models';\nimport { seedEssentialUsers } from './seeders/user.seeder';\n\nconst DEFAULT_MAX_RETRIES = 5;\nconst DEFAULT_BASE_DELAY_MS = 2000;\nconst DEFAULT_SERVER_SELECTION_TIMEOUT_MS = 5000;\nconst DEFAULT_SOCKET_TIMEOUT_MS = 45000;\n\nconst sleep = (ms: number) => new Promise((resolve) => setTimeout(resolve, ms));\n\nconst connectDB = async () => {\n  const maxRetries = Number(process.env.MONGODB_MAX_RETRIES ?? DEFAULT_MAX_RETRIES);\n  const baseDelayMs = Number(process.env.MONGODB_RETRY_DELAY_MS ?? DEFAULT_BASE_DELAY_MS);\n  const serverSelectionTimeoutMs = Number(\n    process.env.MONGODB_SERVER_SELECTION_TIMEOUT_MS ?? DEFAULT_SERVER_SELECTION_TIMEOUT_MS,\n  );\n  const socketTimeoutMs = Number(process.env.MONGODB_SOCKET_TIMEOUT_MS ?? DEFAULT_SOCKET_TIMEOUT_MS);\n\n  const baseUri = process.env.MONGODB_URI;\n  const dbName = process.env.MONGODB_NAME;\n\n  if (!baseUri || !dbName) {\n    throw new Error('Missing MongoDB configuration: MONGODB_URI and MONGODB_NAME are required');\n  }\n\n  const mongoUri = `${baseUri}/${dbName}`;\n  let lastError: unknown;\n\n  for (let attempt = 1; attempt <= maxRetries; ++attempt) {\n    try {\n      logger.info(`MongoDB connect attempt: ${attempt}/${maxRetries}`);\n\n      await mongoose.connect(mongoUri, {\n        authSource: process.env.MONGODB_AUTH_SOURCE || 'admin',\n        user: process.env.MONGODB_USER,\n        pass: process.env.MONGODB_PASS,\n        serverSelectionTimeoutMS: serverSelectionTimeoutMs,\n        socketTimeoutMS: socketTimeoutMs,\n      });\n\n      logger.info(`MongoDB Connected to database: ${mongoose.connection.name}`);\n\n      // Trigger essential seeding\n      await seedEssentialUsers();\n\n      return mongoose.connection;\n    } catch (err: any) {\n      lastError = err;\n      logger.error(`Connect to MongoDB failed (attempt ${attempt}/${maxRetries})`, err);\n\n      if (attempt >= maxRetries) {\n        break;\n      }\n\n      const delayMs = Math.min(baseDelayMs * 2 ** (attempt - 1), 30000);\n      logger.warn(`Retrying MongoDB connection in ${delayMs}ms...`);\n      await sleep(delayMs);\n    }\n  }\n\n  throw new Error(\n    `Failed to connect to MongoDB after ${maxRetries} attempts: ${\n      lastError instanceof Error ? lastError.message : String(lastError)\n    }`,\n  );\n};\n\nexport default connectDB;\n"}],"isError":false,"timestamp":1776937827188}}
