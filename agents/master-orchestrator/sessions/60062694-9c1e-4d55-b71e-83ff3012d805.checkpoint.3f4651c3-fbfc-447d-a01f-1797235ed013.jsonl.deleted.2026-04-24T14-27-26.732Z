{"type":"message","id":"2fced828","parentId":"9a8b3bd9","timestamp":"2026-04-23T10:46:49.910Z","message":{"role":"toolResult","toolCallId":"call_X5en261HJiTen7cxasx3nRVd","toolName":"read","content":[{"type":"text","text":"                                        className={`w-4 h-4 rounded ${checkColor}`}\n                                      />\n                                      <span\n                                        className={`text-sm font-bold ${isComplete ? 'text-gray-800' : 'text-gray-600'}`}\n                                      >\n                                        {item.label}\n                                      </span>\n                                    </div>\n                                    {isComplete ? (\n                                      <div className=\"flex items-center gap-1.5 text-emerald-600\">\n                                        <CheckCircle2 className=\"w-4 h-4\" />{' '}\n                                        <span className=\"text-[10px] font-bold\">Đã hoàn thành</span>\n                                      </div>\n                                    ) : (\n                                      <span className=\"text-[10px] font-bold text-gray-400\">Chưa học</span>\n                                    )}\n                                  </label>\n                                );\n                              })}\n                            </div>\n\n                            {/* DAT Progress */}\n                            <div\n                              className={`flex flex-col p-4 bg-white border rounded-xl gap-3 transition-colors ${datOk ? 'border-emerald-200' : 'border-gray-200'}`}\n                            >\n                              <div className=\"flex justify-between items-center\">\n                                <div className=\"flex items-center gap-2\">\n                                  <Activity className={`w-4 h-4 ${datOk ? 'text-emerald-500' : 'text-gray-400'}`} />\n                                  <span className=\"font-extrabold text-sm text-gray-800\">\n                                    Học lái đường trường (DAT)\n                                  </span>\n                                </div>\n                                <div className=\"flex items-center gap-3 text-xs\">\n                                  <span\n                                    className={`font-bold border px-2 py-0.5 rounded ${datOk ? 'bg-emerald-50 border-emerald-200 text-emerald-600' : 'bg-gray-50 border-gray-200 text-gray-500'}`}\n                                  >\n                                    {displayDatKm.toFixed(1)} / {requiredKm} km\n                                  </span>\n                                  <button\n                                    onClick={() => setIsDatModalOpen(true)}\n                                    className=\"flex items-center gap-1 text-primary hover:text-indigo-700 font-bold bg-indigo-50 px-2 py-1 rounded transition-colors\"\n                                  >\n                                    <Plus className=\"w-3 h-3\" /> Thêm buổi\n                                  </button>\n                                </div>\n                              </div>\n                              <div className=\"flex flex-col gap-2 mt-1\">\n                                <div className=\"flex items-center gap-3 text-[10px] font-bold text-gray-500\">\n                                  <span className=\"w-16\">Quãng đường</span>\n                                  <div className=\"flex-1 h-1.5 bg-gray-100 rounded-full overflow-hidden\">\n                                    <div\n                                      className=\"h-full bg-blue-500 rounded-full transition-all duration-500\"\n                                      style={{\n                                        width: `${Math.min((datKm / requiredKm) * 100, 100)}%`,\n                                      }}\n                                    ></div>\n                                  </div>\n                                  <span className={`w-16 text-right ${datKm >= requiredKm ? 'text-emerald-600' : ''}`}>\n                                    {displayDatKm.toFixed(1)}/{requiredKm} km\n                                  </span>\n                                </div>\n                                <div className=\"flex items-center gap-3 text-[10px] font-bold text-gray-500\">\n                                  <span className=\"w-16\">Thời gian</span>\n                                  <div className=\"flex-1 h-1.5 bg-gray-100 rounded-full overflow-hidden\">\n                                    <div\n                                      className=\"h-full bg-amber-500 rounded-full transition-all duration-500\"\n                                      style={{\n                                        width: `${Math.min((datMins / 480) * 100, 100)}%`,\n                                      }}\n                                    ></div>\n                                  </div>\n                                  <span className={`w-16 text-right ${datMins >= 480 ? 'text-emerald-600' : ''}`}>\n                                    {Math.round(datMins)} phút/8h\n                                  </span>\n                                </div>\n                              </div>\n                              {!fullData?.dat_stats?.session_count ? (\n                                <div className=\"text-xs text-gray-400 italic mt-1\">Chưa có buổi DAT nào được ghi.</div>\n                              ) : (\n                                <div className=\"flex items-center justify-between mt-1\">\n                                  <div className=\"text-[10px] text-indigo-600 font-bold\">\n                                    Đã ghi nhận {fullData.dat_stats.session_count} buổi học.\n                                  </div>\n                                  {datOk && (\n                                    <div className=\"flex items-center gap-1 text-emerald-600\">\n                                      <CheckCircle2 className=\"w-3.5 h-3.5\" />{' '}\n                                      <span className=\"text-[10px] font-bold\">Đã hoàn thành DAT</span>\n                                    </div>\n                                  )}\n                                </div>\n                              )}\n                            </div>\n\n                            {/* Graduation Exam */}\n                            <div\n                              className={`flex items-center justify-between p-4 border rounded-xl transition-all ${isEligible ? 'bg-emerald-50/50 border-emerald-200' : 'bg-gray-50 border-gray-200'}`}\n                            >\n                              <div className=\"flex flex-col gap-1\">\n                                <div className=\"flex items-center gap-2 text-sm font-extrabold text-gray-800\">\n                                  <GraduationCap\n                                    className={`w-4 h-4 ${isEligible ? 'text-emerald-500' : 'text-gray-400'}`}\n                                  />{' '}\n                                  Thi tốt nghiệp\n                                  {isEligible ? (\n                                    <span className=\"px-2 py-0.5 bg-emerald-100 text-emerald-700 border border-emerald-200 rounded text-[9px] uppercase animate-in zoom-in-95 duration-300\">\n                                      Đủ điều kiện\n                                    </span>\n                                  ) : (\n                                    <span className=\"px-2 py-0.5 bg-rose-50 text-rose-600 border border-rose-200 rounded text-[9px] uppercase\">\n                                      Chưa đủ ĐK\n                                    </span>\n                                  )}\n                                </div>\n                                <span className=\"text-[11px] text-gray-500 font-medium pl-6\">\n                                  {isEligible\n                                    ? 'Học viên đã hoàn thành các điều kiện để thi tốt nghiệp.'\n                                    : 'Hoàn thành học thực hành và DAT để đủ ĐK thi.'}\n                                </span>\n                              </div>\n                              <button\n                                onClick={async () => {\n                                  const newStatus = !flags.graduation_eligible;\n                                  const updated = {\n                                    ...flags,\n                                    graduation_eligible: newStatus,\n                                  };\n                                  setFullData((prev: any) => ({\n                                    ...prev,\n                                    progress_flags: updated,\n                                  }));\n\n                                  toast.success(\n                                    newStatus\n                                      ? 'Đã xác nhận đủ điều kiện thi tốt nghiệp!'\n                                      : 'Đã hủy xác nhận đủ điều kiện thi.',\n                                  );\n\n                                  if (student?.id) {\n                                    try {\n                                      await updateStudent(student.id, {\n                                        graduation_eligible: newStatus,\n                                      });\n                                    } catch {\n                                      toast.error('Lỗi khi cập nhật trạng thái tốt nghiệp.');\n                                    }\n                                  }\n                                }}\n                                className={`flex items-center gap-1 px-3 py-1.5 border rounded-lg text-xs font-bold transition-all ${\n                                  flags.graduation_eligible\n                                    ? 'bg-rose-50 border-rose-200 text-rose-600 hover:bg-rose-100'\n                                    : 'bg-white border-gray-200 text-gray-600 hover:bg-gray-50'\n                                }`}\n                              >\n                                <Edit className=\"w-3 h-3\" /> {flags.graduation_eligible ? 'Bỏ xác nhận' : 'Cập nhật'}\n                              </button>\n                            </div>\n                          </>\n                        );\n                      })()}\n                    </div>\n\n                    <FieldWrapper label=\"Ghi chú tiến độ\" colSpan={2}>\n                      <textarea\n                        rows={3}\n                        placeholder=\"Ghi chú...\"\n                        className=\"w-full px-3 py-2 bg-white border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-600/20 text-sm font-medium resize-none\"\n                      />\n                    </FieldWrapper>\n                  </div>\n                ))}\n\n              {/* TAB: SÁT HẠCH & KQ */}\n              {activeTab === 'sathach' &&\n                (!fullData ? (\n                  <div className=\"flex justify-center items-center h-40\">\n                    <div className=\"w-8 h-8 border-4 border-indigo-200 border-t-indigo-600 rounded-full animate-spin\"></div>\n                  </div>\n                ) : (\n                  <div className=\"flex flex-col gap-4 animate-in fade-in slide-in-from-bottom-2 duration-300\">\n                    <div className=\"flex items-center justify-between\">\n                      <h4 className=\"font-extrabold text-gray-900\">Lịch sử thi hết môn</h4>\n                      <a\n                        href=\"/sat-hach\"\n                        className=\"flex items-center gap-1.5 text-xs font-bold text-indigo-600 hover:text-indigo-800 hover:bg-indigo-50 px-3 py-1.5 rounded-lg border border-indigo-100 transition-colors\"\n                      >\n                        <ExternalLink className=\"w-3 h-3\" /> Trang Thi sát hạch\n                      </a>\n                    </div>\n\n                    {exams.length === 0 ? (\n                      <div className=\"p-10 border border-dashed border-gray-200 rounded-2xl flex flex-col items-center justify-center text-gray-400 gap-3 bg-gray-50/50\">\n                        <Trophy className=\"w-10 h-10 opacity-30 text-indigo-500\" />\n                        <div className=\"text-center\">\n                          <p className=\"text-sm font-bold text-gray-600\">Chưa có đợt thi.</p>\n                          <a\n                            href=\"/sat-hach\"\n                            className=\"text-xs mt-1 text-indigo-600 hover:underline cursor-pointer block\"\n                          >\n                            Thêm lịch trên trang Lịch thi\n                          </a>\n                        </div>\n                      </div>\n                    ) : (\n                      <div className=\"flex flex-col gap-3\">\n                        {exams.map((exam: any, idx: number) => {\n                          const resultColor =\n                            exam.result === 'pass'\n                              ? 'bg-emerald-50 text-emerald-700 border-emerald-200'\n                              : exam.result === 'fail'\n                                ? 'bg-rose-50 text-rose-700 border-rose-200'\n                                : 'bg-amber-50 text-amber-700 border-amber-200';\n\n                          return (\n                            <div\n                              key={idx}\n                              className={`p-4 border rounded-xl flex items-center justify-between transition-all ${resultColor}`}\n                            >\n                              <div className=\"flex flex-col gap-1\">\n                                <div className=\"flex items-center gap-2\">\n                                  <span className=\"text-xs font-black uppercase\">\n\n[791 more lines in file. Use offset=1670 to continue.]"}],"isError":false,"timestamp":1776941209902}}
