c/components/students/StudentDetailDrawer.tsx:399:  }, [licenseCats, student?.rank, selectedRank, fullData]);\nsrc/components/students/StudentDetailDrawer.tsx:425:            rank: 'Hạng bằng',\nsrc/components/students/StudentDetailDrawer.tsx:431:          const action = (f === 'rank' || f === 'course' || f === 'region' || f === 'city') ? 'chọn' : 'nhập';\nsrc/components/students/StudentDetailDrawer.tsx:660:                    student.rank ||\nsrc/components/students/StudentDetailDrawer.tsx:697:                        student.rank ||\nsrc/components/students/StudentDetailDrawer.tsx:715:                    className={`px-3 py-1 rounded-lg text-xs font-bold mr-2 border ${getStatusBadgeStyle(currentStatusValue, fullData?.enrollment?.course_id || fullData?.course_id, currentCourseEndDate)}`}\nsrc/components/students/StudentDetailDrawer.tsx:719:                      fullData?.enrollment?.course_id || fullData?.course_id,\nsrc/components/students/StudentDetailDrawer.tsx:804:                        rank: selectedRank,\nsrc/components/students/StudentDetailDrawer.tsx:805:                        license_category_id: selectedRank,\nsrc/components/students/StudentDetailDrawer.tsx:809:                        course: selectedCourse,\nsrc/components/students/StudentDetailDrawer.tsx:995:                      required={isFieldRequired('rank')}\nsrc/components/students/StudentDetailDrawer.tsx:996:                      error={profileErrors.rank}\nsrc/components/students/StudentDetailDrawer.tsx:997:                      touched={profileTouched.rank}\nsrc/components/students/StudentDetailDrawer.tsx:1000:                        name=\"rank\"\nsrc/components/students/StudentDetailDrawer.tsx:1001:                        required={isFieldRequired('rank')}\nsrc/components/students/StudentDetailDrawer.tsx:1003:                        onBlur={() => setProfileTouched((prev) => ({ ...prev, rank: true }))}\nsrc/components/students/StudentDetailDrawer.tsx:1008:                          // Auto-fi