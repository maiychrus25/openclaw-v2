{"type":"message","id":"f3c3e440","parentId":"c77e516e","timestamp":"2026-04-14T06:44:48.848Z","message":{"role":"toolResult","toolCallId":"call_function_nnjw7ceh3pkl_1","toolName":"read","content":[{"type":"text","text":"import { Router } from 'express';\nimport * as authMiddleware from '../../middlewares/auth.middleware';\nimport { listenNotify } from '@common/notifications/notification.dispatcher';\n\nimport coursesRoute from '../../modules/courses/courses.route';\nimport lessonRoute from '../../modules/lessons/lessons.route';\nimport teacherRoute from '../../modules/teacherInfos/teacherInfos.route';\nimport teacherLicenseCategoryRoute from '../../modules/teacherLicenseCategories/teacherLicenseCategories.route';\nimport StudentInfoRoute from '../../modules/studentInfos/studentInfos.route';\nimport coursesStudents from '../../modules/coursesStudents/coursesStudents.route';\nimport workCalendarRoute from '../../modules/workCalendars/workCalendars.route';\nimport LessonTypeRoute from '../../modules/lessonTypes/lessonTypes.route';\nimport examsRoute from '../../modules/exams/exams.route';\nimport examResultsRoute from '../../modules/examResults/examResults.route';\nimport ExamSchedulesRoute from '../../modules/examSchedules/examSchedules.route';\nimport ExamRegistrationsRouter from '../../modules/examRegistrations/examRegistrations.route';\nimport StudentCommentRouter from '../../modules/studentComments/studentComments.route';\nimport TeacherCommentRouter from '../../modules/teacherComments/teacherComments.route';\n\nconst router = Router();\n\nrouter.use('/courses', listenNotify, coursesRoute);\nrouter.use('/courses-students', listenNotify, coursesStudents);\nrouter.use('/lessons', authMiddleware.checkPermissions, lessonRoute);\nrouter.use('/lesson-types', authMiddleware.checkPermissions, listenNotify, LessonTypeRoute);\nrouter.use('/teacher-infos', listenNotify, teacherRoute);\nrouter.use('/teacher-license-categories', authMiddleware.checkPermissions, listenNotify, teacherLicenseCategoryRoute);\nrouter.use('/work-calendars', authMiddleware.checkPermissions, listenNotify, workCalendarRoute);\nrouter.use('/student-infos', authMiddleware.checkPermissions, listenNotify, StudentInfoRoute);\nrouter.use('/exams', authMiddleware.checkPermissions, listenNotify, examsRoute);\nrouter.use('/exam-results', authMiddleware.checkPermissions, listenNotify, examResultsRoute);\nrouter.use('/exam-schedules', authMiddleware.checkPermissions, ExamSchedulesRoute);\nrouter.use('/exam-registrations', authMiddleware.checkPermissions, ExamRegistrationsRouter);\nrouter.use('/student-comments', StudentCommentRouter);\nrouter.use('/teacher-comments', TeacherCommentRouter);\n\nexport default router;\n"}],"isError":false,"timestamp":1776149088659}}
{"type":"message","id":"307a3063","parentId":"f3c3e440","timestamp":"2026-04-14T06:44:49.015Z","message":{"role":"toolResult","toolCallId":"call_function_nnjw7ceh3pkl_2","toolName":"read","content":[{"type":"text","text":"import { Router } from 'express';\nimport * as authMiddleware from '../../middlewares/auth.middleware';\nimport { listenNotify } from '@common/notifications/notification.dispatcher';\n\nimport vehiclesRoute from '../../modules/vehicles/vehicles.route';\nimport licenseCategoriesRoute from '../../modules/licenseCategories/licenseCategories.route';\nimport paymentsRoute from '../../modules/payments/payments.route';\nimport stadiumsRoute from '../../modules/stadiums/stadiums.route';\nimport leadSourceRoute from '../../modules/leadSources/leadSources.route';\nimport leadInfoRoute from '../../modules/leadInfos/leadInfos.route';\nimport ImportRouter from '../../modules/imports/imports.route';\nimport InternalCostTypesRouter from '../../modules/internalCostTypes/internalCostTypes.route';\nimport InternalCostsRouter from '../../modules/internalCosts/internalCosts.route';\nimport DashBoardsRouter from '../../modules/dashboards/dashboards.route';\n\nconst router = Router();\n\nrouter.use('/vehicles', listenNotify, vehiclesRoute);\nrouter.use('/license-categories', listenNotify, licenseCategoriesRoute);\nrouter.use('/payments', authMiddleware.checkPermissions, listenNotify, paymentsRoute);\nrouter.use('/stadiums', authMiddleware.checkPermissions, listenNotify, stadiumsRoute);\nrouter.use('/lead-sources', authMiddleware.checkPermissions, listenNotify, leadSourceRoute);\nrouter.use('/lead-infos', authMiddleware.checkPermissions, listenNotify, leadInfoRoute);\nrouter.use('/imports', authMiddleware.checkPermissions, listenNotify, ImportRouter);\nrouter.use('/internal-cost-types', authMiddleware.checkPermissions, listenNotify, InternalCostTypesRouter);\nrouter.use('/internal-costs', authMiddleware.checkPermissions, listenNotify, InternalCostsRouter);\nrouter.use('/