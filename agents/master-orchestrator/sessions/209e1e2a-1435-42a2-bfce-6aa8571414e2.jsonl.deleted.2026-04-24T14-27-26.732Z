{"type":"message","id":"35fb4fc6","parentId":"97805813","timestamp":"2026-04-14T06:44:40.860Z","message":{"role":"toolResult","toolCallId":"call_function_0w95h7f89pyp_1","toolName":"read","content":[{"type":"text","text":"import express from 'express';\nimport * as authMiddleware from './middlewares/auth.middleware';\n\nimport systemRoutes from './routes/v1/system.routes';\nimport educationRoutes from './routes/v1/education.routes';\nimport operationRoutes from './routes/v1/operation.routes';\nimport notificationRoutes from './routes/v1/notification.routes';\n\nimport authRoute from './modules/auth/auth.route';\nimport guestsRoute from './modules/guests/guests.route';\nimport DeviceRoute from './modules/devices/devices.route';\n\nconst router = express.Router();\n\nrouter.use('/auth', authRoute);\nrouter.use('/guests', guestsRoute);\nrouter.use('/devices', DeviceRoute);\n\nrouter.use(authMiddleware.auth());\n\nrouter.use(systemRoutes);\nrouter.use(educationRoutes);\nrouter.use(operationRoutes);\nrouter.use(notificationRoutes);\n\nexport default router;\n"}],"isError":false,"timestamp":1776149080621}}
