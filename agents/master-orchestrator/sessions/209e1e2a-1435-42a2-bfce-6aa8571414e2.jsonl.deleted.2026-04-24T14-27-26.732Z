{"type":"message","id":"43437178","parentId":"307a3063","timestamp":"2026-04-14T06:44:49.199Z","message":{"role":"toolResult","toolCallId":"call_function_nnjw7ceh3pkl_3","toolName":"read","content":[{"type":"text","text":"import { Router } from 'express';\nimport * as authMiddleware from '../../middlewares/auth.middleware';\n\nimport NotifyContentsRoute from '../../modules/notifyContents/notifyContents.route';\nimport NotifyConfigsRoute from '../../modules/notifyConfigs/notifyConfigs.route';\nimport NotifiesRoute from '../../modules/notifies/notifies.route';\nimport NotifyUserRoute from '../../modules/notifyUsers/notifyUsers.route';\nimport ConventionRoute from '../../modules/conventions/conventions.route';\n\nconst router = Router();\n\nrouter.use('/notify-contents', authMiddleware.checkPermissions, NotifyContentsRoute);\nrouter.use('/notify-users', authMiddleware.checkPermissions, NotifyUserRoute);\nrouter.use('/notify-configs', authMiddleware.checkPermissions, NotifyConfigsRoute);\nrouter.use('/notifies', authMiddleware.checkPermissions, NotifiesRoute);\nrouter.use('/conventions', authMiddleware.checkPermissions, ConventionRoute);\n\nexport default router;\n"}],"isError":false,"timestamp":1776149089015}}
