{"type":"message","id":"f0d7a17f","parentId":"d1a008dc","timestamp":"2026-04-23T12:26:35.502Z","message":{"role":"user","content":[{"type":"text","text":"Conversation info (untrusted metadata):\n```json\n{\n  \"message_id\": \"5998\",\n  \"sender_id\": \"6053576134\",\n  \"sender\": \"Khuong\",\n  \"timestamp\": \"Thu 2026-04-23 12:26 UTC\"\n}\n```\n\nSender (untrusted metadata):\n```json\n{\n  \"label\": \"Khuong (6053576134)\",\n  \"id\": \"6053576134\",\n  \"name\": \"Khuong\",\n  \"username\": \"khuowgn\"\n}\n```\n\nbackend đã kết nối tới db thành công nhưng tại sao khi fe call tới backend lại hiển thị như này mặc dù tài khoản mật khẩu chính xác {\"success\":false,\"message\":\"Lỗi hệ thống, vui lòng thử lại sau.\",\"errors\":null}"}],"timestamp":1776947195483}}
{"type":"message","id":"ef772e2f","parentId":"f0d7a17f","timestamp":"2026-04-23T12:26:56.710Z","message":{"role":"assistant","content":[{"type":"text","text":"Mình kiểm tra thẳng log/runtime của API login để xem nó đang vấp ở bước nào trong backend, vì lúc này không còn là CORS hay DB connect nữa mà là lỗi xử lý đăng nhập."},{"type":"toolCall","id":"call_KqBosIUF9cYFE8PDa64vYxOY","name":"read","arguments":{"path":"/root/.openclaw/workspaces2/projects/ahv-qlhv-be/src/interface/controllers/auth.controller.ts","offset":1,"limit":220}},{"type":"toolCall","id":"call_Y0avnLaEacVaOi8fAqG8N2WP","name":"exec","arguments":{"command":"tail -n 120 /tmp/ahv-qlhv-be-5002.log || true","workdir":"/root/.openclaw/workspaces2/projects/ahv-qlhv-be","yieldMs":10000,"timeout":20}},{"type":"toolCall","id":"call_yjBMNLp6DzznXkX6PGfftUZr","name":"exec","arguments":{"command":"curl -s -X POST http://127.0.0.1:5002/api/v1/auth/login -H 'Content-Type: application/json' -d '{\"email\":\"admin@qlhv.vn\",\"password\":\"123456\"}'","workdir":"/root/.openclaw/workspaces2/projects/ahv-qlhv-be","yieldMs":10000,"timeout":30}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-TroLy","usage":{"input":3006,"output":294,"cacheRead":88832,"cacheWrite":0,"totalTokens":92132,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776947195503,"responseId":"1776947197362"}}
{"type":"message","id":"fa53bed7","parentId":"ef772e2f","timestamp":"2026-04-23T12:26:56.778Z","message":{"role":"toolResult","toolCallId":"call_KqBosIUF9cYFE8PDa64vYxOY","toolName":"read","content":[{"type":"text","text":"import type {} from '../types/express.d';\nimport { Request, Response } from 'express';\nimport bcrypt from 'bcrypt';\nimport jwt from 'jsonwebtoken';\nimport { UserModel as User } from '@/infrastructure/database/models/user.model';\nimport { catchAsync } from '@/interface/middlewares/catchAsync.middleware';\nimport { ctrlLogger } from '@/infrastructure/logging/controller-logger';\nimport { tokenBlacklist } from '@/infrastructure/security/token-blacklist.service';\nimport { SystemLogModel, ActionType } from '@/infrastructure/database/models/system_log.model';\nimport { UserAgentModel } from '@/infrastructure/database/models/user_agent.model';\nimport { UserRoleModel } from '@/infrastructure/database/models/user_role.model';\nimport { RoleModel } from '@/infrastructure/database/models/role.model';\nimport logger from '@/infrastructure/logging/logger';\n\n/**\n * Helper to fetch all of a user's role names relationally\n */\nasync function getUserRoles(userId: any): Promise<string[]> {\n  const userRoles = await UserRoleModel.find({ user_id: userId }).populate('role_id');\n  const roles = userRoles.map((ur) => (ur.role_id as any)?.role_name).filter((name) => !!name);\n\n  return roles.length > 0 ? roles : ['student']; // Default fallback\n}\n\nexport const register = catchAsync(async (req: Request, res: Response) => {\n  const log = ctrlLogger('auth.register', req);\n  const { username, password, role, first_name, last_name, email, phone, address, identity_card } = req.body;\n\n  const normalizedUsername = username.trim().toLowerCase();\n  const normalizedEmail = email.trim().toLowerCase();\n\n  log.start({ username: normalizedUsername, email: normalizedEmail, role });\n\n  // Proactive duplicate checking with user-friendly messages\n  const existingUser = await User.findOne({\n    $or: [{ username: normalizedUsername }, { email: normalizedEmail }],\n  })\n    .select('username email')\n    .lean();\n\n  if (existingUser) {\n    const duplicateErrors: { path: string; message: string }[] = [];\n    if (existingUser.username === normalizedUsername) {\n      duplicateErrors.push({ path: 'body.username', message: 'Tên đăng nhập đã được sử dụng.' });\n    }\n    if (existingUser.email === normalizedEmail) {\n      duplicateErrors.push({ path: 'body.email', message: 'Email đã được sử dụng.' });\n    }\n    logger.warn(`[auth.register] Duplicate detected for: ${normalizedUsername} / ${normalizedEmail}`);\n    return res.status(409).json({\n      success: false,\n      message: 'Thông tin đăng ký bị trùng. Vui lòng kiểm tra lại.',\n      errors: duplicateErrors,\n    });\n  }\n\n  const passwordHash = await bcrypt.hash(password, 10);\n\n  const user = await User.create({\n    username: normalizedUsername,\n    password: passwordHash,\n    first_name: first_name?.trim(),\n    last_name: last_name?.trim(),\n    email: normalizedEmail,\n    phone: phone?.trim(),\n    address: address || 'N/A',\n    identity_card: identity_card || 'N/A',\n  });\n\n  // Assign roles in userroles collection\n  if (role) {\n    const rolesToAssign = Array.isArray(role) ? role : [role];\n    for (const r of rolesToAssign) {\n      const roleDoc = await RoleModel.findOne({ role_name: r.toLowerCase() });\n      if (roleDoc) {\n        await UserRoleModel.create({\n          user_id: user._id,\n          role_id: roleDoc._id,\n        });\n      } else {\n        logger.warn(`[auth.register] Role '${r}' not found in roles collection`);\n      }\n    }\n  }\n\n  logger.info(`[auth.register] User created successfully: ${user.username} (${user._id})`);\n\n  log.success(\n    res,\n    { id: user._id, username: user.username, roles: Array.isArray(role) ? role : [role] },\n    'User registered successfully',\n  );\n});\n\nexport const login = catchAsync(async (req: Request, res: Response) => {\n  const log = ctrlLogger('auth.login', req);\n  const { username, password } = req.body;\n\n  const normalizedUsername = username.trim().toLowerCase();\n  log.start({ username: normalizedUsername });\n\n  const user = await User.findOne({\n    $or: [{ username: normalizedUsername }, { email: normalizedUsername }],\n  });\n\n  if (!user) {\n    logger.warn(`Login failed: User not found for username \"${username}\"`);\n    return log.fail('invalid_credentials', res, 401, 'Invalid credentials', { username });\n  }\n\n  const isMatch = await bcrypt.compare(password, user.password);\n  if (!isMatch) {\n    logger.warn(`Login failed: Password mismatch for user \"${username}\"`);\n    return log.fail('invalid_credentials', res, 401, 'Invalid credentials', { username });\n  }\n\n  // Fetch agent_id and roles relationally\n  const [userAgent, roles] = await Promise.all([UserAgentModel.findOne({ user_id: user._id }), getUserRoles(user._id)]);\n\n  const agentId = userAgent?.agent_id || null;\n  const primaryRole = roles[0];\n\n  const accessToken = jwt.sign(\n    { id: user._id, role: primaryRole, roles: roles, agent_id: agentId },\n    process.env.JWT_SECRET!,\n    { expiresIn: '24h' },\n  );\n\n  const refreshToken = jwt.sign({ id: user._id }, process.env.JWT_REFRESH_SECRET!, { expiresIn: '7d' });\n\n  // Save refresh token to user\n  user.refresh_token = refreshToken;\n  await user.save();\n\n  // Cross-domain cookie config: Render (BE) <-> Vercel (FE)\n  // SameSite=None + Secure=true is required for cross-site cookies over HTTPS\n  const isProduction = process.env.RENDER === 'true' || process.env.NODE_ENV === 'production';\n  res.cookie('refreshToken', refreshToken, {\n    httpOnly: true,\n    secure: isProduction, // true trên Render (HTTPS), false trên localhost\n    sameSite: isProduction ? 'none' : 'lax', // 'none' cho phép cross-domain trên HTTPS\n    maxAge: 7 * 24 * 60 * 60 * 1000, // 7 days\n  });\n\n  // Log successful login to system audit log (non-critical — fires after response)\n  const loginResponse = {\n    token: accessToken,\n    user: {\n      id: user._id,\n      username: user.username,\n      role: primaryRole,\n      roles: roles,\n      first_name: user.first_name,\n      last_name: user.last_name,\n      agent_id: agentId,\n    },\n  };\n\n  log.success(res, loginResponse, 'Login successful');\n\n  try {\n    await SystemLogModel.create({\n      user_id: user._id,\n      title: 'Đăng nhập hệ thống',\n      action: ActionType.LOGIN,\n      entity_type: 'AUTH',\n      entity_id: user._id.toString(),\n      ip_address: req.ip,\n      user_agent: req.headers['user-agent'],\n    });\n  } catch (error) {\n    logger.error('Failed to log login:', error);\n  }\n});\n\nexport const refreshToken = catchAsync(async (req: Request, res: Response) => {\n  const log = ctrlLogger('auth.refresh_token', req);\n  const tokenFromCookie = req.cookies.refreshToken;\n\n  log.start({});\n\n  if (!tokenFromCookie) {\n    return log.fail('no_refresh_token', res, 401, 'No refresh token provided');\n  }\n\n  const user = await User.findOne({ refresh_token: tokenFromCookie });\n  if (!user) {\n    return log.fail('invalid_refresh_token', res, 403, 'Invalid refresh token');\n  }\n\n  try {\n    const roles = await getUserRoles(user._id);\n\n    const newAccessToken = jwt.sign({ id: user._id, role: roles[0], roles: roles }, process.env.JWT_SECRET!, {\n      expiresIn: '24h',\n    });\n\n    log.success(res, { token: newAccessToken }, 'Token refreshed successfully');\n  } catch (error) {\n    log.error('jwt_sign_failed', error);\n    return res.statusError('Refresh token expired', 403);\n  }\n});\n\nexport const getMe = catchAsync(async (req: any, res: Response) => {\n  const log = ctrlLogger('auth.get_me', req);\n  log.start({ userId: req.user.id });\n\n  const user = await User.findById(req.user.id).select('-password');\n  if (!user) {\n    return log.fail('user_not_found', res, 404, 'User not found');\n  }\n\n  // Fetch agent_id and roles\n  const [userAgent, roles] = await Promise.all([UserAgentModel.findOne({ user_id: user._id }), getUserRoles(user._id)]);\n\n  // Normalize user object for frontend\n  const userProfile = {\n    id: user._id,\n    username: user.username,\n\n[145 more lines in file. Use offset=221 to continue.]"}],"isError":false,"timestamp":1776947216769}}
