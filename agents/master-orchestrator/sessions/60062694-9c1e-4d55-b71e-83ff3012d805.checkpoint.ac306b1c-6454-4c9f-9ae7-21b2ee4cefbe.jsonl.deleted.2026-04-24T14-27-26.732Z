lse if (isNaN(parseFloat(data.distance)) || parseFloat(data.distance) <= 0) {\n      errs.distance = 'Quãng đường phải là số dương.';\n    }\n\n    setErrors(errs);\n    return errs;\n  };\n","newText":"  const validate = (data = form) => {\n    const errs: Record<string, string> = {};\n\n    if (!data.date) errs.date = 'Vui lòng chọn ngày học.';\n\n    if (!data.timeStart) errs.timeStart = 'Vui lòng nhập giờ bắt đầu.';\n    if (!data.timeEnd) errs.timeEnd = 'Vui lòng nhập giờ kết thúc.';\n\n    if (!data.duration.trim()) errs.duration = 'Vui lòng nhập thời lượng.';\n    else if (isNaN(parseInt(data.duration)) || parseInt(data.duration) <= 0) {\n      errs.duration = 'Thời lượng phải là số dương.';\n    }\n\n    if (!data.distance.trim()) errs.distance = 'Vui lòng nhập quãng đường.';\n    else if (isNaN(parseFloat(data.distance)) || parseFloat(data.distance) <= 0) {\n      errs.distance = 'Quãng đường phải là số dương.';\n    }\n\n    if (data.timeStart && data.timeEnd) {\n      const [sh, sm] = data.timeStart.split(':').map(Number);\n      const [eh, em] = data.timeEnd.split(':').map(Number);\n      const diffMinutes = eh * 60 + em - (sh * 60 + sm);\n\n      if (diffMinutes <= 0) {\n        errs.timeEnd = 'Thời gian kết thúc phải sau thời gian bắt đầu.';\n      } else if (!errs.duration && parseInt(data.duration) > diffMinutes) {\n        errs.duration = 'Thời lượng không được lớn hơn khoảng thời gian từ bắt đầu đến kết thúc.';\n      }\n    }\n\n    setErrors(errs);\n    return errs;\n  };\n"},{"oldText":"  const handleChange = (field: keyof DatFormData, value: string) => {\n    setForm((prev) => {\n      const updated = { ...prev, [field]: value };\n\n      if (field === 'timeStart') {\n        if (updated.timeEnd) {\n          updated.duration = syncDuration(value, updated.timeEnd);\n        } else if (updated.duration) {\n          updated.timeEnd = syncEndTime(value, updated.duration);\n        }\n      }\n\n      if (field === 'timeEnd') {\n        updated.duration = syncDuration(updated.timeStart, value);\n      }\n\n      if (field === 'duration') {\n        updated.timeEnd = syncEndTime(updated.timeStart, value);\n      }\n\n      if (touched[field]) {\n        validate(updated);\n      }\n\n      return updated;\n    });\n  };\n","newText":"  const handleChange = (field: keyof DatFormData, value: string) => {\n    setForm((prev) => {\n      const updated = { ...prev, [field]: value };\n      if (touched[field]) {\n        validate(updated);\n      }\n      return updated;\n    });\n  };\n"},{"oldText":"      const startTime = form.timeStart || '08:00';\n      const endTime = form.timeEnd || '10:00';\n\n      const start = new Date(`${form.date}T${startTime}:00`);\n      const end = new Date(`${form.date}T${endTime}:00`);\n","newText":"      const start = new Date(`${form.date}T${form.timeStart}:00`);\n      const end = new Date(`${form.date}T${form.timeEnd}:00`);\n"}]}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":323,"output":1568,"cacheRead":5168,"cacheWrite":132231,"totalTokens":139290,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776958747320,"responseId":"0639701dd9358ed1b113f9988179776b"}}
