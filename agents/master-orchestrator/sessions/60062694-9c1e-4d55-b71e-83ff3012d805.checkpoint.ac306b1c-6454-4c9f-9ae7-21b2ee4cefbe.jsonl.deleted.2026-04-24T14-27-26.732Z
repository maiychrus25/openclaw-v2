return null;\n+  const handleChange = (field: keyof DatFormData, value: string) => {\n+    setForm((prev) => {\n+      const updated = { ...prev, [field]: value };\n+\n+      if (field === 'timeStart') {\n+        if (updated.timeEnd) {\n+          updated.duration = syncDuration(value, updated.timeEnd);\n+        } else if (updated.duration) {\n+          updated.timeEnd = syncEndTime(value, updated.duration);\n+        }\n+      }\n+\n+      if (field === 'timeEnd') {\n+        updated.duration = syncDuration(updated.timeStart, value);\n+      }\n+\n+      if (field === 'duration') {\n+        updated.timeEnd = syncEndTime(updated.timeStart, value);\n+      }\n+\n+      if (touched[field]) {\n+        validate(updated);\n+      }\n+\n+      return updated;\n+    });\n+  };\n+\n+  const handleBlur = (field: string) => {\n+    setTouched((prev) => ({ ...prev, [field]: true }));\n+    validate();\n+  };\n+\n+  const getInputClass = (field: string) => {\n+    const base =\n+      'w-full px-4 py-2.5 bg-white border rounded-xl focus:outline-none focus:ring-4 transition-all text-sm font-medium';\n+    if (touched[field] && errors[field]) {\n+      return `${base} border-rose-300 bg-rose-50/20 text-rose-900 focus:ring-rose-500/10 focus:border-rose-500`;\n+    }\n+    return `${base} border-gray-200 focus:ring-indigo-500/10 focus:border-indigo-500`;\n+  };\n \n   const handleSubmit = async (e: React.FormEvent) => {\n     e.preventDefault();\n-    if (!formData.distance || isNaN(parseFloat(formData.distance))) {\n-      toast.error('Vui lòng nhập quãng đường hợp lệ.');\n+\n+    if (!enrollmentId) {\n+      toast.error('Không tìm thấy thông tin đăng ký của học viên.');\n       return;\n     }\n-    if (!formData.duration || isNaN(parseInt(formData.duration))) {\n-      toast.error('Vui lòng nhập số phút học hợp lệ.');\n+\n+    const allTouched = { date: true, duration: true, distance: true, timeStart: true, timeEnd: true };\n+    setTouched(allTouched);\n+\n+    const errs 