eStudent}\n                  onRetire={onRetireStudent}\n                />\n              ))\n            )}\n          </tbody>\n        </table>\n      </div>\n\n      {/* Pagination */}\n      <div className=\"p-4 border-t border-gray-50 flex items-center justify-between text-sm text-gray-500 font-medium bg-gray-50/50\">\n        <span>\n          Hiển thị {students.length} {meta ? `/ ${meta.total}` : ''} học viên\n        </span>\n        <div className=\"flex gap-1\">\n          <button\n            disabled={!meta || meta.page <= 1}\n            onClick={() => onFetchData(meta.page - 1)}\n            className=\"px-3 py-1 border border-gray-200 rounded text-gray-400 disabled:cursor-not-allowed hover:bg-gray-100 transition-colors\"\n          >\n            Trước\n          </button>\n          <button className=\"px-3 py-1 bg-indigo-600 text-white font-bold rounded shadow-sm shadow-indigo-600/20\">\n            {meta ? meta.page : 1}\n          </button>\n          <button\n            disabled={!meta || meta.page >= meta.total_pages}\n            onClick={() => onFetchData(meta.page + 1)}\n            className=\"px-3 py-1 border border-gray-200 rounded hover:bg-gray-100 disabled:cursor-not-allowed disabled:text-gray-400 transition-colors\"\n          >\n            Tiếp\n          </button>\n        </div>\n      </div>\n    </div>\n  );\n};\n\nexport default StudentTable;\n"}],"isError":false,"timestamp":1776960591324}}
