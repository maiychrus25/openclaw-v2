{"type":"message","id":"235e3763","parentId":"0739808a","timestamp":"2026-04-23T09:45:18.922Z","message":{"role":"toolResult","toolCallId":"call_5ktTV2tFwZ3hmKkDO0rAOOyi","toolName":"read","content":[{"type":"text","text":"                    <div className=\"w-8 h-8 border-4 border-indigo-200 border-t-indigo-600 rounded-full animate-spin\"></div>\n                  </div>\n                ) : (\n                  <form\n                    className=\"flex flex-col gap-6 animate-in fade-in slide-in-from-bottom-2 duration-300\"\n                    onSubmit={async (e) => {\n                      e.preventDefault();\n                      try {\n                        const { status, date, hospital, note } = healthCheckState;\n                        // Update: The backend StudentService.updateStudent expects flat fields for health_check sync\n                        const res = await updateStudent(student.id, {\n                          health_check_status: status,\n                          health_check_date: date,\n                          hospital_id: hospital,\n                          health_check_note: note,\n                        });\n                        if (res.success) {\n                          toast.success('Đã cập nhật thông tin khám sức khỏe.');\n                          setFullData((prev: any) => ({\n                            ...prev,\n                            health_check: { status, date, hospital, note },\n                          }));\n                          onRefresh?.();\n                        }\n                      } catch {\n                        toast.error('Có lỗi xảy ra khi lưu thông tin.');\n                      }\n                    }}\n                  >\n                    <div className=\"grid grid-cols-2 gap-x-6 gap-y-5\">\n                      <FieldWrapper label=\"Trạng thái khám SK\">\n                        <select\n                          name=\"status\"\n                          value={healthCheckState.status}\n                          onChange={(e) =>\n\n[1208 more lines in file. Use offset=1253 to continue.]"}],"isError":false,"timestamp":1776937518912}}
{"type":"message","id":"bf2a0515","parentId":"235e3763","timestamp":"2026-04-23T09:45:18.930Z","message":{"role":"toolResult","toolCallId":"call_68sZMo4RruU7eBcE1i6fQleo","toolName":"read","content":[{"type":"text","text":"import { apiClient } from './api';\n\nexport const getStudents = (page = 1, limit = 10, filters = {}) => {\n  const queryParams = new URLSearchParams({\n    page: page.toString(),\n    limit: limit.toString(),\n    ...Object.fromEntries(Object.entries(filters).filter(([_, v]) => v != null && v !== '')),\n  });\n  return apiClient(`/students?${queryParams.toString()}`);\n};\n\nexport const getStudentById = (id: string) => apiClient(`/students/${id}`);\n\nexport const getCities = () => apiClient('/cities');\n\nexport const getLicenseCategories = () => apiClient('/students/license-categories');\nexport const getLeads = () => apiClient('/students/leads');\nexport const createStudent = (data: any) =>\n  apiClient('/students', {\n    method: 'POST',\n    body: JSON.stringify(data),\n  });\n\nexport const exportStudents = async (filters = {}) => {\n  const queryParams = new URLSearchParams(\n    Object.fromEntries(\n      Object.entries(filters)\n        .filter(([_, v]) => v != null && v !== '' && v !== 'Tất cả')\n        .map(([k, v]) => [k, String(v)]),\n    ),\n  );\n\n  const blob = await apiClient<Blob>(`/students/export?${queryParams.toString()}`, {\n    responseType: 'blob',\n  });\n\n  const url = window.URL.createObjectURL(blob);\n  const a = document.createElement('a');\n  a.href = url;\n  a.download = `danh_sach_hoc_vien_${new Date().getTime()}.xlsx`;\n  document.body.appendChild(a);\n  a.click();\n  window.URL.revokeObjectURL(url);\n  document.body.removeChild(a);\n};\nexport const updateStudent = (id: string, data: any) =>\n  apiClient(`/students/${id}`, {\n    method: 'PUT',\n    body: JSON.stringify(data),\n  });\n\nexport const deleteStudent = (id: string) =>\n  apiClient(`/students/${id}`, {\n    method: 'DELETE',\n  });\n\nexport const bulkDeleteStudents = (ids: string[]) =>\n  apiClient('/students/bulk', {\n    method: 'DELETE',\n    body: JSON.stringify({ ids }),\n  });\n\nexport const getStudentHistory = (id: string, page = 1, limit = 20) => {\n  return apiClient(`/students/${id}/history?page=${page}&limit=${limit}`);\n};\n\nexport const importStudents = async (file: File, importType: string = 'student_only') => {\n  const formData = new FormData();\n  formData.append('file', file);\n  formData.append('import_type', importType);\n\n  return apiClient('/students/import', {\n    method: 'POST',\n    body: formData,\n  });\n};\n\nexport const downloadStudentTemplate = async (importType: string = 'student_only') => {\n  const blob = await apiClient<Blob>(`/students/import-template?type=${importType}`, {\n    responseType: 'blob',\n  });\n\n  const url = window.URL.createObjectURL(blob);\n  const a = document.createElement('a');\n  a.href = url;\n  a.download = importType === 'student_only' ? `mau_nhap_hoc_vien_ahv.xlsx` : `mau_nhap_hoc_vien_va_khoa_ahv.xlsx`;\n  document.body.appendChild(a);\n  a.click();\n  window.URL.revokeObjectURL(url);\n  document.body.removeChild(a);\n};\n\nexport const getImportStats = () => apiClient('/students/import-stats');\n"}],"isError":false,"timestamp":1776937518923}}
{"type":"message","id":"80f6f33f","parentId":"bf2a0515","timestamp":"2026-04-23T09:45:18.945Z","message":{"role":"toolResult","toolCallId":"call_YiMSFWe9QkTgHfFhcD7aluB6","toolName":"read","content":[{"type":"text","text":"import mongoose, { Schema, Document, Types } from 'mongoose';\n\nexport interface ICourseStudent extends Document {\n  student_id: Types.ObjectId; // References Student(student_infos)\n  course_id: Types.ObjectId; // References Course(course_infos)\n  stadium_id?: Types.ObjectId | null;\n  teacher_id?: Types.ObjectId | null;\n  sale_id?: Types.ObjectId | null;\n  license_category_id?: Types.ObjectId | null;\n  status: 'unfinished' | 'finished' | 'canceled';\n  km: number;\n  hour: string;\n  fee: number;\n  paid_fee: number;\n  balance?: any; // Treasury balance for this enrollment\n  contract_date?: Date | null;\n  status_detail?: string;\n  progress_flags?: {\n    theory_completed: boolean;\n    sand_yard_completed: boolean;\n    simulation_completed: boolean;\n    dat_completed: boolean;\n    cabin_completed: boolean;\n    graduation_eligible: boolean;\n  };\n  health_check?: {\n    status: string;\n    date: Date | null;\n    hospital: string | null;\n    note: string | null;\n  };\n  created_at: Date;\n  updated_at: Date;\n}\n\nconst CourseStudentSchema = new Schema<ICourseStudent>(\n  {\n    student_id: { type: Schema.Types.ObjectId, ref: 'StudentInfos', required: true, index: true },\n    course_id: { type: Schema.Types.ObjectId, ref: 'Courses', required: true, index: true },\n    stadium_id: { type: Schema.Types.ObjectId, ref: 'Stadiums', default: null },\n    teacher_id: { type: Schema.Types.ObjectId, ref: 'Users', default: null },\n    sale_id: { type: Schema.Types.ObjectId, ref: 'Users', default: null },\n    license_category_id: { type: Schema.Types.ObjectId, ref: 'LicenseCategories', default: null },\n    status: {\n      type: String,\n      enum: ['unfinished', 'finished', 'canceled'],\n      default: 'unfinished',\n    },\n    km: { type: Number, default: 0 },\n    hour: { type: String, default: '00:00' },\n    fee: { type: Number, default: 0 },\n    paid_fee: { type: Number, default: 0 },\n    balance: {\n      type: Schema.Types.Decimal128,\n      default: 0,\n      get: (v: any) => (v ? parseFloat(v.toString()) : 0),\n    },\n    contract_date: { type: Date, default: null },\n    status_detail: { type: String, default: 'Chờ KSK' },\n    progress_flags: {\n      theory_completed: { type: Boolean, default: false },\n      sand_yard_completed: { type: Boolean, default: false },\n      simulation_completed: { type: Boolean, default: false },\n      dat_completed: { type: Boolean, default: false },\n      cabin_completed: { type: Boolean, default: false },\n      graduation_eligible: { type: Boolean, default: false },\n    },\n    health_check: {\n      status: { type: String, enum: ['Chờ khám', 'Đủ điều kiện', 'Không đủ điều kiện'], default: 'Chờ khám' },\n      date: { type: Date, default: null },\n      hospital: { type: String, default: null },\n      note: { type: String, default: null },\n    },\n  },\n  {\n    timestamps: { createdAt: 'created_at', updatedAt: 'updated_at' },\n    versionKey: false,\n    collection: 'coursestudents',\n  },\n);\n\nCourseStudentSchema.index({ student_id: 1, created_at: -1 });\nCourseStudentSchema.index({ course_id: 1, created_at: -1 });\nCourseStudentSchema.index({ status_detail: 1, created_at: -1 });\nCourseStudentSchema.index({ sale_id: 1, created_at: -1 });\nCourseStudentSchema.index({ 'progress_flags.dat_completed': 1, status_detail: 1 });\nCourseStudentSchema.index({ fee: 1, paid_fee: 1 });\n\nexport const CourseStudentModel =\n  mongoose.models.CourseStudents ||\n  mongoose.model<ICourseStudent>('CourseStudents', CourseStudentSchema, 'coursestudents');\n"}],"isError":false,"timestamp":1776937518938}}
{"type":"message","id":"d217a56d","parentId":"80f6f33f","timestamp":"2026-04-23T09:45:36.847Z","message":{"role":"assistant","content":[{"type":"text","text":"Mình đã thấy điểm nghi vấn mạnh: FE gửi cập nhật khám sức khỏe thành công, nhưng cần bám tiếp xem BE có thực sự ghi vào enrollment mới nhất hay chỉ merge trong response. Tiếp theo mình đọc đúng hàm update để chốt nguyên nhân rồi vá luôn."},{"type":"toolCall","id":"call_KzTPQ5RNsEyfUE1QuHwenRJb","name":"read","arguments":{"path":"/root/.openclaw/workspaces2/projects/ahv-qlhv-be/src/application/services/student.service.ts","offset":1,"limit":260}},{"type":"toolCall","id":"call_sEFLe77SGagfaKMgbGxp8TVs","name":"read","arguments":{"path":"/root/.openclaw/workspaces2/projects/ahv-qlhv-be/src/infrastructure/repositories/student.repository.ts","offset":1,"limit":260}},{"type":"toolCall","id":"call_PJbuCKtr7fru2owEUlL4hq5M","name":"exec","arguments":{"command":"grep -RIn \"router.put('/students\\|put('/students\\|updateStudentSchema\\|students/:id\" src --exclude-dir=node_modules","workdir":"/root/.openclaw/workspaces2/projects/ahv-qlhv-be","yieldMs":10000,"timeout":40}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-TroLy","usage":{"input":4076,"output":328,"cacheRead":49664,"cacheWrite":0,"totalTokens":54068,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776937518962,"responseId":"1776937520334"}}
{"type":"message","id":"40bbbfb4","parentId":"d217a56d","timestamp":"2026-04-23T09:45:36.901Z","message":{"role":"toolResult","toolCallId":"call_KzTPQ5RNsEyfUE1QuHwenRJb","toolName":"read","content":[{"type":"text","text":"import mongoose from 'mongoose';\nimport { StudentRepository } from '@/infrastructure/repositories/student.repository';\nimport { SettingsRepository } from '@/infrastructure/database/repositories/settings.repository';\nimport { PaymentRepository } from '@/infrastructure/repositories/payment.repository';\nimport { IStudent } from '@/domain/interfaces/student.interface';\nimport { COURSE_TYPES } from '@/domain/constants/course.constants';\nimport { STUDENT_STATUSES } from '@/domain/constants/student.constants';\nimport { ExcelHelper } from '@/infrastructure/utils/excel.helper';\nimport { Response } from 'express';\nimport { SystemLogModel } from '../../infrastructure/database/models/system_log.model';\nimport { StudentModel } from '../../infrastructure/database/models/student.model';\nimport { CourseStudentModel } from '../../infrastructure/database/models/course_student.model';\nimport { CourseModel } from '../../infrastructure/database/models/course.model';\nimport { LicenseCategoryModel } from '../../infrastructure/database/models/license_category.model';\nimport { CityModel } from '../../infrastructure/database/models/city.model';\nimport { NotificationModel } from '../../infrastructure/database/models/notification.model';\nimport { UserService } from './user.service';\nimport { NotifyService } from './notify.service';\nimport { StatusTransitionHelper } from './status-transition.helper';\nimport { PaginationOptions } from '@/domain/types/pagination.types';\nimport fs from 'fs';\nimport logger from '@/infrastructure/logging/logger';\nimport { AppError } from '@/domain/exceptions/app-error';\nimport { UserModel } from '../../infrastructure/database/models/user.model';\nimport { RoleModel, UserRoleName } from '../../infrastructure/database/models/role.model';\nimport { UserRoleModel } from '../../infrastructure/database/models/user_role.model';\n\nexport class StudentService {\n  private studentRepository: StudentRepository;\n  private paymentRepository: PaymentRepository;\n  private userService: UserService;\n  private excelHelper: ExcelHelper;\n  private notifyService: NotifyService;\n  private settingsRepository: SettingsRepository;\n\n  constructor() {\n    this.studentRepository = new StudentRepository();\n    this.paymentRepository = new PaymentRepository();\n    this.userService = new UserService();\n    this.excelHelper = new ExcelHelper();\n    this.notifyService = new NotifyService();\n    this.settingsRepository = new SettingsRepository();\n  }\n\n  async getAllStudents(filters = {}, options: PaginationOptions = { page: 1, limit: 10 }, currentUser?: any) {\n    return await this.studentRepository.findAll(filters, options, currentUser);\n  }\n\n  async getStudentById(id: string, currentUser?: any) {\n    const student = await this.studentRepository.findById(id, currentUser);\n    if (!student) {\n      throw new AppError('Học viên không tồn tại hoặc bạn không có quyền truy cập', 404);\n    }\n    return student;\n  }\n\n  async updateStudent(id: string, data: any) {\n    const student = await this.studentRepository.findById(id);\n    if (!student) throw new AppError('Học viên không tồn tại', 404);\n\n    // Business Logic Guard: Validate status transition if requested\n    if (data.status) {\n      StatusTransitionHelper.validate(student, data.status);\n    }\n\n    // 1. Update Core User Data\n    const userId = (student.user_id as any)._id || student.user_id;\n    const coreFields = [\n      'name',\n      'first_name',\n      'last_name',\n      'phone',\n      'identity_number',\n      'identity_card',\n      'email',\n      'existing_license_num',\n      'existing_license_rank',\n    ];\n    if (Object.keys(data).some((k) => coreFields.includes(k))) {\n      await this.userService.updateUserProfile(userId, data);\n    }\n\n    // 2. Map and Update Core Student Attributes (Demographics & Category)\n    const demographicUpdate: any = {};\n    if (data.city !== undefined) {\n      demographicUpdate.region_id =\n        data.city === ''\n          ? null\n          : mongoose.Types.ObjectId.isValid(data.city)\n            ? new mongoose.Types.ObjectId(data.city)\n            : data.city;\n    }\n    if (data.region_id !== undefined) {\n      demographicUpdate.region_id =\n        data.region_id === ''\n          ? null\n          : mongoose.Types.ObjectId.isValid(data.region_id)\n            ? new mongoose.Types.ObjectId(data.region_id)\n            : data.region_id;\n    }\n\n    // ENSURE: license_category_id is ALSO updated on the Student document, not just CourseStudent\n    if (data.rank !== undefined && data.rank !== '') {\n      demographicUpdate.license_category_id = await this._resolveLicenseCategoryId(data.rank);\n    } else if (data.license_category_id !== undefined && data.license_category_id !== '') {\n      demographicUpdate.license_category_id = await this._resolveLicenseCategoryId(data.license_category_id);\n    }\n\n    if (data.status !== undefined && data.status !== '') {\n      let sanitizedStatus = data.status;\n      if (sanitizedStatus === 'Đã xong KSK') sanitizedStatus = 'Đã KSK';\n      demographicUpdate.status_detail = sanitizedStatus;\n    }\n\n    if (data.lead_manager !== undefined) {\n      demographicUpdate.lead_manager = data.lead_manager === '' ? null : data.lead_manager;\n    }\n\n    if (Object.keys(demographicUpdate).length > 0) {\n      await this.studentRepository.update(id, demographicUpdate);\n    }\n\n    // 3. Map Course details for latest CourseStudent Enrollment\n    const courseUpdate = await this._mapCourseUpdateData(data);\n\n    const needsEnrollmentUpdate =\n      Object.keys(courseUpdate).length > 0 ||\n      [\n        'health_check_status',\n        'health_check_date',\n        'hospital_id',\n        'health_check_note',\n        'theory_completed',\n        'sand_yard_completed',\n        'simulation_completed',\n        'dat_completed',\n        'cabin_completed',\n        'graduation_eligible',\n      ].some((k) => data[k] !== undefined);\n\n    if (needsEnrollmentUpdate) {\n      const latestEnrollment = await CourseStudentModel.findOne({ student_id: id }).sort({ created_at: -1 });\n      if (latestEnrollment) {\n        this._mergeLatestEnrollmentFlags(courseUpdate, latestEnrollment, data);\n        await CourseStudentModel.updateOne({ _id: latestEnrollment._id }, { $set: courseUpdate });\n      } else if (courseUpdate.course_id) {\n        // Create new enrollment if none exists but course info is provided\n        await CourseStudentModel.create({\n          student_id: id,\n          ...courseUpdate,\n        });\n      }\n    }\n\n    return await this.studentRepository.findById(id);\n  }\n\n  private async _mapCourseUpdateData(data: any): Promise<any> {\n    const courseUpdate: any = {};\n    if (data.status !== undefined) {\n      // Sanitize old status labels coming from legacy clients or old constants\n      let sanitizedStatus = data.status;\n      if (sanitizedStatus === 'Đã xong KSK') sanitizedStatus = 'Đã KSK';\n      courseUpdate.status_detail = sanitizedStatus;\n    }\n    if (data.course !== undefined && data.course !== '') {\n      courseUpdate.course_id = data.course;\n      // Fetch course fee to initialize tuition\n      const course = await CourseModel.findById(data.course).select('course_fee').lean().exec();\n      if (course) {\n        courseUpdate.fee = (course as any).course_fee || 0;\n      }\n    }\n    \n    // Support both 'rank' string and 'license_category_id' ObjectId\n    const rankValue = data.rank || data.license_category_id;\n    if (rankValue !== undefined && rankValue !== '') {\n      courseUpdate.license_category_id = await this._resolveLicenseCategoryId(rankValue);\n    }\n    return courseUpdate;\n  }\n\n  private async _resolveLicenseCategoryId(rank: string | null | undefined): Promise<any> {\n    if (!rank) return null;\n    // Already an ObjectId\n    if (mongoose.Types.ObjectId.isValid(rank)) return rank;\n\n    const normalized = rank.trim().toUpperCase();\n\n    // 1. Exact match by code or name\n    const exact = await LicenseCategoryModel.findOne({\n      $or: [\n        { code: { $regex: `^${normalized}$`, $options: 'i' } },\n        { name: { $regex: `^${normalized}$`, $options: 'i' } },\n        { name: { $regex: `^H\\u1ea1ng ${normalized}$`, $options: 'i' } },\n      ],\n    }).exec();\n    if (exact) return exact._id;\n\n    // 2. Prefix fallback: 'B2' → tries 'B', 'A1' → tries 'A', etc.\n    const prefix = normalized.replace(/\\d+$/, '');\n    if (prefix && prefix !== normalized) {\n      const fallback = await LicenseCategoryModel.findOne({\n        $or: [\n          { code: { $regex: `^${prefix}$`, $options: 'i' } },\n          { name: { $regex: `^${prefix}$`, $options: 'i' } },\n          { name: { $regex: `^H\\u1ea1ng ${prefix}$`, $options: 'i' } },\n        ],\n      }).exec();\n      if (fallback) {\n        logger.info('_resolveLicenseCategoryId: prefix fallback matched', { input: rank, matched: fallback.code });\n        return fallback._id;\n      }\n    }\n\n    logger.warn('_resolveLicenseCategoryId: no match found', { rank });\n    return null;\n  }\n\n  private _mergeLatestEnrollmentFlags(courseUpdate: any, latestEnrollment: any, data: any) {\n    const { health_check_status, health_check_date, hospital_id, health_check_note } = data;\n    if ([health_check_status, health_check_date, hospital_id, health_check_note].some((v) => v !== undefined)) {\n      const hc: any = latestEnrollment.health_check || {};\n\n      let parsedDate = hc.date ?? null;\n      if (health_check_date === '' || health_check_date === null) {\n        parsedDate = null;\n      } else if (health_check_date && health_check_date !== 'Invalid Date') {\n        const d = new Date(health_check_date);\n        if (!isNaN(d.getTime())) {\n          parsedDate = d;\n        }\n      }\n\n      courseUpdate.health_check = {\n        status: health_check_status ?? hc.status ?? 'Chờ khám',\n        date: parsedDate,\n        hospital: hospital_id ?? hc.hospital ?? null,\n        note: health_check_note ?? hc.note ?? null,\n      };\n\n      // --- DATA SYNCHRONIZATION: Health Check -> Dashboard Status ---\n      // If health check status is updated to 'Đủ điều kiện', auto-set dashboard status to 'Đã KSK'\n      // This ensures dashboard stats stay in sync with actual biological/medical progress.\n      if (courseUpdate.health_check.status === 'Đủ điều kiện' && courseUpdate.status_detail !== 'Đã KSK') {\n        courseUpdate.status_detail = 'Đã KSK';\n      } else if (courseUpdate.health_check.status === 'Chờ khám' && latestEnrollment.status_detail === 'Đã KSK') {\n        // If downgraded or reset, sync back to 'Chờ KSK'\n        courseUpdate.status_detail = 'Chờ KSK';\n      }\n    }\n\n    const {\n      theory_completed,\n      sand_yard_completed,\n      simulation_completed,\n      dat_completed,\n      cabin_completed,\n      graduation_eligible,\n    } = data;\n\n[558 more lines in file. Use offset=261 to continue.]"}],"isError":false,"timestamp":1776937536888}}
{"type":"message","id":"204defd8","parentId":"40bbbfb4","timestamp":"2026-04-23T09:45:36.939Z","message":{"role":"toolResult","toolCallId":"call_sEFLe77SGagfaKMgbGxp8TVs","toolName":"read","content":[{"type":"text","text":"import mongoose, { Types } from 'mongoose';\nimport { IStudent, StudentModel } from '../database/models/student.model';\nimport { UserModel } from '../database/models/user.model';\nimport { PaginatedResult, PaginationOptions } from '@/domain/types/pagination.types';\nimport { CourseStudentModel } from '../database/models/course_student.model';\nimport { CityModel } from '../database/models/city.model';\nimport { LicenseCategoryModel } from '../database/models/license_category.model';\nimport logger from '@/infrastructure/logging/logger';\nimport { addOwnershipFilter, canAccessResource } from '../utils/queryFilters';\nimport { Role } from '@/domain/constants/rbac';\n\nexport class StudentRepository {\n  async getAssignedStudentIds(teacherId: string): Promise<Types.ObjectId[]> {\n    if (!mongoose.Types.ObjectId.isValid(teacherId)) return [];\n    \n    const teacherObjectId = new mongoose.Types.ObjectId(teacherId);\n    const fromEnrollments = await CourseStudentModel.find({ teacher_id: teacherObjectId }).distinct('student_id').exec();\n    const fromDirectOwnership = await StudentModel.find({ teacher_id: teacherObjectId }).distinct('_id').exec();\n    \n    // Combine both sets of IDs\n    const allIds = Array.from(new Set([\n      ...fromDirectOwnership.map(id => id.toString()),\n      ...fromEnrollments.map(id => id.toString())\n    ]));\n\n    logger.info(`Found ${allIds.length} assigned students for teacher ${teacherId}`, { \n      teacherId, \n      fromDirect: fromDirectOwnership.length, \n      fromEnrollments: fromEnrollments.length \n    });\n\n    return allIds.map((id) => new mongoose.Types.ObjectId(id));\n  }\n\n  async getStats(currentUser?: any): Promise<any> {\n    const match: any = {};\n\n    if (currentUser?.role === Role.TEACHER) {\n      const teacherId = currentUser.id || currentUser._id;\n      const assignedIds = await this.getAssignedStudentIds(teacherId.toString());\n      match._id = { $in: assignedIds };\n    }\n\n    const [total, active] = await Promise.all([\n      StudentModel.countDocuments(match),\n      StudentModel.countDocuments({ ...match, status_detail: 'Đang học' }),\n    ]);\n\n    return { total, active };\n  }\n\n  async create(data: Partial<IStudent>): Promise<IStudent> {\n    return await StudentModel.create(data);\n  }\n\n  async update(id: string, data: Partial<IStudent>): Promise<IStudent | null> {\n    if (!mongoose.Types.ObjectId.isValid(id)) return null;\n    return await StudentModel.findByIdAndUpdate(new mongoose.Types.ObjectId(id), { $set: data }, { new: true }).exec();\n  }\n\n  async findById(id: string, currentUser?: any): Promise<any | null> {\n    if (!mongoose.Types.ObjectId.isValid(id)) return null;\n\n    // Ownership Match Stage\n    const matchStage: any = { _id: new mongoose.Types.ObjectId(id) };\n    if (currentUser?.role === Role.TEACHER) {\n      const assignedIds = await this.getAssignedStudentIds(currentUser.id || currentUser._id);\n      const isAssigned = assignedIds.some((aid) => aid.toString() === id);\n      if (!isAssigned) {\n        logger.warn(`[StudentRepository] Teacher ${currentUser.id} tried to access unassigned student ${id}`);\n        return null;\n      }\n    } else if (currentUser) {\n      Object.assign(matchStage, addOwnershipFilter(currentUser));\n    }\n\n    const results = await StudentModel.aggregate([\n      { $match: matchStage },\n\n      // Basic info\n      { $lookup: { from: 'users', localField: 'user_id', foreignField: '_id', as: 'user_id' } },\n      { $unwind: { path: '$user_id', preserveNullAndEmptyArrays: true } },\n\n      // Resilient region lookup\n      {\n        $addFields: {\n          region_id_obj: {\n            $convert: {\n              input: '$region_id',\n              to: 'objectId',\n              onError: '$region_id', // Fallback to original if not a valid hex string\n              onNull: null,\n            },\n          },\n        },\n      },\n      {\n        $lookup: {\n          from: 'cities',\n          localField: 'region_id_obj',\n          foreignField: '_id',\n          as: 'region_id_info',\n        },\n      },\n      { $unwind: { path: '$region_id_info', preserveNullAndEmptyArrays: true } },\n      {\n        $addFields: {\n          region_id: { $ifNull: ['$region_id_info', '$region_id'] }, // Prefer populated object, fallback to whatever was there\n        },\n      },\n\n      // Detailed Enrollment Info\n      {\n        $lookup: {\n          from: 'coursestudents',\n          let: { studentId: '$_id' },\n          pipeline: [{ $match: { $expr: { $eq: ['$student_id', '$$studentId'] } } }, { $sort: { created_at: 1 } }],\n          as: 'enrollments',\n        },\n      },\n      { $addFields: { latest_enrollment: { $arrayElemAt: ['$enrollments', -1] } } },\n      // Course Info from enrollment\n      {\n        $lookup: {\n          from: 'courses',\n          let: { courseId: '$latest_enrollment.course_id' },\n          pipeline: [\n            {\n              $match: {\n                $expr: {\n                  $eq: ['$_id', { $convert: { input: '$$courseId', to: 'objectId', onError: null, onNull: null } }],\n                },\n              },\n            },\n          ],\n          as: 'enrollment_course',\n        },\n      },\n      { $unwind: { path: '$enrollment_course', preserveNullAndEmptyArrays: true } },\n\n      {\n        $lookup: {\n          from: 'datsessions',\n          let: { enrollmentId: '$latest_enrollment._id' },\n          pipeline: [{ $match: { $expr: { $eq: ['$course_student_id', '$$enrollmentId'] }, session_type: 'dat' } }],\n          as: 'dat_sessions',\n        },\n      },\n\n      {\n        $lookup: {\n          from: 'licensecategories',\n          let: { licenseId: '$latest_enrollment.license_category_id' },\n          pipeline: [\n            {\n              $match: {\n                $expr: {\n                  $eq: ['$_id', { $convert: { input: '$$licenseId', to: 'objectId', onError: null, onNull: null } }],\n                },\n              },\n            },\n          ],\n          as: 'license_info',\n        },\n      },\n\n      // If enrollment doesn't have a rank, fall back to course's rank\n      {\n        $lookup: {\n          from: 'licensecategories',\n          let: { courseLicenseId: '$enrollment_course.license_category_id' },\n          pipeline: [\n            {\n              $match: {\n                $expr: {\n                  $eq: [\n                    '$_id',\n                    { $convert: { input: '$$courseLicenseId', to: 'objectId', onError: null, onNull: null } },\n                  ],\n                },\n              },\n            },\n          ],\n          as: 'course_license_info',\n        },\n      },\n      // Fallback to student's own license category\n      {\n        $lookup: {\n          from: 'licensecategories',\n          let: { studentLicenseId: '$license_category_id' },\n          pipeline: [\n            {\n              $match: {\n                $expr: {\n                  $eq: [\n                    '$_id',\n                    { $convert: { input: '$$studentLicenseId', to: 'objectId', onError: null, onNull: null } },\n                  ],\n                },\n              },\n            },\n          ],\n          as: 'student_license_info',\n        },\n      },\n\n      // Calculate derived fields\n      {\n        $addFields: {\n          license_info_doc: {\n            $ifNull: [\n              { $arrayElemAt: ['$license_info', 0] },\n              {\n                $ifNull: [\n                  { $arrayElemAt: ['$course_license_info', 0] },\n                  { $arrayElemAt: ['$student_license_info', 0] },\n                ],\n              },\n            ],\n          },\n        },\n      },\n      {\n        $addFields: {\n          tuition: {\n            total: { $ifNull: ['$latest_enrollment.fee', 0] },\n            paid: { $ifNull: ['$latest_enrollment.paid_fee', 0] },\n            balance: { $ifNull: ['$latest_enrollment.balance', 0] },\n            remaining: { $max: [0, { $subtract: [{ $ifNull: ['$latest_enrollment.fee', 0] }, { $ifNull: ['$latest_enrollment.paid_fee', 0] }] }] },\n          },\n          dat_stats: {\n            total_km: { $sum: '$dat_sessions.distance_km' },\n            session_count: { $size: '$dat_sessions' },\n            total_minutes: {\n              $sum: {\n                $map: {\n                  input: '$dat_sessions',\n                  as: 's',\n                  in: {\n                    $divide: [{ $subtract: ['$$s.end_time', '$$s.start_time'] }, 1000 * 60],\n                  },\n                },\n              },\n            },\n          },\n          status_detail: { $ifNull: ['$latest_enrollment.status_detail', { $ifNull: ['$status_detail', 'Chờ KSK'] }] },\n          progress_flags: {\n            $ifNull: [\n              '$latest_enrollment.progress_flags',\n              {\n                theory_completed: false,\n                sand_yard_completed: false,\n                simulation_completed: false,\n                dat_completed: false,\n                cabin_completed: false,\n                graduation_eligible: false,\n              },\n            ],\n          },\n\n[686 more lines in file. Use offset=261 to continue.]"}],"isError":false,"timestamp":1776937536933}}
