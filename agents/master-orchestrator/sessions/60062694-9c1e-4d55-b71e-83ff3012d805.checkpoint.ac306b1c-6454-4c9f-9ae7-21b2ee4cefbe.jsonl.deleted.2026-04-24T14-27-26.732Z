{"type":"message","id":"e28ec97d","parentId":"92441473","timestamp":"2026-04-23T12:17:37.832Z","message":{"role":"toolResult","toolCallId":"call_W85yawFIngo5tB5BDicOcjKD","toolName":"read","content":[{"type":"text","text":"import express from 'express';\nimport cors from 'cors';\nimport cookieParser from 'cookie-parser';\nimport swaggerUi from 'swagger-ui-express';\nimport helmet from 'helmet';\nimport { xssMiddleware } from '@/interface/middlewares/xss.middleware';\nimport { globalRateLimit } from '@/interface/middlewares/rate-limit.middleware';\nimport { jsonResponseMiddleware } from '@/interface/middlewares/response.middleware';\nimport { globalErrorHandler } from '@/interface/middlewares/error.middleware';\nimport router from '@/interface/routes/index';\nimport * as swaggerDocument from './interface/docs/swagger.json';\n\nconst app = express();\n\n// 1. CORS MUST be at the top to handle Preflight (OPTIONS)\nconst ALLOWED_ORIGINS = [\n  process.env.FRONTEND_URL,\n  process.env.FRONTEND_URL_2,\n  /\\.vercel\\.app$/,\n  'http://localhost:3001',\n  'http://localhost:3000',\n].filter(Boolean);\n\napp.use(\n  cors({\n    origin: ALLOWED_ORIGINS as (string | RegExp)[],\n    credentials: true,\n  }),\n);\n\n// 2. Decorate Response object early\napp.use(jsonResponseMiddleware);\n\n// 3. Security Headers with Cross-Origin support\napp.use(\n  helmet({\n    crossOriginResourcePolicy: { policy: 'cross-origin' },\n  }),\n);\n\n// 4. Other Global Middlewares\napp.use(xssMiddleware);\napp.use(globalRateLimit);\napp.use(express.json());\napp.use(cookieParser());\n\n// Swagger Documentation\napp.use('/api-docs', swaggerUi.serve, swaggerUi.setup(swaggerDocument));\n\n// Root Health Check — for infrastructure monitoring (Docker, K8s, Render)\napp.get('/health', (_req, res) => {\n  res.status(200).json({\n    status: 'ok',\n    service: 'dtlx-api',\n    timestamp: new Date().toISOString(),\n    uptime: process.uptime(),\n  });\n});\n\n// Main Router\napp.use('/api/v1', router);\n\n