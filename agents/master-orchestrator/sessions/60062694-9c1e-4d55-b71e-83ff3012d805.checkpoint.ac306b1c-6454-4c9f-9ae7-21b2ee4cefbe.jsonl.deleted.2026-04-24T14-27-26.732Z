{"type":"message","id":"fbe328e7","parentId":"748c4b87","timestamp":"2026-04-23T10:55:18.142Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"call_oqeq1B9xTjzzIjOZSGuW24NT","name":"read","arguments":{"path":"/root/.openclaw/workspaces2/projects/ahv-qlhv-fe/src/app/progress/page.tsx","offset":260,"limit":220}},{"type":"toolCall","id":"call_gOtNMhobHUtznRngwVEk90v3","name":"read","arguments":{"path":"/root/.openclaw/workspaces2/projects/ahv-qlhv-fe/src/components/progress/AddDatModal.tsx","offset":1,"limit":180}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-TroLy","usage":{"input":2216,"output":110,"cacheRead":97024,"cacheWrite":0,"totalTokens":99350,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776941708387,"responseId":"1776941710713"}}
{"type":"message","id":"561e5233","parentId":"fbe328e7","timestamp":"2026-04-23T10:55:18.186Z","message":{"role":"toolResult","toolCallId":"call_oqeq1B9xTjzzIjOZSGuW24NT","toolName":"read","content":[{"type":"text","text":"                <th className=\"px-6 py-4\">Học viên</th>\n                <th className=\"px-6 py-4\">Lý thuyết</th>\n                <th className=\"px-6 py-4\">Cabin</th>\n                <th className=\"px-6 py-4\">Sa hình</th>\n                <th className=\"px-6 py-4 min-w-[200px]\">DAT (km/h)</th>\n                <th className=\"px-6 py-4 text-center\">Tốt nghiệp</th>\n                <th className=\"px-6 py-4 text-right\">Thao tác</th>\n              </tr>\n            </thead>\n            <tbody className=\"divide-y divide-gray-50\">\n              {loading ? (\n                Array.from({ length: 6 }).map((_, i) => (\n                  <tr key={i}>\n                    <td className=\"px-6 py-4\">\n                      <Skeleton variant=\"rect\" height={20} width=\"60%\" />\n                    </td>\n                    <td className=\"px-6 py-4\">\n                      <Skeleton variant=\"rect\" height={20} width={80} />\n                    </td>\n                    <td className=\"px-6 py-4\">\n                      <Skeleton variant=\"rect\" height={20} width={80} />\n                    </td>\n                    <td className=\"px-6 py-4\">\n                      <Skeleton variant=\"rect\" height={20} width={80} />\n                    </td>\n                    <td className=\"px-6 py-4\">\n                      <Skeleton variant=\"rect\" height={20} width=\"70%\" />\n                    </td>\n                    <td className=\"px-6 py-4\">\n                      <Skeleton variant=\"rect\" height={20} width={90} />\n                    </td>\n                    <td className=\"px-6 py-4 text-right\">\n                      <Skeleton variant=\"rect\" height={32} width={100} className=\"inline-block\" />\n                    </td>\n                  </tr>\n                ))\n              ) : students.length === 0 ? (\n                <tr>\n                  <td colSpan={7} className=\"px-6 py-20 text-center text-gray-400 font-medium\">\n                    Không tìm thấy học viên nào.\n                  </td>\n                </tr>\n              ) : (\n                students.map((item, idx) => {\n                  const theoryStatus = item.progress_flags?.theory_completed ? 'done' : 'waiting';\n                  const cabinStatus = item.progress_flags?.cabin_completed ? 'done' : 'waiting';\n                  const sahinhStatus = item.progress_flags?.sand_yard_completed ? 'done' : 'waiting';\n                  const km = item.dat_stats?.total_km || 0;\n                  const requiredKm = parseInt(item.license_category_dat) || 840;\n                  const displayKm = Math.min(km, requiredKm);\n                  const datMins = item.dat_stats?.total_minutes || 0;\n                  const datOk = km >= requiredKm && datMins >= 480;\n                  const isEligible =\n                    item.progress_flags?.graduation_eligible ||\n                    (item.progress_flags?.theory_completed &&\n                      item.progress_flags?.cabin_completed &&\n                      item.progress_flags?.sand_yard_completed &&\n                      item.progress_flags?.simulation_completed &&\n                      datOk);\n                  const gradStatus = isEligible ? 'passed' : 'pending';\n\n                  const renderStatus = (status: string) => {\n                    if (status === 'done')\n                      return (\n                        <div className=\"flex items-center gap-1.5 text-emerald-600\">\n                          <CheckCircle2 className=\"w-4 h-4\" /> <span className=\"font-bold text-[11px]\">Hoàn thành</span>\n                        </div>\n                      );\n                    if (status === 'learning')\n                      return (\n                        <div className=\"flex items-center gap-1.5 text-indigo-600\">\n                          <PlayCircle className=\"w-4 h-4\" /> <span className=\"font-bold text-[11px]\">Đang học</span>\n                        </div>\n                      );\n                    return <div className=\"text-gray-400 font-medium text-[11px]\">- Chưa học -</div>;\n                  };\n\n                  const fullName = `${item.user_id?.last_name || ''} ${item.user_id?.first_name || ''}`;\n\n                  return (\n                    <tr key={`${item._id}-${idx}`} className=\"hover:bg-indigo-50/20 transition-colors group\">\n                      <td className=\"px-6 py-4\">\n                        <div className=\"flex flex-col\">\n                          <span\n                            onClick={() => {\n                              setSelectedStudentObj({\n                                id: item._id,\n                                name: fullName,\n                                phone: item.user_id?.phone || 'Chưa cập nhật',\n                                rank: item.license_category_name || item.license_category_id || 'N/A',\n                                region: item.region_id?.name || 'Chưa phân bổ',\n                                status: item.status_detail || 'Đang học',\n                              });\n                              setIsDetailDrawerOpen(true);\n                            }}\n                            className=\"font-extrabold text-sm text-indigo-700 hover:underline transition-colors cursor-pointer\"\n                          >\n                            {fullName}\n                          </span>\n                          <div className=\"flex flex-wrap items-center gap-2 mt-1\">\n                            <span className=\"px-1.5 py-0.5 rounded bg-blue-50 text-blue-700 text-[10px] font-black border border-blue-100\">\n                              {item.license_category_name || item.license_category_id || 'N/A'}\n                            </span>\n                            <span className=\"text-[10px] text-gray-400 font-medium\">{item.user_id?.phone}</span>\n                          </div>\n                        </div>\n                      </td>\n                      <td className=\"px-6 py-4\">{renderStatus(theoryStatus)}</td>\n                      <td className=\"px-6 py-4\">{renderStatus(cabinStatus)}</td>\n                      <td className=\"px-6 py-4\">{renderStatus(sahinhStatus)}</td>\n                      <td className=\"px-6 py-4\">\n                        <div className=\"flex flex-col gap-2\">\n                          <div className=\"flex items-center gap-3\">\n                            <span className=\"text-xs font-bold text-gray-600 w-14\">\n                              {displayKm.toFixed(1)} <span className=\"font-medium text-[10px]\">km</span>\n                            </span>\n                            <div className=\"flex-1 max-w-[120px] h-2.5 bg-gray-100 rounded-full overflow-hidden border border-gray-200\">\n                              <div\n                                className={`h-full rounded-full ${km >= requiredKm ? 'bg-emerald-500' : 'bg-primary'}`}\n                                style={{ width: `${Math.min(100, (km / requiredKm) * 100)}%` }}\n                              ></div>\n                            </div>\n                          </div>\n                        </div>\n                      </td>\n                      <td className=\"px-6 py-4 text-center\">\n                        <span\n                          className={`px-2 py-1 rounded-lg text-[10px] uppercase font-bold border ${\n                            gradStatus === 'passed'\n                              ? 'bg-emerald-50 text-emerald-600 border-emerald-200'\n                              : 'bg-rose-50 text-rose-500 border-rose-200'\n                          }`}\n                        >\n                          {gradStatus === 'passed' ? 'Đủ điều kiện' : 'Chưa đủ ĐK'}\n                        </span>\n                      </td>\n                      <td className=\"px-6 py-4 text-right\">\n                        <button\n                          onClick={() => {\n                            setSelectedStudent(fullName);\n                            setSelectedStudentObj(item);\n                            setIsDatModalOpen(true);\n                          }}\n                          className=\"inline-flex items-center gap-1.5 px-3 py-1.5 bg-indigo-600 text-white hover:bg-indigo-700 transition-colors rounded-lg font-bold text-[11px] shadow-sm shadow-indigo-600/25 active:scale-95\"\n                        >\n                          <Plus className=\"w-3.5 h-3.5\" /> Thêm DAT\n                        </button>\n                      </td>\n                    </tr>\n                  );\n                })\n              )}\n            </tbody>\n          </table>\n        </div>\n      </div>\n\n      <AddDatModal\n        isOpen={isDatModalOpen}\n        onClose={() => setIsDatModalOpen(false)}\n        studentName={selectedStudent}\n        enrollmentId={selectedStudentObj?.enrollment_id || selectedStudentObj?.enrollment?._id}\n        onSuccess={handleRefresh}\n      />\n\n      <StudentDetailDrawer\n        isOpen={isDetailDrawerOpen}\n        onClose={() => setIsDetailDrawerOpen(false)}\n        student={selectedStudentObj}\n        defaultTab=\"tiendo\"\n        onRefresh={handleRefresh}\n      />\n    </div>\n  );\n}\n"}],"isError":false,"timestamp":1776941718172}}
{"type":"message","id":"f5a0e20d","parentId":"561e5233","timestamp":"2026-04-23T10:55:18.197Z","message":{"role":"toolResult","toolCallId":"call_gOtNMhobHUtznRngwVEk90v3","toolName":"read","content":[{"type":"text","text":"'use client';\n\nimport React, { useState, useEffect } from 'react';\nimport { X, Calendar, MapPin, User, Save, Clock, Ruler } from 'lucide-react';\nimport { toast } from 'sonner';\nimport { addDatSession } from '@/src/services/datService';\nimport ViDateInput from '@/src/components/shared/ViDateInput';\n\ninterface AddDatModalProps {\n  isOpen: boolean;\n  onClose: () => void;\n  studentName?: string;\n  enrollmentId?: string;\n  onSuccess?: () => void;\n}\n\ninterface DatFormData {\n  date: string;\n  timeStart: string;\n  timeEnd: string;\n  duration: string;\n  distance: string;\n  note: string;\n}\n\nconst initialState: DatFormData = {\n  date: new Date().toISOString().split('T')[0],\n  timeStart: '',\n  timeEnd: '',\n  duration: '',\n  distance: '',\n  note: '',\n};\n\nconst FieldWrapper = ({\n  label,\n  required,\n  children,\n  field,\n  touched,\n  errors,\n  icon: Icon,\n}: {\n  label: string;\n  required?: boolean;\n  children: React.ReactNode;\n  field: string;\n  touched: Record<string, boolean>;\n  errors: Record<string, string>;\n  icon?: any;\n}) => {\n  const hasError = touched[field] && errors[field];\n  return (\n    <div className=\"flex flex-col gap-1.5\">\n      <label\n        className={`text-[10px] font-black uppercase tracking-widest flex items-center gap-1.5 transition-colors ${hasError ? 'text-rose-500' : 'text-gray-400'}`}\n      >\n        {Icon && <Icon className=\"w-3.5 h-3.5 text-indigo-500\" />}\n        {label} {required && <span className=\"text-rose-500\">*</span>}\n      </label>\n      <div className=\"relative group\">{children}</div>\n      {hasError && (\n        <p className=\"text-[10px] font-bold text-rose-500 mt-1 ml-1 animate-in fade-in slide-in-from-top-1\">\n          {errors[field]}\n        </p>\n      )}\n    </div>\n  );\n};\n\nexport default function AddDatModal({ isOpen, onClose, studentName = '', enrollmentId, onSuccess }: AddDatModalProps) {\n  const [loading, setLoading] = useState(false);\n  const [form, setForm] = useState<DatFormData>({ ...initialState });\n  const [errors, setErrors] = useState<Record<string, string>>({});\n  const [touched, setTouched] = useState<Record<string, boolean>>({});\n\n  useEffect(() => {\n    if (isOpen) {\n      setForm({ ...initialState, date: new Date().toISOString().split('T')[0] });\n      setErrors({});\n      setTouched({});\n    }\n  }, [isOpen]);\n\n  if (!isOpen) return null;\n\n  const validate = (data = form) => {\n    const errs: Record<string, string> = {};\n    if (!data.date) errs.date = 'Vui lòng chọn ngày học.';\n    if (!data.duration.trim()) errs.duration = 'Vui lòng nhập thời lượng.';\n    else if (isNaN(parseInt(data.duration)) || parseInt(data.duration) <= 0)\n      errs.duration = 'Thời lượng phải là số dương.';\n\n    if (!data.distance.trim()) errs.distance = 'Vui lòng nhập quãng đường.';\n    else if (isNaN(parseFloat(data.distance)) || parseFloat(data.distance) <= 0)\n      errs.distance = 'Quãng đường phải là số dương.';\n\n    setErrors(errs);\n    return errs;\n  };\n\n  const handleChange = (field: string, value: string) => {\n    const updated = { ...form, [field]: value };\n    setForm(updated);\n    if (touched[field]) {\n      validate(updated);\n    }\n  };\n\n  const handleBlur = (field: string) => {\n    setTouched((prev) => ({ ...prev, [field]: true }));\n    validate();\n  };\n\n  const handleSubmit = async (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!enrollmentId) {\n      toast.error('Không tìm thấy thông tin đăng ký của học viên.');\n      return;\n    }\n\n    const allTouched = { date: true, duration: true, distance: true, timeStart: true, timeEnd: true };\n    setTouched(allTouched);\n\n    const errs = validate();\n    if (Object.keys(errs).length > 0) {\n      toast.error('Vui lòng kiểm tra lại thông tin buổi DAT');\n      return;\n    }\n\n    setLoading(true);\n    try {\n      const startTime = form.timeStart || '08:00';\n      const endTime = form.timeEnd || '10:00';\n\n      const start = new Date(`${form.date}T${startTime}:00`);\n      const end = new Date(`${form.date}T${endTime}:00`);\n\n      if (end <= start) {\n        toast.error('Thời gian kết thúc phải sau thời gian bắt đầu.');\n        setLoading(false);\n        return;\n      }\n\n      const res = await addDatSession({\n        course_student_id: enrollmentId,\n        session_type: 'dat',\n        start_time: start.toISOString(),\n        end_time: end.toISOString(),\n        distance_km: parseFloat(form.distance),\n        notes: form.note,\n      });\n\n      if (res.success) {\n        toast.success(`Đã lưu thành công buổi DAT ${form.distance}km cho ${studentName}!`);\n        onSuccess?.();\n        onClose();\n      } else {\n        toast.error(res.message || 'Lỗi khi lưu dữ liệu DAT.');\n      }\n    } catch (error) {\n      toast.error('Lỗi khi kết nối đến máy chủ.');\n    } finally {\n      setLoading(false);\n    }\n  };\n\n  const getInputClass = (field: string) => {\n    const base =\n      'w-full px-4 py-2.5 bg-white border rounded-xl focus:outline-none focus:ring-4 transition-all text-sm font-medium';\n    if (touched[field] && errors[field]) {\n      return `${base} border-rose-300 bg-rose-50/20 text-rose-900 focus:ring-rose-500/10 focus:border-rose-500`;\n    }\n    return `${base} border-gray-200 focus:ring-indigo-500/10 focus:border-indigo-500`;\n  };\n\n  return (\n    <div className=\"fixed inset-0 z-50 flex items-center justify-center p-4 bg-gray-900/40 backdrop-blur-sm animate-in fade-in duration-300\">\n      <div className=\"bg-white/95 backdrop-blur-xl rounded-[2rem] w-full max-w-md shadow-2xl overflow-hidden animate-in zoom-in-95 duration-300 border border-white/20\">\n        {/* Header */}\n\n[142 more lines in file. Use offset=181 to continue.]"}],"isError":false,"timestamp":1776941718187}}
