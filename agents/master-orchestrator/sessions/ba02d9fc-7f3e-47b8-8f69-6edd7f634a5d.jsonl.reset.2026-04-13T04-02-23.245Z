https://gitlab.com/ahv-dtlx/ahv-dtlx-backend/-/commit/a8b246d7c6abe74bb69f8608dd8bc8a61a37a2da\"\n  },\n  {\n    \"id\": \"e3887cfec4c6e7c9f646f44f74c58660762d18fc\",\n    \"short_id\": \"e3887cfe\",\n    \"created_at\": \"2026-03-11T09:16:53.000+07:00\",\n    \"parent_ids\": [\n      \"a64eee97f19f45a6abddb8f42233adfad097cf2a\"\n    ],\n    \"title\": \"refactor(auth): migrate sensitive tokens from headers to secure cookies\",\n    \"message\": \"refactor(auth): migrate sensitive tokens from headers to secure cookies\\n\\n- Replace manual header-based token handling with httpOnly and secure cookies.\\n- Implement Bearer token support for mobile/third-party clients.\\n- Update Login, Change Password, and Refresh Token logic to sync with new storage.\\n- Enhance security by preventing XSS access to refresh tokens.\\n\",\n    \"author_name\": \"Ninh Thanh Khuong\",\n    \"author_email\": \"ninhem575@gmail.com\",\n    \"authored_date\": \"2026-03-11T09:16:53.000+07:00\",\n    \"committer_name\": \"Ninh Thanh Khuong\",\n    \"committer_email\": \"ninhem575@gmail.com\",\n    \"committed_date\": \"2026-03-11T09:16:53.000+07:00\",\n    \"trailers\": {},\n    \"extended_trailers\": {},\n    \"web_url\": \"https://gitlab.com/ahv-dtlx/ahv-dtlx-backend/-/commit/e3887cfec4c6e7c9f646f44f74c58660762d18fc\"\n  },\n  {\n    \"id\": \"54210ed49ee75ce40c938d8440c34423bb13e483\",\n    \"short_id\": \"54210ed4\",\n    \"created_at\": \"2026-03-10T08:34:15.000+00:00\",\n    \"parent_ids\": [\n      \"acad09580650d6311688d489f97df718985f13fa\",\n      \"a64eee97f19f45a6abddb8f42233adfad097cf2a\"\n    ],\n    \"title\": \"Merge branch 'feature/authentication-authorization' into 'refactor/main'\",\n    \"message\": \"Merge branch 'feature/authentication-authorization' into 'refactor/main'\\n\\nrefactor: replace environment.ts with centralized env.helper.ts\\n\\nSee merge request ahv-dtlx/ahv-dtlx-backend!154\",\n    \"author_name\": \"Hiếu Phạm Minh\",\n    \"author_email\": \"hieupm.98.tn