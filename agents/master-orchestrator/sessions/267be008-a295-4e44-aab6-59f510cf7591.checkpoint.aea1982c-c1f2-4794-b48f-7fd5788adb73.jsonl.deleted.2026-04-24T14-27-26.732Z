{"type":"message","id":"311c8c79","parentId":"58badf1e","timestamp":"2026-04-17T15:28:17.387Z","message":{"role":"toolResult","toolCallId":"call_function_d3eqkjeihmbw_1","toolName":"exec","content":[{"type":"text","text":"extraReducers: (builder) => {\n    builder\n      .addCase(login.pending, (state) => {\n        state.loading = true;\n        state.error = null;\n      })\n      .addCase(login.fulfilled, (state, action) => {\n        state.loading = false;\n        const payload = action.payload || {};\n        const doc = payload.doc || {};\n        state.user = {\n          ...payload,\n          ...doc,\n          roles: payload.roles || doc.role_name || [],\n        };\n      })\n      .addCase(login.rejected, (state, action) => {\n        state.loading = false;\n        state.error = action.payload;\n      })\n\n      // Replaced by local storage loading in ProtectedRoute/App\n  },\n});\n\nexport const { logout, setLocalToken, loadToken } = authSlice.actions;\nexport default authSlice.reducer;"}],"details":{"status":"completed","exitCode":0,"durationMs":68,"aggregated":"extraReducers: (builder) => {\n    builder\n      .addCase(login.pending, (state) => {\n        state.loading = true;\n        state.error = null;\n      })\n      .addCase(login.fulfilled, (state, action) => {\n        state.loading = false;\n        const payload = action.payload || {};\n        const doc = payload.doc || {};\n        state.user = {\n          ...payload,\n          ...doc,\n          roles: payload.roles || doc.role_name || [],\n        };\n      })\n      .addCase(login.rejected, (state, action) => {\n        state.loading = false;\n        state.error = action.payload;\n      })\n\n      // Replaced by local storage loading in ProtectedRoute/App\n  },\n});\n\nexport const { logout, setLocalToken, loadToken } = authSlice.actions;\nexport default authSlice.reducer;","cwd":"/root/.openclaw/workspaces2/v4-ecosystem-review/master-orchestrator"},"isError":false,"timestamp":17