{"type":"message","id":"c3c005e1","parentId":"1fee61bb","timestamp":"2026-04-17T14:31:32.467Z","message":{"role":"toolResult","toolCallId":"call_function_dpb78ined0n5_1","toolName":"exec","content":[{"type":"text","text":"=== QLHV FE — src/app layout ===\nimport type { Metadata } from \"next\";\nimport { Be_Vietnam_Pro } from \"next/font/google\";\nimport { Toaster, toast } from \"sonner\";\nimport Layout from \"@/src/components/layout/Layout\";\nimport { AuthProvider } from \"@/src/context/AuthContext\";\nimport AppleTopLoader from \"@/src/components/shared/AppleTopLoader\";\nimport { Suspense } from \"react\";\nimport \"./globals.css\";\n\nconst beVietnamPro = Be_Vietnam_Pro({\n  weight: ['400', '500', '600', '700'],\n  subsets: ['latin', 'vietnamese'],\n  display: 'swap',\n  variable: '--font-be-vietnam-pro',\n});\n\nexport const metadata: Metadata = {\n  title: \"QLHV Driving — Hệ thống quản lý đào tạo lái xe chuyên nghiệp\",\n  description: \"Giải pháp toàn diện tối ưu hóa quy trình quản lý học viên, học phí và lịch thi sát hạch cho các trung tâm đào tạo lái xe tại Việt Nam. Tự động hóa nhắc lịch Zalo và VietQR.\",\n  keywords: [\"quản lý đào tạo lái xe\", \"phần mềm quản lý học viên\", \"VietQR học phí\", \"tự động nhắc lịch Zalo\", \"phần mềm dạy lái xe\"],\n  authors: [{ name: \"QLHV Team\" }],\n  robots: \"index, follow\",\n  openGraph: {\n    title: \"QLHV Driving — Quản lý đào tạo lái xe thông minh\",\n    description: \"Nâng cao hiệu suất quản lý đào tạo lái xe với công nghệ 3-tap và tự động hóa toàn quy trình.\",\n    url: \"https://qlhv-driving.com\",\n    siteName: \"QLHV Driving\",\n    locale: \"vi_VN\",\n    type: \"website\",\n  },\n  twitter: {\n    card: \"summary_large_image\",\n    title: \"QLHV Driving — Hệ thống quản lý đào tạo lái xe\",\n    description: \"Số hóa quy trình đăng ký, học tập và thi sát hạch lái xe chuyên nghiệp.\",\n  },\n};\n\nexport const viewport = {\n  width: \"device-width\",\n  initialScale: 1,\n};\n\nconst jsonLd = {\n  \"@context\": \"https://schema.org\",\n  \"@graph\": [\n    {\n      \"@type\": \"SoftwareApplication\",\n      \"@id\": \"https://qlhv-driving.com/#software\",\n      \"name\": \"QLHV Driving\",\n      \"operatingSystem\": \"Web\",\n      \"applicationCategory\": \"BusinessApplication\",\n      \"description\": \"Hệ thống quản lý đào tạo lái xe (Student Management System) dành cho các trung tâm đào tạo và cơ sở tuyển sinh.\",\n      \"offers\": {\n        \"@type\": \"Offer\",\n        \"price\": \"0\",\n        \"priceCurrency\": \"VND\"\n      },\n      \"aggregateRating\": {\n        \"@type\": \"AggregateRating\",\n        \"ratingValue\": \"4.9\",\n        \"ratingCount\": \"1250\"\n      }\n    },\n    {\n      \"@type\": \"Organization\",\n      \"@id\": \"https://qlhv-driving.com/#organization\",\n      \"name\": \"QLHV Driving\",\n      \"url\": \"https://qlhv-driving.com\",\n      \"logo\": \"https://qlhv-driving.com/favicon.ico\",\n      \"contactPoint\": {\n        \"@type\": \"ContactPoint\",\n        \"telephone\": \"+84-123-456-789\",\n        \"contactType\": \"customer service\",\n        \"areaServed\": \"VN\",\n        \"availableLanguage\": \"Vietnamese\"\n      }\n    },\n    {\n      \"@type\": \"FAQPage\",\n      \"mainEntity\": [\n=== Sidebar ===\nsrc/components/layout/Sidebar.tsx"}],"details":{"status":"completed","exitCode":0,"durationMs":98,"aggregated":"=== QLHV FE — src/app layout ===\nimport type { Metadata } from \"next\";\nimport { Be_Vietnam_Pro } from \"next/font/google\";\nimport { Toaster, toast } from \"sonner\";\nimport Layout from \"@/src/components/layout/Layout\";\nimport { AuthProvider } from \"@/src/context/AuthContext\";\nimport AppleTopLoader from \"@/src/components/shared/AppleTopLoader\";\nimport { Suspense } from \"react\";\nimport \"./globals.css\";\n\nconst beVietnamPro = Be_Vietnam_Pro({\n  weight: ['400', '500', '600', '700'],\n  subsets: ['latin', 'vietnamese'],\n  display: 'swap',\n  variable: '--font-be-vietn