{"type":"message","id":"fe078b8e","parentId":"a8606552","timestamp":"2026-04-17T14:32:13.264Z","message":{"role":"toolResult","toolCallId":"call_function_jfkin82kt7kw_1","toolName":"exec","content":[{"type":"text","text":"import {\n  MdDashboard,\n  MdStar,\n  MdGroups,\n  MdCalendarToday,\n  MdCalendarMonth,\n  MdCurrencyExchange,\n  MdOutlinePerson,\n  MdHistory,\n  MdManageHistory,\n  MdSettings,\n  MdOutlineSettingsSuggest,\n} from \"react-icons/md\";\nimport { GiTeacher } from \"react-icons/gi\";\nimport { FaAddressBook } from \"react-icons/fa\";\nimport { FaUser } from \"react-icons/fa\";\nimport { BiSolidUserAccount } from \"react-icons/bi\";\nimport { MdPayments } from \"react-icons/md\";\nimport { VscSourceControl } from \"react-icons/vsc\";\nimport { FaRankingStar, FaRoad } from \"react-icons/fa6\";\nimport { RiRoadsterFill } from \"react-icons/ri\";\nimport { GrSystem } from \"react-icons/gr\";\n\nexport const menuItems = [\n  {\n    type: \"item\",\n    href: \"/dashboard\",\n    icon: <MdDashboard className=\"text-success\" />,\n    label: \"Dashboard\",\n    roles: [\"admin\"],\n  },\n  {\n    type: \"submenu\",\n    label: \"Quản lý Sales\",\n    icon: <MdGroups className=\"text-primary\" />,\n    id: \"sale\",\n    roles: [\"admin\", \"sale\"],\n    children: [\n      {\n        type: \"item\",\n        href: \"/leads\",\n        icon: <MdStar className=\"text-primary\" />,\n        label: \"Quản lý Leads\",\n        roles: [\"admin\", \"sale\"],\n      },\n      {\n        type: \"item\",\n        href: \"/sales\",\n        icon: <MdGroups className=\"text-primary\" />,\n        label: \"Danh sách sale\",\n        roles: [\"admin\", \"sale\"],\n      },\n      {\n        type: \"item\",\n        href: \"/guests\",\n        icon: <MdGroups className=\"text-primary\" />,\n        label: \"Khách hàng đăng ký\",\n        roles: [\"admin\", \"sale\"],\n      },\n    ],\n  },\n\n  {\n    type: \"submenu\",\n    label: \"Quản lý học viên\",\n    icon: <FaU