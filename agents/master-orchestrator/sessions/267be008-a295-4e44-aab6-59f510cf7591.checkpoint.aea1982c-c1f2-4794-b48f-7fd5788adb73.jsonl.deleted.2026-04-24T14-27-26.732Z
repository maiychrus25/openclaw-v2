{"type":"message","id":"5bc6aadb","parentId":"e1805411","timestamp":"2026-04-17T14:31:59.219Z","message":{"role":"toolResult","toolCallId":"call_function_bp537myqaoha_1","toolName":"exec","content":[{"type":"text","text":"import React, { useEffect, useState } from \"react\";\nimport SimpleBar from \"simplebar-react\";\nimport { TbChevronRight } from \"react-icons/tb\";\nimport { NavLink, useLocation } from \"react-router-dom\";\nimport { IoMdClose } from \"react-icons/io\";\nimport { Button } from \"antd\";\nimport { useSelector } from \"react-redux\";\n\nimport { menuItems } from \"../constants/menu.constant\";\nimport { getHighestRole, ROLE_HOME } from \"../constants/role.constant\";\nimport \"simplebar-react/dist/simplebar.min.css\";\n\nconst SideNav = ({ isCondensed }) => {\n  const { pathname } = useLocation();\n  const roles = useSelector((state) => state.auths?.user?.roles);\n\n  const [openMenus, setOpenMenus] = useState({});\n\n  const toggleMenu = (id) => {\n    setOpenMenus((prev) => ({\n      ...prev,\n      [id]: !prev[id],\n    }));\n  };\n\n  const hasPermission = (itemRoles) => {\n    if (!itemRoles) return true;\n    return itemRoles.some((r) => roles.includes(r));\n  };\n\n  const filteredMenu = menuItems\n    .map((item) => {\n      if (item.type === \"submenu\") {\n        const filteredChildren = item.children.filter((child) =>\n          hasPermission(child.roles)\n        );\n\n        if (!hasPermission(item.roles) && filteredChildren.length === 0) {\n          return null;\n        }\n\n        return { ...item, children: filteredChildren };\n      }\n\n      if (!hasPermission(item.roles)) return null;\n\n      return item;\n    })\n    .filter(Boolean);\n\n  const highestRole = getHighestRole(roles);\n  const home = ROLE_HOME[highestRole] || \"/403\";\n\n  useEffect(() => {\n    const newOpenMenus = {};\n\n    menuItems.forEach((item) => {\n      if (item.type === \"submenu\") {\n        const hasActiveChild = item.children.some((c) => pathname === c.href);\n        if (hasActiveChild) {\n          newOpenMenus[item.id] = true;\n        }\n      }\n    });\n\n    setOpenMenus((prev) => ({ ...prev, ...newOpenMenus }));\n  }, [pathname]);\n\n  return (\n    <div className=\"sidenav-menu\">\n      <a href={home} className=\"logo\" style={{ padding: 0 }}>\n        <span className=\"logo-light\">\n          <span className=\"logo-lg\">\n            <img\n              style={{ height: 70 }}\n              src=\"/assets/images/logoPhucAn.png\"\n              alt=\"logo\"\n            />\n          </span>\n          <span className=\"logo-sm\">\n            <img\n              style={{ height: 48 }}\n              src=\"/assets/images/logoPhucAn.png\"\n              alt=\"small logo\"\n            />\n          </span>\n        </span>\n        <span className=\"logo-dark\">\n          <span className=\"logo-lg\">\n            <img\n              style={{ height: \"70px\" }}\n              src=\"/assets/images/logoPhucAn.png\"\n              alt=\"logo\"\n            />\n          </span>\n          <span className=\"logo-sm\">\n            <img\n              style={{ height: \"48px\" }}\n              src=\"/assets/images/logoPhucAn.png\"\n              alt=\"small logo\""}],"details":{"status":"completed","exitCode":0,"durationMs":74,"aggregated":"import React, { useEffect, useState } from \"react\";\nimport SimpleBar from \"simplebar-react\";\nimport { TbChevronRight } from \"react-icons/tb\";\nimport { NavLink, useLocation } from \"react-router-dom\";\nimport { IoMdClose } from \"react-icons/io\";\nimport { Button } from \"antd\";\nimport { useSelector } from \"react-redux\";\n\nimport { menuItems } from \"../constants/menu.constant\";\nimport { getHighestRole, ROLE_HOME } from \"../constants/role.constant\";\nimport \"simplebar-react/dist/simplebar.min.css\";\n\nconst SideNav = ({ isCondensed }) => {\n  const { pathname } = useLocation();\n  const roles = useSelector((state) => state.auths?.user?.roles);\n\n  const [openMenus, setOpenMenus] = useState({});\n\n  const toggleMenu = (id) => {\n    setOpenMenus((prev) => ({\n      ...prev,\n      [id]: !prev[id],\n    }));\n  };\n\n  const hasPermission = (itemRoles) => {\n    if (!itemRoles) return true;\n    return itemRoles.some((r) => roles.includes(r));\n  };\n\n  const filteredMenu = menuItems\n    .map((item) => {\n      if (item.type === \"submenu\") {\n        const filteredChildren = item.children.filter((child) =>\n          hasPermission(child.roles)\n        );\n\n        if (!hasPermission(item.roles) && filteredChildren.length === 0) {\n          return null;\n        }\n\n        return { ...item, children: filteredChildren };\n      }\n\n      if (!hasPermission(item.roles)) return null;\n\n      return item;\n    })\n    .filter(Boolean);\n\n  const highestRole = getHighestRole(roles);\n  const home = ROLE_HOME[highestRole] || \"/403\";\n\n  useEffect(() => {\n    const newOpenMenus = {};\n\n    menuItems.forEach((item) => {\n      if (item.type === \"submenu\") {\n        const hasActiveChild = item.children.some((c) => pathname === c.href);\n        if (hasActiveChild) {\n          newOpenMenus[item.id] = true;\n        }\n      }\n    });\n\n    setOpenMenus((prev) => ({ ...prev, ...newOpenMenus }));\n  }, [pathname]);\n\n  return (\n    <div className=\"sidenav-menu\">\n      <a href={home} className=\"logo\" style={{ padding: 0 }}>\n        <span className=\"logo-light\">\n          <span className=\"logo-lg\">\n            <img\n              style={{ height: 70 }}\n              src=\"/assets/images/logoPhucAn.png\"\n              alt=\"logo\"\n            />\n          </span>\n          <span className=\"logo-sm\">\n            <img\n              style={{ height: 48 }}\n              src=\"/assets/images/logoPhucAn.png\"\n              alt=\"small logo\"\n            />\n          </span>\n        </span>\n        <span className=\"logo-dark\">\n          <span className=\"logo-lg\">\n            <img\n              style={{ height: \"70px\" }}\n              src=\"/assets/images/logoPhucAn.png\"\n              alt=\"logo\"\n            />\n          </span>\n          <span className=\"logo-sm\">\n            <img\n              style={{ height: \"48px\" }}\n              src=\"/assets/images/logoPhucAn.png\"\n              alt=\"small logo\"","cwd":"/root/.openclaw/workspaces2/v4-ecosystem-review/master-orchestrator"},"isError":false,"timestamp":1776436319162}}
