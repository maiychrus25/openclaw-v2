/departments/department.route';\nimport EmployeeRouter from '@modules/employees/employee.route';\nimport DeductionsRouter from '@modules/deductions/deductions.route';\nimport LeaveRequests from '@modules/leaveRequests/leaveRequests.route';\nimport LeaveBalances from '@modules/leaveBalances/leaveBalances.route';\nimport AttendancesRouter from '@modules/attendances/attendances.route';\nimport shiftRoute from '@modules/shifts/shift.route';\nimport SalaryDecisionRouter from '@modules/salaryDecision/salaryDecision.route';\nimport scheduleRoute from '@modules/schedules/schedule.route';\nimport payrollRoute from '@modules/payroll/payroll.route';\nimport contractsRoute from '@modules/contracts/contracts.route';\nimport payrollDetailsRoute from '@modules/payrollDetails/payrollDetails.route';\nimport SystemLogRoute from '@modules/systemLogs/systemLog.route';\nimport OKRsRoute from '@modules/okrs/okrs.route';\nimport OKRCommentRoute from '@modules/okrComments/okrComments.route';\nimport keyResultRoute from '@modules/keyResults/keyResults.route';\nimport keyResultScoreRoute from '@modules/keyResultScores/keyResultScores.route';\nimport objectiveRoute from '@modules/objectives/objectives.route';\nimport keyResultLinkRoute from '@modules/keyResultLinks/keyResultLinks.route';\nimport NikoCriteriaRoute from '@modules/nikoCriteria/nikoCriteria.route';\nimport NikoGiftsRoute from '@modules/nikoGifts/nikoGifts.route';\nimport NikoGiftCartsRoute from '@modules/nikoGiftCarts/nikoGiftCarts.route';\nimport NikoOrdersRoute from '@modules/nikoOrders/nikoOrders.route';\nimport NikoSectorsRoute from '@modules/nikoSectors/nikoSector.route';\nimport NikoEmotionsRoute from '@modules/nikoEmotions/nikoEmotion.route';\nimport NikoWalletsRoute from '@modules/nikoWallets/nikoWallets.route';\nimport AccountRoleRoute from '@modules/accountRoles/accountRole.route';\nimport CheckinRoute from '@modules/checkins/checkins.route';\nimport PermissionRoute from '@modules/permissions/permission.route';\nimport { createAttendanceFromDevice } from '@modules/attendances/attendances.controller';\nimport { authenticationMiddleware } from '@common/middlewares/authen.middleware';\nimport { authorizationPermissionMiddleware } from '@common/middlewares/author.middleware';\nimport multer from 'multer';\n\nconst storage = multer.diskStorage({\n    destination: (req, file, cb) => {\n        cb(null, './uploads');\n    },\n});\nconst upload = multer({ storage: storage });\n\nconst router = Router();\n\n// ===== Auth & Core =====\nrouter.use('/auth', AuthRoute);\n\n// ===== Master data =====\nrouter.use('/roles', authenticationMiddleware, authorizationPermissionMiddleware, RoleRoute);\n\n=== payroll service ===\nimport { IApiResponse, IPaginatedResponse } from '@common/interfaces/response.interface';\nimport { ApiError } from '@common/utils/ApiError';\nimport PayrollModel from './payroll.model';\nimport { QueryFilter } from 'mongoose';\nimport { IPayroll, IPayrollFilter, IPayrollFilterGetOne, IPayrollPayload } from '@common/interfaces/payroll.interface';\n\nexport class PayrollService {\n    public async createPayroll(payload: IPayrollPayload): Promise<IApiResponse<IPayroll>> {\n        const newDeductions = await PayrollModel.create(payload);\n        return {\n            success: true,\n            message: 'Tạo bảng lương thành công',\n            data: newDeductions,\n        };\n    }\n\n    public async getOnePayroll(filter: IPayrollFilterGetOne): Promise<IApiResponse<IPayroll>> {\n        const record = await PayrollModel.findOne(filter);\n        if (!record) {\n            return {\n                success: false,\n                message: 'Không tìm thấy bảng lương',\n                data: null,\n            };\n        }\n        return {\n            success: true,\n            message: 'Đã thấy bảng lương',\n            data: record,\n        };\n    }\n\n    public async getPayrollByFilter(filter: IPayrollFilter): Promise<IPaginatedResponse<IPayroll>> {\n        const limit = filter.limit || 10;\n        const page = filter.page || 1;\n        const query: QueryFilter<IPayrollFilter> = {};\n\n        if (filter.employeeId) {\n            query.employeeId = filter.employeeId;\n        }\n\n=== systemLogs service ===\nimport { IApiResponse, IPaginatedResponse } from '@common/interfaces/response.interface';\nimport SystemLogModel from './systemLog.model';\nimport { ApiError } from '@common/utils/ApiError';\nimport { PipelineStage } from 'mongoose';\nimport { ISystemLogs, ISystemLogsFilter, ISystemLogsPayload } from '@common/interfaces/systemLog.interface';\n\nexport class SystemLogService {\n    public async createSystemLog(payload: ISystemLogsPayload): Promise<IApiResponse<ISystemLogs>> {\n        const newDepartment = await SystemLogModel.create(payload);\n        return {\n            success: true,\n            message: 'Tạo lịch chấm công thành công',\n            data: newDepartment,\n        };\n    }\n\n    public async getSystemLogsByFilter(filter: ISystemLogsFilter): Promise<IPaginatedResponse<ISystemLogs>> {\n        const limit = filter.limit || 10;\n        const page = filter.page || 1;\n        const aggregateQuery: PipelineStage[] = [\n            { $sort: { createdAt: -1 } },\n            { $skip: (page - 1) * limit },\n            { $limit: limit },\n        ];\n\n        const [records, docCounter] = await Promise.all([\n            SystemLogModel.aggregate(aggregateQuery),\n            SystemLogModel.aggregate([...aggregateQuery, { $count: 'count' }]),\n        ]);\n        const count = docCounter[0]?.count || 0;\n\n        return {\n            data: records,\n            success: true,\n            message: 'Lấy danh sách lịch chấm công thành công',\n            meta: {\n                totalItems: count,\n                itemCount: records.length,\n                itemsPerPage: limit,\n                totalPages: Math.ceil(count / limit),\n\n=== contracts service ===\nimport { IApiResponse, IPaginatedResponse } from '@common/interfaces/response.interface';\nimport { ApiError } from '@common/utils/ApiError';\nimport ContractsModel from './contracts.model';\nimport { QueryFilter } from 'mongoose';\nimport { IPayroll } from '@common/interfaces/payroll.interface';\nimport {\n    IContracts,\n    IContractsFilter,\n    IContractsFilterGetOne,\n    IContractsPayload,\n} from '@common/interfaces/contracts.interface';\n\nexport class ContractsService {\n    public async createContract(payload: IContractsPayload): Promise<IApiResponse<IContracts>> {\n        const newContract = await ContractsModel.create(payload);\n        return {\n            success: true,\n            message: 'Tạo hợp đồng thành công',\n            data: newContract,\n        };\n    }\n\n    public async getOneContract(filter: IContractsFilterGetOne): Promise<IApiResponse<IContracts>> {\n        const record = await ContractsModel.findOne(filter);\n        if (!record) {\n            return {\n                success: false,\n                message: 'Không tìm thấy hợp đồng',\n                data: null,\n            };\n        }\n        return {\n            success: true,\n            message: 'Đã thấy hợp đồng',\n            data: record,\n        };\n    }\n\n    public async getContractsByFilter(filter: IContractsFilter): Promise<IPaginatedResponse<IPayroll>> {\n        const limit = filter.limit || 10;","cwd":"/root/.openclaw/workspaces2/v4-ecosystem-review/master-orchestrator"},"isError":false,"timestamp":1775982450527}}
{"type":"message","id":"162a4f11","parentId":"4af07a6d","timestamp":"2026-04-12T08:27:47.260Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now I have enough information to write all the review reports. Let me write them now.\n\nKey findings summary:\n\n**Database:**\n1. CRITICAL: Missing indexes on most collections (attendances, departments, positions, contracts, payrolls, employees, roles, permissions, systemLogs)\n2. CRITICAL: Employees has no unique constraints on email, code, phone, tamCode\n3. HIGH: Attendances.date stored as String (not Date) - prevents native date queries/indexes\n4. HIGH: systemLogs has no TTL index - will grow unbounded\n5. HIGH: Inconsistent ref usage in accounts.model (employeeId is ref but not validated as ObjectId)\n\n\n6. MEDIUM: Contracts and Payrolls also lack proper indexing, while MongoDB write concern and replica set options aren't configured\n7. MEDIUM: NikoOrders denormalizes giftName and giftImage instead of using refs\n8. MEDIUM: No soft delete pattern anywhere in the system\n\n**Security:**\n1. CRITICAL: No rate limiting on any endpoint\n2. CRITICAL: Default password '123456' used when creating employees\n3. HIGH: No refresh token mechanism - access tokens must be short-lived or users get logged out\n4. HIGH: CORS origin is false in production, blocking legitimate traffic\n5. HIGH: Missing password strength validation (Joi schema only enforces minimum length)\n6. HIGH: NikoOrders missing authorization checks on employeeId\n7. MEDIUM: No helmet.js for security headers\n8. MEDIUM: Missing audit trail for permission changes\n\n**Backend Architecture:**\n1. Clean Architecture with Controllers → Services → Models layering\n2. Redis caching with getOrSet pattern for permissions\n3. Socket.IO for real-time events\n4. But: Services are instantiated as singletons with new - not proper DI\n5. No interface-based abstraction\n6. No transaction support for multi-document writes\n\n**Code Quality:**\n1. DRY violation in employee creation - auto-creates account, role, and wallet in controller\n2. Inconsistent return types across the codebase\n3. TypeScript types scattered across interfaces and models\n4. Validation, error handling, and response formats all lack consistency\n\n**Frontend:**\n1. Solid foundation with lazy loading, routing guards, Redux Toolkit, and Axios interceptors\n2. Major gaps: no error interceptor for Axios, no auth state persistence, no module-level code splitting, and unused axios.ts file\n3. Missing critical features: dark mode, responsive table components, and empty states\n4. Incomplete Redux RTK setup for mutations\n\n**Performance:**\n1. Most models lack indexes, and systemLogs will grow indefinitely without TTL management\n2. Payroll and systemLogs aggregations are inefficient, and auth middleware repeatedly queries account and role data instead of caching\n3. Frontend missing virtual scrolling for large datasets\n\nNow I'm going to write all these reports.","thinkingSignature":"0200b00e66b9bf68c6e69d7355076a8bcda396c41e667210a82328719ff39f03"},{"type":"text","text":"I now have enough data from the source. Let me write all review reports directly.\n"},{"type":"toolCall","id":"call_function_niuoizvd5spu_1","name":"exec","arguments":{"command":"mkdir -p /root/.openclaw/workspaces2/v4-ecosystem-review/master-orchestrator/reviews","timeout":5}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":2215,"output":670,"cacheRead":44473,"cacheWrite":5429,"totalTokens":52787,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775982450560,"responseId":"062a8a744ecbe40427c8788d2e732004"}}
{"type":"message","id":"4ee5d838","parentId":"162a4f11","timestamp":"2026-04-12T08:27:47.356Z","message":{"role":"toolResult","toolCallId":"call_function_niuoizvd5spu_1","toolName":"exec","content":[{"type":"text","text":"(no output)"}],"details":{"status":"completed","exitCode":0,"durationMs":23,"aggregated":"","cwd":"/root/.openclaw/workspaces2/v4-ecosystem-review/master-orchestrator"},"isError":false,"timestamp":1775982467339}}
{"type":"message","id":"d3845af6","parentId":"4ee5d838","timestamp":"2026-04-12T08:28:35.326Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me write all the review reports. I'll start with the database review, then security, then the others.","thinkingSignature":"ebd6eaf63eda2c05950074f85e08b394fef38d36c219f26b539b37d6bdec3ffb"},{"type":"toolCall","id":"call_function_6hbodpevj4na_1","name":"write","arguments":{"path":"/root/.openclaw/workspaces2/v4-ecosystem-review/master-orchestrator/reviews/database.md","content":"# 🗄️ Database Review — AHV Works Backend\n**Branch:** `develop` (SHA: bfdf0515)  \n**Source:** `ahv-works/ahv-hrm/ahv-hrm-backend` (GitLab #78077025)  \n**Reviewed by:** Orbis — Database Reviewer (via master-orchestrator direct audit)  \n**Models reviewed:** 39 model files via Git LFS archive\n\n---\n\n## ✅ STRENGTHS\n\n- **Good use of `timestamps: true`** — all 23 schemas use `createdAt` / `updatedAt` consistently via Mongoose timestamps\n- **`unique: true` index on `LeaveBalances`** (`employeeId + year`) prevents duplicate balance records\n- **`unique: true` index on `NikoEmotions`** (`employeeId + date`) ensures one mood per employee per day\n- **`select: false` on password field** in AccountSchema — prevents accidental password exposure in queries\n- **`Schema.Types.Mixed`** used for `oldValue/newValue` in SystemLog — flexible enough to store any change\n- **Enum validation via `IAccountStatus`, `IPayrollStatus`, etc.** — consistent status fields across schemas\n- **Referential integrity via `ref: 'Employees'`** on most foreign keys (leaveRequests, checkins, nikoWallets, etc.)\n- **Subdocument validation** — CheckinConfirmationSchema and OrderItemSchema are properly defined subdocs\n\n---\n\n## 🚨 CRITICAL ISSUES\n\n### C1. Employees — No Unique Constraints on Critical Fields\n**File:** `src/modules/employees/employees.model.ts`\n\nThe `Employees` collection has NO unique indexes on `email`, `code`, `phone`, or `tamCode`. The service layer checks for duplicates manually before insert:\n\n```ts\n// employees.service.ts — sequential findOne before every insert\nconst exitedEmployee = await EmployeesModel.findOne({ email: payload.email });\nconst exitedEmployee = await EmployeesModel.findOne({ code: payload.code });\nconst exitedEmployee = await EmployeesModel.findOne({ phone: payload.phone });\n```\n\nThis is a **TOCTOU race condition**. Two concurrent requests can both pass the checks and insert duplicates. Fix with unique indexes:\n\n```ts\nEmployeesSchema.index({ email: 1 }, { unique: true, sparse: true });\nEmployeesSchema.index({ code: 1 }, { unique: true, sparse: true });\nEmployeesSchema.index({ phone: 1 }, { unique: true, sparse: true });\nEmployeesSchema.index({ tamCode: 1 }, { unique: true, sparse: true });\n```\n\n### C2. Attendances — `date` Field Stored as String (Not Date)\n**File:** `src/modules/attendances/attendances.model.ts`\n\n```ts\ndate: { type: String }, // ❌ Should be Date\n```\n\nStoring dates as strings breaks:\n- Native `$gte`, `$lte` date range queries\n- MongoDB date indexing\n- Timezone handling\n- Any date arithmetic on the DB side\n\n**Fix:** Change to `type: Date` and store as ISO date string `YYYY-MM-DD`.\n\n### C3. Accounts — `employeeId` Missing `ref` Declaration\n**File:** `src/modules/accounts/accounts.model.ts`\n\n```ts\nemployeeId: { type: Types.ObjectId, trim: true }, // ❌ Missing ref\n```\n\nOther collections correctly use `ref: 'Employees'` but accounts does not. This breaks Mongoose population and prevents referential integrity checks.\n\n### C4. Contracts & Payrolls — No Indexes At All\n**Files:** `src/modules/contracts/contracts.model.ts`, `src/modules/payroll/payroll.model.ts`\n\nThese high-traffic, large datasets have ZERO indexes beyond the default `_id`. Common query patterns will do full collection scans:\n- `Payroll`: `employeeId`, `year+month`, `status`\n- `Contracts`: `employeeId`, `status`, `departmentId`\n\n---\n\n## 🔴 HIGH ISSUES\n\n### H1. systemLogs — No TTL Index (Unbounded Growth)\n**File:** `src/modules/systemLogs/systemLog.model.ts`\n\nSystem logs accumulate indefinitely. With heavy write volume (every mutation logged), this collection will balloon and degrade overall DB performance. No archival or TTL strategy.\n\n**Fix:** Add a TTL index:\n```ts\nSystemLogSchema.index(\n  { createdAt: 1 },\n  { expireAfterSeconds: 90 * 24 * 60 * 60 } // 90 days\n);\n```\n\n### H2. systemLogs — No Indexes for Common Queries\n**File:** `src/modules/systemLogs/systemLog.model.ts`\n\nMissing indexes on: `accountId`, `action`, `effectTable`, `recordId`. The service sorts by `createdAt: -1` but even that lacks an index.\n\n### H3. Payroll — No Compound Index for Salary Queries\n**File:** `src/modules/payroll/payroll.model.ts`\n\nPayroll queries filter by `employeeId + year + month` (the natural key). Add:\n```ts\nPayrollSchema.index({ employeeId: 1, year: 1, month: 1 }, { unique: true });\nPayrollSchema.index({ status: 1 });\n```\n\n### H4. Departments — No Indexes\n**File:** `src/modules/departments/department.model.ts`\n\nMissing: `parentId` (for tree queries), `managerId`, `code` (likely unique), `status`.\n\n### H5. Positions — No Indexes\n**File:** `src/modules/positions/positions.model.ts`\n\nEmpty model file (just exports empty schema). No indexes defined at all.\n\n### H6. NikoOrders — Denormalized Gift Data\n**File:** `src/modules/nikoOrders/nikoOrders.model.ts`\n\n```ts\nOrderItemSchema = {\n    giftId: { type: Types.ObjectId, ref: 'Niko-Gifts' },\n    giftName: { type: String, required: true },    // denormalized\n    giftImage: { type: String },                    // denormalized\n    price: { type: Number, required: true },        // denormalized\n}\n```\n\nGift details are stored redundantly. If a gift is updated (price change, name change), historical orders become inconsistent. Only store `giftId` and look up current price at query time if needed for display.\n\n### H7. No Soft Delete Anywhere\nNo collection uses a `deletedAt` or `isDeleted` field. Once a record is deleted, it's gone. This is dangerous for: employees, contracts, payroll records, system logs. Consider adding soft delete for audit-critical entities.\n\n---\n\n## 🟡 MEDIUM ISSUES\n\n### M1. Inconsistent Schema Conventions\n\n| Collection | Naming | Timestamps | Index Count |\n|---|---|---|---|\n| Accounts | camelCase | ✅ | 2 |\n| Employees | camelCase | ✅ | 2 |\n| Attendances | camelCase | ✅ | 0 ❌ |\n| Departments | camelCase | ✅ | 0 ❌ |\n| Contracts | camelCase | ✅ | 0 ❌ |\n| Payroll | camelCase | ✅ | 0 ❌ |\n| SystemLogs | camelCase | ✅ | 0 ❌ |\n| Roles | ? | ? | 0 ❌ |\n| Permissions | ? | ? | 0 ❌ |\n| LeaveRequests | ✅ compound idx | ✅ | 2 |\n\n### M2. MongoDB Write Concern Not Enforced\n**File:** `src/common/config/database.ts`\n\nReplica set write concern (`w: 'majority'`) and read preferences are configured via env vars but not verified on startup. If a single-node MongoDB is used, these settings silently degrade.\n\n### M3. KeyResults — Score Array Design\n**File:** `src/modules/keyResults/keyResults.model.ts`\n\n```ts\nscore: { type: [Number] }  // Array of numbers — what does each represent?\n```\n\nNo documentation on what each array element means. Is it a history of scores? Weekly snapshots? Consider an explicit subdocument:\n```ts\nscores: [{\n    date: Date,\n    value: Number,\n    updatedBy: Types.ObjectId\n}]\n```\n\n### M4. Attendances — `records` Array of Dates\n**File:** `src/modules/attendances/attendances.model.ts`\n\n```ts\nrecords: { type: [Date] }  // Multiple clock-in/out events per day\n```\n\nThis array can grow large with frequent punching. Evaluate whether embedding is better or if a separate `AttendanceRecord` collection is needed for high-frequency attendance tracking.\n\n### M5. OKRs — Quarter Enum Parsing Bug Risk\n**File:** `src/modules/okrs/okrs.model.ts`\n\n```ts\nquarter: {\n    type: Number,\n    enum: Object.values(IOKRQuarter).filter((key) => !isNaN(Number(key))),\n}\n```\n\nFiltering with `!isNaN(Number(key))` will include enum values that are numeric strings but may miss edge cases. Safer approach: define quarters as pure integers in the enum.\n\n---\n\n## 📋 RECOMMENDATIONS\n\n### Schema Design\n1. Add all missing unique indexes (Employees: email, code, phone; Payroll: employeeId+year+month)\n2. Change `Attendances.date` from String to Date\n3. Add `ref: 'Employees'` to accounts.employeeId\n4. Add `deletedAt: Date` soft-delete field to critical collections\n\n### Indexing Strategy\n5. Audit all list/query endpoints in services and add matching compound indexes\n6. Add TTL index on SystemLogs (90 days)\n7. Add compound indexes on Payroll, Contracts, Departments, Positions, SystemLogs\n\n### Relationships & Denormalization\n8. Denormalize gift data in NikoOrders only if historical accuracy is required; otherwise reference-only\n9. Consider embedding `CheckinConfirmationSchema` directly in Checkin (already done) — verify this works well at scale\n\n### Operational\n10. Set up MongoDB Atlas dashboard alerts for: index miss rate, document growth rate, slow queries (>100ms)\n11. Document expected document counts per collection and set up archival automation\n\n### Security\n12. Add `sparse: true` on optional unique indexes (email, phone) to allow null values\n13. Review `Schema.Types.Mixed` usage in SystemLog — consider strict schema for audit trail integrity\n\n---\n\n## 🔧 PRIORITY FIX LIST\n\n| # | Priority | Fix | Collection | Effort | Owner |\n|---|---|---|---|---|---|\n| 1 | 🔴 P0 | Unique indexes on Employees (email, code, phone) | Employees | Low | Backend |\n| 2 | 🔴 P0 | Fix Attendances.date → Date type + index | Attendances | Low | Backend |\n| 3 | 🔴 P0 | Add ref to accounts.employeeId | Accounts | Low | Backend |\n| 4 | 🔴 P0 | Payroll compound unique index (emp+year+month) | Payroll | Low | Backend |\n| 5 | 🟠 P1 | TTL index on SystemLogs (90 days) | SystemLogs | Low | Backend |\n| 6 | 🟠 P1 | Indexes on Contracts (employeeId, status, deptId) | Contracts | Low | Backend |\n| 7 | 🟠 P1 | Indexes on Departments (parentId, managerId, code) | Departments | Low | Backend |\n| 8 | 🟠 P1 | Indexes on SystemLogs (accountId, action, effectTable) | SystemLogs | Low | Backend |\n| 9 | 🟡 P2 | Soft delete field on Employees, Contracts, Payroll | Multiple | Medium | Backend |\n| 10 | 🟡 P2 | Remove denormalization in NikoOrders | NikoOrders | Medium | Backend |\n"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":95,"output":2553,"cacheRead":49262,"cacheWrite":3448,"totalTokens":55358,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775982467361,"responseId":"062a8a84a404aa379d05c0503756d1a9"}}
