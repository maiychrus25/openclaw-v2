{"type":"message","id":"e6a17525","parentId":"e2c1569a","timestamp":"2026-04-12T08:24:20.741Z","message":{"role":"toolResult","toolCallId":"call_function_7pn6tfwqprin_1","toolName":"exec","content":[{"type":"text","text":"=== accounts/accounts.model.ts ===\nimport { IAccounts } from '@common/interfaces/accounts.interface';\nimport { IAccountStatus } from '@common/utils/enum';\nimport mongoose, { Schema, Types } from 'mongoose';\n\nconst AccountSchema: Schema = new Schema(\n    {\n        username: { type: String, trim: true },\n        password: { type: String, trim: true, select: false },\n        email: { type: String, unique: true, trim: true },\n        employeeId: { type: Types.ObjectId, trim: true },\n        tokenVersion: { type: Number, default: 0 },\n        status: {\n            type: String,\n            enum: Object.values(IAccountStatus),\n            default: undefined,\n        },\n    },\n    {\n        timestamps: {\n            createdAt: 'createdAt',\n            updatedAt: 'updatedAt',\n        },\n    },\n);\n\nAccountSchema.index({ createdAt: -1, username: 1 });\nAccountSchema.index({ createdAt: -1, email: 1 });\n\nconst AccountModel = mongoose.model<IAccounts>('Accounts', AccountSchema);\nexport default AccountModel;\n\n=== employees/employees.model.ts ===\nimport { IEmployees } from '@common/interfaces/employee.interface';\nimport { IAccountStatus } from '@common/utils/enum';\nimport mongoose, { Schema, Types } from 'mongoose';\n\nconst EmployeesSchema: Schema = new Schema(\n    {\n        fullName: { type: String },\n        code: { type: String },\n        tamCode: { type: String },\n        phone: { type: String },\n        email: { type: String },\n        address: { type: String },\n        avatar: { type: String },\n        departmentId: { type: Types.ObjectId, ref: 'Departments' },\n        positionId: { type: Types.ObjectId, ref: 'Positions' },\n        status: {\n            type: String,\n            enum: Object.values(IAccountStatus),\n            default: undefined,\n        },\n        dateOfBirth: { type: Date },\n    },\n    {\n        timestamps: {\n            createdAt: 'createdAt',\n            updatedAt: 'updatedAt',\n        },\n    },\n);\n\nEmployeesSchema.index(\n    { departmentId: 1 },\n    {\n        name: 'idx_employee_departmentId',\n        background: true,\n    },\n);\n\nEmployeesSchema.index(\n    { positionId: 1 },\n    {\n        name: 'idx_employee_positionId',\n        background: true,\n    },\n);\n\nconst EmployeesModel = mongoose.model<IEmployees>('Employees', EmployeesSchema);\nexport default EmployeesModel;\n\n=== attendances/attendances.model.ts ===\nimport { IAttendances } from '@common/interfaces/attendances.interface';\nimport mongoose, { Schema, Types } from 'mongoose';\n\nconst AttendancesSchema: Schema = new Schema(\n    {\n        employeeId: { type: Types.ObjectId, trim: true, ref: 'Employees' },\n        shiftId: { type: Types.ObjectId, trim: true, ref: 'Shifts' },\n        statusId: { type: Types.ObjectId, trim: true, ref: 'Attendance-Statuses' },\n        date: { type: String },\n        checkin: { type: Date },\n        checkout: { type: Date },\n        deviceInfo: { type: String, trim: true },\n        totalWorkingHours: { type: Number },\n        records: { type: [Date] },\n        note: { type: String, trim: true },\n    },\n    {\n        timestamps: {\n            createdAt: 'createdAt',\n            updatedAt: 'updatedAt',\n        },\n    },\n);\n\nconst AttendancesModel = mongoose.model<IAttendances>('Attendances', AttendancesSchema);\nexport default AttendancesModel;\n\n=== departments/department.model.ts ===\nimport { IDepartments } from '@common/interfaces/department.interface';\nimport { IAccountStatus } from '@common/utils/enum';\nimport mongoose, { Schema, Types } from 'mongoose';\n\nconst DepartmentSchema: Schema = new Schema(\n    {\n        code: { type: String, trim: true },\n        name: { type: String, trim: true },\n        parentId: { type: Types.ObjectId },\n        managerId: { type: Types.ObjectId },\n        description: { type: String, trim: true },\n        status: {\n            type: String,\n            enum: Object.values(IAccountStatus),\n            default: undefined,\n        },\n    },\n    {\n        timestamps: {\n            createdAt: 'createdAt',\n            updatedAt: 'updatedAt',\n        },\n    },\n);\n\nconst DepartmentModel = mongoose.model<IDepartments>('Departments', DepartmentSchema);\nexport default DepartmentModel;\n\n=== positions/positions.model.ts ===\n\n=== roles/roles.model.ts ===\n\n=== permissions/permissions.model.ts ===\n\n=== checkins/checkin.model.ts ===\nimport { Schema, model, Types } from 'mongoose';\nimport { ICheckin } from '@common/interfaces/checkin.interface';\nimport { ICheckinStatus, ICheckinType } from '@common/utils/enum';\n\nconst CheckinConfirmationSchema = new Schema({\n    employeeId: { type: Schema.Types.ObjectId, ref: 'Employees', required: true },\n    confirmed: { type: Boolean, default: null }, // null = waiting, true = ok, false = refused\n    confirmedAt: { type: Date },\n}, { _id: false });\n\nconst CheckinSchema = new Schema<ICheckin>(\n    {\n        scheduleId: { type: Schema.Types.ObjectId, ref: 'checkin-schedules' },\n        creatorId: { type: Schema.Types.ObjectId, ref: 'Employees', required: true },\n        participantIds: {\n            type: [{ type: Schema.Types.ObjectId, ref: 'Employees' }],\n            validate: [\n                (val: Types.ObjectId[]) => val.length === 2,\n                'Buổi checkin phải có đúng 2 người tham gia',\n            ],\n            required: true,\n        },\n        checkinDate: { type: Date, required: true },\n        startTime: { type: String, required: true },\n        type: {\n            type: String,\n            enum: Object.values(ICheckinType),\n            required: true,\n        },\n        status: {\n            type: String,\n            enum: Object.values(ICheckinStatus),\n            default: ICheckinStatus.PENDING,\n        },\n        confirmations: [CheckinConfirmationSchema],\n        notified: { type: Boolean, default: false },\n        startNotified: { type: Boolean, default: false },\n    },\n    { timestamps: true }\n);\n\nexport default model<ICheckin>('checkins', CheckinSchema);\n\n=== checkins/checkin-schedule.model.ts ===\nimport { Schema, model, Types } from 'mongoose';\nimport { ICheckinSchedule } from '@common/interfaces/checkin.interface';\n\nconst CheckinScheduleSchema = new Schema<ICheckinSchedule>(\n    {\n        creatorId: { type: Schema.Types.ObjectId, ref: 'Employees', required: true },\n        participantIds: {\n            type: [{ type: Schema.Types.ObjectId, ref: 'Employees' }],\n            validate: [\n                (val: Types.ObjectId[]) => val.length === 2,\n                'Buổi checkin phải có đúng 2 người tham gia',\n            ],\n            required: true,\n        },\n        dayOfWeek: { type: Number, required: true, min: 0, max: 6 },\n        startTime: { type: String, required: true }, // Format HH:mm\n        isActive: { type: Boolean, default: true },\n    },\n    { timestamps: true }\n);\n\nexport default model<ICheckinSchedule>('checkin-schedules', CheckinScheduleSchema);\n\n=== leaveRequests/leaveRequests.model.ts ===\nimport { ILeaveRequests } from '@common/interfaces/leaveRequests.interface';\nimport { ILeaveRequestsStatus, ILeaveSession } from '@common/utils/enum';\nimport mongoose, { Schema, Types } from 'mongoose';\n\nconst LeaveRequestsSchema: Schema = new Schema(\n    {\n        employeeId: { type: Types.ObjectId, ref: 'Employees', required: true },\n        leaveTypeId: { type: Types.ObjectId, ref: 'Leave-Types', required: true },\n        departmentId: { type: Types.ObjectId, ref: 'Departments' },\n        startDate: { type: Date, required: true },\n        endDate: { type: Date, required: true },\n        totalDays: { type: Number },\n        paidDays: { type: Number, default: 0 },\n        unpaidDays: { type: Number, default: 0 },\n        session: {\n            type: String,\n            enum: Object.values(ILeaveSession),\n            default: ILeaveSession.FULL_DAY,\n        },\n        reason: { type: String, trim: true },\n        status: {\n            type: String,\n            enum: Object.values(ILeaveRequestsStatus),\n            default: ILeaveRequestsStatus.PENDING,\n        },\n        level1ApproverEmployeeId: { type: Types.ObjectId, ref: 'Employees' },\n        level1ApprovedAt: { type: Date },\n        hrApproverEmployeeId: { type: Types.ObjectId, ref: 'Employees' },\n        hrApprovedAt: { type: Date },\n        evidence: { type: String, trim: true },\n    },\n    {\n        timestamps: {\n            createdAt: 'createdAt',\n            updatedAt: 'updatedAt',\n        },\n    },\n);\n\nLeaveRequestsSchema.index(\n    { employeeId: 1, startDate: 1, endDate: 1 },\n    { name: 'idx_leave_request_employee_date', background: true },\n);\n\nLeaveRequestsSchema.index(\n    { status: 1 },\n    { name: 'idx_leave_request_status', background: true },\n);\n\nconst LeaveRequestsModel = mongoose.model<ILeaveRequests>('Leave-Requests', LeaveRequestsSchema);\nexport default LeaveRequestsModel;\n\n=== leaveTypes/leaveType.model.ts ===\nimport { ILeaveTypes } from '@common/interfaces/leaveType.interface';\nimport mongoose, { Schema } from 'mongoose';\n\nconst LeaveTypesSchema: Schema = new Schema(\n    {\n        code: { type: String, trim: true },\n        name: { type: String, trim: true },\n        requiresEvidence: { type: Boolean },\n        maxDaysPerYear: { type: Number },\n        isPaid: { type: Boolean },\n        isDeductible: { type: Boolean },\n        description: { type: String, trim: true },\n    },\n    {\n        timestamps: {\n            createdAt: 'createdAt',\n            updatedAt: 'updatedAt',\n        },\n    },\n);\n\nconst LeaveTypeModel = mongoose.model<ILeaveTypes>('Leave-Types', LeaveTypesSchema);\nexport default LeaveTypeModel;\n\n=== leaveBalances/leaveBalances.model.ts ===\nimport { ILeaveBalances } from '@common/interfaces/leaveBalances.interface';\nimport mongoose, { Schema, Types } from 'mongoose';\n\nconst LeaveBalancesSchema: Schema = new Schema(\n    {\n        employeeId: { type: Types.ObjectId, ref: 'Employees', required: true },\n        year: { type: Number, required: true },\n        totalEntitled: { type: Number, default: 0 },\n        totalUsed: { type: Number, default: 0 },\n        totalPending: { type: Number, default: 0 },\n        carryOver: { type: Number, default: 0 },\n        carryOverExpiry: { type: Date },\n    },\n    {\n        timestamps: {\n            createdAt: 'createdAt',\n            updatedAt: 'updatedAt',\n        },\n    },\n);\n\nLeaveBalancesSchema.index(\n    { employeeId: 1, year: 1 },\n    { unique: true, name: 'idx_leave_balance_employee_year', background: true },\n);\n\nconst LeaveBalancesModel = mongoose.model<ILeaveBalances>('Leave-Balances', LeaveBalancesSchema);\nexport default LeaveBalancesModel;\n\n=== okrs/okrs.model.ts ===\nimport { IOKRs } from '@common/interfaces/okrs.interface';\nimport { IOKRQuarter, IOKRStatus } from '@common/utils/enum';\nimport mongoose, { Schema, Types } from 'mongoose';\n\nconst OKRsSchema: Schema = new Schema(\n    {\n        employeeId: { type: Types.ObjectId, trim: true, ref: 'Employees' },\n        name: { type: String, trim: true },\n        quarter: {\n            type: Number,\n            enum: Object.values(IOKRQuarter).filter((key) => !isNaN(Number(key))),\n        },\n        year: { type: Number },\n        weekTotal: { type: Number },\n        status: {\n            type: String,\n            enum: Object.values(IOKRStatus),\n            default: IOKRStatus.Active,\n        },\n    },\n    {\n        timestamps: {\n            createdAt: 'createdAt',\n            updatedAt: 'updatedAt',\n        },\n    },\n);\n\nOKRsSchema.index(\n    { employeeId: 1, year: 1, quarter: 1 },\n    {\n        name: 'idx_okrs_employeeId_year_quater',\n        unique: true,\n        background: true,\n    },\n);\n\nconst OKRsModel = mongoose.model<IOKRs>('OKRs', OKRsSchema);\nexport default OKRsModel;\n\n=== objectives/objectives.model.ts ===\nimport { IObjective } from '@common/interfaces/objective.interface';\nimport { IObjectiveStatus } from '@common/utils/enum';\nimport mongoose, { Schema, Types } from 'mongoose';\n\nconst ObjectiveSchema: Schema = new Schema(\n    {\n        okrId: { type: Types.ObjectId, trim: true, ref: 'OKRs' },\n        description: { type: String, trim: true },\n        status: {\n            type: String,\n            enum: Object.values(IObjectiveStatus),\n            default: IObjectiveStatus.Active,\n        },\n    },\n    {\n        timestamps: {\n            createdAt: 'createdAt',\n            updatedAt: 'updatedAt',\n        },\n    },\n);\n\nObjectiveSchema.index(\n    { okrId: 1 },\n    {\n        name: 'idx_objectives_okrId',\n        background: true,\n    },\n);\n\nconst ObjectiveModel = mongoose.model<IObjective>('Objectives', ObjectiveSchema);\nexport default ObjectiveModel;\n\n=== keyResults/keyResults.model.ts ===\nimport { IKeyResults } from '@common/interfaces/keyResults.interface';\nimport { IKeyResultsStatus } from '@common/utils/enum';\nimport mongoose, { Schema, Types } from 'mongoose';\n\nconst KeyResultsSchema: Schema = new Schema(\n    {\n        objectiveId: { type: Types.ObjectId, trim: true, ref: 'Objectives' },\n        description: { type: String, trim: true },\n        status: {\n            type: String,\n            enum: Object.values(IKeyResultsStatus),\n            default: IKeyResultsStatus.Active,\n        },\n        score: { type: [Number] },\n        hasLink: { type: Boolean },\n        troubles: { type: String },\n        solutions: { type: String },\n        docs: { type: [String] },\n        children: [\n            {\n                description: { type: String, trim: true },\n                isPriority: { type: Boolean },\n                color: { type: String },\n            },\n        ],\n    },\n    {\n        timestamps: {\n            createdAt: 'createdAt',\n            updatedAt: 'updatedAt',\n        },\n    },\n);\n\nKeyResultsSchema.index(\n    { objectiveId: 1 },\n    {\n        name: 'idx_key_results_objectiveId',\n        background: true,\n    },\n);\n\nconst KeyResultsModel = mongoose.model<IKeyResults>('Key-Results', KeyResultsSchema);\nexport default KeyResultsModel;\n\n=== payroll/payroll.model.ts ===\nimport { IPayroll } from '@common/interfaces/payroll.interface';\nimport { IPayrollStatus } from '@common/utils/enum';\nimport mongoose, { Schema, Types } from 'mongoose';\n\nconst PayrollSchema: Schema = new Schema(\n    {\n        employeeId: { type: Types.ObjectId, trim: true },\n        contractId: { type: Types.ObjectId, trim: true },\n        code: { type: String, trim: true },\n        year: { type: Number },\n        month: { type: Number },\n        totalStandardDays: { type: Number },\n        actualWorkDays: { type: Number },\n        totalOTHours: { type: Number },\n        grossSalary: { type: Number },\n        netSalary: { type: Number },\n        status: { type: String, enum: Object.values(IPayrollStatus) },\n    },\n    {\n        timestamps: {\n            createdAt: 'createdAt',\n            updatedAt: 'updatedAt',\n        },\n    },\n);\n\nconst PayrollModel = mongoose.model<IPayroll>('Payrolls', PayrollSchema);\nexport default PayrollModel;\n\n=== contracts/contracts.model.ts ===\nimport { IContracts } from '@common/interfaces/contracts.interface';\nimport { IContractsStatus } from '@common/utils/enum';\nimport mongoose, { Schema, Types } from 'mongoose';\n\nconst ContractsSchema: Schema = new Schema(\n    {\n        employeeId: { type: Types.ObjectId, trim: true },\n        previousContractId: { type: Types.ObjectId, trim: true },\n        positionId: { type: Types.ObjectId, trim: true },\n        departmentId: { type: Types.ObjectId, trim: true },\n        code: { type: String, trim: true },\n        status: { type: String, enum: Object.values(IContractsStatus) },\n        name: { type: String, trim: true },\n        type: { type: String, trim: true },\n        signatoryName: { type: String, trim: true },\n        workingPlace: { type: String, trim: true },\n        description: { type: String, trim: true },\n        fileUrl: { type: String, trim: true },\n        workingTime: { type: String, trim: true },\n        startDate: { type: Date },\n        endDate: { type: Date },\n        signedDate: { type: Date },\n        probationEndDate: { type: Date },\n        baseSalary: { type: Number },\n        allowance: { type: Number },\n        probationSalaryRate: { type: Number },\n        insuranceSalary: { type: Number },\n        isRenewable: { type: Boolean },\n        isSigned: { type: Boolean },\n        documentUrls: [\n            {\n                name: { type: String, trim: true },\n                url: { type: String, trim: true },\n            },\n        ],\n    },\n    {\n        timestamps: {\n            createdAt: 'createdAt',\n            updatedAt: 'updatedAt',\n        },\n    },\n);\n\nconst ContractsModel = mongoose.model<IContracts>('Contracts', ContractsSchema);\nexport default ContractsModel;\n\n=== shifts/shifts.model.ts ===\n\n=== shiftTypes/shiftTypes.model.ts ===\n\n=== nikoEmotions/nikoEmotion.model.ts ===\nimport mongoose, { Schema, Types } from 'mongoose';\nimport { INikoEmotions } from '@common/interfaces/nikoEmotion.interface';\nimport { INikoEmotionType } from '@common/utils/enum';\n\nconst NikoEmotionsSchema: Schema = new Schema(\n    {\n        employeeId: { type: Types.ObjectId, ref: 'Employees', required: true },\n        date: { type: Date, required: true },\n        emoji: {\n            type: String,\n            required: true,\n            enum: Object.values(INikoEmotionType),\n        },\n    },\n    {\n        timestamps: true,\n    },\n);\n\n// Mỗi nhân viên chỉ được chấm một lần mỗi ngày; có thể cập nhật lại trong cùng ngày làm việc.\nNikoEmotionsSchema.index({ employeeId: 1, date: 1 }, { unique: true });\n\nconst NikoEmotionsModel = mongoose.model<INikoEmotions>('Niko-Emotions', NikoEmotionsSchema);\nexport default NikoEmotionsModel;\n\n=== nikoGifts/nikoGifts.model.ts ===\nimport mongoose, { Schema } from 'mongoose';\nimport { INikoGifts } from '@common/interfaces/nikoGifts.interface';\nimport { INikoGiftsStatus } from '@common/utils/enum';\n\nconst NikoGiftsSchema: Schema = new Schema(\n    {\n        name: { type: String, required: true },\n        stars: { type: Number, required: true },\n        imageUrl: { type: String },\n        monthLimit: { type: Number, default: 0 },\n        userLimit: { type: Number, default: 0 },\n        description: { type: String },\n        status: {\n            type: String,\n            enum: Object.values(INikoGiftsStatus),\n            default: INikoGiftsStatus.Active,\n        },\n    },\n    {\n        timestamps: true,\n    },\n);\n\nconst NikoGiftsModel = mongoose.model<INikoGifts>('Niko-Gifts', NikoGiftsSchema);\nexport default NikoGiftsModel;\n\n=== nikoWallets/nikoWallets.model.ts ===\nimport { INikoWalletStatus } from '@common/utils/enum';\nimport mongoose, { Schema, Types } from 'mongoose';\nimport { INikoWallets } from '@common/interfaces/nikoWallet.interface';\n\nconst NikoWalletsSchema: Schema = new Schema(\n    {\n        employeeId: { type: Types.ObjectId, ref: 'Employees', required: true, unique: true },\n        starsTotal: { type: Number, default: 0 },\n        starsUsable: { type: Number, default: 0 },\n        complimentsTotal: { type: Number, default: 0 },\n        status: {\n            type: String,\n            enum: Object.values(INikoWalletStatus),\n            default: INikoWalletStatus.ACTIVE,\n        },\n    },\n    {\n        timestamps: true,\n    },\n);\n\nconst NikoWalletsModel = mongoose.model<INikoWallets>('Niko-Wallets', NikoWalletsSchema);\nexport default NikoWalletsModel;\n\n=== nikoOrders/nikoOrders.model.ts ===\nimport mongoose, { Schema, Types } from 'mongoose';\nimport { INikoOrders } from '@common/interfaces/nikoOrders.interface';\nimport { INikoOrderStatus } from '@common/utils/enum';\n\nconst OrderItemSchema = new Schema({\n    giftId: { type: Types.ObjectId, ref: 'Niko-Gifts', required: true },\n    giftName: { type: String, required: true },\n    giftImage: { type: String },\n    price: { type: Number, required: true },\n    quantity: { type: Number, required: true },\n});\n\nconst NikoOrdersSchema: Schema = new Schema(\n    {\n        employeeId: { type: Types.ObjectId, ref: 'Employees', required: true },\n        items: [OrderItemSchema],\n        totalPrice: { type: Number, required: true },\n        status: {\n            type: String,\n            enum: Object.values(INikoOrderStatus),\n            default: INikoOrderStatus.PENDING,\n        },\n    },\n    {\n        timestamps: true,\n    },\n);\n\nconst NikoOrdersModel = mongoose.model<INikoOrders>('Niko-Orders', NikoOrdersSchema);\nexport default NikoOrdersModel;\n\n=== systemLogs/systemLog.model.ts ===\nimport { ISystemLogs } from '@common/interfaces/systemLog.interface';\nimport { IActionSystemLog } from '@common/utils/enum';\nimport mongoose, { Schema, Types } from 'mongoose';\n\nconst SystemLogSchema: Schema = new Schema(\n    {\n        accountId: {\n            type: Types.ObjectId,\n            ref: 'Accounts',\n        },\n\n        action: {\n            type: String,\n            enum: Object.values(IActionSystemLog),\n        },\n\n        effectTable: {\n            type: String,\n            trim: true,\n        },\n\n        recordId: {\n            type: Types.ObjectId,\n        },\n\n        oldValue: {\n            type: Schema.Types.Mixed, // json\n            default: null,\n        },\n\n        newValue: {\n            type: Schema.Types.Mixed, // json\n            default: null,\n        },\n\n        ipAddress: {\n            type: String,\n            trim: true,\n        },\n\n        userAgent: {\n            type: String,\n            trim: true,\n        },\n\n        location: {\n            type: String,\n            trim: true,\n        },\n    },\n    {\n        timestamps: {\n            createdAt: 'createdAt',\n            updatedAt: 'updatedAt',\n        },\n    },\n);\n\nconst SystemLogModel = mongoose.model<ISystemLogs>('System-Logs', SystemLogSchema);\nexport default SystemLogModel;\n\n=== nikoCriteria/nikoCriteria.model.ts ===\nimport { INikoCriteriaStatus } from '@common/utils/enum';\nimport mongoose, { Schema, Types } from 'mongoose';\nimport { INikoCriteria } from '@common/interfaces/nikoCriteria.interface';\n\nconst NikoCriteriaSchema: Schema = new Schema(\n    {\n        name: { type: String, required: true },\n        stars: { type: Number, required: true },\n        sectorIds: {\n            type: [{ type: Types.ObjectId, ref: 'Niko-Sectors' }],\n            required: true,\n        },\n        status: {\n            type: String,\n            enum: Object.values(INikoCriteriaStatus),\n            default: INikoCriteriaStatus.Active,\n        },\n    },\n    {\n        timestamps: true,\n    },\n);\n\nconst NikoCriteriaModel = mongoose.model<INikoCriteria>('Niko-Criteria', NikoCriteriaSchema);\nexport default NikoCriteriaModel;"}],"details":{"status":"completed","exitCode":0,"durationMs":264,"aggregated":"=== accounts/accounts.model.ts ===\nimport { IAccounts } from '@common/interfaces/accounts.interface';\nimport { IAccountStatus } from '@common/utils/enum';\nimport mongoose, { Schema, Types } from 'mongoose';\n\nconst AccountSchema: Schema = new Schema(\n    {\n        username: { type: String, trim: true },\n        password: { type: String, trim: true, select: false },\n        email: { type: String, unique: true, trim: true },\n        employeeId: { type: Types.ObjectId, trim: true },\n        tokenVersion: { type: Number, default: 0 },\n        status: {\n            type: String,\n            enum: Object.values(IAccountStatus),\n            default: undefined,\n        },\n    },\n    {\n        timestamps: {\n            createdAt: 'createdAt',\n            updatedAt: 'updatedAt',\n        },\n    },\n);\n\nAccountSchema.index({ createdAt: -1, username: 1 });\nAccountSchema.index({ createdAt: -1, email: 1 });\n\nconst AccountModel = mongoose.model<IAccounts>('Accounts', AccountSchema);\nexport default AccountModel;\n\n=== employees/employees.model.ts ===\nimport { IEmployees } from '@common/interfaces/employee.interface';\nimport { IAccountStatus } from '@common/utils/enum';\nimport mongoose, { Schema, Types } from 'mongoose';\n\nconst EmployeesSchema: Schema = new Schema(\n    {\n        fullName: { type: String },\n        code: { type: String },\n        tamCode: { type: String },\n        phone: { type: String },\n        email: { type: String },\n        address: { type: String },\n        avatar: { type: String },\n        departmentId: { type: Types.ObjectId, ref: 'Departments' },\n        positionId: { type: Types.ObjectId, ref: 'Positions' },\n        status: {\n            type: String,\n            enum: Object.values(IAccountStatus),\n            default: undefined,\n        },\n        dateOfBirth: { type: Date },\n    },\n    {\n        timestamps: {\n            createdAt: 'createdAt',\n            updatedAt: 'updatedAt',\n        },\n    },\n);\n\nEmployeesSchema.index(\n    { departmentId: 1 },\n    {\n        name: 'idx_employee_departmentId',\n        background: true,\n    },\n);\n\nEmployeesSchema.index(\n    { positionId: 1 },\n    {\n        name: 'idx_employee_positionId',\n        background: true,\n    },\n);\n\nconst EmployeesModel = mongoose.model<IEmployees>('Employees', EmployeesSchema);\nexport default EmployeesModel;\n\n=== attendances/attendances.model.ts ===\nimport { IAttendances } from '@common/interfaces/attendances.interface';\nimport mongoose, { Schema, Types } from 'mongoose';\n\nconst AttendancesSchema: Schema = new Schema(\n    {\n        employeeId: { type: Types.ObjectId, trim: true, ref: 'Employees' },\n        shiftId: { type: Types.ObjectId, trim: true, ref: 'Shifts' },\n        statusId: { type: Types.ObjectId, trim: true, ref: 'Attendance-Statuses' },\n        date: { type: String },\n        checkin: { type: Date },\n        checkout: { type: Date },\n        deviceInfo: { type: String, trim: true },\n        totalWorkingHours: { type: Number },\n        records: { type: [Date] },\n        note: { type: String, trim: true },\n    },\n    {\n        timestamps: {\n            createdAt: 'createdAt',\n            updatedAt: 'updatedAt',\n        },\n    },\n);\n\nconst AttendancesModel = mongoose.model<IAttendances>('Attendances', AttendancesSchema);\nexport default AttendancesModel;\n\n=== departments/department.model.ts ===\nimport { IDepartments } from '@common/interfaces/department.interface';\nimport { IAccountStatus } from '@common/utils/enum';\nimport mongoose, { Schema, Types } from 'mongoose';\n\nconst DepartmentSchema: Schema = new Schema(\n    {\n        code: { type: String, trim: true },\n        name: { type: String, trim: true },\n        parentId: { type: Types.ObjectId },\n        managerId: { type: Types.ObjectId },\n        description: { type: String, trim: true },\n        status: {\n            type: String,\n            enum: Object.values(IAccountStatus),\n            default: undefined,\n        },\n    },\n    {\n        timestamps: {\n            createdAt: 'createdAt',\n            updatedAt: 'updatedAt',\n        },\n    },\n);\n\nconst DepartmentModel = mongoose.model<IDepartments>('Departments', DepartmentSchema);\nexport default DepartmentModel;\n\n=== positions/positions.model.ts ===\n\n=== roles/roles.model.ts ===\n\n=== permissions/permissions.model.ts ===\n\n=== checkins/checkin.model.ts ===\nimport { Schema, model, Types } from 'mongoose';\nimport { ICheckin } from '@common/interfaces/checkin.interface';\nimport { ICheckinStatus, ICheckinType } from '@common/utils/enum';\n\nconst CheckinConfirmationSchema = new Schema({\n    employeeId: { type: Schema.Types.ObjectId, ref: 'Employees', required: true },\n    confirmed: { type: Boolean, default: null }, // null = waiting, true = ok, false = refused\n    confirmedAt: { type: Date },\n}, { _id: false });\n\nconst CheckinSchema = new Schema<ICheckin>(\n    {\n        scheduleId: { type: Schema.Types.ObjectId, ref: 'checkin-schedules' },\n        creatorId: { type: Schema.Types.ObjectId, ref: 'Employees', required: true },\n        participantIds: {\n            type: [{ type: Schema.Types.ObjectId, ref: 'Employees' }],\n            validate: [\n                (val: Types.ObjectId[]) => val.length === 2,\n                'Buổi checkin phải có đúng 2 người tham gia',\n            ],\n            required: true,\n        },\n        checkinDate: { type: Date, required: true },\n        startTime: { type: String, required: true },\n        type: {\n            type: String,\n            enum: Object.values(ICheckinType),\n            required: true,\n        },\n        status: {\n            type: String,\n            enum: Object.values(ICheckinStatus),\n            default: ICheckinStatus.PENDING,\n        },\n        confirmations: [CheckinConfirmationSchema],\n        notified: { type: Boolean, default: false },\n        startNotified: { type: Boolean, default: false },\n    },\n    { timestamps: true }\n);\n\nexport default model<ICheckin>('checkins', CheckinSchema);\n\n=== checkins/checkin-schedule.model.ts ===\nimport { Schema, model, Types } from 'mongoose';\nimport { ICheckinSchedule } from '@common/interfaces/checkin.interface';\n\nconst CheckinScheduleSchema = new Schema<ICheckinSchedule>(\n    {\n        creatorId: { type: Schema.Types.ObjectId, ref: 'Employees', required: true },\n        participantIds: {\n            type: [{ type: Schema.Types.ObjectId, ref: 'Employees' }],\n            validate: [\n                (val: Types.ObjectId[]) => val.length === 2,\n                'Buổi checkin phải có đúng 2 người tham gia',\n            ],\n            required: true,\n        },\n        dayOfWeek: { type: Number, required: true, min: 0, max: 6 },\n        startTime: { type: String, required: true }, // Format HH:mm\n        isActive: { type: Boolean, default: true },\n    },\n    { timestamps: true }\n);\n\nexport default model<ICheckinSchedule>('checkin-schedules', CheckinScheduleSchema);\n\n=== leaveRequests/leaveRequests.model.ts ===\nimport { ILeaveRequests } from '@common/interfaces/leaveRequests.interface';\nimport { ILeaveRequestsStatus, ILeaveSession } from '@common/utils/enum';\nimport mongoose, { Schema, Types } from 'mongoose';\n\nconst LeaveRequestsSchema: Schema = new Schema(\n    {\n        employeeId: { type: Types.ObjectId, ref: 'Employees', required: true },\n        leaveTypeId: { type: Types.ObjectId, ref: 'Leave-Types', required: true },\n        departmentId: { type: Types.ObjectId, ref: 'Departments' },\n        startDate: { type: Date, required: true },\n        endDate: { type: Date, required: true },\n        totalDays: { type: Number },\n        paidDays: { type: Number, default: 0 },\n        unpaidDays: { type: Number, default: 0 },\n        session: {\n            type: String,\n            enum: Object.values(ILeaveSession),\n            default: ILeaveSession.FULL_DAY,\n        },\n        reason: { type: String, trim: true },\n        status: {\n            type: String,\n            enum: Object.values(ILeaveRequestsStatus),\n            default: ILeaveRequestsStatus.PENDING,\n        },\n        level1ApproverEmployeeId: { type: Types.ObjectId, ref: 'Employees' },\n        level1ApprovedAt: { type: Date },\n        hrApproverEmployeeId: { type: Types.ObjectId, ref: 'Employees' },\n        hrApprovedAt: { type: Date },\n        evidence: { type: String, trim: true },\n    },\n    {\n        timestamps: {\n            createdAt: 'createdAt',\n            updatedAt: 'updatedAt',\n        },\n    },\n);\n\nLeaveRequestsSchema.index(\n    { employeeId: 1, startDate: 1, endDate: 1 },\n    { name: 'idx_leave_request_employee_date', background: true },\n);\n\nLeaveRequestsSchema.index(\n    { status: 1 },\n    { name: 'idx_leave_request_status', background: true },\n);\n\nconst LeaveRequestsModel = mongoose.model<ILeaveRequests>('Leave-Requests', LeaveRequestsSchema);\nexport default LeaveRequestsModel;\n\n=== leaveTypes/leaveType.model.ts ===\nimport { ILeaveTypes } from '@common/interfaces/leaveType.interface';\nimport mongoose, { Schema } from 'mongoose';\n\nconst LeaveTypesSchema: Schema = new Schema(\n    {\n        code: { type: String, trim: true },\n        name: { type: String, trim: true },\n        requiresEvidence: { type: Boolean },\n        maxDaysPerYear: { type: Number },\n        isPaid: { type: Boolean },\n        isDeductible: { type: Boolean },\n        description: { type: String, trim: true },\n    },\n    {\n        timestamps: {\n            createdAt: 'createdAt',\n            updatedAt: 'updatedAt',\n        },\n    },\n);\n\nconst LeaveTypeModel = mongoose.model<ILeaveTypes>('Leave-Types', LeaveTypesSchema);\nexport default LeaveTypeModel;\n\n=== leaveBalances/leaveBalances.model.ts ===\nimport { ILeaveBalances } from '@common/interfaces/leaveBalances.interface';\nimport mongoose, { Schema, Types } from 'mongoose';\n\nconst LeaveBalancesSchema: Schema = new Schema(\n    {\n        employeeId: { type: Types.ObjectId, ref: 'Employees', required: true },\n        year: { type: Number, required: true },\n        totalEntitled: { type: Number, default: 0 },\n        totalUsed: { type: Number, default: 0 },\n        totalPending: { type: Number, default: 0 },\n        carryOver: { type: Number, default: 0 },\n        carryOverExpiry: { type: Date },\n    },\n    {\n        timestamps: {\n            createdAt: 'createdAt',\n            updatedAt: 'updatedAt',\n        },\n    },\n);\n\nLeaveBalancesSchema.index(\n    { employeeId: 1, year: 1 },\n    { unique: true, name: 'idx_leave_balance_employee_year', background: true },\n);\n\nconst LeaveBalancesModel = mongoose.model<ILeaveBalances>('Leave-Balances', LeaveBalancesSchema);\nexport default LeaveBalancesModel;\n\n=== okrs/okrs.model.ts ===\nimport { IOKRs } from '@common/interfaces/okrs.interface';\nimport { IOKRQuarter, IOKRStatus } from '@common/utils/enum';\nimport mongoose, { Schema, Types } from 'mongoose';\n\nconst OKRsSchema: Schema = new Schema(\n    {\n        employeeId: { type: Types.ObjectId, trim: true, ref: 'Employees' },\n        name: { type: String, trim: true },\n        quarter: {\n            type: Number,\n            enum: Object.values(IOKRQuarter).filter((key) => !isNaN(Number(key))),\n        },\n        year: { type: Number },\n        weekTotal: { type: Number },\n        status: {\n            type: String,\n            enum: Object.values(IOKRStatus),\n            default: IOKRStatus.Active,\n        },\n    },\n    {\n        timestamps: {\n            createdAt: 'createdAt',\n            updatedAt: 'updatedAt',\n        },\n    },\n);\n\nOKRsSchema.index(\n    { employeeId: 1, year: 1, quarter: 1 },\n    {\n        name: 'idx_okrs_employeeId_year_quater',\n        unique: true,\n        background: true,\n    },\n);\n\nconst OKRsModel = mongoose.model<IOKRs>('OKRs', OKRsSchema);\nexport default OKRsModel;\n\n=== objectives/objectives.model.ts ===\nimport { IObjective } from '@common/interfaces/objective.interface';\nimport { IObjectiveStatus } from '@common/utils/enum';\nimport mongoose, { Schema, Types } from 'mongoose';\n\nconst ObjectiveSchema: Schema = new Schema(\n    {\n        okrId: { type: Types.ObjectId, trim: true, ref: 'OKRs' },\n        description: { type: String, trim: true },\n        status: {\n            type: String,\n            enum: Object.values(IObjectiveStatus),\n            default: IObjectiveStatus.Active,\n        },\n    },\n    {\n        timestamps: {\n            createdAt: 'createdAt',\n            updatedAt: 'updatedAt',\n        },\n    },\n);\n\nObjectiveSchema.index(\n    { okrId: 1 },\n    {\n        name: 'idx_objectives_okrId',\n        background: true,\n    },\n);\n\nconst ObjectiveModel = mongoose.model<IObjective>('Objectives', ObjectiveSchema);\nexport default ObjectiveModel;\n\n=== keyResults/keyResults.model.ts ===\nimport { IKeyResults } from '@common/interfaces/keyResults.interface';\nimport { IKeyResultsStatus } from '@common/utils/enum';\nimport mongoose, { Schema, Types } from 'mongoose';\n\nconst KeyResultsSchema: Schema = new Schema(\n    {\n        objectiveId: { type: Types.ObjectId, trim: true, ref: 'Objectives' },\n        description: { type: String, trim: true },\n        status: {\n            type: String,\n            enum: Object.values(IKeyResultsStatus),\n            default: IKeyResultsStatus.Active,\n        },\n        score: { type: [Number] },\n        hasLink: { type: Boolean },\n        troubles: { type: String },\n        solutions: { type: String },\n        docs: { type: [String] },\n        children: [\n            {\n                description: { type: String, trim: true },\n                isPriority: { type: Boolean },\n                color: { type: String },\n            },\n        ],\n    },\n    {\n        timestamps: {\n            createdAt: 'createdAt',\n            updatedAt: 'updatedAt',\n        },\n    },\n);\n\nKeyResultsSchema.index(\n    { objectiveId: 1 },\n    {\n        name: 'idx_key_results_objectiveId',\n        background: true,\n    },\n);\n\nconst KeyResultsModel = mongoose.model<IKeyResults>('Key-Results', KeyResultsSchema);\nexport default KeyResultsModel;\n\n=== payroll/payroll.model.ts ===\nimport { IPayroll } from '@common/interfaces/payroll.interface';\nimport { IPayrollStatus } from '@common/utils/enum';\nimport mongoose, { Schema, Types } from 'mongoose';\n\nconst PayrollSchema: Schema = new Schema(\n    {\n        employeeId: { type: Types.ObjectId, trim: true },\n        contractId: { type: Types.ObjectId, trim: true },\n        code: { type: String, trim: true },\n        year: { type: Number },\n        month: { type: Number },\n        totalStandardDays: { type: Number },\n        actualWorkDays: { type: Number },\n        totalOTHours: { type: Number },\n        grossSalary: { type: Number },\n        netSalary: { type: Number },\n        status: { type: String, enum: Object.values(IPayrollStatus) },\n    },\n    {\n        timestamps: {\n            createdAt: 'createdAt',\n            updatedAt: 'updatedAt',\n        },\n    },\n);\n\nconst PayrollModel = mongoose.model<IPayroll>('Payrolls', PayrollSchema);\nexport default PayrollModel;\n\n=== contracts/contracts.model.ts ===\nimport { IContracts } from '@common/interfaces/contracts.interface';\nimport { IContractsStatus } from '@common/utils/enum';\nimport mongoose, { Schema, Types } from 'mongoose';\n\nconst ContractsSchema: Schema = new Schema(\n    {\n        employeeId: { type: Types.ObjectId, trim: true },\n        previousContractId: { type: Types.ObjectId, trim: true },\n        positionId: { type: Types.ObjectId, trim: true },\n        departmentId: { type: Types.ObjectId, trim: true },\n        code: { type: String, trim: true },\n        status: { type: String, enum: Object.values(IContractsStatus) },\n        name: { type: String, trim: true },\n        type: { type: String, trim: true },\n        signatoryName: { type: String, trim: true },\n        workingPlace: { type: String, trim: true },\n        description: { type: String, trim: true },\n        fileUrl: { type: String, trim: true },\n        workingTime: { type: String, trim: true },\n        startDate: { type: Date },\n        endDate: { type: Date },\n        signedDate: { type: Date },\n        probationEndDate: { type: Date },\n        baseSalary: { type: Number },\n        allowance: { type: Number },\n        probationSalaryRate: { type: Number },\n        insuranceSalary: { type: Number },\n        isRenewable: { type: Boolean },\n        isSigned: { type: Boolean },\n        documentUrls: [\n            {\n                name: { type: String, trim: true },\n                url: { type: String, trim: true },\n            },\n        ],\n    },\n    {\n        timestamps: {\n            createdAt: 'createdAt',\n            updatedAt: 'updatedAt',\n        },\n    },\n);\n\nconst ContractsModel = mongoose.model<IContracts>('Contracts', ContractsSchema);\nexport default ContractsModel;\n\n=== shifts/shifts.model.ts ===\n\n=== shiftTypes/shiftTypes.model.ts ===\n\n=== nikoEmotions/nikoEmotion.model.ts ===\nimport mongoose, { Schema, Types } from 'mongoose';\nimport { INikoEmotions } from '@common/interfaces/nikoEmotion.interface';\nimport { INikoEmotionType } from '@common/utils/enum';\n\nconst NikoEmotionsSchema: Schema = new Schema(\n    {\n        employeeId: { type: Types.ObjectId, ref: 'Employees', required: true },\n        date: { type: Date, required: true },\n        emoji: {\n            type: String,\n            required: true,\n            enum: Object.values(INikoEmotionType),\n        },\n    },\n    {\n        timestamps: true,\n    },\n);\n\n// Mỗi nhân viên chỉ được chấm một lần mỗi ngày; có thể cập nhật lại trong cùng ngày làm việc.\nNikoEmotionsSchema.index({ employeeId: 1, date: 1 }, { unique: true });\n\nconst NikoEmotionsModel = mongoose.model<INikoEmotions>('Niko-Emotions', NikoEmotionsSchema);\nexport default NikoEmotionsModel;\n\n=== nikoGifts/nikoGifts.model.ts ===\nimport mongoose, { Schema } from 'mongoose';\nimport { INikoGifts } from '@common/interfaces/nikoGifts.interface';\nimport { INikoGiftsStatus } from '@common/utils/enum';\n\nconst NikoGiftsSchema: Schema = new Schema(\n    {\n        name: { type: String, required: true },\n        stars: { type: Number, required: true },\n        imageUrl: { type: String },\n        monthLimit: { type: Number, default: 0 },\n        userLimit: { type: Number, default: 0 },\n        description: { type: String },\n        status: {\n            type: String,\n            enum: Object.values(INikoGiftsStatus),\n            default: INikoGiftsStatus.Active,\n        },\n    },\n    {\n        timestamps: true,\n    },\n);\n\nconst NikoGiftsModel = mongoose.model<INikoGifts>('Niko-Gifts', NikoGiftsSchema);\nexport default NikoGiftsModel;\n\n=== nikoWallets/nikoWallets.model.ts ===\nimport { INikoWalletStatus } from '@common/utils/enum';\nimport mongoose, { Schema, Types } from 'mongoose';\nimport { INikoWallets } from '@common/interfaces/nikoWallet.interface';\n\nconst NikoWalletsSchema: Schema = new Schema(\n    {\n        employeeId: { type: Types.ObjectId, ref: 'Employees', required: true, unique: true },\n        starsTotal: { type: Number, default: 0 },\n        starsUsable: { type: Number, default: 0 },\n        complimentsTotal: { type: Number, default: 0 },\n        status: {\n            type: String,\n            enum: Object.values(INikoWalletStatus),\n            default: INikoWalletStatus.ACTIVE,\n        },\n    },\n    {\n        timestamps: true,\n    },\n);\n\nconst NikoWalletsModel = mongoose.model<INikoWallets>('Niko-Wallets', NikoWalletsSchema);\nexport default NikoWalletsModel;\n\n=== nikoOrders/nikoOrders.model.ts ===\nimport mongoose, { Schema, Types } from 'mongoose';\nimport { INikoOrders } from '@common/interfaces/nikoOrders.interface';\nimport { INikoOrderStatus } from '@common/utils/enum';\n\nconst OrderItemSchema = new Schema({\n    giftId: { type: Types.ObjectId, ref: 'Niko-Gifts', required: true },\n    giftName: { type: String, required: true },\n    giftImage: { type: String },\n    price: { type: Number, required: true },\n    quantity: { type: Number, required: true },\n});\n\nconst NikoOrdersSchema: Schema = new Schema(\n    {\n        employeeId: { type: Types.ObjectId, ref: 'Employees', required: true },\n        items: [OrderItemSchema],\n        totalPrice: { type: Number, required: true },\n        status: {\n            type: String,\n            enum: Object.values(INikoOrderStatus),\n            default: INikoOrderStatus.PENDING,\n        },\n    },\n    {\n        timestamps: true,\n    },\n);\n\nconst NikoOrdersModel = mongoose.model<INikoOrders>('Niko-Orders', NikoOrdersSchema);\nexport default NikoOrdersModel;\n\n=== systemLogs/systemLog.model.ts ===\nimport { ISystemLogs } from '@common/interfaces/systemLog.interface';\nimport { IActionSystemLog } from '@common/utils/enum';\nimport mongoose, { Schema, Types } from 'mongoose';\n\nconst SystemLogSchema: Schema = new Schema(\n    {\n        accountId: {\n            type: Types.ObjectId,\n            ref: 'Accounts',\n        },\n\n        action: {\n            type: String,\n            enum: Object.values(IActionSystemLog),\n        },\n\n        effectTable: {\n            type: String,\n            trim: true,\n        },\n\n        recordId: {\n            type: Types.ObjectId,\n        },\n\n        oldValue: {\n            type: Schema.Types.Mixed, // json\n            default: null,\n        },\n\n        newValue: {\n            type: Schema.Types.Mixed, // json\n            default: null,\n        },\n\n        ipAddress: {\n            type: String,\n            trim: true,\n        },\n\n        userAgent: {\n            type: String,\n            trim: true,\n        },\n\n        location: {\n            type: String,\n            trim: true,\n        },\n    },\n    {\n        timestamps: {\n            createdAt: 'createdAt',\n            updatedAt: 'updatedAt',\n        },\n    },\n);\n\nconst SystemLogModel = mongoose.model<ISystemLogs>('System-Logs', SystemLogSchema);\nexport default SystemLogModel;\n\n=== nikoCriteria/nikoCriteria.model.ts ===\nimport { INikoCriteriaStatus } from '@common/utils/enum';\nimport mongoose, { Schema, Types } from 'mongoose';\nimport { INikoCriteria } from '@common/interfaces/nikoCriteria.interface';\n\nconst NikoCriteriaSchema: Schema = new Schema(\n    {\n        name: { type: String, required: true },\n        stars: { type: Number, required: true },\n        sectorIds: {\n            type: [{ type: Types.ObjectId, ref: 'Niko-Sectors' }],\n            required: true,\n        },\n        status: {\n            type: String,\n            enum: Object.values(INikoCriteriaStatus),\n            default: INikoCriteriaStatus.Active,\n        },\n    },\n    {\n        timestamps: true,\n    },\n);\n\nconst NikoCriteriaModel = mongoose.model<INikoCriteria>('Niko-Criteria', NikoCriteriaSchema);\nexport default NikoCriteriaModel;","cwd":"/root/.openclaw/workspaces2/v4-ecosystem-review/master-orchestrator"},"isError":false,"timestamp":1775982260712}}
