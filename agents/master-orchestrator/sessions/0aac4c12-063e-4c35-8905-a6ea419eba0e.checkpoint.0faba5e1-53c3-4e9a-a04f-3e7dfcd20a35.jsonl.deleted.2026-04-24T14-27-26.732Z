{"type":"message","id":"45ac5dec","parentId":"fb988451","timestamp":"2026-04-19T03:47:14.344Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me write the study page and search page.","thinkingSignature":"8dadf8315c496c70e87aec9ec41af41c61928fc7bb14ce3fb9d59f430cb6a7e7"},{"type":"toolCall","id":"call_function_i7yespnfzpz0_1","name":"write","arguments":{"path":"/root/.openclaw/workspaces2/v4-ecosystem-review/maiy-tech-hub/app/study/page.tsx","content":"'use client'\n\nimport { useState, useEffect, useCallback } from 'react'\nimport { Users, Copy, Play, Pause, RotateCcw, Volume2 } from 'lucide-react'\n\nconst AMBIENT_OPTIONS = [\n  { id: 'rain', label: '🌧️ Rain', sound: 'rain' },\n  { id: 'cafe', label: '☕ Café', sound: 'cafe' },\n  { id: 'library', label: '📖 Library', sound: 'library' },\n] as const\n\nconst DEFAULT_WORK = 25\nconst DEFAULT_BREAK = 5\n\nexport default function StudyPage() {\n  const [roomCode, setRoomCode] = useState('')\n  const [joinCode, setJoinCode] = useState('')\n  const [joined, setJoined] = useState(false)\n  const [username, setUsername] = useState('')\n  const [participants, setParticipants] = useState<string[]>(['Bạn'])\n  const [timeLeft, setTimeLeft] = useState(DEFAULT_WORK * 60)\n  const [phase, setPhase] = useState<'work' | 'break'>('work')\n  const [isRunning, setIsRunning] = useState(false)\n  const [sessions, setSessions] = useState(0)\n  const [goal, setGoal] = useState('')\n  const [ambient, setAmbient] = useState<string | null>(null)\n\n  const formatTime = (s: number) =>\n    `${Math.floor(s / 60).toString().padStart(2, '0')}:${(s % 60).toString().padStart(2, '0')}`\n\n  const resetTimer = useCallback(() => {\n    setTimeLeft(phase === 'work' ? DEFAULT_WORK * 60 : DEFAULT_BREAK * 60)\n    setIsRunning(false)\n  }, [phase])\n\n  useEffect(() => {\n    if (!isRunning) return\n    const interval = setInterval(() => {\n      setTimeLeft((t) => {\n        if (t <= 1) {\n          // Phase complete\n          if (phase === 'work') {\n            setSessions((s) => s + 1)\n            setPhase('break')\n            return DEFAULT_BREAK * 60\n          } else {\n            setPhase('work')\n            return DEFAULT_WORK * 60\n          }\n        }\n        return t - 1\n      })\n    }, 1000)\n    return () => clearInterval(interval)\n  }, [isRunning, phase])\n\n  const createRoom = () => {\n    const code = Math.random().toString(36).substring(2, 8).toUpperCase()\n    setRoomCode(code)\n    setJoined(true)\n    setParticipants(['Bạn'])\n  }\n\n  const joinRoom = () => {\n    if (!joinCode.trim() || !username.trim()) return\n    setRoomCode(joinCode.toUpperCase())\n    setJoined(true)\n    setParticipants(['Bạn', 'Minh', 'Linh'])\n  }\n\n  const copyRoomCode = () => {\n    navigator.clipboard.writeText(roomCode)\n  }\n\n  if (!joined) {\n    return (\n      <div className=\"container py-12\">\n        <div className=\"max-w-lg mx-auto\">\n          <h1 className=\"text-3xl font-bold mb-2\">📚 Phòng học Live</h1>\n          <p className=\"text-muted-foreground mb-10\">\n            Học cùng nhau với Pomodoro timer. Tạo phòng mới hoặc tham gia phòng có sẵn.\n          </p>\n\n          {/* Create room */}\n          <div className=\"rounded-xl border border-border p-6 mb-6\">\n            <h2 className=\"font-semibold mb-4\">Tạo phòng mới</h2>\n            <button\n              onClick={createRoom}\n              className=\"w-full px-4 py-3 rounded-lg bg-primary text-primary-foreground font-medium hover:bg-primary/90 transition-colors\"\n            >\n              + Tạo phòng học mới\n            </button>\n          </div>\n\n          {/* Join room */}\n          <div className=\"rounded-xl border border-border p-6\">\n            <h2 className=\"font-semibold mb-4\">Tham gia phòng</h2>\n            <div className=\"space-y-3\">\n              <input\n                type=\"text\"\n                value={username}\n                onChange={(e) => setUsername(e.target.value)}\n                placeholder=\"Tên của bạn\"\n                className=\"w-full px-4 py-2.5 rounded-lg border border-input bg-background text-sm focus:outline-none focus:ring-2 focus:ring-ring\"\n              />\n              <input\n                type=\"text\"\n                value={joinCode}\n                onChange={(e) => setJoinCode(e.target.value.toUpperCase())}\n                placeholder=\"Mã phòng (VD: ABC123)\"\n                className=\"w-full px-4 py-2.5 rounded-lg border border-input bg-background text-sm font-mono tracking-widest text-center uppercase focus:outline-none focus:ring-2 focus:ring-ring\"\n                maxLength={6}\n              />\n              <button\n                onClick={joinRoom}\n                disabled={!joinCode.trim() || !username.trim()}\n                className=\"w-full px-4 py-3 rounded-lg bg-primary text-primary-foreground font-medium hover:bg-primary/90 transition-colors disabled:opacity-50\"\n              >\n                Tham gia\n              </button>\n            </div>\n          </div>\n        </div>\n      </div>\n    )\n  }\n\n  return (\n    <div className=\"container py-8\">\n      <div className=\"mb-6 flex items-center justify-between\">\n        <div>\n          <h1 className=\"text-2xl font-bold\">📚 Phòng học: {roomCode}</h1>\n          <p className=\"text-sm text-muted-foreground\">\n            {participants.length} người đang học\n          </p>\n        </div>\n        <div className=\"flex items-center gap-2\">\n          <button\n            onClick={copyRoomCode}\n            className=\"inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-border text-sm hover:bg-accent transition-colors\"\n          >\n            <Copy className=\"h-3.5 w-3.5\" />\n            Copy mã phòng\n          </button>\n          <button\n            onClick={() => setJoined(false)}\n            className=\"px-3 py-1.5 rounded-lg border border-border text-sm text-muted-foreground hover:bg-accent transition-colors\"\n          >\n            Thoát\n          </button>\n        </div>\n      </div>\n\n      <div className=\"grid md:grid-cols-3 gap-8\">\n        {/* Pomodoro Timer */}\n        <div className=\"md:col-span-2\">\n          <div className=\"rounded-2xl border border-border bg-card p-8 text-center mb-6\">\n            {/* Phase indicator */}\n            <div className=\"flex justify-center gap-2 mb-6\">\n              {Array.from({ length: 4 }).map((_, i) => (\n                <div\n                  key={i}\n                  className={`w-4 h-4 rounded-full ${\n                    i < sessions % 4\n                      ? 'bg-green-500'\n                      : phase === 'break' && i === sessions % 4\n                      ? 'bg-yellow-500 animate-pulse'\n                      : 'bg-muted'\n                  }`}\n                />\n              ))}\n            </div>\n\n            <p className=\"text-sm font-medium text-muted-foreground mb-2 uppercase tracking-wider\">\n              {phase === 'work' ? '⏱️ Thời gian làm việc' : '☕ Nghỉ giải lao'}\n            </p>\n\n            <div className=\"text-7xl font-bold font-mono mb-8 tabular-nums\">\n              {formatTime(timeLeft)}\n            </div>\n\n            <div className=\"flex justify-center gap-3\">\n              <button\n                onClick={() => setIsRunning(!isRunning)}\n                className=\"inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-primary text-primary-foreground font-medium hover:bg-primary/90 transition-colors\"\n              >\n                {isRunning ? (\n                  <>\n                    <Pause className=\"h-4 w-4\" /> Tạm dừng\n                  </>\n                ) : (\n                  <>\n                    <Play className=\"h-4 w-4\" /> Bắt đầu\n                  </>\n                )}\n              </button>\n              <button\n                onClick={resetTimer}\n                className=\"inline-flex items-center gap-2 px-4 py-3 rounded-lg border border-border hover:bg-accent transition-colors\"\n              >\n                <RotateCcw className=\"h-4 w-4\" /> Reset\n              </button>\n            </div>\n\n            <p className=\"text-xs text-muted-foreground mt-4\">\n              Chu kỳ Pomodoro: 25 phút làm việc → 5 phút nghỉ\n            </p>\n          </div>\n\n          {/* Goal */}\n          <div className=\"rounded-xl border border-border p-6 mb-6\">\n            <h3 className=\"font-semibold mb-3\">🎯 Mục tiêu hôm nay</h3>\n            {goal ? (\n              <p className=\"text-muted-foreground\">{goal}</p>\n            ) : (\n              <input\n                type=\"text\"\n                placeholder=\"VD: Hoàn thành bài Binary Search\"\n                className=\"w-full px-3 py-2 rounded-lg border border-input bg-background text-sm focus:outline-none focus:ring-2 focus:ring-ring\"\n              />\n            )}\n          </div>\n\n          {/* Ambient */}\n          <div className=\"rounded-xl border border-border p-6\">\n            <h3 className=\"font-semibold mb-3 flex items-center gap-2\">\n              <Volume2 className=\"h-4 w-4\" /> Âm thanh nền\n            </h3>\n            <div className=\"flex gap-2\">\n              {AMBIENT_OPTIONS.map((opt) => (\n                <button\n                  key={opt.id}\n                  onClick={() => setAmbient(ambient === opt.id ? null : opt.id)}\n                  className={`px-4 py-2 rounded-lg text-sm transition-all ${\n                    ambient === opt.id\n                      ? 'bg-primary text-primary-foreground'\n                      : 'border border-border hover:bg-accent'\n                  }`}\n                >\n                  {opt.label}\n                </button>\n              ))}\n            </div>\n          </div>\n        </div>\n\n        {/* Participants */}\n        <div>\n          <div className=\"rounded-xl border border-border p-6\">\n            <h3 className=\"font-semibold mb-4 flex items-center gap-2\">\n              <Users className=\"h-4 w-4\" /> Người đang học ({participants.length})\n            </h3>\n            <div className=\"space-y-2\">\n              {participants.map((p, i) => (\n                <div\n                  key={i}\n                  className=\"flex items-center gap-3 p-2 rounded-lg bg-muted/50\"\n                >\n                  <div className=\"w-8 h-8 rounded-full bg-gradient-to-br from-indigo-500 to-purple-500 flex items-center justify-center text-white text-xs font-bold\">\n                    {p[0].toUpperCase()}\n                  </div>\n                  <div>\n                    <p className=\"text-sm font-medium\">{p}</p>\n                    <p className=\"text-xs text-muted-foreground\">đang học</p>\n                  </div>\n                </div>\n              ))}\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  )\n}\n"}},{"type":"toolCall","id":"call_function_i7yespnfzpz0_2","name":"write","arguments":{"path":"/root/.openclaw/workspaces2/v4-ecosystem-review/maiy-tech-hub/app/search/page.tsx","content":"'use client'\n\nimport { useState, useEffect, useCallback } from 'react'\nimport { Search, X } from 'lucide-react'\nimport Fuse from 'fuse.js'\nimport { ArticleCard, type ArticleSummary } from '@/components/blog/article-card'\nimport { CATEGORIES } from '@/config/site'\n\nexport default function SearchPage() {\n  const [query, setQuery] = useState('')\n  const [results, setResults] = useState<ArticleSummary[]>([])\n  const [allArticles, setAllArticles] = useState<ArticleSummary[]>([])\n  const [activeCategory, setActiveCategory] = useState<string | null>(null)\n  const [loading, setLoading] = useState(false)\n\n  // Fetch all articles on mount\n  useEffect(() => {\n    fetch('/api/articles')\n      .then((r) => r.json())\n      .then((data) => setAllArticles(data.articles || []))\n      .catch(() => {})\n  }, [])\n\n  const performSearch = useCallback(() => {\n    setLoading(true)\n    let filtered = allArticles\n\n    // Category filter\n    if (activeCategory) {\n      filtered = filtered.filter((a) => a.category === activeCategory)\n    }\n\n    // Text search\n    if (query.trim()) {\n      const fuse = new Fuse(filtered, {\n        keys: ['title', 'excerpt', 'tags'],\n        threshold: 0.4,\n        includeScore: true,\n      })\n      const fuseResults = fuse.search(query).map((r) => r.item)\n      setResults(fuseResults)\n    } else {\n      setResults(filtered)\n    }\n    setLoading(false)\n  }, [query, activeCategory, allArticles])\n\n  useEffect(() => {\n    const timer = setTimeout(performSearch, 300)\n    return () => clearTimeout(timer)\n  }, [performSearch])\n\n  return (\n    <div className=\"container py-8\">\n      <div className=\"mb-8\">\n        <h1 className=\"text-3xl font-bold mb-2\">Tìm kiếm</h1>\n        <p className=\"text-muted-foreground\">\n          Tìm bài viết về CTDL, AI, Web Dev...\n        </p>\n      </div>\n\n      {/* Search input */}\n      <div className=\"relative mb-6\">\n        <Search className=\"absolute left-4 top-1/2 -translate-y-1/2 h-5 w-5 text-muted-foreground\" />\n        <input\n          type=\"text\"\n          value={query}\n          onChange={(e) => setQuery(e.target.value)}\n          placeholder=\"Tìm bài viết... (VD: binary search, neural network)\"\n          className=\"w-full pl-12 pr-10 py-4 rounded-xl border border-border bg-background text-lg focus:outline-none focus:ring-2 focus:ring-ring\"\n          autoFocus\n        />\n        {query && (\n          <button\n            onClick={() => setQuery('')}\n            className=\"absolute right-4 top-1/2 -translate-y-1/2 text-muted-foreground hover:text-foreground\"\n          >\n            <X className=\"h-5 w-5\" />\n          </button>\n        )}\n      </div>\n\n      {/* Category filters */}\n      <div className=\"flex flex-wrap gap-2 mb-8\">\n        <button\n          onClick={() => setActiveCategory(null)}\n          className={`px-4 py-2 rounded-full text-sm font-medium transition-all ${\n            !activeCategory\n              ? 'bg-primary text-primary-foreground'\n              : 'border border-border hover:bg-accent'\n          }`}\n        >\n          Tất cả\n        </button>\n        {CATEGORIES.map((cat) => (\n          <button\n            key={cat.slug}\n            onClick={() => setActiveCategory(activeCategory === cat.slug ? null : cat.slug)}\n            className={`px-4 py-2 rounded-full text-sm font-medium transition-all ${\n              activeCategory === cat.slug\n                ? 'bg-primary text-primary-foreground'\n                : 'border border-border hover:bg-accent'\n            }`}\n          >\n            {cat.label}\n          </button>\n        ))}\n      </div>\n\n      {/* Results */}\n      <div className=\"mb-4\">\n        <p className=\"text-sm text-muted-foreground\">\n          {loading\n            ? 'Đang tìm...'\n            : `${results.length} kết quả${query ? ` cho \"${query}\"` : ''}`}\n        </p>\n      </div>\n\n      {results.length === 0 && !loading ? (\n        <div className=\"text-center py-20\">\n          <Search className=\"h-12 w-12 text-muted-foreground mx-auto mb-4\" />\n          <h2 className=\"text-lg font-medium mb-2\">\n            {query ? `Không tìm thấy kết quả cho \"${query}\"` : 'Chưa có bài viết nào'}\n          </h2>\n          <p className=\"text-sm text-muted-foreground\">\n            {query ? 'Thử từ khóa khác hoặc duyệt theo chủ đề.' : 'Bài viết đầu tiên sẽ xuất hiện ở đây!'}\n          </p>\n        </div>\n      ) : (\n        <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\">\n          {results.map((article) => (\n            <ArticleCard key={article.slug} article={article} />\n          ))}\n        </div>\n      )}\n    </div>\n  )\n}\n"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":181,"output":3981,"cacheRead":85984,"cacheWrite":5090,"totalTokens":95236,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776570389496,"responseId":"063383163aec03e7dc36b6b75242ac86"}}
