{"type":"message","id":"07cc2970","parentId":"297a4c36","timestamp":"2026-04-19T03:44:37.431Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me write the Header, Footer, MiniPlayer, and the home page.","thinkingSignature":"09da5983b48c71812f47eb08d01a4db743f459533bd7d5e26f0484d134a9edad"},{"type":"toolCall","id":"call_function_37gda7izykx0_1","name":"write","arguments":{"path":"/root/.openclaw/workspaces2/v4-ecosystem-review/maiy-tech-hub/components/layout/header.tsx","content":"'use client'\n\nimport Link from 'next/link'\nimport { usePathname } from 'next/navigation'\nimport { useTheme } from 'next-themes'\nimport { useState, useEffect } from 'react'\nimport { Search, Moon, Sun, Menu, X } from 'lucide-react'\nimport { cn } from '@/lib/utils'\nimport { ThemeToggle } from '@/components/shared/theme-toggle'\n\nconst NAV_LINKS = [\n  { href: '/articles', label: 'Bài viết' },\n  { href: '/music', label: 'Âm nhạc' },\n  { href: '/study', label: 'Học live' },\n  { href: '/about', label: 'Giới thiệu' },\n]\n\nexport function Header() {\n  const pathname = usePathname()\n  const { theme } = useTheme()\n  const [mounted, setMounted] = useState(false)\n  const [mobileOpen, setMobileOpen] = useState(false)\n\n  useEffect(() => setMounted(true), [])\n\n  return (\n    <header className=\"sticky top-0 z-50 w-full border-b border-border/40 bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/60\">\n      <div className=\"container flex h-16 items-center justify-between\">\n        {/* Logo */}\n        <Link href=\"/\" className=\"flex items-center gap-2 font-bold text-xl\">\n          <span className=\"text-2xl\">💡</span>\n          <span className=\"bg-gradient-to-r from-indigo-500 to-purple-500 bg-clip-text text-transparent\">\n            MAIY Tech Hub\n          </span>\n        </Link>\n\n        {/* Desktop Nav */}\n        <nav className=\"hidden md:flex items-center gap-6\">\n          {NAV_LINKS.map((link) => (\n            <Link\n              key={link.href}\n              href={link.href}\n              className={cn(\n                'text-sm font-medium transition-colors hover:text-primary',\n                pathname?.startsWith(link.href)\n                  ? 'text-primary'\n                  : 'text-muted-foreground'\n              )}\n            >\n              {link.label}\n            </Link>\n          ))}\n        </nav>\n\n        {/* Right side */}\n        <div className=\"flex items-center gap-2\">\n          <Link\n            href=\"/search\"\n            className=\"p-2 rounded-md hover:bg-accent transition-colors\"\n            aria-label=\"Tìm kiếm\"\n          >\n            <Search className=\"h-4 w-4 text-muted-foreground\" />\n          </Link>\n\n          {mounted && <ThemeToggle />}\n\n          {/* Mobile menu button */}\n          <button\n            className=\"md:hidden p-2 rounded-md hover:bg-accent transition-colors\"\n            onClick={() => setMobileOpen(!mobileOpen)}\n            aria-label=\"Menu\"\n          >\n            {mobileOpen ? (\n              <X className=\"h-5 w-5\" />\n            ) : (\n              <Menu className=\"h-5 w-5\" />\n            )}\n          </button>\n        </div>\n      </div>\n\n      {/* Mobile Nav */}\n      {mobileOpen && (\n        <div className=\"md:hidden border-t border-border/40 bg-background\">\n          <nav className=\"container py-4 flex flex-col gap-2\">\n            {NAV_LINKS.map((link) => (\n              <Link\n                key={link.href}\n                href={link.href}\n                onClick={() => setMobileOpen(false)}\n                className={cn(\n                  'px-3 py-2 rounded-md text-sm font-medium transition-colors hover:bg-accent',\n                  pathname?.startsWith(link.href)\n                    ? 'bg-accent text-primary'\n                    : 'text-muted-foreground'\n                )}\n              >\n                {link.label}\n              </Link>\n            ))}\n          </nav>\n        </div>\n      )}\n    </header>\n  )\n}\n"}},{"type":"toolCall","id":"call_function_37gda7izykx0_2","name":"write","arguments":{"path":"/root/.openclaw/workspaces2/v4-ecosystem-review/maiy-tech-hub/components/layout/footer.tsx","content":"import Link from 'next/link'\nimport { CATEGORIES } from '@/config/site'\n\nexport function Footer() {\n  const currentYear = new Date().getFullYear()\n\n  return (\n    <footer className=\"border-t border-border/40 bg-muted/30\">\n      <div className=\"container py-12\">\n        <div className=\"grid grid-cols-1 md:grid-cols-4 gap-8\">\n          {/* Brand */}\n          <div className=\"md:col-span-2\">\n            <Link href=\"/\" className=\"flex items-center gap-2 font-bold text-lg mb-3\">\n              <span className=\"text-2xl\">💡</span>\n              <span>MAIY Tech Hub</span>\n            </Link>\n            <p className=\"text-sm text-muted-foreground max-w-sm\">\n              Nền tảng blog chia sẻ kiến thức CNTT chuẩn chỉnh bằng tiếng Việt.\n              Code thật, giải thích dễ hiểu.\n            </p>\n          </div>\n\n          {/* Categories */}\n          <div>\n            <h3 className=\"font-semibold mb-4 text-sm\">Chủ đề</h3>\n            <ul className=\"space-y-2\">\n              {CATEGORIES.map((cat) => (\n                <li key={cat.slug}>\n                  <Link\n                    href={`/articles/category/${cat.slug}`}\n                    className=\"text-sm text-muted-foreground hover:text-primary transition-colors\"\n                  >\n                    {cat.label}\n                  </Link>\n                </li>\n              ))}\n            </ul>\n          </div>\n\n          {/* Links */}\n          <div>\n            <h3 className=\"font-semibold mb-4 text-sm\">Liên kết</h3>\n            <ul className=\"space-y-2\">\n              {[\n                { href: '/about', label: 'Giới thiệu' },\n                { href: '/articles', label: 'Tất cả bài viết' },\n                { href: '/music', label: 'Âm nhạc' },\n                { href: '/study', label: 'Phòng học live' },\n                { href: '/search', label: 'Tìm kiếm' },\n              ].map((link) => (\n                <li key={link.href}>\n                  <Link\n                    href={link.href}\n                    className=\"text-sm text-muted-foreground hover:text-primary transition-colors\"\n                  >\n                    {link.label}\n                  </Link>\n                </li>\n              ))}\n            </ul>\n          </div>\n        </div>\n\n        <div className=\"mt-8 pt-8 border-t border-border/40 flex flex-col sm:flex-row items-center justify-between gap-4\">\n          <p className=\"text-xs text-muted-foreground\">\n            © {currentYear} MAIY Tech Hub. Kiến thức vì cộng đồng.\n          </p>\n          <p className=\"text-xs text-muted-foreground\">\n            Built với Next.js 14 + ❤️\n          </p>\n        </div>\n      </div>\n    </footer>\n  )\n}\n"}},{"type":"toolCall","id":"call_function_37gda7izykx0_3","name":"write","arguments":{"path":"/root/.openclaw/workspaces2/v4-ecosystem-review/maiy-tech-hub/components/shared/theme-toggle.tsx","content":"'use client'\n\nimport { useTheme } from 'next-themes'\nimport { useEffect, useState } from 'react'\nimport { Moon, Sun } from 'lucide-react'\n\nexport function ThemeToggle() {\n  const { theme, setTheme } = useTheme()\n  const [mounted, setMounted] = useState(false)\n\n  useEffect(() => setMounted(true), [])\n\n  if (!mounted) {\n    return (\n      <div className=\"w-9 h-9 rounded-md bg-muted animate-pulse\" />\n    )\n  }\n\n  return (\n    <button\n      onClick={() => setTheme(theme === 'dark' ? 'light' : 'dark')}\n      className=\"p-2 rounded-md hover:bg-accent transition-colors\"\n      aria-label=\"Toggle theme\"\n    >\n      {theme === 'dark' ? (\n        <Sun className=\"h-4 w-4 text-muted-foreground\" />\n      ) : (\n        <Moon className=\"h-4 w-4 text-muted-foreground\" />\n      )}\n    </button>\n  )\n}\n"}},{"type":"toolCall","id":"call_function_37gda7izykx0_4","name":"write","arguments":{"path":"/root/.openclaw/workspaces2/v4-ecosystem-review/maiy-tech-hub/components/music/mini-player.tsx","content":"'use client'\n\nimport Link from 'next/link'\nimport { Pause, Play, SkipForward, Volume2, X } from 'lucide-react'\nimport { useMusic } from '@/providers/music-provider'\nimport { useEffect, useState } from 'react'\n\nexport function MiniPlayer() {\n  const { currentTrack, isPlaying, pause, resume, skipNext } = useMusic()\n  const [visible, setVisible] = useState(false)\n\n  useEffect(() => {\n    if (currentTrack) setVisible(true)\n  }, [currentTrack])\n\n  if (!visible || !currentTrack) return null\n\n  return (\n    <div className=\"fixed bottom-0 left-0 right-0 z-50 border-t border-border/40 bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/80\">\n      <div className=\"container flex h-16 items-center gap-4\">\n        {/* Track info */}\n        <div className=\"flex items-center gap-3 min-w-0 flex-1\">\n          {currentTrack.coverUrl && (\n            // eslint-disable-next-line @next/next/no-img-element\n            <img\n              src={currentTrack.coverUrl}\n              alt={currentTrack.title}\n              className=\"w-10 h-10 rounded object-cover flex-shrink-0\"\n            />\n          )}\n          <div className=\"min-w-0\">\n            <p className=\"text-sm font-medium truncate\">{currentTrack.title}</p>\n            <p className=\"text-xs text-muted-foreground truncate\">\n              {currentTrack.artist}\n            </p>\n          </div>\n        </div>\n\n        {/* Controls */}\n        <div className=\"flex items-center gap-2\">\n          <button\n            onClick={isPlaying ? pause : resume}\n            className=\"p-2 rounded-full bg-primary text-primary-foreground hover:bg-primary/90 transition-colors\"\n            aria-label={isPlaying ? 'Tạm dừng' : 'Phát'}\n          >\n            {isPlaying ? (\n              <Pause className=\"h-4 w-4\" />\n            ) : (\n              <Play className=\"h-4 w-4 ml-0.5\" />\n            )}\n          </button>\n\n          <button\n            onClick={skipNext}\n            className=\"p-2 rounded-full hover:bg-accent transition-colors\"\n            aria-label=\"Bài tiếp theo\"\n          >\n            <SkipForward className=\"h-4 w-4 text-muted-foreground\" />\n          </button>\n\n          <Link\n            href=\"/music\"\n            className=\"hidden sm:flex p-2 rounded-full hover:bg-accent transition-colors\"\n            aria-label=\"Mở trang nhạc\"\n          >\n            <Volume2 className=\"h-4 w-4 text-muted-foreground\" />\n          </Link>\n        </div>\n\n        {/* Close */}\n        <button\n          onClick={() => setVisible(false)}\n          className=\"p-1 rounded hover:bg-accent transition-colors\"\n          aria-label=\"Đóng\"\n        >\n          <X className=\"h-4 w-4 text-muted-foreground\" />\n        </button>\n      </div>\n    </div>\n  )\n}\n"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":204,"output":2683,"cacheRead":75372,"cacheWrite":2919,"totalTokens":81178,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776570246517,"responseId":"06338287edad79608fccb71c558cd8dc"}}
