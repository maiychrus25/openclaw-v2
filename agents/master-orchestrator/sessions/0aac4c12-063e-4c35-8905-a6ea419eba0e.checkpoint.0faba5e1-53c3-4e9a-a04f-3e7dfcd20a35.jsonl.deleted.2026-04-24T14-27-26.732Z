{"type":"message","id":"67836057","parentId":"fe59ec14","timestamp":"2026-04-19T04:34:51.965Z","message":{"role":"toolResult","toolCallId":"call_function_hscoruthircs_1","toolName":"read","content":[{"type":"text","text":"import Link from 'next/link'\nimport { ArrowRight, Play } from 'lucide-react'\nimport { CATEGORIES } from '@/config/site'\nimport { ArticleCard } from '@/components/blog/article-card'\nimport { NewsletterForm } from '@/components/shared/newsletter-form'\nimport { getFeaturedArticles, getRecentArticles } from '@/lib/content'\n\nexport default async function HomePage() {\n  const featured = await getFeaturedArticles()\n  const recent = await getRecentArticles(6)\n  const featuredArticle = featured[0]\n\n  return (\n    <div className=\"flex flex-col\">\n      {/* Hero Section */}\n      <section className=\"relative overflow-hidden border-b border-border/40 bg-muted/30\">\n        <div className=\"container py-20 md:py-28 relative z-10\">\n          <div className=\"max-w-3xl mx-auto text-center\">\n            <div className=\"inline-flex items-center gap-2 px-3 py-1 mb-6 text-xs font-medium rounded-full bg-primary/10 text-primary border border-primary/20\">\n              🚀 MAIY Tech Hub — Học CNTT không bao giờ boring\n            </div>\n\n            <h1 className=\"text-4xl md:text-6xl font-bold tracking-tight mb-6\">\n              Kiến thức CNTT{' '}\n              <span className=\"bg-gradient-to-r from-indigo-500 to-purple-500 bg-clip-text text-transparent\">\n                chuẩn chỉnh\n              </span>\n              <br />\n              bằng tiếng Việt\n            </h1>\n\n            <p className=\"text-lg text-muted-foreground mb-10 max-w-2xl mx-auto\">\n              Bài viết về CTDL & Giải thuật, AI, Web Dev — code thật, giải thích\n              dễ hiểu, có bài tập thực hành. Kèm nhạc thư giãn và phòng học live.\n            </p>\n\n            <div className=\"flex flex-col sm:flex-row items-center justify-center gap-4\">\n              <Link\n                href=\"/articles\"\n                className=\"inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-primary text-primary-foreground font-medium hover:bg-primary/90 transition-colors\"\n              >\n                Khám phá bài viết\n                <ArrowRight className=\"h-4 w-4\" />\n              </Link>\n              <Link\n                href=\"/music\"\n                className=\"inline-flex items-center gap-2 px-6 py-3 rounded-lg border border-border hover:bg-accent transition-colors font-medium\"\n              >\n                <Play className=\"h-4 w-4\" />\n                Nghe nhạc thư giãn\n              </Link>\n            </div>\n          </div>\n        </div>\n\n        {/* Background decoration */}\n        <div className=\"absolute inset-0 bg-gradient-to-br from-indigo-500/5 via-transparent to-purple-500/5 pointer-events-none\" />\n      </section>\n\n      {/* Featured Article */}\n      {featuredArticle && (\n        <section className=\"container py-12\">\n          <h2 className=\"text-sm font-semibold text-muted-foreground uppercase tracking-wider mb-6\">\n            Bài viết nổi bật\n          </h2>\n          <Link\n            href={`/articles/${featuredArticle.slug}`}\n            className=\"group block rounded-2xl overflow-hidden border border-border/40 hover:border-primary/30 transition-all hover:shadow-lg\"\n          >\n            <div className=\"grid md:grid-cols-2 gap-0\">\n              {featuredArticle.hero && (\n                // eslint-disable-next-line @next/next/no-img-element\n                <img\n                  src={featuredArticle.hero}\n                  alt={featuredArticle.title}\n                  className=\"w-full h-64 md:h-full object-cover group-hover:scale-105 transition-transform duration-500\"\n                />\n              )}\n              <div className=\"p-6 md:p-10 flex flex-col justify-center\">\n                <div className=\"flex items-center gap-2 mb-3\">\n                  <span className=\"px-2 py-0.5 text-xs font-medium rounded bg-primary/10 text-primary\">\n                    {featuredArticle.category}\n                  </span>\n                  <span className=\"text-xs text-muted-foreground\">\n                    {featuredArticle.readingTime} phút đọc\n                  </span>\n                </div>\n                <h3 className=\"text-2xl font-bold mb-3 group-hover:text-primary transition-colors\">\n                  {featuredArticle.title}\n                </h3>\n                <p className=\"text-muted-foreground mb-4 line-clamp-3\">\n                  {featuredArticle.excerpt}\n                </p>\n                <span className=\"inline-flex items-center text-sm font-medium text-primary\">\n                  Đọc tiếp <ArrowRight className=\"h-4 w-4 ml-1\" />\n                </span>\n              </div>\n            </div>\n          </Link>\n        </section>\n      )}\n\n      {/* Categories */}\n      <section className=\"container\">\n        <div className=\"flex flex-wrap gap-2 mb-10\">\n          {CATEGORIES.map((cat) => (\n            <Link\n              key={cat.slug}\n              href={`/articles/category/${cat.slug}`}\n              className=\"inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-medium border border-border hover:border-primary/50 hover:bg-primary/5 transition-all\"\n            >\n              <span className={`w-2 h-2 rounded-full ${cat.color}`} />\n              {cat.label}\n            </Link>\n          ))}\n        </div>\n      </section>\n\n      {/* Recent Posts */}\n      <section className=\"container py-12\">\n        <div className=\"flex items-center justify-between mb-8\">\n          <h2 className=\"text-sm font-semibold text-muted-foreground uppercase tracking-wider\">\n            Bài viết mới nhất\n          </h2>\n          <Link\n            href=\"/articles\"\n            className=\"text-sm font-medium text-primary hover:underline\"\n          >\n            Xem tất cả →\n          </Link>\n        </div>\n\n        <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\">\n          {recent.map((article) => (\n            <ArticleCard key={article.slug} article={article} />\n          ))}\n        </div>\n\n        {recent.length === 0 && (\n          <div className=\"text-center py-20 text-muted-foreground\">\n            <p className=\"text-lg mb-2\">Chưa có bài viết nào.</p>\n            <p className=\"text-sm\">Hãy là người đầu tiên đóng góp!</p>\n          </div>\n        )}\n      </section>\n\n      {/* Music Preview */}\n      <section className=\"border-y border-border/40 bg-muted/30\">\n        <div className=\"container py-12\">\n          <div className=\"flex flex-col md:flex-row items-center gap-6\">\n            <div className=\"flex-1\">\n              <h2 className=\"text-2xl font-bold mb-2\">🎵 Relaxation Zone</h2>\n              <p className=\"text-muted-foreground mb-4\">\n                Nhạc lo-fi, ambient, classical giúp bạn tập trung khi học.\n                Mini-player hoạt động xuyên suốt các trang.\n              </p>\n              <Link\n                href=\"/music\"\n                className=\"inline-flex items-center gap-2 text-primary font-medium hover:underline\"\n              >\n                Khám phá khu vực âm nhạc <ArrowRight className=\"h-4 w-4\" />\n              </Link>\n            </div>\n            <div className=\"flex-shrink-0\">\n              <Link\n                href=\"/music\"\n                className=\"inline-flex items-center justify-center w-20 h-20 rounded-full bg-primary/10 hover:bg-primary/20 transition-colors\"\n              >\n                <Play className=\"h-8 w-8 text-primary ml-1\" />\n              </Link>\n            </div>\n          </div>\n        </div>\n      </section>\n\n      {/* Live Study Preview */}\n      <section className=\"container py-12\">\n        <div className=\"flex flex-col md:flex-row items-center gap-6\">\n          <div className=\"flex-shrink-0 order-2 md:order-1\">\n            <Link\n              href=\"/study\"\n              className=\"inline-flex items-center justify-center w-20 h-20 rounded-full bg-green-500/10 hover:bg-green-500/20 transition-colors\"\n            >\n              <span className=\"text-3xl\">📚</span>\n            </Link>\n          </div>\n          <div className=\"flex-1 order-1 md:order-2\">\n            <h2 className=\"text-2xl font-bold mb-2\">📚 Phòng học Live</h2>\n            <p className=\"text-muted-foreground mb-4\">\n              Học cùng nhau với Pomodoro timer, participant list, và ambient sound.\n              Tạo phòng hoặc tham gia phòng có sẵn.\n            </p>\n            <Link\n              href=\"/study\"\n              className=\"inline-flex items-center gap-2 text-green-600 font-medium hover:underline dark:text-green-400\"\n            >\n              Vào phòng học ngay <ArrowRight className=\"h-4 w-4\" />\n            </Link>\n          </div>\n        </div>\n      </section>\n\n      {/* Newsletter */}\n      <section className=\"container pb-12\">\n        <div className=\"rounded-2xl bg-gradient-to-r from-indigo-500 to-purple-500 p-8 md:p-12 text-center text-white\">\n          <h2 className=\"text-2xl md:text-3xl font-bold mb-3\">\n            Nhận bài viết mới mỗi tuần\n          </h2>\n          <p className=\"text-white/80 mb-6 max-w-md mx-auto\">\n            Đăng ký email để nhận bài viết mới về CTDL, AI, Web Dev — hoàn toàn miễn phí.\n          </p>\n          <NewsletterForm />\n        </div>\n      </section>\n    </div>\n  )\n}\n"}],"isError":false,"timestamp":1776573291944}}
