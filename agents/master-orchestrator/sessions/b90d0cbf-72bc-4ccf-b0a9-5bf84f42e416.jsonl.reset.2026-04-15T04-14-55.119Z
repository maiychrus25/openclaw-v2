atedTeacher = await this.teacherRepository.updateByUserId(userId, payload as any);\n        const teacherInfos = await this.teacherRepository.findById(id);\n        const teacher = await this.teacherRepository.findByUserId(user_id);","cwd":"/root/.openclaw/workspaces/ahv-driving-training-system/ahv-dtlx-backend"},"isError":false,"timestamp":1776222327842}}
