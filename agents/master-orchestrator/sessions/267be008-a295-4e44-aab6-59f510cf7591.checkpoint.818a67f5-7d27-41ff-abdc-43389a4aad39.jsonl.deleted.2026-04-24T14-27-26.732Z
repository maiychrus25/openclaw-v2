\");\n    }\n\n    // npm install (skip if already done)\n    if (!fs.existsSync(path.join(destDir, \"node_modules\"))) {\n      console.log(chalk.dim(`  рџ“¦ ${mcpName}: npm install...`));\n      try {\n        execSync(\"npm install --silent\", { cwd: destDir, encoding: \"utf8\", timeout: 120000 });\n      } catch {\n        try {\n          execSync(\"npm install\", { cwd: destDir, encoding: \"utf8\", timeout: 120000 });\n        } catch (e) {\n          console.log(chalk.yellow(`  вљ пёЏ  npm install failed for ${mcpName}`));\n        }\n      }\n    }\n    console.log(chalk.green(`  вњ… ${mcpName}`));\n  }\n}\n---\n-rw-------  1 root root   261 Apr  2 13:17 /root/.openclaw/auth-profiles.json\n-rw-------  1 root root   171 Apr 16 02:52 /root/.openclaw/exec-approvals.json\n-rw-------  1 root root 33764 Apr 16 02:47 /root/.openclaw/openclaw.json\n-rw-------  1 root root 54294 Apr 16 02:02 /root/.openclaw/openclaw.json.backup-1776304957486.json\n-rw-------  1 root root 44445 Apr 12 06:41 /root/.openclaw/openclaw.json.bak\n-rw-r--r--  1 root root 39000 Apr 11 18:28 /root/.openclaw/openclaw2.json\n-rw-------  1 root root   189 Apr 15 13:29 /root/.openclaw/update-check.json\n\n/root/.openclaw:\ntotal 584\ndrwx------ 28 root root  4096 Apr 16 02:02 .\ndrwx------ 18 root root  4096 Apr 16 02:50 ..\n-rw-r--r--  1 root root 17289 Apr  8 04:56 EOF\ndrwxr-xr-x 42 root root  4096 Apr 11 18:28 agents\n-rw-------  1 root root   261 Apr  2 13:17 auth-profiles.json\ndrwxr-xr-x  2 root root  4096 Apr  2 13:34 canvas\ndrwxr-xr-x  2 root root  4096 Apr  7 04:18 completions\ndrwx------  2 root root  4096 Apr 11 19:23 credentials\ndrwx------  3 root root  4096 Apr 15 13:55 cron\ndrwx------  3 root root  4096 Apr 16 01:29 delivery-queue\ndrwxr-xr-x  2 root root  4096 Apr 16 01:24 devices\ndrwxr-xr-x  4 root root  4096 Apr 11 18:28 ecosystem-backup-2026-04-11\n-rw-------  1 root root   171 Apr 16 02:52 exec-approvals.json\ndrwx------  2 root root  4096 Apr  8 04:52 flows\ndrwxr-xr-x  2