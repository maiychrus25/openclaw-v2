{"type":"message","id":"7cfe8b5d","parentId":"33e774e1","timestamp":"2026-04-15T12:24:05.573Z","message":{"role":"toolResult","toolCallId":"call_function_sgca1rqfy3o2_2","toolName":"exec","content":[{"type":"text","text":"{\n  \"servers\": {\n    \"gitlab\": {\n      \"command\": \"npx\",\n      \"args\": [\n        \"-y\",\n        \"@openclaw/mcp-gitlab\"\n      ],\n      \"env\": {\n        \"GITLAB_URL\": \"https://gitlab.com\",\n        \"GITLAB_TOKEN\": \"YOUR_GITLAB_TOKEN\"\n      }\n    },\n    \"stitch\": {\n      \"command\": \"node\",\n      \"args\": [\n        \"/path/to/your/openclaw/mcp-stitch-key/server.mjs\"\n      ]\n    },\n    \"confluence\": {\n      \"command\": \"npx\",\n      \"args\": [\n        \"-y\",\n        \"confluence-mcp-server\"\n      ],\n      \"env\": {\n        \"CONFLUENCE_BASE_URL\": \"https://annoinfo.atlassian.net/wiki\",\n        \"CONFLUENCE_API_TOKEN\": \"YOUR_CONFLUENCE_TOKEN\",\n        \"CONFLUENCE_EMAIL\": \"your@email.com\"\n      }\n    }\n  },\n  \"list\": [\n    \"gitlab\",\n    \"confluence\",\n    \"stitch\"\n  ]\n}"}],"details":{"status":"completed","exitCode":0,"durationMs":152,"aggregated":"{\n  \"servers\": {\n    \"gitlab\": {\n      \"command\": \"npx\",\n      \"args\": [\n        \"-y\",\n        \"@openclaw/mcp-gitlab\"\n      ],\n      \"env\": {\n        \"GITLAB_URL\": \"https://gitlab.com\",\n        \"GITLAB_TOKEN\": \"YOUR_GITLAB_TOKEN\"\n      }\n    },\n    \"stitch\": {\n      \"command\": \"node\",\n      \"args\": [\n        \"/path/to/your/openclaw/mcp-stitch-key/server.mjs\"\n      ]\n    },\n    \"confluence\": {\n      \"command\": \"npx\",\n      \"args\": [\n        \"-y\",\n        \"confluence-mcp-server\"\n      ],\n      \"env\": {\n        \"CONFLUENCE_BASE_URL\": \"https://annoinfo.atlassian.net/wiki\",\n        \"CONFLUENCE_API_TOKEN\": \"YOUR_CONFLUENCE_TOKEN\",\n        \"CONFLUENCE_EMAIL\": \"your@email.com\"\n      }\n    }\n  },\n  \"list\": [\n    \"gitlab\",\n    \"conflue