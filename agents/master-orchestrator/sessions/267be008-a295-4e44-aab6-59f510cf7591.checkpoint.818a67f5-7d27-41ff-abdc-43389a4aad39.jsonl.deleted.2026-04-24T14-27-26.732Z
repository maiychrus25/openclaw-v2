)):\n        dec[i] = buf[i] ^ SKILL_KEY_BYTES[i % len(SKILL_KEY_BYTES)] ^ (i & 0xff)\n    return zlib.decompress(bytes(dec))\n\nAGENTS = ['agile-product-owner','clean-code','code-reviewer','coding-standards','content-strategy',\n  'database-reviewer','database-schema-designer','epic-design','harness-optimizer',\n  'market-intelligence','master-orchestrator','performance-optimizer','planner',\n  'playwright-pro','product-marketing-context','product-strategy','prompt-optimizer',\n  'realistic-seeder','refactor-cleaner','security-reviewer','senior-architect',\n  'senior-backend','senior-devops','senior-frontend','senior-qa','senior-security',\n  'seo-audit','shadcn-expert','stitch-design','stitch-loop','typescript-reviewer',\n  'ui-design-system','ui-ux-pro-max']\n\nECOSYSTEM = \"/root/.openclaw/workspaces2/v4-ecosystem-review\"\n\nmanifest = []\npayloads = {}\nfailed = []\ncount = 0\n\n# Source 1: agent-defs/ and agent-templates/\nfor agent in sorted(AGENTS):\n    src_dir = f'agent-defs/{agent}' if os.path.isdir(f'agent-defs/{agent}') else f'agent-templates/{agent}'\n    if not os.path.isdir(src_dir):\n        continue\n    for fname in sorted(os.listdir(src_dir)):\n        fpath = os.path.join(src_dir, fname)\n        if not os.path.isfile(fpath):\n            continue\n        with open(fpath, 'rb') as f:\n            content = f.read()\n        entry_path = f'{agent}/{fname}'\n        encrypted = encrypt(content)\n        try:\n            text = decrypt(encrypted)\n            assert text == content\n        except Exception as e:\n            failed.append((entry_path, str(e)))\n        manifest.append({'file': entry_path, 'size': len(content)})\n        payloads[entry_path] = encrypted\n        count += 1\n\n# Source 2: ecosystem workspace skills/ directories\nskill_files = open('/tmp/skill_files.txt').read().strip().split('\\n')\nprint(f\"Packing {len(skill_files)} skill files from ecosystem...\")\n\nfor rel_path in sorted(skill_files):\n    fpath = os.path.join(ECOSYSTEM, rel_path)\n    if not os.path.isfile(fpath):\n        continue\n    with open(fpath, 'rb') as f:\n        content = f.read()\n    entry_path = rel_path  # e.g. \"agile-product-owner/skills/.../SKILL.md\"\n    encrypted = encrypt(content)\n    try:\n        text = decrypt(encrypted)\n        assert text == content\n    except Exception as e:\n        failed.append((entry_path, str(e)))\n    manifest.append({'file': entry_path, 'size': len(content)})\n    payloads[entry_path] = encrypted\n    count += 1\n\nprint(f'Generated {count} entries, {len(failed)} failed')\nif failed:\n    for f in failed[:5]:\n        print(f'  FAIL: {f[0]}: {f[1]}')\nelse:\n    print('вњ… All verified OK!')\n\npack = {\n    'version': '1.0',\n    'packedAt': '2026-04-16T00:00:00.000Z',\n    'fileCount': len(manifest),\n    'key': SKILL_KEY,\n    'manifest': manifest,\n    'payloads': payloads\n}\nwith open('skills.pack', 'w') as f:\n    json.dump(pack, f, indent=2)\nsize = os.path.getsize('skills.pack')\nprint(f'вњ… Pack saved: {size/1024:.1f}KB, {len(manifest)} entries')\nPYEOF","timeout":120}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":333,"output":1254,"cacheRead":51987,"cacheWrite":659,"totalTokens":54233,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776304063007,"responseId":"062f72c0f66716036efdc91e9d1caf3f"}}
