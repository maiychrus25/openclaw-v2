ateway:\"\n  echo \"     openclaw gateway restart\"\n  echo \"\"\n  echo \"  ${CYAN}2.${RESET} Mo TUI:\"\n  echo \"     openclaw tui --token \\$(grep token /root/.openclaw/openclaw.json | head -1 | sed 's/.*\\\"\\\\([a-f0-9]*\\\\)\\\".*/\\\\1/')\"\n  echo \"\"\n  echo \"  ${CYAN}3.${RESET} Kiem tra:\"\n  echo \"     openclaw agents list\"'''\n\nnew_done = '''  echo \"\"\n  log \"Setup hoan tat!\"\n  echo \"\"\n  echo \"  Config da tao: ${HOME}/.openclaw/openclaw.generated-\\${SETUP_TEAM:-dev}.json\"\n  echo \"\"\n  echo \"  Tiбєїp theo:\"\n  echo \"  ${CYAN}1.${RESET} Review file config:\"\n  echo \"     cat ~/.openclaw/openclaw.generated-\\${SETUP_TEAM:-dev}.json | head -50\"\n  echo \"\"\n  echo \"  ${CYAN}2.${RESET} Merge vao openclaw.json hoac rename:\"\n  echo \"     mv ~/.openclaw/openclaw.json ~/.openclaw/openclaw.json.backup 2>/dev/null || true\"\n  echo \"     cp ~/.openclaw/openclaw.generated-\\${SETUP_TEAM:-dev}.json ~/.openclaw/openclaw.json\"\n  echo \"\"\n  echo \"  ${CYAN}3.${RESET} Restart gateway:\"\n  echo \"     openclaw gateway restart\"'''\n\nif old_done in content:\n    content = content.replace(old_done, new_done)\n    print('вњ… done message updated')\nelse:\n    print('вќЊ done message not found')\n\nwith open('/root/.openclaw/workspaces2/v4-ecospace-review/ahv-openclaw-setup/install.sh', 'w') as f:\n    f.write(content)\nPYEOF\npython3 /tmp/patch_install.py"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":144,"output":879,"cacheRead":115131,"cacheWrite":912,"totalTokens":117066,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776308986722,"responseId":"062f85fd4d34371b4ebc87b23cf5ff08"}}
