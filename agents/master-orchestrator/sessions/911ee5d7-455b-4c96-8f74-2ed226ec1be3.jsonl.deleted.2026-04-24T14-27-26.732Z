Auto-close stale sessions |\n| `subagents.maxConcurrent` | 4 | 3 | 3 | Giới hạn agent chạy song song |\n| `subagents.runTimeout` | 10min | 10min | 15min | Timeout subagent — tránh runaway |\n| `session.maxHistory` | 40 msg | 35 msg | 50 msg | Giữ lịch sử message/session |\n| `session.compactAfter` | 25 msg | 20 msg | 30 msg | Tự động compact để tiết kiệm tokens |\n| `session.maxAge` | 2h | 3h | 2h | Tự động xóa session cũ |\n| `memory.auto-compact` | ✅ | ✅ | ✅ | Tự động compact memory |\n\n**Kết quả:** Kiểm soát context window, giảm token usage, không agent treo, không memory leak.\n\n---\n\n## 🔒 Security"}]}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":424,"output":457,"totalTokens":61693,"cacheRead":60409,"cacheWrite":403,"cost":{"total":0}},"stopReason":"toolUse","timestamp":1776235257828,"responseId":"062e65fb67d6eeeca433fc5c03e053c8","__openclaw":{"id":"334453e4","seq":1826}}]},{"key":"agent:master-orchestrator:cron:e7885813-0446-4101-a171-941c2416848e","kind":"other","channel":"webchat","label":"Cron: Agent Status to Lead","displayName":"webchat:g-agent-master-orchestrator-cron-e7885813-0446-4101-a171-941c2416848e","deliveryContext":{"channel":"webchat"},"updatedAt":1776235099528,"sessionId":"04289801-6f69-427f-b5c2-f7ed3beeb516","model":"AHV-Holding-DEV","contextTokens":200000,"totalTokens":21351,"estimatedCostUsd":0,"status":"running","startedAt":1776235098987,"systemSent":true,"abortedLastRun":false,"lastChannel":"webchat","transcriptPath":"/root/.openclaw/agents/master-orchestrator/sessions/04289801-6f69-427f-b5c2-f7ed3beeb516.jsonl","messages":[{"role":"assistant","content":[],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":0,"output":0,"totalTokens":0,"cacheRead":0,"cacheWrite":0,"cost":{"total":0}},"stopReason":"aborted","timestamp":1776235191768,"errorMessage":"Request was aborted.","__openclaw":{"id":"51864a4c","seq":8}}]},{"key":"agent:master-orchestrator