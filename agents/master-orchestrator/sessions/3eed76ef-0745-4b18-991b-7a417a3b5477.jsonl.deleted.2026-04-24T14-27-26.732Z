 Lead] You are Orbis. Check sessions_list and compile a brief status of all ACTIVE master-orchestrator sessions (excluding this cron session).\n\nFor each active session, report:\n- Session key (shortened)\n- Status (running/done)\n- What it's doing (from context)\n- How long it's been running\n\nSend the report to Lead directly via sessions_send to sessionKey: agent:master-orchestrator:telegram:direct:6053576134\n\nFormat:\n🌐 Orbis — Agent Status | {HH:MM} UTC {DD MMM}\n\nActive sessions: N\n• [session name]: [status] — [task/description] — [duration]\n\nIf only this cron session is active (no other sessions), send HEARTBEAT_OK only.\nIf there are no sessions at all, stay SILENT.\nCurrent time: Wednesday, April 15th, 2026 - 12:54 AM (UTC) / 2026-04-15 00:54 UTC"}],"timestamp":1776214507530,"__openclaw":{"id":"0c211062","seq":1}},{"role":"assistant","content":[{"type":"thinking","thinking":"Let me check the sessions_list to see what active master-orchestrator sessions are running."},{"type":"toolCall","id":"call_function_onvvs709b2oh_1","name":"sessions_list","arguments":{"kinds":["agent"],"limit":20,"messageLimit":3}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":345,"output":69,"totalTokens":14263,"cacheRead":10789,"cacheWrite":3060,"cost":{"total":0}},"stopReason":"toolUse","timestamp":1776214507684,"responseId":"062e14ec2e0881b7f57b066f119d9793","__openclaw":{"id":"ba0fb787","seq":2}}]},{"key":"agent:master-orchestrator:cron:ed2d0b5d-fc56-42eb-a8fc-973a48024df7","kind":"other","channel":"webchat","origin":{"provider":"heartbeat"},"label":"Cron: 5p Progress Report","displayName":"webchat:g-agent-master-orchestrator-cron-ed2d0b5d-fc56-42eb-a8fc-973a48024df7","deliveryContext":{"channel":"webchat"},"updatedAt":1776214479608,"sessionId":"8d7f7dcd-c062-4347-a165-05baf0374d06","model":"AHV-Holding-DEV","contextTokens":200000,"totalTokens":11158,"estimatedCostUsd":0,"status":"running","startedAt":1776214290785,"endedAt":