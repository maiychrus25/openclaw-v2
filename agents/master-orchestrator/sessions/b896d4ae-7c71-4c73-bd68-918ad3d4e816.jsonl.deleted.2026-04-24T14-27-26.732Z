tes (no new failures)\\n\\nNo new changes detected. Pipeline status unchanged. Staying silent.\"\n            }\n          ],\n          \"api\": \"anthropic-messages\",\n          \"provider\": \"ahvholding\",\n          \"model\": \"AHV-Holding-DEV\",\n          \"usage\": {\n            \"input\": 11534,\n            \"output\": 671,\n            \"totalTokens\": 26556,\n            \"cacheRead\": 13944,\n            \"cacheWrite\": 407,\n            \"cost\": {\n              \"total\": 0\n            }\n          },\n          \"stopReason\": \"stop\",\n          \"timestamp\": 1776219453918,\n          \"responseId\": \"062e283ef8da5868bad39a53b0752172\",\n          \"__openclaw\": {\n            \"id\": \"380fe29d\",\n            \"seq\": 5\n          }\n        }\n      ]\n    },\n    {\n      \"key\": \"agent:master-orchestrator:telegram:group:-5163901258\",\n      \"kind\": \"group\",\n      \"channel\": \"telegram\",\n      \"origin\": {\n        \"provider\": \"telegram\",\n        \"accountId\": \"main_bot\"\n      },\n      \"displayName\": \"telegram:g-ahv-qlhv-ecosystem\",\n      \"deliveryContext\": {\n        \"channel\": \"telegram\",\n        \"to\": \"telegram:-5163901258\",\n        \"accountId\": \"main_bot\"\n      },\n      \"updatedAt\": 1776219281472,\n      \"sessionId\": \"8e0cb2bc-8245-4c89-bc2c-e3cca2257d0f\",\n      \"model\": \"AHV-Holding-DEV\",\n      \"contextTokens\": 200000,\n      \"totalTokens\": 102147,\n      \"estimatedCostUsd\": 0,\n      \"status\": \"running\",\n      \"startedAt\": 1776163408296,\n      \"endedAt\": 1776163783190,\n      \"runtimeMs\": 8014,\n      \"childSessions\": [\n        \"agent:senior-backend:subagent:f42cdd0e-8c76-42e7-ac2a-f1474568e0d4\",\n        \"agent:senior-frontend:subagent:cf1f74df-fd21-47ed-8a91-4c146aead234\",\n        \"agent:ui-ux-pro-max:subagent:469f1534-e128-44ea-af0d-73710c607372\",\n        \"agent:ui-ux-pro-max:subagent:ae038bd3-76fe-45b5-a5d7-b8797a299b2d\"\n      ],\n      \