0110b\\\"><p local-id=\\\"08ba35a6-4956-4518-82dd-ed7931943aa8\\\"><strong>Condition</strong></p></th><th data-highlight-colour=\\\"#f0f1f2\\\" ac:local-id=\\\"660d889e-b120-4528-8aed-af4ac0258086\\\"><p local-id=\\\"44fb16b0-7905-4ebf-b7c4-703405281502\\\"><strong>Description</strong></p></th></tr><tr ac:local-id=\\\"558edf90-a6e5-4bfd-b5f9-8789578fe42a\\\"><td ac:local-id=\\\"86ee8a1a-03a0-426a-babb-f1e5af0266f1\\\"><ac:image ac:align=\\\"center\\\" ac:layout=\\\"center\\\" ac:original-height=\\\"51\\\" ac:original-width=\\\"89\\\" ac:custom-width=\\\"true\\\" ac:local-id=\\\"31db5105-3a53-4808-8717-0d65b7684756\\\" ac:alt=\\\"image-20250729-082101.png\\\" ac:width=\\\"89\\\"><ri:attachment ri:filename=\\\"image-20250729-082101.png\\\" ri:version-at-save=\\\"1\\\" /></ac:image><p local-id=\\\"5e725920-88f2-4e99-861b-d1c8ce2756fe\\\" /></td><td ac:local-id=\\\"286415ea-af51-4294-b834-6ddc29836ddf\\\"><p local-id=\\\"5d05c939-9bc5-4332-9d63-20c45cd2ee8e\\\">Tạo lead</p></td><td ac:local-id=\\\"510179e3-d713-445d-b88a-bd2befe8fd98\\\"><p local-id=\\\"748ab90c-a7b5-4035-85cb-f1bb6ad5e975\\\">Button</p></td><td ac:local-id=\\\"97f86adc-6a1a-40e1-98d3-5689fa96f879\\\"><p local-id=\\\"da1353c9-8ce0-49b6-bd58-8b9ae08e81ee\\\">-</p></td><td ac:local-id=\\\"e5d26302-6068-4df4-8854-20f06bc0509c\\\"><p local-id=\\\"5a7579de-b956-4fd0-9bb1-5a3d61247f8e\\\">Y</p></td><td ac:local-id=\\\"40aee848-85eb-4b85-9050-95f5dcde73ee\\\"><p local-id=\\\"7ba134ac-993c-4625-90ac-341c0cc7616e\\\">-</p></td><td ac:local-id=\\\"9a93c257-e407-4c4a-b5a1-159ee60fc615\\\"><p local-id=\\\"ad32db4c-33ee-4abc-9c76-96b5c23a8db8\\\">Cho ph&eacute;p người d&ugrave;ng c&oacute; thể th&ecirc;m mới được kh&aacute;ch h&agrave;ng tiềm năng để tư vấn về dịch vụ của m&igrave;nh</p><p local-id=\\\"fdc0b74a-a5c8-467f-b4bd-478e8680da6a\\\"><strong>OnClick:</strong></p><p local-id=\\\"31cd699a-1e60-4547-aa3c-99869499d1fd\\\">Chuyển hướng đến trang &ldquo;Th&ecirc;m mới kh&aacute;ch h&agrave;ng tiềm năng&rdquo;</p></td></tr><tr ac:local-id=\\\"6e37b9a1-f9ed-4093-a5a2-a7105733bd72\\\"><td rowspan=\\\"7\\\" ac:local-id=\\\"c169d10b-fd88-406d-a304-3d0a4c736a5a\\\"><ac:image ac:align=\\\"center\\\" ac:layout=\\\"center\\\" ac:original-height=\\\"227\\\" ac:original-width=\\\"1798\\\" ac:custom-width=\\\"true\\\" ac:local-id=\\\"a965688e-0421-41f6-be30-0bd8fa51d627\\\" ac:alt=\\\"image-20250729-023451.png\\\" ac:width=\\\"163\\\"><ri:attachment ri:filename=\\\"image-20250729-023451.png\\\" ri:version-at-save=\\\"1\\\" /><ac:caption ac:local-id=\\\"254b0eb5-035a-48ed-bdb7-40e790933657\\\"><p>Bộ lọc</p></ac:caption></ac:image></td><td ac:local-id=\\\"ff15215d-414d-41db-a0c7-3df6da9033a2\\\"><p local-id=\\\"01df3a51-95c2-4d4a-bced-ddc1b1848570\\\">T&ecirc;n</p></td><td ac:local-id=\\\"3ee84aa5-a89e-4974-a602-43df79d78e56\\\"><p local-id=\\\"45e69393-c6e7-4959-a3d4-ac71d4c28166\\\">Textbox</p></td><td ac:local-id=\\\"40f4bfb3-9147-4389-bbde-cc7b92a5a9b0\\\"><p local-id=\\\"29dbe162-f91d-4570-8bc3-038a1b120c23\\\">Text</p></td><td ac:local-id=\\\"c4132f23-aab9-47e2-b155-bc6f977bb815\\\"><p local-id=\\\"1287e146-80ec-47dd-832b-5e5586537127\\\">-</p></td><td ac:local-id=\\\"d17ff9cf-9676-4c93-bb9f-2afcfc2b82fa\\\"><p local-id=\\\"a3ec7637-3cc2-4822-9920-cb385ca28a54\\\">-</p></td><td ac:local-id=\\\"c684f3f6-d07e-4af5-a458-754d88b8f1b1\\\"><p local-id=\\\"83042ecb-fc4c-470e-8797-5304b5451b54\\\"><strong>Default value:</strong></p><p local-id=\\\"58db86fc-bbb9-41ae-bee4-2226bda467ff\\\">Hint text hiển thị &ldquo;Nhập t&ecirc;n&rdquo;</p><p local-id=\\\"e7197535-009d-44e5-8347-238bbb806ac5\\\"><strong>OnClick:</strong></p><p local-id=\\\"c1fcdf28-9909-4de6-ba09-4a19a5579498\\\">Nhập t&ecirc;n leads muốn t&igrave;m kiếm &rarr; Click button &ldquo;T&igrave;m kiếm&rdquo; or Enter:</p><ul local-id=\\\"525f6e1f-c1a1-464d-95ba-7662c4e1ba73\\\"><li local-id=\\\"421d1496-ed44-493e-91cc-fcf8ead6e743\\\"><p local-id=\\\"35849935-3b67-4723-a387-e3d6b1c95e48\\\">TH1: C&oacute; dữ liệu &rarr; Hiển thị 