ed_at\": \"2026-04-11T09:21:47.000+00:00\",\n    \"parent_ids\": [\n      \"0482434dacd1a09744b0ffff811558f008ddc4f5\"\n    ],\n    \"title\": \"feat(date-input): migrate all date fields to ViDateInput (dd/mm/yyyy display)\",\n    \"message\": \"feat(date-input): migrate all date fields to ViDateInput (dd/mm/yyyy display)\\n\\nReplace all raw <input type=date> with ViDateInput component across 11 files.\\n\\nRules applied:\\n- onChange={e => fn(e.target.value)} → onChange={val => fn(val)}\\n- API format stays YYYY-MM-DD; ViDateInput handles dd/mm/yyyy display\\n- onBlur props removed (ViDateInput doesn't support them)\\n\\nAlso included: students/page.tsx status filter fix\\n(Nộp HS → Đã nộp HS mapping to match BE status_detail values).\\n\\nFiles changed: 16 files, +238 -83 lines\\n\\nVerified: grep 'type=\\\"date\\\"' → 0 remaining inputs in src/\\n\",\n    \"author_name\": \"Orbis\",\n    \"author_email\": \"orbis@local\",\n    \"authored_date\": \"2026-04-11T09:21:47.000+00:00\",\n    \"committer_name\": \"Orbis\",\n    \"committer_email\": \"orbis@local\",\n    \"committed_date\": \"2026-04-11T09:21:47.000+00:00\",\n    \"trailers\": {},\n    \"extended_trailers\": {},\n    \"web_url\": \"https://gitlab.com/ahv-dtlx/ahv-qlhv-fe/-/commit/ea157861e66a7dc3ce5864082d22a10828259041\"\n  }\n]"}],"details":{"mcpServer":"gitlab","mcpTool":"gitlab_list_commits"},"isError":false,"timestamp":1775987740461}}
