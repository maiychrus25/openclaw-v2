i\" suppressHydrationWarning>\n      <body className=\"min-h-screen flex flex-col\">\n        <ThemeProvider>\n          <MusicProvider>\n            <Header />\n            <main className=\"flex-1\">{children}</main>\n            <Footer />\n            <KeyboardShortcuts />\n            <MiniPlayer />\n            <BackToTop />\n          </MusicProvider>\n        </ThemeProvider>\n        <WebSiteSchema />\n      </body>\n    </html>\n  )\n}\n"}],"isError":false,"timestamp":1776587127853}}
