{"type":"message","id":"07793e7e","parentId":"7f7f1aad","timestamp":"2026-04-19T03:45:58.991Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me write the articles listing page, article detail page, music page, study page, search page, and sitemap/robots files.","thinkingSignature":"b907d26378fb71ce69c9808b9f95ba3caa24285306de7be8665193950ed8b3b4"},{"type":"toolCall","id":"call_function_b8bed7uinp9g_1","name":"write","arguments":{"path":"/root/.openclaw/workspaces2/v4-ecosystem-review/maiy-tech-hub/app/articles/page.tsx","content":"import Link from 'next/link'\nimport { ArticleCard } from '@/components/blog/article-card'\nimport { getAllArticles } from '@/lib/content'\nimport { CATEGORIES } from '@/config/site'\n\nexport const metadata = {\n  title: 'Tất cả bài viết',\n  description: 'Tất cả bài viết về CTDL & Giải thuật, AI, Web Dev, DevOps và CS Fundamentals.',\n}\n\nexport default async function ArticlesPage() {\n  const articles = await getAllArticles()\n\n  return (\n    <div className=\"container py-12\">\n      <div className=\"mb-10\">\n        <h1 className=\"text-3xl font-bold mb-3\">Tất cả bài viết</h1>\n        <p className=\"text-muted-foreground\">\n          {articles.length} bài viết về CNTT — từ cơ bản đến nâng cao\n        </p>\n      </div>\n\n      {/* Category filter */}\n      <div className=\"flex flex-wrap gap-2 mb-10\">\n        <Link\n          href=\"/articles\"\n          className=\"px-4 py-2 rounded-full text-sm font-medium bg-primary text-primary-foreground\"\n        >\n          Tất cả\n        </Link>\n        {CATEGORIES.map((cat) => (\n          <Link\n            key={cat.slug}\n            href={`/articles/category/${cat.slug}`}\n            className=\"px-4 py-2 rounded-full text-sm font-medium border border-border hover:border-primary/50 hover:bg-primary/5 transition-all\"\n          >\n            {cat.label}\n          </Link>\n        ))}\n      </div>\n\n      {articles.length === 0 ? (\n        <div className=\"text-center py-20\">\n          <p className=\"text-lg text-muted-foreground mb-2\">\n            Chưa có bài viết nào.\n          </p>\n          <p className=\"text-sm text-muted-foreground\">\n            Bài viết đầu tiên sẽ xuất hiện ở đây!\n          </p>\n        </div>\n      ) : (\n        <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\">\n          {articles.map((article) => (\n            <ArticleCard key={article.slug} article={article} />\n          ))}\n        </div>\n      )}\n    </div>\n  )\n}\n"}},{"type":"toolCall","id":"call_function_b8bed7uinp9g_2","name":"write","arguments":{"path":"/root/.openclaw/workspaces2/v4-ecosystem-review/maiy-tech-hub/app/articles/[slug]/page.tsx","content":"import { notFound } from 'next/navigation'\nimport Link from 'next/link'\nimport { Clock, Calendar, ArrowLeft, Share2, BookOpen } from 'lucide-react'\nimport { getArticleBySlug, getAllSlugs, getArticlesByCategory } from '@/lib/content'\nimport { ArticleCard } from '@/components/blog/article-card'\nimport { Breadcrumbs } from '@/components/seo/breadcrumbs'\nimport { ArticleSchema } from '@/components/seo/article-schema'\n\ninterface Props {\n  params: { slug: string }\n}\n\nexport async function generateStaticParams() {\n  const slugs = await getAllSlugs()\n  return slugs.map((slug) => ({ slug }))\n}\n\nexport async function generateMetadata({ params }: Props) {\n  const article = await getArticleBySlug(params.slug)\n  if (!article) return { title: 'Không tìm thấy' }\n\n  return {\n    title: article.title,\n    description: article.excerpt,\n    openGraph: {\n      type: 'article',\n      title: article.title,\n      description: article.excerpt,\n      images: article.hero ? [{ url: article.hero }] : [],\n      publishedTime: article.publishedAt,\n    },\n  }\n}\n\nexport default async function ArticlePage({ params }: Props) {\n  const article = await getArticleBySlug(params.slug)\n  if (!article) notFound()\n\n  const related = (await getArticlesByCategory(article.category))\n    .filter((a) => a.slug !== params.slug)\n    .slice(0, 3)\n\n  const publishDate = new Date(article.publishedAt).toLocaleDateString('vi-VN', {\n    day: 'numeric',\n    month: 'long',\n    year: 'numeric',\n  })\n\n  return (\n    <>\n      <ArticleSchema article={article} />\n\n      <div className=\"container py-8\">\n        {/* Breadcrumbs */}\n        <Breadcrumbs\n          items={[\n            { label: 'Trang chủ', href: '/' },\n            { label: 'Bài viết', href: '/articles' },\n            { label: article.category, href: `/articles/category/${article.category}` },\n            { label: article.title },\n          ]}\n        />\n\n        <article className=\"max-w-3xl mx-auto\">\n          {/* Back */}\n          <Link\n            href=\"/articles\"\n            className=\"inline-flex items-center gap-1 text-sm text-muted-foreground hover:text-primary mb-6 transition-colors\"\n          >\n            <ArrowLeft className=\"h-4 w-4\" /> Quay lại bài viết\n          </Link>\n\n          {/* Header */}\n          <header className=\"mb-8\">\n            <div className=\"flex items-center gap-3 mb-4\">\n              <span className=\"px-3 py-1 text-xs font-medium rounded-full bg-primary/10 text-primary\">\n                {article.category}\n              </span>\n              <span className=\"flex items-center gap-1 text-sm text-muted-foreground\">\n                <Clock className=\"h-4 w-4\" />\n                {article.readingTime} phút đọc\n              </span>\n            </div>\n\n            <h1 className=\"text-3xl md:text-4xl font-bold tracking-tight mb-4\">\n              {article.title}\n            </h1>\n\n            <p className=\"text-lg text-muted-foreground mb-6\">{article.excerpt}</p>\n\n            <div className=\"flex items-center gap-4 text-sm text-muted-foreground\">\n              <span className=\"flex items-center gap-1\">\n                <BookOpen className=\"h-4 w-4\" />\n                {article.author}\n              </span>\n              <span className=\"flex items-center gap-1\">\n                <Calendar className=\"h-4 w-4\" />\n                {publishDate}\n              </span>\n              <button className=\"ml-auto flex items-center gap-1 hover:text-primary transition-colors\">\n                <Share2 className=\"h-4 w-4\" /> Chia sẻ\n              </button>\n            </div>\n          </header>\n\n          {/* Hero Image */}\n          {article.hero && (\n            // eslint-disable-next-line @next/next/no-img-element\n            <img\n              src={article.hero}\n              alt={article.title}\n              className=\"w-full rounded-xl mb-8 aspect-video object-cover\"\n            />\n          )}\n\n          {/* Tags */}\n          {article.tags.length > 0 && (\n            <div className=\"flex flex-wrap gap-2 mb-8\">\n              {article.tags.map((tag) => (\n                <Link\n                  key={tag}\n                  href={`/search?q=${tag}`}\n                  className=\"px-3 py-1 text-xs rounded-full border border-border hover:border-primary/50 hover:bg-primary/5 transition-all\"\n                >\n                  #{tag}\n                </Link>\n              ))}\n            </div>\n          )}\n\n          {/* Article content */}\n          <div className=\"prose prose-lg dark:prose-invert max-w-none\">\n            <ContentRenderer content={article.content} />\n          </div>\n        </article>\n\n        {/* Related posts */}\n        {related.length > 0 && (\n          <section className=\"max-w-3xl mx-auto mt-16\">\n            <h2 className=\"text-xl font-bold mb-6\">Bài viết liên quan</h2>\n            <div className=\"grid grid-cols-1 md:grid-cols-3 gap-4\">\n              {related.map((a) => (\n                <ArticleCard key={a.slug} article={a} />\n              ))}\n            </div>\n          </section>\n        )}\n      </div>\n    </>\n  )\n}\n\n// Simple content renderer for demo — replace with MDXRemote in production\nfunction ContentRenderer({ content }: { content: string }) {\n  return (\n    <div\n      className=\"prose-headings:scroll-mt-20 prose-a:text-primary prose-code:bg-muted prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-pre:bg-muted\"\n      dangerouslySetInnerHTML={{\n        __html: content\n          .replace(/```(\\w+)?\\n([\\s\\S]*?)```/g, '<pre><code>$2</code></pre>')\n          .replace(/`([^`]+)`/g, '<code>$1</code>')\n          .replace(/\\*\\*([^*]+)\\*\\*/g, '<strong>$1</strong>')\n          .replace(/\\*([^*]+)\\*/g, '<em>$1</em>')\n          .replace(/# (.*)/g, '<h1>$1</h1>')\n          .replace(/## (.*)/g, '<h2>$1</h2>')\n          .replace(/### (.*)/g, '<h3>$1</h3>')\n          .replace(/\\n\\n/g, '</p><p>')\n          .replace(/^(.*)$/gm, (line) => {\n            if (line.startsWith('<')) return line\n            return line\n          }),\n      }}\n    />\n  )\n}\n"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":177,"output":2197,"cacheRead":81263,"cacheWrite":4611,"totalTokens":88248,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776570333046,"responseId":"063382de96a33e84b933734f6289b8f3"}}
