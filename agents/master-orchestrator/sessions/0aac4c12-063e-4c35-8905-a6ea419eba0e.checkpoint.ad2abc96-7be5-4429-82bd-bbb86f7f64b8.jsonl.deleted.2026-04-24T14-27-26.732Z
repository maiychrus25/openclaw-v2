{"type":"message","id":"7288f73c","parentId":"5138c05a","timestamp":"2026-04-19T07:37:59.744Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me create the MediaControls component for toggling camera, mic, screen share, and opening chat.","thinkingSignature":"d6442ba154ac690488a6e816f559af64e20fc7dc0ea760d8098c9845a2a56af4"},{"type":"text","text":"**Phase 3: Media Controls:**\n"},{"type":"toolCall","id":"call_function_avawswvmhjuf_1","name":"write","arguments":{"path":"/root/.openclaw/workspaces2/v4-ecosystem-review/maiy-tech-hub/components/study/media-controls.tsx","content":"'use client'\n\nimport { useState } from 'react'\nimport {\n  Mic,\n  MicOff,\n  Video,\n  VideoOff,\n  Monitor,\n  MonitorOff,\n  MessageCircle,\n  PhoneOff,\n  Maximize2,\n  Users,\n} from 'lucide-react'\nimport { motion } from 'framer-motion'\n\ninterface MediaControlsProps {\n  isMicOn: boolean\n  isCameraOn: boolean\n  isScreenOn: boolean\n  unreadMessages: number\n  participantCount: number\n  onToggleMic: () => void\n  onToggleCamera: () => void\n  onToggleScreen: () => void\n  onToggleChat: () => void\n  onLeave: () => void\n  onToggleParticipants?: () => void\n}\n\nexport function MediaControls({\n  isMicOn,\n  isCameraOn,\n  isScreenOn,\n  unreadMessages,\n  participantCount,\n  onToggleMic,\n  onToggleCamera,\n  onToggleScreen,\n  onToggleChat,\n  onLeave,\n  onToggleParticipants,\n}: MediaControlsProps) {\n  const [isHovered, setIsHovered] = useState<string | null>(null)\n\n  const ControlButton = ({\n    icon: Icon,\n    label,\n    active,\n    danger,\n    onClick,\n    badge,\n  }: {\n    icon: typeof Mic\n    label: string\n    active?: boolean\n    danger?: boolean\n    onClick: () => void\n    badge?: number\n  }) => (\n    <div className=\"relative flex flex-col items-center gap-1\">\n      <motion.button\n        whileHover={{ scale: 1.1 }}\n        whileTap={{ scale: 0.9 }}\n        onClick={onClick}\n        onMouseEnter={() => setIsHovered(label)}\n        onMouseLeave={() => setIsHovered(null)}\n        className={`relative w-12 h-12 rounded-full flex items-center justify-center transition-all\n          ${\n            active\n              ? danger\n                ? 'bg-red-500 hover:bg-red-600 text-white'\n                : 'bg-primary hover:bg-primary/90 text-primary-foreground'\n              : 'bg-muted hover:bg-muted/80 text-muted-foreground'\n          }`}\n        aria-label={label}\n      >\n        <Icon className=\"h-5 w-5\" />\n        {badge !== undefined && badge > 0 && (\n          <span className=\"absolute -top-1 -right-1 w-5 h-5 bg-red-500 text-white text-[10px] font-bold rounded-full flex items-center justify-center\">\n            {badge > 9 ? '9+' : badge}\n          </span>\n        )}\n      </motion.button>\n      <span className=\"text-[10px] text-muted-foreground\">{label}</span>\n      {isHovered === label && (\n        <motion.div\n          initial={{ opacity: 0, y: 4 }}\n          animate={{ opacity: 1, y: 0 }}\n          className=\"absolute -top-8 px-2 py-1 bg-foreground text-background text-[10px] rounded whitespace-nowrap\"\n        >\n          {label}\n        </motion.div>\n      )}\n    </div>\n  )\n\n  return (\n    <div className=\"flex items-center justify-center gap-4 p-4\">\n      {/* Mic */}\n      <ControlButton\n        icon={isMicOn ? Mic : MicOff}\n        label={isMicOn ? 'Tắt mic' : 'Bật mic'}\n        active={!isMicOn}\n        onClick={onToggleMic}\n      />\n\n      {/* Camera */}\n      <ControlButton\n        icon={isCameraOn ? Video : VideoOff}\n        label={isCameraOn ? 'Tắt cam' : 'Bật cam'}\n        active={!isCameraOn}\n        onClick={onToggleCamera}\n      />\n\n      {/* Screen share */}\n      <ControlButton\n        icon={isScreenOn ? MonitorOff : Monitor}\n        label={isScreenOn ? 'Dừng chia sẻ' : 'Chia sẻ màn hình'}\n        active={isScreenOn}\n        danger={isScreenOn}\n        onClick={onToggleScreen}\n      />\n\n      {/* Divider */}\n      <div className=\"w-px h-8 bg-border mx-2\" />\n\n      {/* Chat */}\n      <ControlButton\n        icon={MessageCircle}\n        label=\"Chat\"\n        active\n        onClick={onToggleChat}\n        badge={unreadMessages}\n      />\n\n      {/* Participants */}\n      {onToggleParticipants && (\n        <ControlButton\n          icon={Users}\n          label=\"Thành viên\"\n          onClick={onToggleParticipants}\n          badge={participantCount > 1 ? participantCount : undefined}\n        />\n      )}\n\n      {/* Divider */}\n      <div className=\"w-px h-8 bg-border mx-2\" />\n\n      {/* Leave */}\n      <motion.button\n        whileHover={{ scale: 1.1 }}\n        whileTap={{ scale: 0.9 }}\n        onClick={onLeave}\n        className=\"w-12 h-12 rounded-full bg-red-500 hover:bg-red-600 text-white flex items-center justify-center transition-colors\"\n        aria-label=\"Rời phòng\"\n      >\n        <PhoneOff className=\"h-5 w-5\" />\n      </motion.button>\n    </div>\n  )\n}\n"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":112,"output":1241,"cacheRead":43870,"cacheWrite":2527,"totalTokens":47750,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776584262378,"responseId":"0633b94783b54cecda5cd983177042f7"}}
