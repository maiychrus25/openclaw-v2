{"type":"message","id":"9aed5b9f","parentId":"eb4e97a8","timestamp":"2026-04-19T05:31:47.800Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me update the footer to include the new pages.","thinkingSignature":"8295b6b1dcf557b090e190cf22eede868e71e34b8a4d369d17533ca51d2a48db"},{"type":"toolCall","id":"call_function_xcv8cwm3li3g_1","name":"write","arguments":{"path":"/root/.openclaw/workspaces2/v4-ecosystem-review/maiy-tech-hub/components/layout/footer.tsx","content":"import Link from 'next/link'\nimport { Lightbulb, Github, Heart } from 'lucide-react'\nimport { CATEGORIES } from '@/config/site'\n\nexport function Footer() {\n  const currentYear = new Date().getFullYear()\n\n  return (\n    <footer className=\"border-t border-border/40 bg-muted/30\">\n      <div className=\"container py-12\">\n        <div className=\"grid grid-cols-1 md:grid-cols-4 gap-8\">\n          {/* Brand */}\n          <div className=\"md:col-span-2\">\n            <Link href=\"/\" className=\"flex items-center gap-2 font-bold text-lg mb-3\">\n              <Lightbulb className=\"h-5 w-5 text-indigo-500\" />\n              <span>MAIY Tech Hub</span>\n            </Link>\n            <p className=\"text-sm text-muted-foreground max-w-sm\">\n              Nền tảng blog chia sẻ kiến thức CNTT chuẩn chỉnh bằng tiếng Việt.\n              Code thật, giải thích dễ hiểu.\n            </p>\n            <div className=\"flex items-center gap-3 mt-4\">\n              <a\n                href=\"https://github.com/khuowgn/maiy-tech-hub\"\n                target=\"_blank\"\n                rel=\"noopener noreferrer\"\n                className=\"p-2 rounded-md hover:bg-accent transition-colors\"\n                aria-label=\"GitHub\"\n              >\n                <Github className=\"h-5 w-5 text-muted-foreground hover:text-foreground\" />\n              </a>\n            </div>\n          </div>\n\n          {/* Categories */}\n          <div>\n            <h3 className=\"font-semibold mb-4 text-sm\">Chủ đề</h3>\n            <ul className=\"space-y-2\">\n              {CATEGORIES.map((cat) => (\n                <li key={cat.slug}>\n                  <Link\n                    href={`/articles/category/${cat.slug}`}\n                    className=\"text-sm text-muted-foreground hover:text-primary transition-colors\"\n                  >\n                    {cat.label}\n                  </Link>\n                </li>\n              ))}\n            </ul>\n          </div>\n\n          {/* Links */}\n          <div>\n            <h3 className=\"font-semibold mb-4 text-sm\">Liên kết</h3>\n            <ul className=\"space-y-2\">\n              {[\n                { href: '/about', label: 'Giới thiệu' },\n                { href: '/articles', label: 'Tất cả bài viết' },\n                { href: '/tags', label: 'Tags' },\n                { href: '/contact', label: 'Liên hệ' },\n                { href: '/contribute', label: 'Đóng góp' },\n                { href: '/music', label: 'Âm nhạc' },\n                { href: '/study', label: 'Phòng học live' },\n                { href: '/search', label: 'Tìm kiếm' },\n              ].map((link) => (\n                <li key={link.href}>\n                  <Link\n                    href={link.href}\n                    className=\"text-sm text-muted-foreground hover:text-primary transition-colors\"\n                  >\n                    {link.label}\n                  </Link>\n                </li>\n              ))}\n            </ul>\n          </div>\n        </div>\n\n        <div className=\"mt-8 pt-8 border-t border-border/40 flex flex-col sm:flex-row items-center justify-between gap-4\">\n          <div className=\"flex flex-wrap items-center gap-4 text-xs text-muted-foreground\">\n            <Link href=\"/privacy\" className=\"hover:text-primary transition-colors\">\n              Chính sách bảo mật\n            </Link>\n            <Link href=\"/terms\" className=\"hover:text-primary transition-colors\">\n              Điều khoản\n            </Link>\n            <span>© {currentYear} MAIY Tech Hub</span>\n          </div>\n          <p className=\"text-xs text-muted-foreground flex items-center gap-1\">\n            Built with Next.js\n            <Heart className=\"h-3 w-3 text-red-500 inline\" />\n          </p>\n        </div>\n      </div>\n    </footer>\n  )\n}\n"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":110,"output":1027,"cacheRead":147346,"cacheWrite":1126,"totalTokens":149609,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776576695059,"responseId":"06339bb8cd51f85137cfc43163d0e7d9"}}
