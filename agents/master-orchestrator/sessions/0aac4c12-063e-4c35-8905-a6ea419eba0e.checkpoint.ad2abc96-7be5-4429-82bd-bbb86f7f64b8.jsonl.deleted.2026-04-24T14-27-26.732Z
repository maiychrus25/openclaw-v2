{"type":"message","id":"b5144f8e","parentId":"388af0e4","timestamp":"2026-04-19T07:31:48.213Z","message":{"role":"toolResult","toolCallId":"call_function_kdyz64j2pk0q_1","toolName":"read","content":[{"type":"text","text":"import fs from 'fs'\nimport path from 'path'\nimport matter from 'gray-matter'\nimport readingTime from 'reading-time'\nimport type { ArticleSummary } from '@/components/blog/article-card'\n\nconst CONTENT_DIR = path.join(process.cwd(), 'content', 'articles')\n\nexport interface Article extends ArticleSummary {\n  content: string\n}\n\nfunction getArticleFiles(): string[] {\n  if (!fs.existsSync(CONTENT_DIR)) return []\n  const files: string[] = []\n  function walk(dir: string) {\n    const entries = fs.readdirSync(dir, { withFileTypes: true })\n    for (const entry of entries) {\n      const full = path.join(dir, entry.name)\n      if (entry.isDirectory()) {\n        walk(full)\n      } else if (entry.name.endsWith('.mdx') || entry.name.endsWith('.md')) {\n        // Store as relative path from CONTENT_DIR\n        files.push(path.relative(CONTENT_DIR, full))\n      }\n    }\n  }\n  walk(CONTENT_DIR)\n  return files\n}\n\n[87 more lines in file. Use offset=31 to continue.]"}],"isError":false,"timestamp":1776583908188}}
