{"type":"message","id":"7cdf47dd","parentId":"7f4f4bb8","timestamp":"2026-04-19T04:45:36.501Z","message":{"role":"toolResult","toolCallId":"call_function_n3p3bj352q44_1","toolName":"read","content":[{"type":"text","text":"import fs from 'fs'\nimport path from 'path'\nimport matter from 'gray-matter'\nimport readingTime from 'reading-time'\nimport type { ArticleSummary } from '@/components/blog/article-card'\n\nconst CONTENT_DIR = path.join(process.cwd(), 'content', 'articles')\n\nexport interface Article extends ArticleSummary {\n  content: string\n}\n\nfunction getArticleFiles(): string[] {\n  if (!fs.existsSync(CONTENT_DIR)) return []\n  return fs\n    .readdirSync(CONTENT_DIR)\n    .filter((f) => f.endsWith('.mdx') || f.endsWith('.md'))\n}\n\nexport async function getAllArticles(): Promise<ArticleSummary[]> {\n  const files = getArticleFiles()\n  const articles = files.map((file) => {\n    const slug = file.replace(/\\.(mdx|md)$/, '')\n    const raw = fs.readFileSync(path.join(CONTENT_DIR, file), 'utf-8')\n    const { data, content } = matter(raw)\n    const rt = readingTime(content)\n\n    return {\n      slug,\n      title: data.title || slug,\n      excerpt: data.excerpt || '',\n      category: data.category || 'cs-fundamentals',\n      tags: data.tags || [],\n      hero: data.hero || null,\n      author: data.author || 'MAIY Tech Hub',\n      readingTime: Math.ceil(rt.minutes),\n      publishedAt: data.date || new Date().toISOString(),\n    } as ArticleSummary\n  })\n\n  return articles.sort(\n    (a, b) => new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime()\n  )\n}\n\nexport async function getRecentArticles(limit = 6): Promise<ArticleSummary[]> {\n  const all = await getAllArticles()\n  return all.slice(0, limit)\n}\n\nexport async function getFeaturedArticles(): Promise<ArticleSummary[]> {\n  const all = await getAllArticles()\n  // Return all articles — featured is determined by the first one in home page\n  return all\n}\n\nexport async function getArticleBySlug(slug: string): Promise<Article | null> {\n  const mdxPath = path.join(CONTENT_DIR, `${slug}.mdx`)\n  const mdPath = path.join(CONTENT_DIR, `${slug}.md`)\n\n  const filePath = fs.existsSync(mdxPath)\n    ? mdxPath\n    : fs.existsSync(mdPath)\n    ? mdPath\n    : null\n\n  if (!filePath) return null\n\n  const raw = fs.readFileSync(filePath, 'utf-8')\n  const { data, content } = matter(raw)\n  const rt = readingTime(content)\n\n  return {\n    slug,\n    title: data.title || slug,\n    excerpt: data.excerpt || '',\n    category: data.category || 'cs-fundamentals',\n    tags: data.tags || [],\n    hero: data.hero || null,\n    author: data.author || 'MAIY Tech Hub',\n    readingTime: Math.ceil(rt.minutes),\n    publishedAt: data.date || new Date().toISOString(),\n    content,\n  }\n}\n\nexport async function getArticlesByCategory(\n  category: string\n): Promise<ArticleSummary[]> {\n  const all = await getAllArticles()\n  return all.filter((a) => a.category === category)\n}\n\nexport async function getAllSlugs(): Promise<string[]> {\n  return getArticleFiles().map((f) => f.replace(/\\.(mdx|md)$/, ''))\n}\n"}],"isError":false,"timestamp":1776573936146}}
{"type":"message","id":"41facf41","parentId":"7cdf47dd","timestamp":"2026-04-19T04:45:42.188Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"The content library looks good. Now I need to update the article page to use MDX rendering. But actually, since we're using gray-matter for frontmatter and the content is plain markdown text, we can render it directly using the dangerouslySetInnerHTML approach with a proper markdown parser. Let me add a proper markdown renderer using the `react-markdown` package which is lighter than full MDX compilation.\n\nActually, let me just use react-markdown which is simpler. Or actually, let me look at what packages are installed.","thinkingSignature":"c1656e30d8dbfaf2988038dbff232d61b33830f784e6a887b97b181b0e4bf601"},{"type":"toolCall","id":"call_function_pfszak2kwcdz_1","name":"exec","arguments":{"command":"cd /root/.openclaw/workspaces2/v4-ecosystem-review/maiy-tech-hub && cat package.json | python3 -c \"import sys,json; d=json.load(sys.stdin); print([k for k in d.get('dependencies',{}).keys()])\""}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":796,"output":190,"cacheRead":63235,"cacheWrite":409,"totalTokens":64630,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776573936655,"responseId":"063390f24424c761e7fc71aea71712e9"}}
{"type":"message","id":"603cf33b","parentId":"41facf41","timestamp":"2026-04-19T04:45:42.360Z","message":{"role":"toolResult","toolCallId":"call_function_pfszak2kwcdz_1","toolName":"exec","content":[{"type":"text","text":"['@mdx-js/react', '@next/mdx', '@radix-ui/react-avatar', '@radix-ui/react-dialog', '@radix-ui/react-separator', 'class-variance-authority', 'clsx', 'date-fns', 'framer-motion', 'fuse.js', 'gray-matter', 'lucide-react', 'mongoose', 'next', 'next-mdx-remote', 'next-seo', 'next-themes', 'react', 'react-dom', 'reading-time', 'rehype-autolink-headings', 'rehype-highlight', 'rehype-slug', 'remark-gfm', 'socket.io', 'socket.io-client', 'tailwind-merge', 'zod']"}],"details":{"status":"completed","exitCode":0,"durationMs":107,"aggregated":"['@mdx-js/react', '@next/mdx', '@radix-ui/react-avatar', '@radix-ui/react-dialog', '@radix-ui/react-separator', 'class-variance-authority', 'clsx', 'date-fns', 'framer-motion', 'fuse.js', 'gray-matter', 'lucide-react', 'mongoose', 'next', 'next-mdx-remote', 'next-seo', 'next-themes', 'react', 'react-dom', 'reading-time', 'rehype-autolink-headings', 'rehype-highlight', 'rehype-slug', 'remark-gfm', 'socket.io', 'socket.io-client', 'tailwind-merge', 'zod']","cwd":"/root/.openclaw/workspaces2/v4-ecosystem-review/master-orchestrator"},"isError":false,"timestamp":1776573942332}}
{"type":"message","id":"8bb109f6","parentId":"603cf33b","timestamp":"2026-04-19T04:46:01.514Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"`next-mdx-remote` is already installed! That's great — it's the best way to render MDX in Next.js App Router. Let me use that. I can also use `react-markdown` which is lightweight but doesn't support full MDX. Let me use `next-mdx-remote` for rendering the MDX content.","thinkingSignature":"3cc0a3ae803f1805e2971947bd452a28b2eab844ca30bdba567a60d2cf5a5483"},{"type":"text","text":"`next-mdx-remote` đã có sẵn — dùng nó để render MDX đúng cách:\n"},{"type":"toolCall","id":"call_function_f2biqxhcnttq_1","name":"write","arguments":{"path":"/root/.openclaw/workspaces2/v4-ecosystem-review/maiy-tech-hub/components/blog/mdx-content.tsx","content":"'use client'\n\nimport { MDXRemote, type MDXRemoteSerializeResult } from 'next-mdx-remote'\nimport { Note, Warning, Code, Copy, Check } from 'lucide-react'\nimport { useState } from 'react'\n\n// Custom components for MDX\nfunction Callout({\n  children,\n  type = 'note',\n}: {\n  children: React.ReactNode\n  type?: 'note' | 'warning' | 'tip'\n}) {\n  const styles = {\n    note: 'border-blue-500 bg-blue-50 dark:bg-blue-950/30 text-blue-800 dark:text-blue-200',\n    warning:\n      'border-amber-500 bg-amber-50 dark:bg-amber-950/30 text-amber-800 dark:text-amber-200',\n    tip: 'border-green-500 bg-green-50 dark:bg-green-950/30 text-green-800 dark:text-green-200',\n  }\n  const icons = { note: Note, warning: Warning, tip: Note }\n\n  const Icon = icons[type]\n  return (\n    <div className={`my-6 rounded-lg border-l-4 p-4 ${styles[type]}`}>\n      <div className=\"flex items-start gap-3\">\n        <Icon className=\"h-5 w-5 mt-0.5 flex-shrink-0 opacity-70\" />\n        <div className=\"flex-1 text-sm leading-relaxed\">{children}</div>\n      </div>\n    </div>\n  )\n}\n\nfunction CodeBlock({\n  children,\n  className,\n}: {\n  children: React.ReactNode\n  className?: string\n}) {\n  const [copied, setCopied] = useState(false)\n  const code = String(children).replace(/\\n$/, '')\n\n  const handleCopy = async () => {\n    try {\n      await navigator.clipboard.writeText(code)\n      setCopied(true)\n      setTimeout(() => setCopied(false), 2000)\n    } catch {\n      // ignore\n    }\n  }\n\n  return (\n    <div className=\"relative group my-4\">\n      <div className=\"rounded-lg overflow-hidden border border-border bg-muted\">\n        {className && (\n          <div className=\"px-4 py-2 border-b border-border bg-muted/80\">\n            <span className=\"text-xs text-muted-foreground font-mono\">\n              {className.replace('language-', '')}\n            </span>\n          </div>\n        )}\n        <pre className=\"p-4 overflow-x-auto\">\n          <code className={`text-sm font-mono ${className || ''}`}>{children}</code>\n        </pre>\n      </div>\n      <button\n        onClick={handleCopy}\n        className=\"absolute top-2 right-2 p-1.5 rounded bg-background/80 hover:bg-background text-muted-foreground hover:text-foreground transition-all opacity-0 group-hover:opacity-100\"\n        aria-label=\"Copy code\"\n      >\n        {copied ? (\n          <Check className=\"h-3.5 w-3.5\" />\n        ) : (\n          <Copy className=\"h-3.5 w-3.5\" />\n        )}\n      </button>\n    </div>\n  )\n}\n\nconst components = {\n  Callout,\n  pre: ({ children, ...props }: any) => (\n    <CodeBlock {...props}>{children}</CodeBlock>\n  ),\n  code: ({ children, className, ...props }: any) => {\n    // Inline code\n    if (!className) {\n      return (\n        <code className=\"px-1.5 py-0.5 rounded bg-muted text-sm font-mono\">\n          {children}\n        </code>\n      )\n    }\n    // Block code\n    return (\n      <CodeBlock className={className} {...props}>\n        {children}\n      </CodeBlock>\n    )\n  },\n  a: ({ children, href, ...props }: any) => (\n    <a\n      href={href}\n      className=\"text-primary underline-offset-4 hover:underline\"\n      target={href?.startsWith('http') ? '_blank' : undefined}\n      rel={href?.startsWith('http') ? 'noopener noreferrer' : undefined}\n      {...props}\n    >\n      {children}\n    </a>\n  ),\n  h2: ({ children, id, ...props }: any) => (\n    <h2 id={id} className=\"scroll-mt-24 font-bold text-2xl mt-10 mb-4\" {...props}>\n      {children}\n    </h2>\n  ),\n  h3: ({ children, id, ...props }: any) => (\n    <h3 id={id} className=\"scroll-mt-24 font-bold text-xl mt-8 mb-3\" {...props}>\n      {children}\n    </h3>\n  ),\n  table: ({ children, ...props }: any) => (\n    <div className=\"overflow-x-auto my-6\">\n      <table className=\"w-full border-collapse border border-border text-sm\" {...props}>\n        {children}\n      </table>\n    </div>\n  ),\n  th: ({ children, ...props }: any) => (\n    <th\n      className=\"border border-border bg-muted px-4 py-2 text-left font-semibold\"\n      {...props}\n    >\n      {children}\n    </th>\n  ),\n  td: ({ children, ...props }: any) => (\n    <td className=\"border border-border px-4 py-2\" {...props}>\n      {children}\n    </td>\n  ),\n}\n\ninterface MDXContentProps {\n  source: MDXRemoteSerializeResult\n}\n\nexport function MDXContent({ source }: MDXContentProps) {\n  return (\n    <div className=\"prose-custom\">\n      <MDXRemote {...source} components={components} />\n    </div>\n  )\n}\n"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":221,"output":1429,"cacheRead":63579,"cacheWrite":997,"totalTokens":66226,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776573942367,"responseId":"063390f763bed5b460a862da7d45dc98"}}
