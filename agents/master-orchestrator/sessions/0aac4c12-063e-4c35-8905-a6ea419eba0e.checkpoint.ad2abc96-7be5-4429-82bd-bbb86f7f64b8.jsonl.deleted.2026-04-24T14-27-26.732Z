{"type":"message","id":"a70fce7a","parentId":"f7ca347d","timestamp":"2026-04-19T05:12:29.889Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me update the study page to use the socket for real-time features. The study page already has Pomodoro timer and room features. Let me make it use the socket hook.","thinkingSignature":"966661ecaf51092c59bf7e3f5b2f5673b2b84b1e5efe00b774699ad3f8ed448d"},{"type":"toolCall","id":"call_function_hsc6r9549qkg_1","name":"write","arguments":{"path":"/root/.openclaw/workspaces2/v4-ecosystem-review/maiy-tech-hub/app/study/page.tsx","content":"'use client'\n\nimport { useState, useEffect, useCallback, useRef } from 'react'\nimport {\n  Users,\n  Copy,\n  Play,\n  Pause,\n  RotateCcw,\n  Volume2,\n  CloudRain,\n  Coffee,\n  BookOpen,\n  Wifi,\n  WifiOff,\n  Link as LinkIcon,\n} from 'lucide-react'\nimport { useSocket } from '@/hooks/use-socket'\nimport { motion, AnimatePresence } from 'framer-motion'\n\nconst AMBIENT_OPTIONS = [\n  { id: 'rain', label: 'Rain', Icon: CloudRain, sound: 'rain' },\n  { id: 'cafe', label: 'Café', Icon: Coffee, sound: 'cafe' },\n  { id: 'library', label: 'Library', Icon: BookOpen, sound: 'library' },\n] as const\n\nconst DEFAULT_WORK = 25\nconst DEFAULT_BREAK = 5\n\nexport default function StudyPage() {\n  const { isConnected, joinRoom, leaveRoom, syncPomodoro } = useSocket()\n  const [roomCode, setRoomCode] = useState('')\n  const [joinCode, setJoinCode] = useState('')\n  const [joined, setJoined] = useState(false)\n  const [username, setUsername] = useState('')\n  const [participants, setParticipants] = useState<string[]>([])\n  const [phase, setPhase] = useState<'work' | 'break'>('work')\n  const [timeLeft, setTimeLeft] = useState(DEFAULT_WORK * 60)\n  const [isRunning, setIsRunning] = useState(false)\n  const [sessionCount, setSessionCount] = useState(0)\n  const [ambient, setAmbient] = useState<string | null>(null)\n  const [goal, setGoal] = useState('')\n  const intervalRef = useRef<NodeJS.Timeout | null>(null)\n  const audioRef = useRef<HTMLAudioElement | null>(null)\n\n  // Generate room code\n  const generateRoomCode = () => {\n    const chars = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789'\n    let code = ''\n    for (let i = 0; i < 6; i++) {\n      code += chars[Math.floor(Math.random() * chars.length)]\n    }\n    return code\n  }\n\n  const handleCreateRoom = () => {\n    if (!username.trim()) {\n      alert('Vui lòng nhập tên của bạn')\n      return\n    }\n    const code = generateRoomCode()\n    setRoomCode(code)\n    setParticipants([username])\n    setJoined(true)\n    joinRoom(code, username)\n  }\n\n  const handleJoinRoom = () => {\n    if (!joinCode.trim() || !username.trim()) {\n      alert('Vui lòng nhập tên và mã phòng')\n      return\n    }\n    setRoomCode(joinCode.toUpperCase())\n    setJoined(true)\n    setParticipants((prev) => [...prev, username])\n    joinRoom(joinCode.toUpperCase(), username)\n  }\n\n  // Listen for real-time events\n  useEffect(() => {\n    if (!isConnected) return\n\n    const socket = (window as any).__socket\n    if (!socket) return\n\n    const handleUserJoined = ({ username: u, count }: { username: string; count: number }) => {\n      setParticipants((prev) => {\n        if (!prev.includes(u)) return [...prev, u]\n        return prev\n      })\n    }\n\n    const handleUserLeft = ({ username: u, count }: { username: string; count: number }) => {\n      setParticipants((prev) => prev.filter((p) => p !== u))\n    }\n\n    const handlePomodoroSync = ({\n      timeLeft: tl,\n      phase: ph,\n      sessionCount: sc,\n    }: {\n      timeLeft: number\n      phase: string\n      sessionCount: number\n    }) => {\n      setTimeLeft(tl)\n      setPhase(ph as 'work' | 'break')\n      setSessionCount(sc)\n    }\n\n    socket.on('user-joined', handleUserJoined)\n    socket.on('user-left', handleUserLeft)\n    socket.on('pomodoro-sync', handlePomodoroSync)\n\n    return () => {\n      socket.off('user-joined', handleUserJoined)\n      socket.off('user-left', handleUserLeft)\n      socket.off('pomodoro-sync', handlePomodoroSync)\n    }\n  }, [isConnected])\n\n  // Timer logic\n  useEffect(() => {\n    if (isRunning && timeLeft > 0) {\n      intervalRef.current = setInterval(() => {\n        setTimeLeft((t) => {\n          const next = t - 1\n          if (next === 0) {\n            handlePhaseEnd()\n            return 0\n          }\n          // Sync with room\n          if (roomCode) {\n            syncPomodoro(roomCode, next, phase, sessionCount)\n          }\n          return next\n        })\n      }, 1000)\n    } else {\n      if (intervalRef.current) clearInterval(intervalRef.current)\n    }\n\n    return () => {\n      if (intervalRef.current) clearInterval(intervalRef.current)\n    }\n  }, [isRunning, timeLeft, roomCode])\n\n  const handlePhaseEnd = useCallback(() => {\n    setIsRunning(false)\n    if (phase === 'work') {\n      setSessionCount((s) => s + 1)\n      setPhase('break')\n      setTimeLeft(DEFAULT_BREAK * 60)\n    } else {\n      setPhase('work')\n      setTimeLeft(DEFAULT_WORK * 60)\n    }\n  }, [phase])\n\n  const toggleTimer = () => setIsRunning((r) => !r)\n\n  const resetTimer = () => {\n    setIsRunning(false)\n    setTimeLeft(DEFAULT_WORK * 60)\n    setPhase('work')\n  }\n\n  const formatTime = (seconds: number) => {\n    const m = Math.floor(seconds / 60)\n    const s = seconds % 60\n    return `${m.toString().padStart(2, '0')}:${s.toString().padStart(2, '0')}`\n  }\n\n  // Copy room code\n  const copyRoomCode = () => {\n    navigator.clipboard.writeText(roomCode)\n  }\n\n  if (!joined) {\n    return (\n      <div className=\"container py-12 max-w-lg mx-auto\">\n        <div className=\"text-center mb-10\">\n          <h1 className=\"text-3xl font-bold mb-2 flex items-center gap-2\">\n            <BookOpen className=\"h-6 w-6\" /> Phòng học Live\n          </h1>\n          <p className=\"text-muted-foreground\">\n            Học cùng nhau với Pomodoro timer — thực hiện công việc hiệu quả hơn\n          </p>\n        </div>\n\n        {/* Name input */}\n        <div className=\"mb-6\">\n          <label className=\"block text-sm font-medium mb-2\">Tên của bạn</label>\n          <input\n            type=\"text\"\n            value={username}\n            onChange={(e) => setUsername(e.target.value)}\n            placeholder=\"VD: Khuong\"\n            className=\"w-full px-4 py-3 rounded-lg border border-border bg-background text-sm focus:outline-none focus:ring-2 focus:ring-ring\"\n          />\n        </div>\n\n        <div className=\"space-y-4\">\n          {/* Create room */}\n          <div className=\"rounded-xl border border-border p-6\">\n            <h3 className=\"font-semibold mb-4\">Tạo phòng mới</h3>\n            <p className=\"text-sm text-muted-foreground mb-4\">\n              Tạo phòng mới và chia sẻ mã phòng với bạn bè\n            </p>\n            <button\n              onClick={handleCreateRoom}\n              className=\"w-full py-3 rounded-lg bg-primary text-primary-foreground font-medium hover:bg-primary/90 transition-colors\"\n            >\n              Tạo phòng mới\n            </button>\n          </div>\n\n          <div className=\"text-center text-muted-foreground text-sm\">— hoặc —</div>\n\n          {/* Join room */}\n          <div className=\"rounded-xl border border-border p-6\">\n            <h3 className=\"font-semibold mb-4\">Tham gia phòng</h3>\n            <div className=\"space-y-3\">\n              <input\n                type=\"text\"\n                value={joinCode}\n                onChange={(e) => setJoinCode(e.target.value.toUpperCase())}\n                placeholder=\"Nhập mã phòng\"\n                maxLength={6}\n                className=\"w-full px-4 py-3 rounded-lg border border-border bg-background text-sm text-center text-lg tracking-widest font-mono uppercase focus:outline-none focus:ring-2 focus:ring-ring\"\n              />\n              <button\n                onClick={handleJoinRoom}\n                className=\"w-full py-3 rounded-lg border border-border hover:bg-accent transition-colors font-medium text-sm\"\n              >\n                Tham gia\n              </button>\n            </div>\n          </div>\n        </div>\n\n        {/* Connection status */}\n        <div className=\"mt-6 flex items-center justify-center gap-2 text-xs text-muted-foreground\">\n          {isConnected ? (\n            <>\n              <Wifi className=\"h-3 w-3 text-green-500\" />\n              Đã kết nối real-time\n            </>\n          ) : (\n            <>\n              <WifiOff className=\"h-3 w-3 text-muted-foreground\" />\n              Chế độ offline — timer cục bộ\n            </>\n          )}\n        </div>\n      </div>\n    )\n  }\n\n  return (\n    <div className=\"container py-8 max-w-2xl mx-auto\">\n      <div className=\"text-center mb-8\">\n        <h1 className=\"text-2xl font-bold mb-2 flex items-center gap-2\">\n          <BookOpen className=\"h-5 w-5\" /> Phòng học: {roomCode}\n        </h1>\n\n        {/* Participants */}\n        <div className=\"flex items-center justify-center gap-2 mb-2\">\n          <Users className=\"h-3.5 w-3.5 text-muted-foreground\" />\n          <span className=\"text-sm text-muted-foreground\">\n            {participants.length} người đang học\n          </span>\n          {isConnected && <Wifi className=\"h-3 w-3 text-green-500\" />}\n        </div>\n\n        <div className=\"flex items-center justify-center gap-2 flex-wrap\">\n          {participants.map((p, i) => (\n            <motion.span\n              key={p}\n              initial={{ scale: 0 }}\n              animate={{ scale: 1 }}\n              className=\"px-2 py-0.5 rounded-full bg-primary/10 text-primary text-xs font-medium\"\n            >\n              {p}\n            </motion.span>\n          ))}\n        </div>\n\n        {/* Copy link */}\n        <button\n          onClick={copyRoomCode}\n          className=\"inline-flex items-center gap-1 text-xs text-muted-foreground hover:text-primary transition-colors mt-2\"\n        >\n          <Copy className=\"h-3 w-3\" />\n          Copy mã phòng\n        </button>\n      </div>\n\n      {/* Pomodoro Timer */}\n      <motion.div\n        key={phase}\n        initial={{ opacity: 0, scale: 0.95 }}\n        animate={{ opacity: 1, scale: 1 }}\n        className={`rounded-2xl border p-8 text-center mb-6 ${\n          phase === 'work'\n            ? 'border-red-200 dark:border-red-900 bg-red-50/30 dark:bg-red-950/20'\n            : 'border-green-200 dark:border-green-900 bg-green-50/30 dark:bg-green-950/20'\n        }`}\n      >\n        {/* Phase label */}\n        <p className=\"text-sm font-medium mb-4 text-muted-foreground\">\n          {phase === 'work' ? 'Thời gian làm việc' : 'Nghỉ giải lao'}\n        </p>\n\n        {/* Timer */}\n        <motion.div\n          key={timeLeft}\n          className={`text-7xl font-bold font-mono mb-6 ${\n            phase === 'work' ? 'text-red-600 dark:text-red-400' : 'text-green-600 dark:text-green-400'\n          }`}\n        >\n          {formatTime(timeLeft)}\n        </motion.div>\n\n        {/* Progress bar */}\n        <div className=\"w-full h-1.5 bg-border rounded-full mb-6 overflow-hidden\">\n          <motion.div\n            className={`h-full ${phase === 'work' ? 'bg-red-500' : 'bg-green-500'}`}\n            initial={{ width: '100%' }}\n            animate={{\n              width: `${(timeLeft / (phase === 'work' ? DEFAULT_WORK * 60 : DEFAULT_BREAK * 60)) * 100}%`,\n            }}\n            transition={{ duration: 1, ease: 'linear' }}\n          />\n        </div>\n\n        {/* Controls */}\n        <div className=\"flex items-center justify-center gap-3 mb-4\">\n          <button\n            onClick={toggleTimer}\n            className={`inline-flex items-center gap-2 px-6 py-3 rounded-lg font-medium transition-colors ${\n              phase === 'work'\n                ? 'bg-red-500 text-white hover:bg-red-600'\n                : 'bg-green-500 text-white hover:bg-green-600'\n            }`}\n          >\n            {isRunning ? (\n              <><Pause className=\"h-4 w-4\" /> Tạm dừng</>\n            ) : (\n              <><Play className=\"h-4 w-4\" /> Bắt đầu</>\n            )}\n          </button>\n          <button\n            onClick={resetTimer}\n            className=\"inline-flex items-center gap-2 px-4 py-3 rounded-lg border border-border hover:bg-accent transition-colors\"\n          >\n            <RotateCcw className=\"h-4 w-4\" /> Reset\n          </button>\n        </div>\n\n        {/* Session count */}\n        <p className=\"text-xs text-muted-foreground\">\n          Đã hoàn thành {sessionCount} session\n        </p>\n      </motion.div>\n\n      {/* Goal */}\n      <div className=\"rounded-xl border border-border p-6 mb-6\">\n        <h3 className=\"font-semibold mb-3 flex items-center gap-2\">\n          <BookOpen className=\"h-4 w-4\" /> Mục tiêu hôm nay\n        </h3>\n        {goal ? (\n          <p className=\"text-muted-foreground\">{goal}</p>\n        ) : (\n          <input\n            type=\"text\"\n            value={goal}\n            onChange={(e) => setGoal(e.target.value)}\n            placeholder=\"VD: Hoàn thành bài Binary Search\"\n            className=\"w-full px-3 py-2 rounded-lg border border-input bg-background text-sm focus:outline-none focus:ring-2 focus:ring-ring\"\n          />\n        )}\n      </div>\n\n      {/* Ambient sound */}\n      <div className=\"rounded-xl border border-border p-6\">\n        <h3 className=\"font-semibold mb-3 flex items-center gap-2\">\n          <Volume2 className=\"h-4 w-4\" /> Âm thanh nền\n        </h3>\n        <div className=\"flex gap-2\">\n          {AMBIENT_OPTIONS.map((opt) => (\n            <button\n              key={opt.id}\n              onClick={() => setAmbient(ambient === opt.id ? null : opt.id)}\n              className={`flex items-center gap-2 px-4 py-2 rounded-lg text-sm transition-all ${\n                ambient === opt.id\n                  ? 'bg-primary text-primary-foreground'\n                  : 'border border-border hover:bg-accent'\n              }`}\n            >\n              <opt.Icon className=\"h-4 w-4\" />\n              {opt.label}\n            </button>\n          ))}\n        </div>\n      </div>\n    </div>\n  )\n}\n"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":111,"output":3700,"cacheRead":121478,"cacheWrite":1079,"totalTokens":126368,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776575506799,"responseId":"0633971426ab0fd0b5300d23afb1a671"}}
