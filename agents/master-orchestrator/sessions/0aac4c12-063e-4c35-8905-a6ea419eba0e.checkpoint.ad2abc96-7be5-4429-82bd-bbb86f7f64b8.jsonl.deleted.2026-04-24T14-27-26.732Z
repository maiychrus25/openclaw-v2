{"type":"message","id":"d36288c9","parentId":"3fb007f3","timestamp":"2026-04-19T08:57:17.726Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"While waiting for Three.js to install, let me create the component.","thinkingSignature":"4c76609e3a61f92a533f94a30577280974cae6999c98cdf6b4ea3e4c10472ab7"},{"type":"toolCall","id":"call_function_a4jewe819p1a_1","name":"process","arguments":{"action":"poll","sessionId":"salty-ridge","timeout":30000}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":109,"output":65,"cacheRead":124224,"cacheWrite":328,"totalTokens":124726,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776589032290,"responseId":"0633cbea5fe0f9be7bd31f9b86c1cb01"}}
{"type":"message","id":"6a334b6e","parentId":"d36288c9","timestamp":"2026-04-19T08:57:17.828Z","message":{"role":"toolResult","toolCallId":"call_function_a4jewe819p1a_1","toolName":"process","content":[{"type":"text","text":"├─ meshoptimizer@1.1.1\n└─ three@0.184.0\nDone in 12.70s.\n\n\nProcess exited with code 0."}],"details":{"status":"completed","sessionId":"salty-ridge","exitCode":0,"aggregated":"├─ meshoptimizer@1.1.1\n└─ three@0.184.0\nDone in 12.70s.\n","name":"cd /root/.openclaw/worksp...m-review/maiy-tech-hub"},"isError":false,"timestamp":1776589037767}}
{"type":"message","id":"85714688","parentId":"6a334b6e","timestamp":"2026-04-19T08:57:56.721Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Good, Three.js is installed. Now let me create the hero component with Three.js.","thinkingSignature":"a219993ea5c6f0599da66c4955949103aa2ca819a44d36e650146895b9eaf794"},{"type":"text","text":"**Three.js Hero section:**\n"},{"type":"toolCall","id":"call_function_4ow2upxvkt43_1","name":"write","arguments":{"path":"/root/.openclaw/workspaces2/v4-ecosystem-review/maiy-tech-hub/components/blog/three-hero.tsx","content":"'use client'\n\nimport { useEffect, useRef } from 'react'\nimport * as THREE from 'three'\nimport { useRouter } from 'next/navigation'\n\ninterface ThreeHeroProps {\n  onExplore?: () => void\n}\n\nexport function ThreeHero({ onExplore }: ThreeHeroProps) {\n  const mountRef = useRef<HTMLDivElement>(null)\n  const router = useRouter()\n\n  useEffect(() => {\n    const mount = mountRef.current\n    if (!mount) return\n\n    // Scene setup\n    const scene = new THREE.Scene()\n    const camera = new THREE.PerspectiveCamera(75, mount.clientWidth / mount.clientHeight, 0.1, 1000)\n    camera.position.z = 30\n\n    const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true })\n    renderer.setSize(mount.clientWidth, mount.clientHeight)\n    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2))\n    renderer.setClearColor(0x000000, 0)\n    mount.appendChild(renderer.domElement)\n\n    // ── Particles (nodes of a network) ──────────────────────────────────────\n    const particleCount = 300\n    const positions = new Float32Array(particleCount * 3)\n    const velocities: number[] = []\n    const colors = new Float32Array(particleCount * 3)\n\n    const colorPalette = [\n      new THREE.Color('#8b5cf6'), // violet\n      new THREE.Color('#06b6d4'), // cyan\n      new THREE.Color('#3b82f6'), // blue\n      new THREE.Color('#ec4899'), // pink\n      new THREE.Color('#10b981'), // emerald\n    ]\n\n    for (let i = 0; i < particleCount; i++) {\n      positions[i * 3] = (Math.random() - 0.5) * 60\n      positions[i * 3 + 1] = (Math.random() - 0.5) * 60\n      positions[i * 3 + 2] = (Math.random() - 0.5) * 40\n\n      velocities.push(\n        (Math.random() - 0.5) * 0.02,\n        (Math.random() - 0.5) * 0.02,\n        (Math.random() - 0.5) * 0.01\n      )\n\n      const col = colorPalette[Math.floor(Math.random() * colorPalette.length)]\n      colors[i * 3] = col.r\n      colors[i * 3 + 1] = col.g\n      colors[i * 3 + 2] = col.b\n    }\n\n    const particleGeo = new THREE.BufferGeometry()\n    particleGeo.setAttribute('position', new THREE.BufferAttribute(positions, 3))\n    particleGeo.setAttribute('color', new THREE.BufferAttribute(colors, 3))\n\n    const particleMat = new THREE.PointsMaterial({\n      size: 0.4,\n      vertexColors: true,\n      transparent: true,\n      opacity: 0.85,\n      blending: THREE.AdditiveBlending,\n      depthWrite: false,\n    })\n\n    const particles = new THREE.Points(particleGeo, particleMat)\n    scene.add(particles)\n\n    // ── Connection lines ─────────────────────────────────────────────────────\n    const linePositions: number[] = []\n    const lineColors: number[] = []\n    const lineThreshold = 8\n\n    for (let i = 0; i < particleCount; i++) {\n      for (let j = i + 1; j < particleCount; j++) {\n        const dx = positions[i * 3] - positions[j * 3]\n        const dy = positions[i * 3 + 1] - positions[j * 3 + 1]\n        const dz = positions[i * 3 + 2] - positions[j * 3 + 2]\n        const dist = Math.sqrt(dx * dx + dy * dy + dz * dz)\n\n        if (dist < lineThreshold) {\n          const alpha = 1 - dist / lineThreshold\n          linePositions.push(\n            positions[i * 3], positions[i * 3 + 1], positions[i * 3 + 2],\n            positions[j * 3], positions[j * 3 + 1], positions[j * 3 + 2]\n          )\n          const col = colorPalette[i % colorPalette.length]\n          lineColors.push(col.r * alpha, col.g * alpha, col.b * alpha)\n          lineColors.push(col.r * alpha, col.g * alpha, col.b * alpha)\n        }\n      }\n    }\n\n    const lineGeo = new THREE.BufferGeometry()\n    lineGeo.setAttribute('position', new THREE.BufferAttribute(new Float32Array(linePositions), 3))\n    lineGeo.setAttribute('color', new THREE.BufferAttribute(new Float32Array(lineColors), 3))\n\n    const lineMat = new THREE.LineBasicMaterial({\n      vertexColors: true,\n      transparent: true,\n      opacity: 0.3,\n      blending: THREE.AdditiveBlending,\n      depthWrite: false,\n    })\n\n    const lines = new THREE.LineSegments(lineGeo, lineMat)\n    scene.add(lines)\n\n    // ── Floating geometric shapes ─────────────────────────────────────────────\n    const shapes: THREE.Mesh[] = []\n    const shapeCount = 6\n\n    for (let i = 0; i < shapeCount; i++) {\n      const geom = i % 2 === 0\n        ? new THREE.IcosahedronGeometry(Math.random() * 0.8 + 0.3, 0)\n        : new THREE.OctahedronGeometry(Math.random() * 0.6 + 0.2, 0)\n\n      const mat = new THREE.MeshBasicMaterial({\n        color: colorPalette[i % colorPalette.length],\n        wireframe: true,\n        transparent: true,\n        opacity: 0.2,\n      })\n\n      const mesh = new THREE.Mesh(geom, mat)\n      mesh.position.set(\n        (Math.random() - 0.5) * 50,\n        (Math.random() - 0.5) * 40,\n        (Math.random() - 0.5) * 20\n      )\n      mesh.userData = {\n        rotSpeed: {\n          x: (Math.random() - 0.5) * 0.005,\n          y: (Math.random() - 0.5) * 0.005,\n          z: (Math.random() - 0.5) * 0.003,\n        },\n      }\n      shapes.push(mesh)\n      scene.add(mesh)\n    }\n\n    // ── Mouse parallax ──────────────────────────────────────────────────────\n    let mouseX = 0, mouseY = 0\n    const handleMouse = (e: MouseEvent) => {\n      mouseX = (e.clientX / window.innerWidth - 0.5) * 2\n      mouseY = (e.clientY / window.innerHeight - 0.5) * 2\n    }\n    window.addEventListener('mousemove', handleMouse)\n\n    // ── Animation loop ────────────────────────────────────────────────────────\n    let animId: number\n    const posAttr = particleGeo.getAttribute('position') as THREE.BufferAttribute\n    const linePosAttr = lineGeo.getAttribute('position') as THREE.BufferAttribute\n    const lineColAttr = lineGeo.getAttribute('color') as THREE.BufferAttribute\n\n    const animate = () => {\n      animId = requestAnimationFrame(animate)\n\n      const time = Date.now() * 0.001\n\n      // Move particles\n      for (let i = 0; i < particleCount; i++) {\n        posAttr.array[i * 3] += velocities[i * 3]\n        posAttr.array[i * 3 + 1] += velocities[i * 3 + 1]\n        posAttr.array[i * 3 + 2] += velocities[i * 3 + 2]\n\n        // Wrap around\n        if (Math.abs(posAttr.array[i * 3]) > 30) velocities[i * 3] *= -1\n        if (Math.abs(posAttr.array[i * 3 + 1]) > 30) velocities[i * 3 + 1] *= -1\n        if (Math.abs(posAttr.array[i * 3 + 2]) > 20) velocities[i * 3 + 2] *= -1\n\n        // Pulse opacity\n        const pulse = Math.sin(time * 2 + i) * 0.15 + 0.85\n        colors[i * 3] = colorPalette[i % colorPalette.length].r * pulse\n        colors[i * 3 + 1] = colorPalette[i % colorPalette.length].g * pulse\n        colors[i * 3 + 2] = colorPalette[i % colorPalette.length].b * pulse\n      }\n      posAttr.needsUpdate = true\n      particleGeo.getAttribute('color')!.needsUpdate = true\n\n      // Animate wireframe shapes\n      shapes.forEach((mesh) => {\n        mesh.rotation.x += mesh.userData.rotSpeed.x\n        mesh.rotation.y += mesh.userData.rotSpeed.y\n        mesh.rotation.z += mesh.userData.rotSpeed.z\n        // Float up and down\n        mesh.position.y += Math.sin(time + mesh.position.x) * 0.005\n      })\n\n      // Camera parallax with mouse\n      camera.position.x += (mouseX * 5 - camera.position.x) * 0.05\n      camera.position.y += (-mouseY * 5 - camera.position.y) * 0.05\n      camera.lookAt(scene.position)\n\n      // Subtle line animation (pulse alpha)\n      lineMat.opacity = 0.15 + Math.sin(time) * 0.1\n\n      renderer.render(scene, camera)\n    }\n\n    animate()\n\n    // ── Resize handler ───────────────────────────────────────────────────────\n    const handleResize = () => {\n      if (!mount) return\n      camera.aspect = mount.clientWidth / mount.clientHeight\n      camera.updateProjectionMatrix()\n      renderer.setSize(mount.clientWidth, mount.clientHeight)\n    }\n    window.addEventListener('resize', handleResize)\n\n    return () => {\n      cancelAnimationFrame(animId)\n      window.removeEventListener('mousemove', handleMouse)\n      window.removeEventListener('resize', handleResize)\n      renderer.dispose()\n      particleGeo.dispose()\n      lineGeo.dispose()\n      if (mount.contains(renderer.domElement)) {\n        mount.removeChild(renderer.domElement)\n      }\n    }\n  }, [])\n\n  return (\n    <section className=\"relative w-full h-screen min-h-[600px] overflow-hidden flex items-center justify-center\">\n      {/* Three.js canvas */}\n      <div ref={mountRef} className=\"absolute inset-0 z-0\" />\n\n      {/* Gradient overlay */}\n      <div className=\"absolute inset-0 z-10 bg-gradient-to-b from-transparent via-transparent to-background/80\" />\n\n      {/* Radial glow center */}\n      <div className=\"absolute inset-0 z-10 bg-[radial-gradient(ellipse_at_center,rgba(139,92,246,0.08)_0%,transparent_70%)]\" />\n\n      {/* Content */}\n      <div className=\"relative z-20 text-center px-4 max-w-4xl mx-auto\">\n        {/* Badge */}\n        <div className=\"inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-primary/10 border border-primary/20 text-primary text-sm font-medium mb-8 backdrop-blur-sm\">\n          <span className=\"w-2 h-2 rounded-full bg-primary animate-pulse\" />\n          Nền tảng học CNTT hàng đầu Việt Nam\n        </div>\n\n        {/* Title */}\n        <h1 className=\"text-5xl md:text-7xl font-bold tracking-tight mb-6 leading-tight\">\n          <span className=\"bg-gradient-to-r from-violet-400 via-cyan-400 to-blue-400 bg-clip-text text-transparent drop-shadow-lg\">\n            MAIY Tech Hub\n          </span>\n        </h1>\n\n        {/* Subtitle */}\n        <p className=\"text-lg md:text-xl text-muted-foreground mb-4 max-w-2xl mx-auto leading-relaxed\">\n          Kiến thức CNTT chuẩn chỉnh — từ CTDL & Giải thuật đến AI, Web Dev & DevOps.\n          Code thật, giải thích dễ hiểu, hoàn toàn bằng tiếng Việt.\n        </p>\n\n        <p className=\"text-sm text-muted-foreground/60 mb-10\">\n          10+ bài viết chất lượng · Phòng học live · Nhạc thư giãn\n        </p>\n\n        {/* CTA buttons */}\n        <div className=\"flex flex-col sm:flex-row items-center justify-center gap-3\">\n          <button\n            onClick={() => router.push('/articles')}\n            className=\"w-full sm:w-auto px-8 py-3.5 rounded-xl bg-gradient-to-r from-violet-600 to-blue-600 text-white font-semibold text-base shadow-lg shadow-violet-500/25 hover:shadow-violet-500/40 hover:scale-[1.02] active:scale-[0.98] transition-all\"\n          >\n            Khám phá bài viết\n          </button>\n          <button\n            onClick={() => router.push('/study')}\n            className=\"w-full sm:w-auto px-8 py-3.5 rounded-xl border border-border bg-background/60 backdrop-blur-sm text-foreground font-medium text-base hover:bg-background hover:border-primary/50 transition-all\"\n          >\n            Phòng học live\n          </button>\n        </div>\n\n        {/* Scroll indicator */}\n        <div className=\"absolute bottom-8 left-1/2 -translate-x-1/2 z-20 flex flex-col items-center gap-2 animate-bounce\">\n          <span className=\"text-xs text-muted-foreground/50\">Cuộn xuống</span>\n          <svg className=\"w-5 h-5 text-muted-foreground/50\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n            <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2} d=\"M19 14l-7 7m0 0l-7-7m7 7V3\" />\n          </svg>\n        </div>\n      </div>\n    </section>\n  )\n}\n"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":113,"output":3224,"cacheRead":124414,"cacheWrite":250,"totalTokens":128001,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776589037874,"responseId":"0633cbef763524dd2df178d8a43093ae"}}
