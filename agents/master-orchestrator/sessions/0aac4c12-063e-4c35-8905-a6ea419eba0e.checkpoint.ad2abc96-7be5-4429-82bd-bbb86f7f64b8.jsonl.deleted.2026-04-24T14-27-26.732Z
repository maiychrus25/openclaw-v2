{"type":"message","id":"44065222","parentId":"9d38eafd","timestamp":"2026-04-19T08:35:29.486Z","message":{"role":"toolResult","toolCallId":"call_function_hhlfztds1f65_1","toolName":"read","content":[{"type":"text","text":"'use client'\n\nimport { useEffect } from 'react'\nimport { Copy, Check } from 'lucide-react'\n\nexport function CodeCopyButtons() {\n  useEffect(() => {\n    const addButtons = () => {\n      document.querySelectorAll('.shiki').forEach((block) => {\n        if (block.querySelector('.copy-btn')) return\n\n        // Get language from class\n        const langClass = block.className.match(/language-(\\w+)/)?.[1] || ''\n        const code = block.querySelector('code')?.textContent || ''\n\n        // Create wrapper\n        const wrapper = document.createElement('div')\n        wrapper.className = 'code-block-container relative group'\n\n        // Header with language + copy\n\n[64 more lines in file. Use offset=21 to continue.]"}],"isError":false,"timestamp":1776587729464}}
{"type":"message","id":"ff3c9ee0","parentId":"44065222","timestamp":"2026-04-19T08:35:45.419Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"The code copy buttons target `.shiki` blocks. I need to change it to target `.hljs` blocks (which is what rehype-highlight generates).","thinkingSignature":"72339314e35a009278063ddb2677012fbf39ea856f95f455ebdfd754c4cfd77f"},{"type":"toolCall","id":"call_function_z1tfdon3exa2_1","name":"write","arguments":{"path":"/root/.openclaw/workspaces2/v4-ecosystem-review/maiy-tech-hub/components/blog/code-copy-buttons.tsx","content":"'use client'\n\nimport { useEffect } from 'react'\n\nexport function CodeCopyButtons() {\n  useEffect(() => {\n    const addButtons = () => {\n      document.querySelectorAll('pre').forEach((pre) => {\n        if (pre.querySelector('.copy-btn')) return\n\n        const code = pre.querySelector('code')\n        if (!code) return\n        const text = code.textContent || ''\n\n        // Detect language from hljs class\n        const langClass = [...pre.classList].find((c) => c.startsWith('language-')) || ''\n        const lang = langClass.replace('language-', '') || 'code'\n\n        // Make pre position relative\n        ;(pre as HTMLElement).style.position = 'relative'\n\n        // Language label\n        if (lang && lang !== 'code') {\n          const label = document.createElement('div')\n          label.className = 'absolute top-0 left-0 px-3 py-1 text-[11px] text-white/40 font-mono bg-black/30 rounded-tr-lg'\n          label.textContent = lang\n          pre.appendChild(label)\n        }\n\n        // Copy button\n        const btn = document.createElement('button')\n        btn.className = 'copy-btn absolute top-2 right-2 p-1.5 rounded-md bg-white/10 hover:bg-white/20 text-white/60 hover:text-white transition-all opacity-0 group-hover:opacity-100'\n        btn.innerHTML = `<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><rect width=\"14\" height=\"14\" x=\"8\" y=\"8\" rx=\"2\"/><path d=\"M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2\"/></svg>`\n        btn.onclick = async (e) => {\n          e.preventDefault()\n          e.stopPropagation()\n          try {\n            await navigator.clipboard.writeText(text)\n            btn.innerHTML = `<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg>`\n            btn.classList.add('text-green-400')\n            setTimeout(() => {\n              btn.innerHTML = `<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><rect width=\"14\" height=\"14\" x=\"8\" y=\"8\" rx=\"2\"/><path d=\"M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2\"/></svg>`\n              btn.classList.remove('text-green-400')\n            }, 2000)\n          } catch {}\n        }\n        pre.appendChild(btn)\n\n        // Add group class to wrapper\n        ;(pre.parentElement as HTMLElement)?.classList.add('group')\n      })\n    }\n\n    addButtons()\n    const observer = new MutationObserver(addButtons)\n    observer.observe(document.body, { childList: true, subtree: true })\n    return () => observer.disconnect()\n  }, [])\n\n  return null\n}\n"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":245,"output":922,"cacheRead":115187,"cacheWrite":312,"totalTokens":116666,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776587729504,"responseId":"0633c6d320290478d6eead8818463ef0"}}
