{"type":"message","id":"7c610a2a","parentId":"aac50fe1","timestamp":"2026-04-19T03:44:06.302Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me write the utility functions, config, and providers.","thinkingSignature":"e98e58a3abe3a973b190b0cb8b0d5d4ab006324b5264205b541ae330927f2270"},{"type":"toolCall","id":"call_function_9f7734natsss_1","name":"write","arguments":{"path":"/root/.openclaw/workspaces2/v4-ecosystem-review/maiy-tech-hub/lib/utils.ts","content":"import { type ClassValue, clsx } from 'clsx'\nimport { twMerge } from 'tailwind-merge'\n\nexport function cn(...inputs: ClassValue[]) {\n  return twMerge(clsx(inputs))\n}\n"}},{"type":"toolCall","id":"call_function_9f7734natsss_2","name":"write","arguments":{"path":"/root/.openclaw/workspaces2/v4-ecosystem-review/maiy-tech-hub/config/site.ts","content":"export const SITE = {\n  name: 'MAIY Tech Hub',\n  tagline: 'Học CNTT không bao giờ boring',\n  url: process.env.NEXT_PUBLIC_SITE_URL || 'https://maiytechhub.com',\n  description:\n    'Nền tảng blog chia sẻ kiến thức CNTT chuẩn chỉnh: CTDL & Giải thuật, AI, Web Dev, DevOps. Kèm nhạc thư giãn và phòng học live.',\n  github: 'https://github.com/khuowgn/maiy-tech-hub',\n  author: 'MAIY Tech Hub',\n} as const\n\nexport const CATEGORIES = [\n  {\n    slug: 'ctdl',\n    label: 'CTDL & Giải thuật',\n    labelShort: 'CTDL',\n    description: 'Thuật toán, cấu trúc dữ liệu từ cơ bản đến nâng cao',\n    color: 'bg-blue-500',\n  },\n  {\n    slug: 'ai',\n    label: 'AI & Machine Learning',\n    labelShort: 'AI',\n    description: 'Trí tuệ nhân tạo, học máy, deep learning',\n    color: 'bg-purple-500',\n  },\n  {\n    slug: 'web-dev',\n    label: 'Web Development',\n    labelShort: 'Web Dev',\n    description: 'Frontend, backend, DevOps thực hành',\n    color: 'bg-green-500',\n  },\n  {\n    slug: 'devops',\n    label: 'DevOps',\n    labelShort: 'DevOps',\n    description: 'Docker, CI/CD, cloud, infrastructure',\n    color: 'bg-orange-500',\n  },\n  {\n    slug: 'cs-fundamentals',\n    label: 'CS Fundamentals',\n    labelShort: 'CS',\n    description: 'Nền tảng khoa học máy tính',\n    color: 'bg-red-500',\n  },\n] as const\n\nexport type CategorySlug = (typeof CATEGORIES)[number]['slug']\n"}},{"type":"toolCall","id":"call_function_9f7734natsss_3","name":"write","arguments":{"path":"/root/.openclaw/workspaces2/v4-ecosystem-review/maiy-tech-hub/providers/theme-provider.tsx","content":"'use client'\n\nimport { ThemeProvider as NextThemesProvider } from 'next-themes'\nimport type { ThemeProviderProps } from 'next-themes'\n\nexport function ThemeProvider({ children, ...props }: ThemeProviderProps) {\n  return <NextThemesProvider {...props}>{children}</NextThemesProvider>\n}\n"}},{"type":"toolCall","id":"call_function_9f7734natsss_4","name":"write","arguments":{"path":"/root/.openclaw/workspaces2/v4-ecosystem-review/maiy-tech-hub/providers/music-provider.tsx","content":"'use client'\n\nimport {\n  createContext,\n  useContext,\n  useState,\n  useCallback,\n  useEffect,\n} from 'react'\n\nexport interface Track {\n  id: string\n  title: string\n  artist: string\n  duration: number\n  youtubeId?: string\n  spotifyUri?: string\n  coverUrl?: string\n  mood: 'focus' | 'sleep' | 'energize' | 'study'\n}\n\ninterface MusicContextValue {\n  currentTrack: Track | null\n  isPlaying: boolean\n  volume: number\n  playlist: Track[]\n  queue: Track[]\n  play: (track: Track) => void\n  pause: () => void\n  resume: () => void\n  setVolume: (v: number) => void\n  addToQueue: (track: Track) => void\n  skipNext: () => void\n}\n\nconst MusicContext = createContext<MusicContextValue | null>(null)\n\nexport function MusicProvider({ children }: { children: React.ReactNode }) {\n  const [currentTrack, setCurrentTrack] = useState<Track | null>(null)\n  const [isPlaying, setIsPlaying] = useState(false)\n  const [volume, setVolumeState] = useState(0.8)\n  const [playlist, setPlaylist] = useState<Track[]>([])\n  const [queue, setQueue] = useState<Track[]>([])\n\n  const play = useCallback((track: Track) => {\n    setCurrentTrack(track)\n    setIsPlaying(true)\n  }, [])\n\n  const pause = useCallback(() => setIsPlaying(false), [])\n  const resume = useCallback(() => setIsPlaying(true), [])\n\n  const setVolume = useCallback((v: number) => {\n    setVolumeState(Math.max(0, Math.min(1, v)))\n  }, [])\n\n  const addToQueue = useCallback((track: Track) => {\n    setQueue((q) => [...q, track])\n  }, [])\n\n  const skipNext = useCallback(() => {\n    if (queue.length > 0) {\n      const [next, ...rest] = queue\n      setCurrentTrack(next)\n      setQueue(rest)\n      setIsPlaying(true)\n    } else {\n      setIsPlaying(false)\n      setCurrentTrack(null)\n    }\n  }, [queue])\n\n  return (\n    <MusicContext.Provider\n      value={{\n        currentTrack,\n        isPlaying,\n        volume,\n        playlist,\n        queue,\n        play,\n        pause,\n        resume,\n        setVolume,\n        addToQueue,\n        skipNext,\n      }}\n    >\n      {children}\n    </MusicContext.Provider>\n  )\n}\n\nexport function useMusic() {\n  const ctx = useContext(MusicContext)\n  if (!ctx) throw new Error('useMusic must be used within MusicProvider')\n  return ctx\n}\n"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":141,"output":1414,"cacheRead":74661,"cacheWrite":2137,"totalTokens":78353,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776570228627,"responseId":"06338275ed879728e23fa9d7207d38f8"}}
