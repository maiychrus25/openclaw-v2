re {\n  @apply bg-muted rounded-lg p-4 overflow-x-auto;\n}\n\ncode {\n  @apply text-sm;\n}\n\n:not(pre) > code {\n  @apply bg-muted px-1.5 py-0.5 rounded text-sm font-medium;\n}\n\n/* Smooth scrolling */\nhtml {\n  scroll-behavior: smooth;\n}\n\n/* Custom scrollbar */\n::-webkit-scrollbar {\n  width: 6px;\n  height: 6px;\n}\n\n::-webkit-scrollbar-track {\n  @apply bg-transparent;\n}\n\n::-webkit-scrollbar-thumb {\n  @apply bg-muted-foreground/30 rounded-full;\n}\n\n/* Focus visible */\n:focus-visible {\n  @apply outline-none ring-2 ring-ring ring-offset-2 ring-offset-background;\n}\n"}},{"type":"toolCall","id":"call_function_oh8fyzby5b86_2","name":"write","arguments":{"path":"/root/.openclaw/workspaces2/v4-ecosystem-review/maiy-tech-hub/app/layout.tsx","content":"import type { Metadata } from 'next'\nimport './globals.css'\nimport { ThemeProvider } from '@/providers/theme-provider'\nimport { MusicProvider } from '@/providers/music-provider'\nimport { Header } from '@/components/layout/header'\nimport { Footer } from '@/components/layout/footer'\nimport { MiniPlayer } from '@/components/music/mini-player'\n\nexport const metadata: Metadata = {\n  title: {\n    default: 'MAIY Tech Hub — Học CNTT không bao giờ boring',\n    template: '%s | MAIY Tech Hub',\n  },\n  description:\n    'Nền tảng blog chia sẻ kiến thức CNTT chuẩn chỉnh: CTDL & Giải thuật, AI, Web Dev, DevOps. Kèm nhạc thư giãn và phòng học live.',\n  keywords: [\n    'học thuật toán',\n    'cấu trúc dữ liệu',\n    'machine learning tiếng Việt',\n    'next.js tutorial',\n    'docker cho developer',\n    'CTDL',\n    'AI',\n  ],\n  authors: [{ name: 'MAIY Tech Hub' }],\n  creator: 'MAIY Tech Hub',\n  openGraph: {\n    type: 'website',\n    locale: 'vi_VN',\n    url: 'https://maiytechhub.com',\n    siteName: 'MAIY Tech Hub',\n    title: 'MAIY Tech Hub — Học CNTT không bao giờ boring',\n    description:\n      'Blog kiến thức CNTT chuẩn chỉnh: CTDL & GT, AI, Web Dev. Code thật, giải thích dễ hiểu.',\n  },\n  twitter: {\n    card: 'summary_large_image',\n    title: 'MAIY Tech Hub — Học CNTT không bao giờ boring',\n    description: 'Blog kiến thức CNTT chuẩn chỉnh bằng tiếng Việt.',\n  },\n  robots: { index: true, follow: true },\n}\n\nexport default function RootLayout({\n  children,\n}: {\n  children: React.ReactNode\n}) {\n  return (\n    <html lang=\"vi\" suppressHydrationWarning>\n      <body className=\"min-h-screen flex flex-col\">\n        <ThemeProvider>\n          <MusicProvider>\n            <Header />\n            <main className=\"flex-1\">{children}</main>\n            <Footer />\n            <MiniPlayer />\n          </MusicProvider>\n        </ThemeProvider>\n      </body>\n    </html>\n  )\n}\n"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":142,"output":1421,"cacheRead":73250,"cacheWrite":2047,"totalTokens":76860,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776570210557,"responseId":"0633826337dd5e1ee1a33b648e7d9853"}}
