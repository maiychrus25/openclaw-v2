{"type":"message","id":"97c294f4","parentId":"81380e3e","timestamp":"2026-04-19T09:24:45.444Z","message":{"role":"toolResult","toolCallId":"call_function_k932tyc8goqm_1","toolName":"read","content":[{"type":"text","text":"import Link from 'next/link'\nimport { Lightbulb, Github, Heart } from 'lucide-react'\nimport { CATEGORIES } from '@/config/site'\n\nexport function Footer() {\n  const currentYear = new Date().getFullYear()\n\n  return (\n    <footer className=\"border-t border-border/40 bg-muted/30\">\n      <div className=\"container py-12\">\n        <div className=\"grid grid-cols-1 md:grid-cols-4 gap-8\">\n          {/* Brand */}\n          <div className=\"md:col-span-2\">\n            <Link href=\"/\" className=\"flex items-center gap-2 font-bold text-lg mb-3\">\n              <Lightbulb className=\"h-5 w-5 text-indigo-500\" />\n              <span>MAIY Tech Hub</span>\n            </Link>\n            <p className=\"text-sm text-muted-foreground max-w-sm\">\n              Nền tảng blog chia sẻ kiến thức CNTT chuẩn chỉnh bằng tiếng Việt.\n              Code thật, giải thích dễ hiểu.\n            </p>\n            <div className=\"flex items-center gap-3 mt-4\">\n              <a\n                href=\"https://github.com/khuowgn/maiy-tech-hub\"\n                target=\"_blank\"\n                rel=\"noopener noreferrer\"\n                className=\"p-2 rounded-md hover:bg-accent transition-colors\"\n                aria-label=\"GitHub\"\n              >\n                <Github className=\"h-5 w-5 text-muted-foreground hover:text-foreground\" />\n              </a>\n            </div>\n          </div>\n\n          {/* Categories */}\n          <div>\n            <h3 className=\"font-semibold mb-4 text-sm\">Chủ đề</h3>\n            <ul className=\"space-y-2\">\n              {CATEGORIES.map((cat) => (\n                <li key={cat.slug}>\n                  <Link\n                    href={`/articles/category/${cat.slug}`}\n                    className=\"text-sm text-muted-foreground hover:text-primary transition-colors\"\n                  >\n                    {cat.label}\n                  </Link>\n                </li>\n              ))}\n            </ul>\n          </div>\n\n          {/* Links */}\n          <div>\n            <h3 className=\"font-semibold mb-4 text-sm\">Liên kết</h3>\n            <ul className=\"space-y-2\">\n              {[\n                { href: '/about', label: 'Giới thiệu' },\n                { href: '/articles', label: 'Tất cả bài viết' },\n                { href: '/tags', label: 'Tags' },\n                { href: '/contact', label: 'Liên hệ' },\n                { href: '/contribute', label: 'Đóng góp' },\n                { href: '/music', label: 'Âm nhạc' },\n                { href: '/study', label: 'Phòng học live' },\n                { href: '/search', label: 'Tìm kiếm' },\n              ].map((link) => (\n                <li key={link.href}>\n                  <Link\n                    href={link.href}\n                    className=\"text-sm text-muted-foreground hover:text-primary transition-colors\"\n                  >\n                    {link.label}\n                  </Link>\n                </li>\n              ))}\n            </ul>\n          </div>\n        </div>\n\n        <div className=\"mt-8 pt-8 border-t border-border/40 flex flex-col sm:flex-row items-center justify-between gap-4\">\n          <div className=\"flex flex-wrap items-center gap-4 text-xs text-muted-foreground\">\n            <Link href=\"/privacy\" className=\"hover:text-primary transition-colors\">\n              Chính sách bảo mật\n            </Link>\n            <Link href=\"/terms\" className=\"hover:text-primary transition-colors\">\n              Điều khoản\n            </Link>\n            <span>© {currentYear} MAIY Tech Hub</span>\n          </div>\n          <p className=\"text-xs text-muted-foreground flex items-center gap-1\">\n            Built with Next.js\n            <Heart className=\"h-3 w-3 text-red-500 inline\" />\n          </p>\n        </div>\n      </div>\n    </footer>\n  )\n}\n"}],"isError":false,"timestamp":1776590685417}}
{"type":"message","id":"66366817","parentId":"97c294f4","timestamp":"2026-04-19T09:25:17.518Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me completely redesign the footer to be more modern and Apple-like.","thinkingSignature":"d90d1e5ddd946300671036aa93b5d42b143ef6884d15a83098865c6189153bfa"},{"type":"toolCall","id":"call_function_6puubwc3hq4o_1","name":"write","arguments":{"path":"/root/.openclaw/workspaces2/v4-ecosystem-review/maiy-tech-hub/components/layout/footer.tsx","content":"import Link from 'next/link'\nimport { Github, Heart, Sparkles, BookOpen, Headphones, Users, Zap } from 'lucide-react'\nimport { CATEGORIES } from '@/config/site'\n\nexport function Footer() {\n  const currentYear = new Date().getFullYear()\n\n  const quickLinks = [\n    { href: '/articles', label: 'Bài viết', Icon: BookOpen },\n    { href: '/music', label: 'Âm nhạc', Icon: Headphones },\n    { href: '/study', label: 'Phòng học', Icon: Users },\n    { href: '/search', label: 'Tìm kiếm', Icon: Zap },\n  ]\n\n  const bottomLinks = [\n    { href: '/about', label: 'Giới thiệu' },\n    { href: '/contact', label: 'Liên hệ' },\n    { href: '/contribute', label: 'Đóng góp' },\n    { href: '/privacy', label: 'Chính sách' },\n    { href: '/terms', label: 'Điều khoản' },\n    { href: '/tags', label: 'Tags' },\n  ]\n\n  return (\n    <footer className=\"relative border-t border-white/5 bg-[#09090b]\">\n      {/* Gradient top */}\n      <div className=\"absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-violet-500/50 to-transparent\" />\n\n      <div className=\"container\">\n        {/* Main footer grid */}\n        <div className=\"py-16 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12\">\n          {/* Brand */}\n          <div className=\"lg:col-span-1\">\n            <Link href=\"/\" className=\"flex items-center gap-2.5 font-bold text-lg mb-4 group\">\n              <div className=\"w-9 h-9 rounded-xl bg-gradient-to-br from-violet-500 to-blue-500 flex items-center justify-center shadow-lg shadow-violet-500/20 group-hover:shadow-violet-500/30 transition-shadow\">\n                <Sparkles className=\"h-4.5 w-4.5 text-white\" />\n              </div>\n              <span className=\"bg-gradient-to-r from-white to-white/80 bg-clip-text text-transparent font-bold tracking-tight\">\n                MAIY Tech Hub\n              </span>\n            </Link>\n            <p className=\"text-sm text-white/40 leading-relaxed mb-6 max-w-xs\">\n              Kiến thức CNTT chuẩn chỉnh, hoàn toàn bằng tiếng Việt. Code thật, giải thích dễ hiểu.\n            </p>\n            {/* Social */}\n            <a\n              href=\"https://github.com/khuowgn/maiy-tech-hub\"\n              target=\"_blank\"\n              rel=\"noopener noreferrer\"\n              className=\"inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-white/5 hover:bg-white/10 border border-white/10 hover:border-white/20 transition-all duration-300 text-sm text-white/60 hover:text-white font-medium\"\n            >\n              <Github className=\"h-4 w-4\" />\n              View on GitHub\n            </a>\n          </div>\n\n          {/* Topics */}\n          <div>\n            <h4 className=\"text-xs font-bold uppercase tracking-widest text-white/30 mb-5\">\n              Chủ đề\n            </h4>\n            <ul className=\"space-y-3\">\n              {CATEGORIES.map((cat) => (\n                <li key={cat.slug}>\n                  <Link\n                    href={`/articles/category/${cat.slug}`}\n                    className=\"group flex items-center gap-2 text-sm text-white/50 hover:text-white transition-colors duration-200\"\n                  >\n                    <span\n                      className=\"w-1.5 h-1.5 rounded-full opacity-0 group-hover:opacity-100 transition-opacity\"\n                      style={{ backgroundColor: cat.color.replace('bg-', '') }}\n                    />\n                    {cat.label}\n                  </Link>\n                </li>\n              ))}\n            </ul>\n          </div>\n\n          {/* Quick links */}\n          <div>\n            <h4 className=\"text-xs font-bold uppercase tracking-widest text-white/30 mb-5\">\n              Khám phá\n            </h4>\n            <ul className=\"space-y-3\">\n              {quickLinks.map((link) => (\n                <li key={link.href}>\n                  <Link\n                    href={link.href}\n                    className=\"group flex items-center gap-2 text-sm text-white/50 hover:text-white transition-colors duration-200\"\n                  >\n                    <link.Icon className=\"h-4 w-4 opacity-50 group-hover:opacity-100 transition-opacity\" />\n                    {link.label}\n                  </Link>\n                </li>\n              ))}\n            </ul>\n          </div>\n\n          {/* About */}\n          <div>\n            <h4 className=\"text-xs font-bold uppercase tracking-widest text-white/30 mb-5\">\n              Về chúng tôi\n            </h4>\n            <ul className=\"space-y-3\">\n              {bottomLinks.map((link) => (\n                <li key={link.href}>\n                  <Link\n                    href={link.href}\n                    className=\"text-sm text-white/50 hover:text-white transition-colors duration-200\"\n                  >\n                    {link.label}\n                  </Link>\n                </li>\n              ))}\n            </ul>\n          </div>\n        </div>\n\n        {/* Bottom bar */}\n        <div className=\"py-6 border-t border-white/5\">\n          <div className=\"flex flex-col sm:flex-row items-center justify-between gap-4\">\n            <p className=\"text-xs text-white/30\">\n              © {currentYear} MAIY Tech Hub. Kiến thức vì cộng đồng.\n            </p>\n            <p className=\"text-xs text-white/20 flex items-center gap-1.5\">\n              Built with Next.js, Tailwind & Framer Motion\n              <Heart className=\"h-3 w-3 text-red-400 fill-red-400\" />\n            </p>\n          </div>\n        </div>\n      </div>\n    </footer>\n  )\n}\n"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":1031,"output":1462,"cacheRead":154431,"cacheWrite":2627,"totalTokens":159551,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776590685475,"responseId":"0633d25f3389c54131c3c8b35752ef92"}}
