{"type":"message","id":"9d7d64dd","parentId":"a9bea24b","timestamp":"2026-04-19T05:22:07.023Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me also add an \"ArticlesFilter\" client component for the articles page, and add keyboard shortcuts to search page. Let me also create a `ContributePage` that was mentioned earlier, and improve the search page.","thinkingSignature":"0447af658a8f5fca355faa2fcaed1310df06825f6022d0538b1ef05a2ac430d4"},{"type":"text","text":"**Phase 4: Articles filter + better search + contribute page:**\n"},{"type":"toolCall","id":"call_function_mi34mzm8ax8f_1","name":"write","arguments":{"path":"/root/.openclaw/workspaces2/v4-ecosystem-review/maiy-tech-hub/components/blog/articles-filter.tsx","content":"'use client'\n\nimport { useState, useMemo } from 'react'\nimport { ArrowUpDown } from 'lucide-react'\nimport type { ArticleSummary } from './article-card'\nimport { ArticleCard } from './article-card'\nimport { CATEGORIES } from '@/config/site'\n\ninterface ArticlesFilterProps {\n  articles: ArticleSummary[]\n}\n\nconst SORT_OPTIONS = [\n  { value: 'newest', label: 'Mới nhất' },\n  { value: 'oldest', label: 'Cũ nhất' },\n  { value: 'reading-time', label: 'Thời gian đọc' },\n  { value: 'a-z', label: 'A → Z' },\n] as const\n\nexport function ArticlesFilter({ articles }: ArticlesFilterProps) {\n  const [sort, setSort] = useState('newest')\n  const [activeCategory, setActiveCategory] = useState<string | null>(null)\n  const [searchQuery, setSearchQuery] = useState('')\n\n  const filtered = useMemo(() => {\n    let result = articles\n\n    // Category filter\n    if (activeCategory) {\n      result = result.filter((a) => a.category === activeCategory)\n    }\n\n    // Search filter\n    if (searchQuery.trim()) {\n      const q = searchQuery.toLowerCase()\n      result = result.filter(\n        (a) =>\n          a.title.toLowerCase().includes(q) ||\n          a.excerpt.toLowerCase().includes(q) ||\n          a.tags.some((t) => t.toLowerCase().includes(q))\n      )\n    }\n\n    // Sort\n    switch (sort) {\n      case 'newest':\n        return [...result].sort(\n          (a, b) =>\n            new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime()\n        )\n      case 'oldest':\n        return [...result].sort(\n          (a, b) =>\n            new Date(a.publishedAt).getTime() - new Date(b.publishedAt).getTime()\n        )\n      case 'reading-time':\n        return [...result].sort((a, b) => a.readingTime - b.readingTime)\n      case 'a-z':\n        return [...result].sort((a, b) => a.title.localeCompare(b.title))\n      default:\n        return result\n    }\n  }, [articles, sort, activeCategory, searchQuery])\n\n  return (\n    <div>\n      {/* Filters bar */}\n      <div className=\"flex flex-wrap items-center gap-3 mb-8\">\n        {/* Search */}\n        <input\n          type=\"text\"\n          value={searchQuery}\n          onChange={(e) => setSearchQuery(e.target.value)}\n          placeholder=\"Tìm bài viết...\"\n          className=\"px-3 py-2 rounded-lg border border-border bg-background text-sm focus:outline-none focus:ring-2 focus:ring-ring flex-1 min-w-[200px]\"\n        />\n\n        {/* Category pills */}\n        <div className=\"flex flex-wrap gap-2\">\n          <button\n            onClick={() => setActiveCategory(null)}\n            className={`px-3 py-1.5 rounded-full text-sm font-medium transition-all ${\n              !activeCategory\n                ? 'bg-primary text-primary-foreground'\n                : 'border border-border hover:border-primary/50 hover:bg-primary/5'\n            }`}\n          >\n            Tất cả\n          </button>\n          {CATEGORIES.map((cat) => (\n            <button\n              key={cat.slug}\n              onClick={() =>\n                setActiveCategory(activeCategory === cat.slug ? null : cat.slug)\n              }\n              className={`px-3 py-1.5 rounded-full text-sm font-medium transition-all ${\n                activeCategory === cat.slug\n                  ? 'bg-primary text-primary-foreground'\n                  : 'border border-border hover:border-primary/50 hover:bg-primary/5'\n              }`}\n            >\n              {cat.label}\n            </button>\n          ))}\n        </div>\n\n        {/* Sort */}\n        <div className=\"flex items-center gap-2 ml-auto\">\n          <ArrowUpDown className=\"h-4 w-4 text-muted-foreground\" />\n          <select\n            value={sort}\n            onChange={(e) => setSort(e.target.value)}\n            className=\"text-sm bg-transparent border border-border rounded-md px-2 py-1.5 cursor-pointer focus:outline-none focus:ring-2 focus:ring-ring\"\n          >\n            {SORT_OPTIONS.map((opt) => (\n              <option key={opt.value} value={opt.value}>\n                {opt.label}\n              </option>\n            ))}\n          </select>\n        </div>\n      </div>\n\n      {/* Results count */}\n      <p className=\"text-sm text-muted-foreground mb-6\">\n        {filtered.length === 0\n          ? 'Không tìm thấy bài viết nào'\n          : `Hiển thị ${filtered.length} / ${articles.length} bài viết`}\n      </p>\n\n      {/* Articles grid */}\n      {filtered.length > 0 ? (\n        <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\">\n          {filtered.map((article, i) => (\n            <ArticleCard key={article.slug} article={article} featured={i === 0} />\n          ))}\n        </div>\n      ) : (\n        <div className=\"text-center py-20\">\n          <p className=\"text-lg text-muted-foreground mb-2\">\n            Không tìm thấy kết quả nào.\n          </p>\n          <button\n            onClick={() => {\n              setActiveCategory(null)\n              setSearchQuery('')\n            }}\n            className=\"text-sm text-primary hover:underline\"\n          >\n            Xóa bộ lọc\n          </button>\n        </div>\n      )}\n    </div>\n  )\n}\n"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":110,"output":1393,"cacheRead":133144,"cacheWrite":701,"totalTokens":135348,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776576108868,"responseId":"0633996e21bb2e85e13263fe71be94b7"}}
