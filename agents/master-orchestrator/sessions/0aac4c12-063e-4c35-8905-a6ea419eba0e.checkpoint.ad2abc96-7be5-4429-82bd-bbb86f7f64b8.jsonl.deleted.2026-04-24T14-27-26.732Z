{"type":"message","id":"b87bd9c9","parentId":"dd29cb27","timestamp":"2026-04-19T05:10:37.488Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me create an animated hero section component and update the home page to use it. Also, let me create an animated section wrapper.","thinkingSignature":"dff3b294025a49bc62239ef0bacf3e635765fe709d5bd57f51a0f3922e2518e4"},{"type":"toolCall","id":"call_function_5z9628niv5hl_1","name":"write","arguments":{"path":"/root/.openclaw/workspaces2/v4-ecosystem-review/maiy-tech-hub/components/shared/animate-on-scroll.tsx","content":"'use client'\n\nimport { motion } from 'framer-motion'\nimport { useEffect, useRef, useState } from 'react'\n\ninterface AnimateInProps {\n  children: React.ReactNode\n  className?: string\n  delay?: number\n  direction?: 'up' | 'down' | 'left' | 'right' | 'none'\n}\n\nexport function AnimateIn({\n  children,\n  className,\n  delay = 0,\n  direction = 'up',\n}: AnimateInProps) {\n  const ref = useRef<HTMLDivElement>(null)\n  const [visible, setVisible] = useState(false)\n\n  useEffect(() => {\n    const el = ref.current\n    if (!el) return\n\n    const observer = new IntersectionObserver(\n      ([entry]) => {\n        if (entry.isIntersecting) {\n          setVisible(true)\n          observer.disconnect()\n        }\n      },\n      { threshold: 0.1 }\n    )\n    observer.observe(el)\n    return () => observer.disconnect()\n  }, [])\n\n  const directionMap = {\n    up: { y: 24, x: 0 },\n    down: { y: -24, x: 0 },\n    left: { y: 0, x: 24 },\n    right: { y: 0, x: -24 },\n    none: { y: 0, x: 0 },\n  }\n\n  const offset = directionMap[direction]\n\n  return (\n    <motion.div\n      ref={ref}\n      className={className}\n      initial={{ opacity: 0, ...offset }}\n      animate={visible ? { opacity: 1, y: 0, x: 0 } : { opacity: 0, ...offset }}\n      transition={{ duration: 0.5, delay, ease: 'easeOut' }}\n    >\n      {children}\n    </motion.div>\n  )\n}\n\ninterface StaggerContainerProps {\n  children: React.ReactNode\n  className?: string\n  staggerDelay?: number\n}\n\nexport function StaggerContainer({\n  children,\n  className,\n  staggerDelay = 0.1,\n}: StaggerContainerProps) {\n  return (\n    <motion.div\n      className={className}\n      initial=\"hidden\"\n      animate=\"visible\"\n      variants={{\n        hidden: {},\n        visible: {\n          transition: {\n            staggerChildren: staggerDelay,\n          },\n        },\n      }}\n    >\n      {children}\n    </motion.div>\n  )\n}\n\nexport function StaggerItem({\n  children,\n  className,\n}: {\n  children: React.ReactNode\n  className?: string\n}) {\n  return (\n    <motion.div\n      className={className}\n      variants={{\n        hidden: { opacity: 0, y: 16 },\n        visible: {\n          opacity: 1,\n          y: 0,\n          transition: { duration: 0.4, ease: 'easeOut' },\n        },\n      }}\n    >\n      {children}\n    </motion.div>\n  )\n}\n"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":112,"output":731,"cacheRead":116653,"cacheWrite":3123,"totalTokens":120619,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776575427034,"responseId":"063396c42482854bdb18315dd5800525"}}
