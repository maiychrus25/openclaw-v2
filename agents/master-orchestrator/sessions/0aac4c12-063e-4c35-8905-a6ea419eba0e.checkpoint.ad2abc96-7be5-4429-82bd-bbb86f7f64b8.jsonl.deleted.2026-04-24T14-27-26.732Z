{"type":"message","id":"27ad5e2f","parentId":"bda668ae","timestamp":"2026-04-19T07:38:38.342Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me create the main StudyRoom component that integrates everything - WebRTC, video, chat, controls.","thinkingSignature":"b4b122274c0e6c74545435864202d7fa970b259ada50a0437f778cda1215534b"},{"type":"text","text":"**Phase 4: StudyRoom integration — rewrite study page:**\n"},{"type":"toolCall","id":"call_function_ene8agn2ftby_1","name":"write","arguments":{"path":"/root/.openclaw/workspaces2/v4-ecosystem-review/maiy-tech-hub/components/study/study-room.tsx","content":"'use client'\n\nimport { useState, useEffect, useRef, useCallback } from 'react'\nimport { useRouter } from 'next/navigation'\nimport { VideoGrid, type VideoPeer } from './video-grid'\nimport { MediaControls } from './media-controls'\nimport { ChatPanel, type ChatMessage } from './chat-panel'\nimport { getLocalStream, getScreenStream, stopStream, toggleTrack } from '@/lib/webrtc'\nimport { v4 as uuidv4 } from 'uuid'\nimport { Loader2, Wifi, WifiOff } from 'lucide-react'\n\ninterface StudyRoomProps {\n  roomId: string\n  username: string\n  socketUrl: string\n}\n\nexport function StudyRoom({ roomId, username, socketUrl }: StudyRoomProps) {\n  const router = useRouter()\n  const [isConnecting, setIsConnecting] = useState(true)\n  const [isConnected, setIsConnected] = useState(false)\n  const [isMicOn, setIsMicOn] = useState(false)\n  const [isCameraOn, setIsCameraOn] = useState(false)\n  const [isScreenOn, setIsScreenOn] = useState(false)\n  const [isChatOpen, setIsChatOpen] = useState(false)\n  const [isParticipantsOpen, setIsParticipantsOpen] = useState(false)\n  const [messages, setMessages] = useState<ChatMessage[]>([])\n  const [unreadMessages, setUnreadMessages] = useState(0)\n  const [peers, setPeers] = useState<VideoPeer[]>([])\n  const [participantCount, setParticipantCount] = useState(1)\n\n  const localStreamRef = useRef<MediaStream | null>(null)\n  const screenStreamRef = useRef<MediaStream | null>(null)\n  const socketRef = useRef<WebSocket | null>(null)\n  const reconnectTimeoutRef = useRef<NodeJS.Timeout | null>(null)\n  const [localStream, setLocalStream] = useState<MediaStream | null>(null)\n\n  // --- WebSocket ---\n  const connectSocket = useCallback(() => {\n    const ws = new WebSocket(`${socketUrl}?room=${roomId}&name=${encodeURIComponent(username)}`)\n\n    ws.onopen = () => {\n      setIsConnecting(false)\n      setIsConnected(true)\n      // Announce join\n      ws.send(JSON.stringify({ type: 'join', roomId, username }))\n    }\n\n    ws.onmessage = (event) => {\n      try {\n        const data = JSON.parse(event.data)\n        handleSignal(data)\n      } catch {}\n    }\n\n    ws.onclose = () => {\n      setIsConnected(false)\n      // Reconnect after 3s\n      reconnectTimeoutRef.current = setTimeout(connectSocket, 3000)\n    }\n\n    ws.onerror = () => {\n      ws.close()\n    }\n\n    socketRef.current = ws\n  }, [roomId, username, socketUrl])\n\n  useEffect(() => {\n    connectSocket()\n    return () => {\n      socketRef.current?.close()\n      if (reconnectTimeoutRef.current) clearTimeout(reconnectTimeoutRef.current)\n    }\n  }, [connectSocket])\n\n  // --- Signal handling ---\n  const handleSignal = (data: any) => {\n    switch (data.type) {\n      case 'user-joined':\n        setPeers((prev) => {\n          if (prev.find((p) => p.peerId === data.peerId)) return prev\n          return [...prev, { peerId: data.peerId, peerName: data.username, stream: new MediaStream() }]\n        })\n        setParticipantCount((n) => n + 1)\n        // Send offer to new peer\n        socketRef.current?.send(JSON.stringify({ type: 'request-offer', to: data.peerId }))\n        break\n\n      case 'user-left':\n        setPeers((prev) => prev.filter((p) => p.peerId !== data.peerId))\n        setParticipantCount((n) => Math.max(1, n - 1))\n        break\n\n      case 'offer-request':\n        // Got offer request from peer, create and send offer\n        createAndSendOffer(data.from, data.fromName)\n        break\n\n      case 'offer':\n        handleOffer(data.from, data.sdp)\n        break\n\n      case 'answer':\n        handleAnswer(data.from, data.sdp)\n        break\n\n      case 'ice-candidate':\n        handleIceCandidate(data.from, data.candidate)\n        break\n\n      case 'chat':\n        addChatMessage(data.from, data.fromName || username, data.text, false)\n        if (!isChatOpen) setUnreadMessages((n) => n + 1)\n        break\n\n      case 'room-users':\n        setParticipantCount(data.users?.length || 1)\n        break\n    }\n  }\n\n  // --- WebRTC peer connections ---\n  const peerConnectionsRef = useRef<Map<string, RTCPeerConnection>>(new Map())\n\n  const createAndSendOffer = async (peerId: string, peerName: string) => {\n    const pc = new RTCPeerConnection({\n      iceServers: [\n        { urls: 'stun:stun.l.google.com:19302' },\n        { urls: 'stun:stun1.l.google.com:19302' },\n      ],\n    })\n\n    peerConnectionsRef.current.set(peerId, pc)\n\n    pc.ontrack = (e) => {\n      const [stream] = e.streams\n      if (stream) {\n        setPeers((prev) =>\n          prev.map((p) =>\n            p.peerId === peerId ? { ...p, stream: stream.clone() } : p\n          )\n        )\n      }\n    }\n\n    pc.onicecandidate = (e) => {\n      if (e.candidate) {\n        socketRef.current?.send(\n          JSON.stringify({ type: 'ice-candidate', to: peerId, candidate: e.candidate.toJSON() })\n        )\n      }\n    }\n\n    // Add local tracks\n    if (localStreamRef.current) {\n      localStreamRef.current.getTracks().forEach((t) => pc.addTrack(t, localStreamRef.current!))\n    }\n\n    const offer = await pc.createOffer()\n    await pc.setLocalDescription(offer)\n\n    socketRef.current?.send(\n      JSON.stringify({ type: 'offer', to: peerId, sdp: pc.localDescription })\n    )\n  }\n\n  const handleOffer = async (from: string, sdp: RTCSessionDescriptionInit) => {\n    const pc = new RTCPeerConnection({\n      iceServers: [\n        { urls: 'stun:stun.l.google.com:19302' },\n        { urls: 'stun:stun1.l.google.com:19302' },\n      ],\n    })\n\n    peerConnectionsRef.current.set(from, pc)\n\n    pc.ontrack = (e) => {\n      const [stream] = e.streams\n      if (stream) {\n        setPeers((prev) =>\n          prev.map((p) =>\n            p.peerId === from ? { ...p, stream: stream.clone() } : p\n          )\n        )\n      }\n    }\n\n    pc.onicecandidate = (e) => {\n      if (e.candidate) {\n        socketRef.current?.send(\n          JSON.stringify({ type: 'ice-candidate', to: from, candidate: e.candidate.toJSON() })\n        )\n      }\n    }\n\n    if (localStreamRef.current) {\n      localStreamRef.current.getTracks().forEach((t) => pc.addTrack(t, localStreamRef.current!))\n    }\n\n    await pc.setRemoteDescription(new RTCSessionDescription(sdp))\n    const answer = await pc.createAnswer()\n    await pc.setLocalDescription(answer)\n\n    socketRef.current?.send(\n      JSON.stringify({ type: 'answer', to: from, sdp: pc.localDescription })\n    )\n  }\n\n  const handleAnswer = async (from: string, sdp: RTCSessionDescriptionInit) => {\n    const pc = peerConnectionsRef.current.get(from)\n    if (pc) {\n      await pc.setRemoteDescription(new RTCSessionDescription(sdp))\n    }\n  }\n\n  const handleIceCandidate = async (from: string, candidate: RTCIceCandidateInit) => {\n    const pc = peerConnectionsRef.current.get(from)\n    if (pc) {\n      await pc.addIceCandidate(new RTCIceCandidate(candidate))\n    }\n  }\n\n  // --- Media controls ---\n  const toggleMic = () => {\n    const stream = localStreamRef.current\n    if (stream) {\n      const track = stream.getAudioTracks()[0]\n      toggleTrack(track)\n      setIsMicOn(track.enabled)\n    }\n  }\n\n  const toggleCamera = () => {\n    const stream = localStreamRef.current\n    if (stream) {\n      const track = stream.getVideoTracks()[0]\n      toggleTrack(track)\n      setIsCameraOn(track.enabled)\n    }\n  }\n\n  const toggleScreen = async () => {\n    if (isScreenOn) {\n      // Stop screen share\n      stopStream(screenStreamRef.current || undefined)\n      screenStreamRef.current = null\n      setIsScreenOn(false)\n    } else {\n      const stream = await getScreenStream()\n      if (stream) {\n        screenStreamRef.current = stream\n        setIsScreenOn(true)\n\n        // Replace video track in all peer connections\n        const videoTrack = stream.getVideoTracks()[0]\n        peerConnectionsRef.current.forEach((pc) => {\n          const sender = pc.getSenders().find((s) => s.track?.kind === 'video')\n          if (sender) {\n            sender.replaceTrack(videoTrack)\n          } else {\n            pc.addTrack(videoTrack, stream)\n          }\n        })\n\n        // Notify others\n        socketRef.current?.send(JSON.stringify({ type: 'screen-share', sharing: true }))\n\n        // Stop on track ended\n        videoTrack.onended = () => {\n          stopStream(screenStreamRef.current || undefined)\n          screenStreamRef.current = null\n          setIsScreenOn(false)\n          socketRef.current?.send(JSON.stringify({ type: 'screen-share', sharing: false }))\n        }\n      }\n    }\n  }\n\n  // --- Chat ---\n  const addChatMessage = (peerId: string, fromName: string, text: string, isOwn: boolean) => {\n    setMessages((prev) => [\n      ...prev,\n      { id: uuidv4(), from: peerId, fromName, text, timestamp: Date.now(), isOwn },\n    ])\n  }\n\n  const sendMessage = (text: string) => {\n    socketRef.current?.send(JSON.stringify({ type: 'chat', text }))\n    addChatMessage('local', username, text, true)\n  }\n\n  // --- Start media on mount ---\n  useEffect(() => {\n    const startMedia = async () => {\n      const stream = await getLocalStream(true, true)\n      if (stream) {\n        localStreamRef.current = stream\n        setLocalStream(stream)\n        setIsMicOn(true)\n        setIsCameraOn(true)\n      }\n    }\n    startMedia()\n\n    return () => {\n      stopStream(localStreamRef.current || undefined)\n      stopStream(screenStreamRef.current || undefined)\n    }\n  }, [])\n\n  // Update peer stream when local tracks change\n  useEffect(() => {\n    if (localStreamRef.current) {\n      setLocalStream(localStreamRef.current.clone())\n    }\n  }, [isMicOn, isCameraOn])\n\n  // --- Leave room ---\n  const handleLeave = () => {\n    socketRef.current?.close()\n    stopStream(localStreamRef.current || undefined)\n    stopStream(screenStreamRef.current || undefined)\n    router.push('/study')\n  }\n\n  return (\n    <div className=\"flex flex-col h-[calc(100vh-4rem)]\">\n      {/* Status bar */}\n      <div className=\"flex items-center justify-between px-4 py-2 bg-muted/50 border-b border-border text-xs\">\n        <div className=\"flex items-center gap-3\">\n          <span className=\"font-medium\">Phòng: {roomId}</span>\n          <span className=\"text-muted-foreground\">\n            {participantCount} thành viên\n          </span>\n        </div>\n        <div className=\"flex items-center gap-1.5\">\n          {isConnected ? (\n            <>\n              <Wifi className=\"h-3 w-3 text-green-500\" />\n              <span className=\"text-green-500\">Đã kết nối</span>\n            </>\n          ) : (\n            <>\n              <WifiOff className=\"h-3 w-3 text-red-500\" />\n              <span className=\"text-red-500\">\n                {isConnecting ? 'Đang kết nối...' : 'Mất kết nối'}\n              </span>\n            </>\n          )}\n        </div>\n      </div>\n\n      {/* Connecting overlay */}\n      {isConnecting && (\n        <div className=\"flex-1 flex items-center justify-center\">\n          <div className=\"flex flex-col items-center gap-3\">\n            <Loader2 className=\"h-8 w-8 animate-spin text-primary\" />\n            <p className=\"text-muted-foreground\">Đang kết nối phòng học...</p>\n          </div>\n        </div>\n      )}\n\n      {/* Video grid */}\n      {!isConnecting && (\n        <div className=\"flex-1 overflow-y-auto bg-slate-950/50\">\n          <VideoGrid\n            localStream={localStream}\n            peers={peers}\n            onSelectPeer={(id) => console.log('selected', id)}\n          />\n        </div>\n      )}\n\n      {/* Controls */}\n      <div className=\"border-t border-border bg-background\">\n        <MediaControls\n          isMicOn={isMicOn}\n          isCameraOn={isCameraOn}\n          isScreenOn={isScreenOn}\n          unreadMessages={unreadMessages}\n          participantCount={participantCount}\n          onToggleMic={toggleMic}\n          onToggleCamera={toggleCamera}\n          onToggleScreen={toggleScreen}\n          onToggleChat={() => {\n            setIsChatOpen(!isChatOpen)\n            if (!isChatOpen) setUnreadMessages(0)\n          }}\n          onLeave={handleLeave}\n        />\n      </div>\n\n      {/* Chat panel */}\n      <ChatPanel\n        messages={messages}\n        onSend={sendMessage}\n        username={username}\n        isOpen={isChatOpen}\n        onClose={() => setIsChatOpen(false)}\n      />\n    </div>\n  )\n}\n"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":112,"output":3203,"cacheRead":44876,"cacheWrite":2812,"totalTokens":51003,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776584279772,"responseId":"0633b959d2682792412c8a93b24fcdb6"}}
{"type":"message","id":"c42d7f01","parentId":"27ad5e2f","timestamp":"2026-04-19T07:38:38.362Z","message":{"role":"toolResult","toolCallId":"call_function_ene8agn2ftby_1","toolName":"write","content":[{"type":"text","text":"Successfully wrote 12137 bytes to /root/.openclaw/workspaces2/v4-ecosystem-review/maiy-tech-hub/components/study/study-room.tsx"}],"isError":false,"timestamp":1776584318353}}
{"type":"message","id":"b93ce4bb","parentId":"c42d7f01","timestamp":"2026-04-19T07:39:07.080Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now I need to update the study page to integrate the StudyRoom component. I also need to handle the WebSocket server on the Next.js custom server.\n\nFirst, let me update the study page to show the room join form and integrate the StudyRoom component. Then update the server to handle WebSocket for WebRTC signaling.","thinkingSignature":"4fd6353d3e94f1523629f79aad3391259a9db085a6a46dbfac51f8895749d5e7"},{"type":"text","text":"**Phase 5: Update study page + WebSocket server:**\n"},{"type":"toolCall","id":"call_function_k290bzt3f4fo_1","name":"write","arguments":{"path":"/root/.openclaw/workspaces2/v4-ecosystem-review/maiy-tech-hub/app/study/page.tsx","content":"'use client'\n\nimport { useState } from 'react'\nimport { useRouter } from 'next/navigation'\nimport { motion } from 'framer-motion'\nimport { Users, Clock, BookOpen, Headphones, Zap, Plus, ArrowRight, Radio } from 'lucide-react'\nimport type { Metadata } from 'next'\n\nexport default function StudyPage() {\n  const router = useRouter()\n  const [roomId, setRoomId] = useState('')\n  const [username, setUsername] = useState('')\n  const [joinMode, setJoinMode] = useState(false)\n\n  const features = [\n    {\n      icon: Radio,\n      title: 'Bật Cam & Mic',\n      desc: 'Giao tiếp trực tiếp với WebRTC',\n      color: 'text-primary',\n    },\n    {\n      icon: Users,\n      title: 'Nhiều Người',\n      desc: 'Học cùng nhau, theo dõi tiến độ',\n      color: 'text-blue-500',\n    },\n    {\n      icon: Clock,\n      title: 'Pomodoro Timer',\n      desc: '25 phút tập trung, 5 phút nghỉ',\n      color: 'text-amber-500',\n    },\n    {\n      icon: Headphones,\n      title: 'Âm Thanh Nền',\n      desc: 'Rain, Coffee, Forest, Ocean',\n      color: 'text-emerald-500',\n    },\n    {\n      icon: BookOpen,\n      title: 'Bài Viết Mở',\n      desc: 'Đọc & học ngay trong phòng',\n      color: 'text-violet-500',\n    },\n    {\n      icon: Zap,\n      title: 'Chia Sẻ Màn Hình',\n      desc: 'Trình bày bài giảng dễ dàng',\n      color: 'text-orange-500',\n    },\n  ]\n\n  const handleJoinRoom = (e: React.FormEvent) => {\n    e.preventDefault()\n    if (!roomId.trim() || !username.trim()) return\n    const wsProtocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:'\n    const wsUrl = `${wsProtocol}//${window.location.host}`\n    router.push(`/study/room/${roomId}?name=${encodeURIComponent(username)}&ws=${encodeURIComponent(wsUrl)}`)\n  }\n\n  const handleQuickJoin = (room: string) => {\n    const name = username.trim() || 'Học sinh ' + Math.floor(Math.random() * 100)\n    const wsProtocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:'\n    const wsUrl = `${wsProtocol}//${window.location.host}`\n    router.push(`/study/room/${room}?name=${encodeURIComponent(name)}&ws=${encodeURIComponent(wsUrl)}`)\n  }\n\n  return (\n    <div className=\"min-h-screen\">\n      {/* Hero */}\n      <section className=\"relative overflow-hidden bg-gradient-to-b from-primary/5 via-background to-background py-16\">\n        <div className=\"container\">\n          <motion.div\n            initial={{ opacity: 0, y: 20 }}\n            animate={{ opacity: 1, y: 0 }}\n            className=\"text-center max-w-2xl mx-auto\"\n          >\n            <div className=\"inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 text-primary text-sm mb-4\">\n              <Radio className=\"h-3.5 w-3.5\" />\n              Học cùng nhau — không một mình\n            </div>\n            <h1 className=\"text-4xl font-bold mb-4\">\n              Phòng Học Live\n            </h1>\n            <p className=\"text-muted-foreground text-lg mb-8\">\n              Bật cam, bật mic, học nhóm thật sự. WebRTC peer-to-peer, không lag, không phí.\n            </p>\n\n            {/* Join form */}\n            <div className=\"bg-card border border-border rounded-xl p-6 max-w-md mx-auto\">\n              {!joinMode ? (\n                <div className=\"space-y-3\">\n                  <input\n                    type=\"text\"\n                    value={username}\n                    onChange={(e) => setUsername(e.target.value)}\n                    placeholder=\"Tên hiển thị của bạn\"\n                    className=\"w-full px-4 py-2.5 rounded-lg border border-border bg-background text-sm focus:outline-none focus:ring-2 focus:ring-ring\"\n                  />\n                  <button\n                    onClick={() => setJoinMode(true)}\n                    className=\"w-full py-2.5 rounded-lg bg-primary text-primary-foreground font-medium hover:bg-primary/90 transition-colors flex items-center justify-center gap-2\"\n                  >\n                    <Plus className=\"h-4 w-4\" />\n                    Tạo hoặc tham gia phòng\n                  </button>\n                  <div className=\"relative\">\n                    <div className=\"absolute inset-0 flex items-center\">\n                      <div className=\"w-full border-t border-border\" />\n                    </div>\n                    <div className=\"relative flex justify-center text-xs\">\n                      <span className=\"bg-card px-2 text-muted-foreground\">hoặc chọn nhanh</span>\n                    </div>\n                  </div>\n                  <div className=\"grid grid-cols-3 gap-2\">\n                    {['CTDL', 'AI', 'WebDev'].map((room) => (\n                      <button\n                        key={room}\n                        onClick={() => {\n                          setUsername(username || 'Học sinh ' + Math.floor(Math.random() * 100))\n                          handleQuickJoin(room)\n                        }}\n                        className=\"py-2 rounded-lg border border-border text-xs font-medium hover:bg-muted transition-colors\"\n                      >\n                        #{room}\n                      </button>\n                    ))}\n                  </div>\n                </div>\n              ) : (\n                <form onSubmit={handleJoinRoom} className=\"space-y-3\">\n                  <div className=\"flex items-center gap-2 text-sm text-muted-foreground mb-2\">\n                    <ArrowRight className=\"h-3 w-3\" />\n                    Nhập mã phòng để tham gia\n                  </div>\n                  <input\n                    type=\"text\"\n                    value={roomId}\n                    onChange={(e) => setRoomId(e.target.value.toUpperCase().replace(/\\s/g, '-'))}\n                    placeholder=\"Mã phòng (VD: CTDL-01)\"\n                    className=\"w-full px-4 py-2.5 rounded-lg border border-border bg-background text-sm font-mono focus:outline-none focus:ring-2 focus:ring-ring tracking-wider\"\n                    autoFocus\n                  />\n                  <input\n                    type=\"text\"\n                    value={username}\n                    onChange={(e) => setUsername(e.target.value)}\n                    placeholder=\"Tên hiển thị\"\n                    className=\"w-full px-4 py-2.5 rounded-lg border border-border bg-background text-sm focus:outline-none focus:ring-2 focus:ring-ring\"\n                  />\n                  <div className=\"flex gap-2\">\n                    <button\n                      type=\"button\"\n                      onClick={() => setJoinMode(false)}\n                      className=\"flex-1 py-2.5 rounded-lg border border-border text-sm hover:bg-muted transition-colors\"\n                    >\n                      Quay lại\n                    </button>\n                    <button\n                      type=\"submit\"\n                      disabled={!roomId.trim() || !username.trim()}\n                      className=\"flex-1 py-2.5 rounded-lg bg-primary text-primary-foreground font-medium hover:bg-primary/90 disabled:opacity-50 transition-colors flex items-center justify-center gap-2\"\n                    >\n                      <Radio className=\"h-4 w-4\" />\n                      Vào phòng\n                    </button>\n                  </div>\n                </form>\n              )}\n            </div>\n          </motion.div>\n        </div>\n      </section>\n\n      {/* Features */}\n      <section className=\"container py-12\">\n        <h2 className=\"text-2xl font-bold text-center mb-8\">Tính năng phòng học</h2>\n        <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4\">\n          {features.map((f, i) => (\n            <motion.div\n              key={f.title}\n              initial={{ opacity: 0, y: 20 }}\n              animate={{ opacity: 1, y: 0 }}\n              transition={{ delay: i * 0.1 }}\n              className=\"p-5 rounded-xl border border-border bg-card hover:border-primary/30 transition-colors\"\n            >\n              <f.icon className={`h-6 w-6 ${f.color} mb-3`} />\n              <h3 className=\"font-semibold mb-1\">{f.title}</h3>\n              <p className=\"text-sm text-muted-foreground\">{f.desc}</p>\n            </motion.div>\n          ))}\n        </div>\n      </section>\n    </div>\n  )\n}\n"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":113,"output":2160,"cacheRead":46442,"cacheWrite":4499,"totalTokens":53214,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776584318368,"responseId":"0633b97ff69313cb4c9e6926aaa2cf55"}}
