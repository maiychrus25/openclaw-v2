{"type":"message","id":"fbb6926a","parentId":"4c885462","timestamp":"2026-04-19T09:18:02.691Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me redesign the home page with modern section headers, better featured section, and more polished layout.","thinkingSignature":"b984ddef92c6999d21d20356a9a1266eeb27fe5a3308e626ca81e806d1c5ad72"},{"type":"text","text":"**Bước 2: Redesign home page:**\n"},{"type":"toolCall","id":"call_function_v02r0m3b06i2_1","name":"write","arguments":{"path":"/root/.openclaw/workspaces2/v4-ecosystem-review/maiy-tech-hub/app/page.tsx","content":"import Link from 'next/link'\nimport { ArrowRight, Play, Headphones, BookOpen, Sparkles } from 'lucide-react'\nimport { CATEGORIES } from '@/config/site'\nimport { ArticleCard } from '@/components/blog/article-card'\nimport { NewsletterForm } from '@/components/shared/newsletter-form'\nimport { ThreeHero } from '@/components/blog/three-hero'\nimport { getFeaturedArticles, getRecentArticles } from '@/lib/content'\n\nexport default async function HomePage() {\n  const featured = await getFeaturedArticles()\n  const recent = await getRecentArticles(6)\n  const featuredArticle = featured[0]\n\n  return (\n    <div className=\"flex flex-col\">\n      <ThreeHero />\n\n      {/* Featured Article */}\n      {featuredArticle && (\n        <section className=\"container py-16\">\n          {/* Section header */}\n          <div className=\"flex items-center gap-3 mb-8\">\n            <div className=\"w-1 h-8 rounded-full bg-gradient-to-b from-violet-500 to-blue-500\" />\n            <div>\n              <h2 className=\"text-2xl font-bold tracking-tight\">Bài viết nổi bật</h2>\n              <p className=\"text-sm text-muted-foreground\">Những bài viết được đánh giá cao nhất</p>\n            </div>\n          </div>\n\n          <Link\n            href={`/articles/${featuredArticle.slug}`}\n            className=\"group block rounded-3xl overflow-hidden border border-border/60 relative\"\n          >\n            {/* Background gradient */}\n            <div className=\"absolute inset-0 bg-gradient-to-br from-violet-600/10 via-transparent to-blue-600/10 opacity-0 group-hover:opacity-100 transition-opacity duration-500\" />\n\n            <div className=\"grid md:grid-cols-2 gap-0 relative\">\n              {featuredArticle.hero ? (\n                // eslint-disable-next-line @next/next/no-img-element\n                <img\n                  src={featuredArticle.hero}\n                  alt={featuredArticle.title}\n                  className=\"w-full h-72 md:h-80 object-cover group-hover:scale-105 transition-transform duration-700\"\n                />\n              ) : (\n                <div className=\"w-full h-72 md:h-80 bg-gradient-to-br from-violet-600/20 to-blue-600/20\" />\n              )}\n\n              {/* Content */}\n              <div className=\"p-8 md:p-12 flex flex-col justify-center relative\">\n                {/* Badge */}\n                <div className=\"inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-amber-500/10 text-amber-400 text-xs font-bold uppercase tracking-wide mb-4 w-fit\">\n                  <Sparkles className=\"h-3 w-3\" />\n                  Nổi bật\n                </div>\n\n                <h3 className=\"text-2xl md:text-3xl font-bold mb-4 leading-tight group-hover:text-primary transition-colors\">\n                  {featuredArticle.title}\n                </h3>\n\n                <p className=\"text-muted-foreground mb-6 leading-relaxed line-clamp-3\">\n                  {featuredArticle.excerpt}\n                </p>\n\n                <div className=\"flex items-center gap-4\">\n                  <span className=\"inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-primary text-primary-foreground font-semibold text-sm group-hover:gap-3 transition-all\">\n                    Đọc ngay\n                    <ArrowRight className=\"h-4 w-4\" />\n                  </span>\n                  <span className=\"text-sm text-muted-foreground\">\n                    {featuredArticle.readingTime} phút đọc\n                  </span>\n                </div>\n              </div>\n            </div>\n          </Link>\n        </section>\n      )}\n\n      {/* Categories */}\n      <section className=\"container pb-16\">\n        <div className=\"flex items-center gap-3 mb-8\">\n          <div className=\"w-1 h-8 rounded-full bg-gradient-to-b from-cyan-500 to-emerald-500\" />\n          <div>\n            <h2 className=\"text-2xl font-bold tracking-tight\">Khám phá chủ đề</h2>\n            <p className=\"text-sm text-muted-foreground\">Chọn lĩnh vực bạn quan tâm</p>\n          </div>\n        </div>\n\n        <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-3\">\n          {CATEGORIES.map((cat, i) => {\n            const colors: Record<string, string> = {\n              ctdl: 'from-blue-600 to-blue-400 border-blue-500/30 hover:border-blue-400/60 hover:from-blue-600/20',\n              ai: 'from-violet-600 to-purple-400 border-violet-500/30 hover:border-violet-400/60 hover:from-violet-600/20',\n              'web-dev': 'from-emerald-600 to-green-400 border-emerald-500/30 hover:border-emerald-400/60 hover:from-emerald-600/20',\n              devops: 'from-orange-600 to-amber-400 border-orange-500/30 hover:border-orange-400/60 hover:from-orange-600/20',\n              'cs-fundamentals': 'from-red-600 to-rose-400 border-red-500/30 hover:border-red-400/60 hover:from-red-600/20',\n            }\n            const icons: Record<string, string> = {\n              ctdl: 'CTDL',\n              ai: 'AI',\n              'web-dev': 'Web',\n              devops: 'Dev',\n              'cs-fundamentals': 'CS',\n            }\n            const c = colors[cat.slug] || colors['ctdl']\n            return (\n              <Link\n                key={cat.slug}\n                href={`/articles/category/${cat.slug}`}\n                className={`group relative flex flex-col items-start p-5 rounded-2xl border bg-gradient-to-br ${c} transition-all duration-300 hover:shadow-lg hover:-translate-y-0.5 overflow-hidden`}\n              >\n                {/* Glow */}\n                <div className=\"absolute -top-6 -right-6 w-24 h-24 rounded-full bg-white/5 group-hover:bg-white/10 transition-colors\" />\n\n                {/* Icon */}\n                <div className=\"w-12 h-12 rounded-xl bg-white/10 backdrop-blur-sm flex items-center justify-center mb-4 text-lg font-black\">\n                  {icons[cat.slug]}\n                </div>\n\n                <h3 className=\"font-bold text-base mb-1\">{cat.label}</h3>\n                <p className=\"text-xs text-white/60 leading-relaxed line-clamp-2\">\n                  {cat.description}\n                </p>\n\n                <div className=\"absolute bottom-3 right-3 opacity-0 group-hover:opacity-100 transition-opacity\">\n                  <ArrowRight className=\"h-4 w-4 text-white/60\" />\n                </div>\n              </Link>\n            )\n          })}\n        </div>\n      </section>\n\n      {/* Recent Posts */}\n      <section className=\"container pb-16\">\n        <div className=\"flex items-center justify-between mb-8\">\n          <div className=\"flex items-center gap-3\">\n            <div className=\"w-1 h-8 rounded-full bg-gradient-to-b from-pink-500 to-rose-500\" />\n            <div>\n              <h2 className=\"text-2xl font-bold tracking-tight\">Bài viết mới nhất</h2>\n              <p className=\"text-sm text-muted-foreground\">Cập nhật kiến thức mới mỗi ngày</p>\n            </div>\n          </div>\n          <Link\n            href=\"/articles\"\n            className=\"inline-flex items-center gap-1.5 text-sm font-medium text-primary hover:gap-2.5 transition-all px-4 py-2 rounded-xl hover:bg-primary/5\"\n          >\n            Xem tất cả\n            <ArrowRight className=\"h-4 w-4\" />\n          </Link>\n        </div>\n\n        <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5\">\n          {recent.map((article, i) => (\n            <ArticleCard\n              key={article.slug}\n              article={article}\n              featured={i === 0}\n              index={i}\n            />\n          ))}\n        </div>\n\n        {recent.length === 0 && (\n          <div className=\"text-center py-20 rounded-2xl border border-dashed border-border\">\n            <p className=\"text-muted-foreground mb-2\">Chưa có bài viết nào.</p>\n            <p className=\"text-sm text-muted-foreground\">Hãy là người đầu tiên đóng góp!</p>\n          </div>\n        )}\n      </section>\n\n      {/* Music + Study CTA */}\n      <section className=\"border-y border-border/60\">\n        <div className=\"container py-16\">\n          <div className=\"grid md:grid-cols-2 gap-6\">\n            {/* Music */}\n            <Link\n              href=\"/music\"\n              className=\"group relative flex items-center gap-5 p-6 rounded-2xl border border-border/60 bg-gradient-to-br from-indigo-500/5 to-purple-500/5 hover:border-indigo-500/30 hover:from-indigo-500/10 hover:to-purple-500/10 transition-all overflow-hidden\"\n            >\n              <div className=\"absolute -top-10 -right-10 w-32 h-32 rounded-full bg-indigo-500/10 blur-2xl group-hover:bg-indigo-500/20 transition-colors\" />\n              <div className=\"w-16 h-16 rounded-2xl bg-gradient-to-br from-indigo-500 to-purple-500 flex items-center justify-center flex-shrink-0 shadow-lg shadow-indigo-500/20\">\n                <Headphones className=\"h-7 w-7 text-white\" />\n              </div>\n              <div className=\"relative\">\n                <h3 className=\"font-bold text-lg mb-1 group-hover:text-indigo-400 transition-colors\">\n                  Relaxation Zone\n                </h3>\n                <p className=\"text-sm text-muted-foreground\">\n                  Nhạc lo-fi, ambient, classical — giúp bạn tập trung khi học\n                </p>\n              </div>\n              <ArrowRight className=\"h-5 w-5 text-muted-foreground ml-auto group-hover:translate-x-1 group-hover:text-indigo-400 transition-all\" />\n            </Link>\n\n            {/* Study */}\n            <Link\n              href=\"/study\"\n              className=\"group relative flex items-center gap-5 p-6 rounded-2xl border border-border/60 bg-gradient-to-br from-emerald-500/5 to-green-500/5 hover:border-emerald-500/30 hover:from-emerald-500/10 hover:to-green-500/10 transition-all overflow-hidden\"\n            >\n              <div className=\"absolute -top-10 -right-10 w-32 h-32 rounded-full bg-emerald-500/10 blur-2xl group-hover:bg-emerald-500/20 transition-colors\" />\n              <div className=\"w-16 h-16 rounded-2xl bg-gradient-to-br from-emerald-500 to-green-500 flex items-center justify-center flex-shrink-0 shadow-lg shadow-emerald-500/20\">\n                <BookOpen className=\"h-7 w-7 text-white\" />\n              </div>\n              <div className=\"relative\">\n                <h3 className=\"font-bold text-lg mb-1 group-hover:text-emerald-400 transition-colors\">\n                  Phòng học Live\n                </h3>\n                <p className=\"text-sm text-muted-foreground\">\n                  Pomodoro timer, cam, mic, chat — học nhóm thật sự\n                </p>\n              </div>\n              <ArrowRight className=\"h-5 w-5 text-muted-foreground ml-auto group-hover:translate-x-1 group-hover:text-emerald-400 transition-all\" />\n            </Link>\n          </div>\n        </div>\n      </section>\n\n      {/* Newsletter */}\n      <section className=\"container py-16\">\n        <div className=\"rounded-3xl bg-gradient-to-br from-violet-600 via-indigo-600 to-blue-600 p-10 md:p-16 text-center text-white relative overflow-hidden\">\n          {/* Decorative circles */}\n          <div className=\"absolute -top-20 -right-20 w-64 h-64 rounded-full bg-white/5\" />\n          <div className=\"absolute -bottom-20 -left-20 w-48 h-48 rounded-full bg-white/5\" />\n\n          <div className=\"relative\">\n            <div className=\"inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/10 text-sm font-medium mb-6 backdrop-blur-sm\">\n              <Sparkles className=\"h-4 w-4\" />\n              Miễn phí — không spam\n            </div>\n            <h2 className=\"text-3xl md:text-4xl font-bold mb-4\">\n              Nhận bài viết mới mỗi tuần\n            </h2>\n            <p className=\"text-white/70 mb-8 max-w-md mx-auto\">\n              Đăng ký email để nhận bài viết mới về CTDL, AI, Web Dev — hoàn toàn miễn phí.\n            </p>\n            <NewsletterForm />\n          </div>\n        </div>\n      </section>\n    </div>\n  )\n}\n"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":111,"output":3139,"cacheRead":144238,"cacheWrite":2091,"totalTokens":149579,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776590246729,"responseId":"0633d0a87ccac5d4e6371963b9430f19"}}
