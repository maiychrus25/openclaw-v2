{"type":"message","id":"b984e199","parentId":"87fab6e5","timestamp":"2026-04-19T08:00:19.297Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me update the server to properly handle the new signaling format. The server needs to:\n1. Generate a unique peerId for each connection\n2. Send `welcome` with the peer's ID and list of existing peers\n3. Relay offer/answer/ice-candidate/chat messages to the correct peer","thinkingSignature":"1dceb38e483e2d6e330456722ee1212b69186f96a84d207f7c6705abc6c69b62"},{"type":"text","text":"Update server để hỗ trợ signaling đúng:\n"},{"type":"toolCall","id":"call_function_bz8fy62gfu6y_1","name":"write","arguments":{"path":"/root/.openclaw/workspaces2/v4-ecosystem-review/maiy-tech-hub/server/server.ts","content":"import { createServer } from 'http'\nimport { parse as parseUrl } from 'url'\nimport { WebSocketServer } from 'ws'\nimport type { WebSocket as WsWebSocket } from 'ws'\nimport next from 'next'\nimport { Server as SocketIOServer } from 'socket.io'\n\nconst dev = process.env.NODE_ENV !== 'production'\nconst app = next({ dev })\nconst handle = app.getRequestHandler()\n\napp.prepare().then(() => {\n  const httpServer = createServer((req, res) => {\n    const parsedUrl = parseUrl(req.url!, true)\n    handle(req, res, parsedUrl)\n  })\n\n  // ─── Native WebSocket — WebRTC signaling ────────────────────────────────────\n  const wss = new WebSocketServer({ noServer: true })\n\n  // roomId -> Map<ws -> {username, peerId}>\n  const rooms = new Map<string, Map<WsWebSocket, { username: string; peerId: string }>>()\n  const wsPeerId = new Map<WsWebSocket, string>()\n  const wsRoomInfo = new Map<WsWebSocket, { roomId: string; username: string; peerId: string }>()\n\n  wss.on('connection', (ws: WsWebSocket, request) => {\n    const url = new URL(request.url || '/', `http://${request.headers.host}`)\n    const roomId = url.searchParams.get('room') || 'default'\n    const username = decodeURIComponent(url.searchParams.get('name') || 'Anonymous')\n    const peerId = 'p-' + Math.random().toString(36).slice(2, 10)\n\n    // Register\n    wsPeerId.set(ws, peerId)\n    wsRoomInfo.set(ws, { roomId, username, peerId })\n\n    if (!rooms.has(roomId)) rooms.set(roomId, new Map())\n    rooms.get(roomId)!.set(ws, { username, peerId })\n\n    // Send welcome to the new peer with list of existing peers\n    const existingPeers = Array.from(rooms.get(roomId)!.entries())\n      .filter(([w]) => w !== ws)\n      .map(([, data]) => ({ peerId: data.peerId, username: data.username }))\n\n    ws.send(JSON.stringify({\n      type: 'welcome',\n      peerId,\n      peers: existingPeers,\n      userCount: rooms.get(roomId)!.size,\n    }))\n\n    // Notify existing peers about the new peer\n    broadcast(ws, {\n      type: 'peer-joined',\n      peerId,\n      username,\n    })\n\n    ws.on('message', (raw) => {\n      try {\n        const msg = JSON.parse(raw.toString())\n        handleMessage(ws, msg)\n      } catch { /* ignore */ }\n    })\n\n    ws.on('close', () => {\n      const info = wsRoomInfo.get(ws)\n      if (info) {\n        rooms.get(info.roomId)?.delete(ws)\n        broadcast(ws, { type: 'peer-left', peerId: info.peerId })\n        if (rooms.get(info.roomId)?.size === 0) {\n          rooms.delete(info.roomId)\n        }\n      }\n      wsPeerId.delete(ws)\n      wsRoomInfo.delete(ws)\n    })\n\n    ws.on('error', () => ws.close())\n  })\n\n  function broadcast(sender: WsWebSocket, msg: object) {\n    const info = wsRoomInfo.get(sender)\n    if (!info) return\n    const room = rooms.get(info.roomId)\n    if (!room) return\n    const payload = JSON.stringify(msg)\n    room.forEach((_, ws) => {\n      if (ws !== sender && ws.readyState === 1) {\n        ws.send(payload)\n      }\n    })\n  }\n\n  function relay(targetPeerId: string, msg: object) {\n    // Find the ws connection with this peerId\n    for (const [ws, info] of wsRoomInfo) {\n      if (info.peerId === targetPeerId && ws.readyState === 1) {\n        ws.send(JSON.stringify(msg))\n        return\n      }\n    }\n  }\n\n  function handleMessage(ws: WsWebSocket, msg: any) {\n    const info = wsRoomInfo.get(ws)\n    if (!info) return\n    const room = rooms.get(info.roomId)\n    if (!room) return\n\n    switch (msg.type) {\n      case 'offer':\n      case 'answer':\n      case 'ice-candidate':\n      case 'chat':\n      case 'screen-share':\n        // Relay to specific peer\n        if (msg.peerId) {\n          relay(msg.peerId, { ...msg, from: info.peerId, fromName: info.username })\n        }\n        break\n\n      case 'join':\n        // Already handled in 'connection' — ignore\n        break\n    }\n  }\n\n  // ─── Socket.IO — Pomodoro + ambient sounds ───────────────────────────────────\n  const io = new SocketIOServer(httpServer, {\n    cors: {\n      origin: process.env.NEXT_PUBLIC_SITE_URL || 'http://localhost:3000',\n      methods: ['GET', 'POST'],\n    },\n  })\n\n  io.on('connection', (socket) => {\n    socket.on('join-room', ({ roomId, username }: { roomId: string; username: string }) => {\n      socket.join(roomId)\n      const room = io.sockets.adapter.rooms.get(roomId)\n      const count = room?.size ?? 0\n      io.to(roomId).emit('user-joined', { username, id: socket.id, count })\n      socket.data.username = username\n      socket.data.roomId = roomId\n    })\n\n    socket.on('leave-room', ({ roomId, username }: { roomId: string; username: string }) => {\n      socket.leave(roomId)\n      const room = io.sockets.adapter.rooms.get(roomId)\n      const count = room?.size ?? 0\n      io.to(roomId).emit('user-left', { username, id: socket.id, count })\n    })\n\n    socket.on('pomodoro-tick', ({ roomId, timeLeft, phase, sessionCount }: any) => {\n      socket.to(roomId).emit('pomodoro-sync', { timeLeft, phase, sessionCount })\n    })\n\n    socket.on('disconnect', () => {\n      if (socket.data.roomId && socket.data.username) {\n        const { roomId, username } = socket.data\n        socket.leave(roomId)\n        const room = io.sockets.adapter.rooms.get(roomId)\n        const count = room?.size ?? 0\n        io.to(roomId).emit('user-left', { username, id: socket.id, count })\n      }\n    })\n  })\n\n  // ─── HTTP upgrade ───────────────────────────────────────────────────────────\n  httpServer.on('upgrade', (request, socket, head) => {\n    const pathname = new URL(request.url || '/', `http://${request.headers.host}`).pathname\n    if (pathname === '/') {\n      wss.handleUpgrade(request, socket, head, (ws) => {\n        wss.emit('connection', ws, request)\n      })\n    } else {\n      socket.destroy()\n    }\n  })\n\n  const port = Number(process.env.PORT) || 3000\n  httpServer.listen(port, () => {\n    console.log(`> Ready on http://localhost:${port}`)\n  })\n})\n"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":113,"output":1705,"cacheRead":65913,"cacheWrite":4913,"totalTokens":72644,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776585598541,"responseId":"0633be7fd98afe67de6cb9cbcfa6ac13"}}
