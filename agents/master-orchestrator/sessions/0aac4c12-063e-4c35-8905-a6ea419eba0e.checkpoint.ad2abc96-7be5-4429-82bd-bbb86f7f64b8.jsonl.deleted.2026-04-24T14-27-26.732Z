{"type":"message","id":"277f3d44","parentId":"97d1557a","timestamp":"2026-04-19T04:42:39.080Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me create the ArticlesSort component.","thinkingSignature":"498199da2e7286a9e3b4c31291dcc4fca3344d4b7157f8b793b13f1841778afc"},{"type":"toolCall","id":"call_function_ild1wq8slomz_1","name":"write","arguments":{"path":"/root/.openclaw/workspaces2/v4-ecosystem-review/maiy-tech-hub/components/blog/articles-sort.tsx","content":"'use client'\n\nimport { useState, useMemo } from 'react'\nimport { ArrowUpDown } from 'lucide-react'\nimport type { ArticleSummary } from './article-card'\nimport { ArticleCard } from './article-card'\n\ninterface ArticlesSortProps {\n  articles: ArticleSummary[]\n}\n\nconst SORT_OPTIONS = [\n  { value: 'newest', label: 'Mới nhất' },\n  { value: 'oldest', label: 'Cũ nhất' },\n  { value: 'reading-time', label: 'Thời gian đọc' },\n  { value: 'a-z', label: 'A → Z' },\n] as const\n\nexport function ArticlesSort({ articles }: ArticlesSortProps) {\n  const [sort, setSort] = useState<string>('newest')\n\n  const sorted = useMemo(() => {\n    const copy = [...articles]\n    switch (sort) {\n      case 'newest':\n        return copy.sort(\n          (a, b) =>\n            new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime()\n        )\n      case 'oldest':\n        return copy.sort(\n          (a, b) =>\n            new Date(a.publishedAt).getTime() - new Date(b.publishedAt).getTime()\n        )\n      case 'reading-time':\n        return copy.sort((a, b) => a.readingTime - b.readingTime)\n      case 'a-z':\n        return copy.sort((a, b) => a.title.localeCompare(b.title))\n      default:\n        return copy\n    }\n  }, [articles, sort])\n\n  return (\n    <div>\n      {/* Sort controls */}\n      <div className=\"flex items-center justify-between mb-6\">\n        <p className=\"text-sm text-muted-foreground\">\n          {sorted.length} bài viết\n        </p>\n        <div className=\"flex items-center gap-2\">\n          <ArrowUpDown className=\"h-4 w-4 text-muted-foreground\" />\n          <select\n            value={sort}\n            onChange={(e) => setSort(e.target.value)}\n            className=\"text-sm bg-transparent border border-border rounded-md px-2 py-1 cursor-pointer focus:outline-none focus:ring-2 focus:ring-ring\"\n          >\n            {SORT_OPTIONS.map((opt) => (\n              <option key={opt.value} value={opt.value}>\n                {opt.label}\n              </option>\n            ))}\n          </select>\n        </div>\n      </div>\n\n      <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\">\n        {sorted.map((article) => (\n          <ArticleCard key={article.slug} article={article} />\n        ))}\n      </div>\n    </div>\n  )\n}\n"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":102,"output":673,"cacheRead":54049,"cacheWrite":1241,"totalTokens":56065,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776573750009,"responseId":"06339037ce847a408a27699107c6aef4"}}
