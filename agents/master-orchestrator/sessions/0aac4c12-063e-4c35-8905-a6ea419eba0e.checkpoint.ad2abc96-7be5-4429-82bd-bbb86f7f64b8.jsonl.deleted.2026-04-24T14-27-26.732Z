{"type":"message","id":"3c258175","parentId":"4649e8a1","timestamp":"2026-04-19T05:21:42.135Z","message":{"role":"toolResult","toolCallId":"call_function_dyrmtccdf244_1","toolName":"edit","content":[{"type":"text","text":"Successfully replaced 2 block(s) in /root/.openclaw/workspaces2/v4-ecosystem-review/maiy-tech-hub/components/blog/article-card.tsx."}],"details":{"diff":"     ...\n  19   variant?: 'default' | 'compact'\n  20   featured?: boolean\n  21 }\n  22 \n- 23 export function ArticleCard({ article, variant = 'default' }: ArticleCardProps) {\n+ 23 export function ArticleCard({ article, variant = 'default', featured = false }: ArticleCardProps) {\n  24   const cat = CATEGORIES.find((c) => c.slug === article.category)\n  25 \n  26   if (variant === 'compact') {\n  27     return (\n     ...\n  49 \n  50   return (\n  51     <Link\n  52       href={`/articles/${article.slug}`}\n- 53       className=\"group flex flex-col rounded-xl border border-border/40 overflow-hidden hover:border-primary/30 hover:shadow-md transition-all\"\n+ 53       className=\"group flex flex-col rounded-xl border border-border/40 overflow-hidden hover:border-primary/30 hover:shadow-md transition-all relative\"\n  54     >\n+ 55       {featured && (\n+ 56         <div className=\"absolute top-3 right-3 z-10\">\n+ 57           <span className=\"inline-flex items-center gap-1 px-2 py-1 rounded-full bg-amber-500/90 text-white text-xs font-semibold shadow-sm\">\n+ 58             <Star className=\"h-3 w-3 fill-white\" />\n+ 59             Nổi bật\n+ 60           </span>\n+ 61         </div>\n+ 62       )}\n  55       {article.hero && (\n  56         // eslint-disable-next-line @next/next/no-img-element\n  57         <img\n  58           src={article.hero}\n     ...","firstChangedLine":23},"isError":false,"timestamp":1776576102115}}
