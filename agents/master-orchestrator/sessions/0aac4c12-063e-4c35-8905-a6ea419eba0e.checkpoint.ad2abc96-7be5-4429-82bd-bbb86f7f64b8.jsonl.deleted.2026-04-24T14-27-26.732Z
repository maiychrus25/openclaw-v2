{"type":"message","id":"6b15d1cb","parentId":"e4c7f8ef","timestamp":"2026-04-19T07:39:21.648Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me update the Next.js custom server to handle WebSocket for WebRTC signaling. The server currently uses Socket.IO, but I need to add native WebSocket support for the new StudyRoom component.\n\nActually, looking at the server code, it uses Socket.IO. For the new StudyRoom, I'm using native WebSocket. I need to add native WebSocket support to the custom server.","thinkingSignature":"8c41879d378132a6b748730f9e25c0ebbbb81b5830506bb78e478c02833da3f4"},{"type":"text","text":"**Phase 6: Update server for native WebSocket:**\n"},{"type":"toolCall","id":"call_function_74z3595es20f_1","name":"read","arguments":{"path":"/root/.openclaw/workspaces2/v4-ecosystem-review/maiy-tech-hub/server/server.ts","limit":20}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":115,"output":149,"cacheRead":53196,"cacheWrite":303,"totalTokens":53763,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776584356661,"responseId":"0633b9a60778657f53fc94d21e7f0c2c"}}
{"type":"message","id":"7a1257da","parentId":"6b15d1cb","timestamp":"2026-04-19T07:39:21.662Z","message":{"role":"toolResult","toolCallId":"call_function_74z3595es20f_1","toolName":"read","content":[{"type":"text","text":"import { createServer } from 'http'\nimport { parse } from 'url'\nimport next from 'next'\nimport { Server as SocketIOServer } from 'socket.io'\n\nconst dev = process.env.NODE_ENV !== 'production'\nconst app = next({ dev })\nconst handle = app.getRequestHandler()\n\napp.prepare().then(() => {\n  const httpServer = createServer((req, res) => {\n    const parsedUrl = parse(req.url!, true)\n    handle(req, res, parsedUrl)\n  })\n\n  const io = new SocketIOServer(httpServer, {\n    cors: {\n      origin: process.env.NEXT_PUBLIC_SITE_URL || 'http://localhost:3000',\n      methods: ['GET', 'POST'],\n    },\n\n[50 more lines in file. Use offset=21 to continue.]"}],"isError":false,"timestamp":1776584361660}}
{"type":"message","id":"76b5cafa","parentId":"7a1257da","timestamp":"2026-04-19T07:39:37.371Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"I need to add native WebSocket support to the server. Let me add it.","thinkingSignature":"d191457ec3242819c8ca0161e57632aba764c73eaab472b18ba24af568cacedf"},{"type":"toolCall","id":"call_function_qmpo39ljaj47_1","name":"edit","arguments":{"path":"/root/.openclaw/workspaces2/v4-ecosystem-review/maiy-tech-hub/server/server.ts","edits":[{"oldText":"import { createServer } from 'http'\nimport { parse } from 'url'\nimport next from 'next'\nimport { Server as SocketIOServer } from 'socket.io'","newText":"import { createServer } from 'http'\nimport { parse } from 'url', WebSocketServer } from 'ws'\nimport next from 'next'\nimport { Server as SocketIOServer } from 'socket.io'\nimport { parse as parseQuery } from 'querystring'"},{"oldText":"  const io = new SocketIOServer(httpServer, {","newText":"  // Native WebSocket server for WebRTC signaling\n  const wss = new WebSocketServer({ noServer: true })\n\n  // Track rooms: roomId -> Map<ws, {username}>\n  const rooms = new Map<string, Map<WebSocket, { username: string }>>()\n  const wsToRoom = new Map<WebSocket, { roomId: string; username: string }>()\n\n  wss.on('connection', (ws, request) => {\n    const url = new URL(request.url || '', `http://${request.headers.host}`)\n    const roomId = url.searchParams.get('room') || 'default'\n    const username = url.searchParams.get('name') || 'Anonymous'\n\n    wsToRoom.set(ws, { roomId, username })\n\n    if (!rooms.has(roomId)) rooms.set(roomId, new Map())\n    rooms.get(roomId)!.set(ws, { username })\n\n    // Broadcast user-joined to existing participants\n    broadcast(ws, {\n      type: 'user-joined',\n      peerId: 'ws-' + Math.random().toString(36).slice(2),\n      username,\n    })\n\n    // Send current room users to the new participant\n    const existingUsers = Array.from(rooms.get(roomId)!.entries())\n      .filter(([w]) => w !== ws)\n      .map(([, data]) => data.username)\n    if (existingUsers.length > 0) {\n      ws.send(JSON.stringify({ type: 'room-users', users: existingUsers }))\n    }\n\n    ws.on('message', (data) => {\n      try {\n        const msg = JSON.parse(data.toString())\n        handleWSMessage(ws, msg)\n      } catch {}\n    })\n\n    ws.on('close', () => {\n      const info = wsToRoom.get(ws)\n      if (info) {\n        rooms.get(info.roomId)?.delete(ws)\n        broadcast(ws, { type: 'user-left', peerId: 'ws-' + Math.random().toString(36).slice(2), username: info.username })\n        wsToRoom.delete(ws)\n      }\n    })\n\n    ws.on('error', () => ws.close())\n  })\n\n  function broadcast(sender: WebSocket, msg: object) {\n    const info = wsToRoom.get(sender)\n    if (!info) return\n    const room = rooms.get(info.roomId)\n    if (!room) return\n    const payload = JSON.stringify(msg)\n    room.forEach((_, ws) => {\n      if (ws !== sender && ws.readyState === 1) {\n        ws.send(payload)\n      }\n    })\n  }\n\n  function handleWSMessage(ws: WebSocket, msg: any) {\n    const info = wsToRoom.get(ws)\n    if (!info) return\n    const room = rooms.get(info.roomId)\n    if (!room) return\n    const payload = JSON.stringify({ ...msg, from: info.username })\n    room.forEach((_, peer) => {\n      if (peer !== ws && peer.readyState === 1) {\n        peer.send(payload)\n      }\n    })\n  }\n\n  // Handle HTTP upgrade for WebSocket\n  httpServer.on('upgrade', (request, socket, head) => {\n    const pathname = new URL(request.url || '', `http://${request.headers.host}`).pathname\n    if (pathname === '/' || pathname.startsWith('/?')) {\n      wss.handleUpgrade(request, socket, head, (ws) => {\n        wss.emit('connection', ws, request)\n      })\n    } else {\n      socket.destroy()\n    }\n  })"}]}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":243,"output":1063,"cacheRead":53295,"cacheWrite":406,"totalTokens":55007,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776584361667,"responseId":"0633b9abdae5208ab31f3319a8925fd8"}}
