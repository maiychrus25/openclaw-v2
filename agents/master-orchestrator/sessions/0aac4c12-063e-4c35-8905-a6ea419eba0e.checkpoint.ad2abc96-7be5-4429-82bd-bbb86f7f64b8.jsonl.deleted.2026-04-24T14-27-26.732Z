er:bg-accent transition-colors font-medium\"\n        >\n          <Search className=\"h-4 w-4\" /> Tìm kiếm\n        </Link>\n      </div>\n      <div className=\"flex items-center gap-2 text-sm text-muted-foreground\">\n        <FileQuestion className=\"h-4 w-4\" />\n        Bạn có thể tìm thấy thông tin hữu ích ở trang chủ hoặc tìm kiếm bài viết.\n      </div>\n    </div>\n  )\n}\n"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":112,"output":617,"cacheRead":143777,"cacheWrite":4028,"totalTokens":148534,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776576685473,"responseId":"06339bafd505672ed847ebd2af956655"}}
