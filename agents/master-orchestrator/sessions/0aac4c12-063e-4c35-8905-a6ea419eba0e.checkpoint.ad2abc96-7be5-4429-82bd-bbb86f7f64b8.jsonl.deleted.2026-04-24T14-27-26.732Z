{"type":"message","id":"4b4962b6","parentId":"8686f0ff","timestamp":"2026-04-19T08:30:54.365Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me update the article page to use rehype-highlight instead of shiki. This will be simpler and build correctly.","thinkingSignature":"109e8e4dfd4dbcf4543b8fc85f7a7170ae23bb0c35e3709ec9d65a1eb99cd0dc"},{"type":"toolCall","id":"call_function_h02da5rwnjhg_1","name":"write","arguments":{"path":"/root/.openclaw/workspaces2/v4-ecosystem-review/maiy-tech-hub/app/articles/[slug]/page.tsx","content":"import { notFound } from 'next/navigation'\nimport Link from 'next/link'\nimport { Clock, Calendar, ArrowLeft, BookOpen } from 'lucide-react'\nimport { compileMDX } from 'next-mdx-remote/rsc'\nimport remarkGfm from 'remark-gfm'\nimport rehypeSlug from 'rehype-slug'\nimport rehypeAutolinkHeadings from 'rehype-autolink-headings'\nimport rehypeHighlight from 'rehype-highlight'\nimport { getArticleBySlug, getAllSlugs, getArticlesByCategory } from '@/lib/content'\nimport { ArticleCard } from '@/components/blog/article-card'\nimport { Breadcrumbs } from '@/components/seo/breadcrumbs'\nimport { ArticleSchema } from '@/components/seo/article-schema'\nimport { ReadingProgress } from '@/components/blog/reading-progress'\nimport { SocialShare } from '@/components/blog/social-share'\nimport { TableOfContents } from '@/components/blog/toc'\nimport { TrackerWrapper } from '@/components/blog/tracker-wrapper'\n\nexport const dynamic = 'force-static'\n\ninterface Props {\n  params: { slug: string }\n}\n\nexport async function generateStaticParams() {\n  const slugs = await getAllSlugs()\n  return slugs.map((slug) => ({ slug }))\n}\n\nexport async function generateMetadata({ params }: Props) {\n  const article = await getArticleBySlug(params.slug)\n  if (!article) return { title: 'Không tìm thấy' }\n  return {\n    title: article.title,\n    description: article.excerpt,\n    openGraph: {\n      type: 'article',\n      title: article.title,\n      description: article.excerpt,\n      images: article.hero ? [{ url: article.hero }] : [],\n      publishedTime: article.publishedAt,\n    },\n  }\n}\n\n// ── MDX components ───────────────────────────────────────────────────────────\nconst mdxComponents = {\n  // Inline code\n  code: ({ children, className, ...p }: any) => {\n    if (className) return <>{children}</>\n    return (\n      <code className=\"px-1.5 py-0.5 rounded bg-muted text-sm font-mono text-primary/90\">\n        {children}\n      </code>\n    )\n  },\n  a: ({ children, href, ...p }: any) => (\n    <a\n      href={href}\n      className=\"text-primary underline-offset-4 hover:underline\"\n      target={href?.startsWith('http') ? '_blank' : undefined}\n      rel={href?.startsWith('http') ? 'noopener noreferrer' : undefined}\n      {...p}\n    >\n      {children}\n    </a>\n  ),\n  h2: ({ children, id, ...p }: any) => (\n    <h2 id={id} className=\"scroll-mt-24 font-bold text-2xl mt-10 mb-4\" {...p}>\n      {children}\n    </h2>\n  ),\n  h3: ({ children, id, ...p }: any) => (\n    <h3 id={id} className=\"scroll-mt-24 font-bold text-xl mt-8 mb-3\" {...p}>\n      {children}\n    </h3>\n  ),\n  table: ({ children, ...p }: any) => (\n    <div className=\"overflow-x-auto my-6\">\n      <table className=\"w-full border-collapse border border-border text-sm\" {...p}>\n        {children}\n      </table>\n    </div>\n  ),\n  th: ({ children, ...p }: any) => (\n    <th className=\"border border-border bg-muted px-4 py-2 text-left font-semibold\" {...p}>\n      {children}\n    </th>\n  ),\n  td: ({ children, ...p }: any) => (\n    <td className=\"border border-border px-4 py-2\" {...p}>\n      {children}\n    </td>\n  ),\n}\n\nexport default async function ArticlePage({ params }: Props) {\n  const article = await getArticleBySlug(params.slug)\n  if (!article) notFound()\n\n  const related = (await getArticlesByCategory(article.category))\n    .filter((a) => a.slug !== params.slug)\n    .slice(0, 3)\n\n  const publishDate = new Date(article.publishedAt).toLocaleDateString('vi-VN', {\n    day: 'numeric',\n    month: 'long',\n    year: 'numeric',\n  })\n\n  const { content } = await compileMDX({\n    source: article.content,\n    options: {\n      mdxOptions: {\n        remarkPlugins: [remarkGfm],\n        rehypePlugins: [\n          rehypeSlug,\n          [rehypeAutolinkHeadings, { behavior: 'wrap' }],\n          rehypeHighlight,\n        ],\n      },\n    },\n    components: mdxComponents,\n  })\n\n  return (\n    <>\n      <TrackerWrapper slug={params.slug} />\n      <ArticleSchema article={article} />\n      <ReadingProgress />\n\n      <div className=\"container py-8\">\n        <Breadcrumbs\n          items={[\n            { label: 'Trang chủ', href: '/' },\n            { label: 'Bài viết', href: '/articles' },\n            { label: article.category, href: `/articles/category/${article.category}` },\n            { label: article.title },\n          ]}\n        />\n\n        <div className=\"flex gap-12 max-w-5xl mx-auto\">\n          <article className=\"flex-1 min-w-0\" data-article-content>\n            {/* Back */}\n            <Link\n              href=\"/articles\"\n              className=\"inline-flex items-center gap-1 text-sm text-muted-foreground hover:text-primary mb-6 transition-colors\"\n            >\n              <ArrowLeft className=\"h-4 w-4\" /> Quay lại bài viết\n            </Link>\n\n            {/* Header */}\n            <header className=\"mb-8\">\n              <div className=\"flex items-center gap-3 mb-4\">\n                <span className=\"px-3 py-1 text-xs font-medium rounded-full bg-primary/10 text-primary\">\n                  {article.category}\n                </span>\n                <span className=\"flex items-center gap-1 text-sm text-muted-foreground\">\n                  <Clock className=\"h-4 w-4\" />\n                  {article.readingTime} phút đọc\n                </span>\n              </div>\n\n              <h1 className=\"text-3xl md:text-4xl font-bold tracking-tight mb-4\">\n                {article.title}\n              </h1>\n\n              <p className=\"text-lg text-muted-foreground mb-6\">{article.excerpt}</p>\n\n              <div className=\"flex items-center gap-4 text-sm text-muted-foreground border-y border-border/40 py-3\">\n                <span className=\"flex items-center gap-1.5\">\n                  <BookOpen className=\"h-4 w-4\" />\n                  {article.author}\n                </span>\n                <span className=\"flex items-center gap-1.5\">\n                  <Calendar className=\"h-4 w-4\" />\n                  {publishDate}\n                </span>\n                <div className=\"ml-auto\">\n                  <SocialShare title={article.title} />\n                </div>\n              </div>\n            </header>\n\n            {/* Hero */}\n            {article.hero && (\n              // eslint-disable-next-line @next/next/no-img-element\n              <img\n                src={article.hero}\n                alt={article.title}\n                className=\"w-full rounded-xl mb-8 aspect-video object-cover\"\n              />\n            )}\n\n            {/* Tags */}\n            {article.tags.length > 0 && (\n              <div className=\"flex flex-wrap gap-2 mb-8\">\n                {article.tags.map((tag) => (\n                  <Link\n                    key={tag}\n                    href={`/search?q=${tag}`}\n                    className=\"px-3 py-1 text-xs rounded-full border border-border hover:border-primary/50 hover:bg-primary/5 transition-all\"\n                  >\n                    #{tag}\n                  </Link>\n                ))}\n              </div>\n            )}\n\n            {/* MDX Content */}\n            <div className=\"prose-custom\">{content}</div>\n\n            {/* Share */}\n            <div className=\"mt-12 pt-8 border-t border-border/40 flex items-center justify-between\">\n              <p className=\"text-sm text-muted-foreground\">\n                Nếu thấy hữu ích, hãy chia sẻ bài viết này nhé!\n              </p>\n              <SocialShare title={article.title} />\n            </div>\n          </article>\n\n          {/* TOC */}\n          <aside className=\"hidden xl:block w-56 flex-shrink-0\">\n            <div className=\"sticky top-24\">\n              <TableOfContents />\n            </div>\n          </aside>\n        </div>\n\n        {related.length > 0 && (\n          <section className=\"max-w-3xl mx-auto mt-16\">\n            <h2 className=\"text-xl font-bold mb-6\">Bài viết liên quan</h2>\n            <div className=\"grid grid-cols-1 md:grid-cols-3 gap-4\">\n              {related.map((a) => (\n                <ArticleCard key={a.slug} article={a} />\n              ))}\n            </div>\n          </section>\n        )}\n      </div>\n    </>\n  )\n}\n"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":102,"output":2112,"cacheRead":108552,"cacheWrite":630,"totalTokens":111396,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776587432959,"responseId":"0633c5aa2074eb528535ff370a72b747"}}
