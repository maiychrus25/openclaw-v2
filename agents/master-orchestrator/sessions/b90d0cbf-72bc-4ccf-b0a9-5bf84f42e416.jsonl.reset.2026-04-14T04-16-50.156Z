print(f\"✅ {method} {path}: {status} | items: {len(d['docs'])}, meta: {d['meta'].get('totalItems', 'N/A')}\")\n            elif \"doc\" in d: print(f\"✅ {method} {path}: {status} | single item\")\n            else: print(f\"✅ {method} {path}: {status} | keys: {list(d.keys())}\")\n        else:\n            print(f\"✅ {method} {path}: {status} | {str(rd)[:60]}\")\n    except urllib.error.HTTPError as e:\n        body = e.read().decode()[:100]\n        print(f\"❌ {method} {path}: {e.code} → {body}\")\n    except Exception as ex:\n        print(f\"❌ {method} {path}: {ex}\")\nPYEOF"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":358,"output":630,"cacheRead":88056,"cacheWrite":200,"totalTokens":89244,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776138271888,"responseId":"062ceb219b5a7f31c223901718131280"}}
