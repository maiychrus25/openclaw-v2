);\nconst express_1 = require(\"express\");\nconst authMiddleware = __importStar(require(\"../../../middlewares/auth.middleware\"));\nconst notification_dispatcher_1 = require(\"../../../common/notifications/notification.dispatcher\");\nconst users_route_1 = __importDefault(require(\"../../../modules/users/users.route\"));\nconst userRoles_route_1 = __importDefault(require(\"../../../modules/userRoles/userRoles.route\"));\nconst roles_route_1 = __importDefault(require(\"../../../modules/roles/roles.route\"));\nconst logTasks_route_1 = __importDefault(require(\"../../../modules/logTasks/logTasks.route\"));\nconst agents_route_1 = __importDefault(require(\"../../../modules/agents/agents.route\"));\nconst router = (0, express_1.Router)();\nrouter.use('/users', authMiddleware.checkPermissions, notification_dispatcher_1.listenNotify, users_route_1.default);\nrouter.use('/roles', notification_dispatcher_1.listenNotify, roles_route_1.default);\nrouter.use('/user-role', notification_dispatcher_1.listenNotify, userRoles_route_1.default);\nrouter.use('/agents', notification_dispatcher_1.listenNotify, agents_route_1.default);\nrouter.use('/log-tasks', authMiddleware.checkPermissions, logTasks_route_1.default);\nexports.default = router;\n//# sourceMappingURL=system.route.js.map","cwd":"/root/.openclaw/workspaces2/v4-ecosystem-review/master-orchestrator"},"isError":false,"timestamp":1776138561378}}
