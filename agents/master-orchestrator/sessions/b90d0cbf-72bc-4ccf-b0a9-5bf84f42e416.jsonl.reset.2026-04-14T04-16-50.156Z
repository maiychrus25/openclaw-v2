el } from '@/infrastructure/database/models/notification.model'; // @deprecated — only used during transition. Use NotifyUser/Notify/NotifyContent instead.\n import { ExamScheduleModel } from '@/infrastructure/database/models/exam_schedule.model';\n import { catchAsync } from '@/interface/middlewares/catchAsync.middleware';\n+import { ctrlLogger } from '@/infrastructure/logging/controller-logger';\n--\n   const countsMap: Record<string, number> = { total: totalStudents, tuitionDebt: tuitionDebtCount };\n   statusCounts.forEach(item => { if (item._id) countsMap[item._id] = item.count; });\n \n-  // 11. Unread notification count & recent\n+  // 11. Unread notification count & recent (from 4-collection model)\n   const userId = (req.user as any)?.id || (req.user as any)?._id;\n-  const unreadNotificationCount = await NotificationModel.countDocuments({ \n-    receive_id: userId,\n--\n+  // JOIN NotifyUser → Notify → NotifyContent for recent notifications\n+  const recentNotifications = await (async () => {\n+    if (recentRows.length === 0) return [];\n+    const notifyIds = recentRows.map((r) => r.notify_id);\n--\n     counts: countsMap,\n@@ -281,4 +321,5 @@ export const getDashboardStats = catchAsync(async (req: Request, res: Response)\n     regionStats,\n     recruiterStats\n--\n+  log.success(res, { counts: countsMap, totalDebtAmount, monthlyGrowthPercent, thisMonthCount, weeklyExamCount }, 'Dashboard statistics retrieved successfully');\n });","cwd":"/root/.openclaw/workspaces2/v4-ecosystem-review/master-orchestrator"},"isError":false,"timestamp":1776002590898}}
