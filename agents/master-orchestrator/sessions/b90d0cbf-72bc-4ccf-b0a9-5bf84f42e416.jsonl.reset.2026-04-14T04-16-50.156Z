;\nconst adminUser = db.users.findOne({ username: 'admin2' });\ndb.userroles.deleteMany({ user_id: adminUser._id });\ndb.userroles.insertOne({ user_id: adminUser._id, role_id: adminRole._id, created_at: new Date(), updated_at: new Date() });\n\nprint('User:', adminUser.username, '| Roles:', db.userroles.countDocuments());\n\" 2>/dev/null"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":388,"output":564,"cacheRead":83691,"cacheWrite":251,"totalTokens":84894,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776139853038,"responseId":"062cf14e4ad41bebe8761c6a43249832"}}
