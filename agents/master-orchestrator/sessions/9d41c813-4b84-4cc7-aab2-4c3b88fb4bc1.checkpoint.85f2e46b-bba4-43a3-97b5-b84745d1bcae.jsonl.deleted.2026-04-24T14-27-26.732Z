{"type":"message","id":"bca9e040","parentId":"4091e08e","timestamp":"2026-04-15T20:48:12.849Z","message":{"role":"toolResult","toolCallId":"call_function_jaolwfzdzh7x_1","toolName":"exec","content":[{"type":"text","text":"import { apiClient } from './api';\n\nexport interface Announcement {\n  id: string;\n  title: string;\n  content: string;\n  target_group: string;\n  channels: string[];\n  status: 'SENT' | 'SCHEDULED';\n  scheduled_at?: string;\n  createdAt: string;\n  updatedAt: string;\n}\n\nexport interface AnnouncementResponse {\n  success: boolean;\n  message: string;\n  data: {\n    data: Announcement[];\n    meta: {\n      total: number;\n      page: number;\n      limit: number;\n      total_pages: number;\n    };\n    stats: {\n      total_recipients: number;\n      total_sent: number;\n      total_scheduled: number;\n    };\n  };\n}\n\nexport const getAnnouncements = async (params: { \n  page?: number; \n  limit?: number; \n  status?: string; \n  target_group?: string;\n  search?: string;\n} = {}) => {\n  const query = new URLSearchParams();\n  if (params.page) query.append('page', params.page.toString());\n  if (params.limit) query.append('limit', params.limit.toString());\n  if (params.status && params.status !== 'Tất cả trạng thái') {\n    const statusMap: Record<string, string> = {\n      'Đã gửi': 'SENT',\n      'Chờ gửi': 'SCHEDULED'\n    };\n    query.append('status', statusMap[params.status] || params.status);\n  }\n  if (params.target_group) query.append('target_group', params.target_group);\n  if (params.search) query.append('search', params.search);\n\n  return apiClient<AnnouncementResponse>(`/announcements?${query.toString()}`);\n};\n\nexport const createAnnouncement = async (data: Partial<Announcement>) => {\n  return apiClient<{ success: boolean; data: Announcement }>('/announcements', {\n    method: 'POST',\n    body: JSON.stringify(data),\n  });\n};\n\nexport const updateAnnouncement = async (id: string, data: Partial<Announcement>) => 