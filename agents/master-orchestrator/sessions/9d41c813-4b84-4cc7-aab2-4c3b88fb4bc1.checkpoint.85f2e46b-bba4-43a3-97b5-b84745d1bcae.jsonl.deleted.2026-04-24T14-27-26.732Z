ent\n=== payment.controller ===\n  Functions: getAllPayments,getPaymentsByStudent,getPaymentStats,createPayment,updatePayment,deletePayment,exportPayments,exportPremiumPayments\n=== settings.controller ===\n  Functions: getSettings,updateSettings\n=== stadium.controller ===\n  Functions: \n=== student.controller ===\n  Functions: createStudent,getAllStudents,getStudentById,updateStudent,deleteStudent,getStudentHistory,getLicenseCategories,exportStudents,importStudents,downloadTemplate\n=== vip_qr.controller ===\n  Functions: configureVipQr,getVipQr"}],"details":{"status":"completed","exitCode":0,"durationMs":209,"aggregated":"=== announcement.controller ===\n  Functions: \n=== auth.controller ===\n  Functions: register,login,refreshToken,getMe,updateMe,changePassword,logout,getLoginHistory\n=== city.controller ===\n  Functions: getAllCities,createCity,updateCity,deleteCity\n=== course.controller ===\n  Functions: getAllCourses,getCourseById,createCourse,updateCourse,deleteCourse,exportCourses,getUnassignedStudents,assignStudents,getStats,importFromExcel,getTemplate\n=== dashboard.controller ===\n  Functions: getDashboardStats\n=== dat.controller ===\n  Functions: getDatAnalytics,addDatSession,getStudentDatSessions\n=== data.controller ===\n  Functions: exportAllData,importAllData\n=== exam.controller ===\n  Functions: getAllExams,getExamById,createExam,updateExam,getExamStudents,deleteExam,removeStudentFromExam,updateStudentResult,getExamsByStudent,exportExams\n=== exam_batch.controller ===\n  Functions: createBatch,getAllBatches,getBatchById,updateBatch,deleteBatch,exportBatches\n=== exam_schedule.controller ===\n  Functions: createExamSchedule,getExamSchedules,getById,getByExam,updateExamSchedule,deleteExamSchedule\n=== lesson.controller ===\n  Functions: createLesson,getLessons,getLessonById,getByTeacher,getByStudent,updateLesson,deleteLesson\n=== license-category.controller ===\n  Functions: getAll,create,update,remove\n=== license_category.controller ===\n  Fun