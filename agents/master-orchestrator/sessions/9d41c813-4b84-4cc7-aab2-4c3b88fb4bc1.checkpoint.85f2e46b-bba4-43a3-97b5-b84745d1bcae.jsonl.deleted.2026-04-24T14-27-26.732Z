{"type":"message","id":"c70ed42f","parentId":"f99a2e02","timestamp":"2026-04-16T03:12:58.519Z","message":{"role":"toolResult","toolCallId":"call_function_0ey0q6a0bup8_1","toolName":"exec","content":[{"type":"text","text":"import mongoose from 'mongoose';\nimport dotenv from 'dotenv';\nimport bcrypt from 'bcrypt';\nimport { UserModel as User } from '../infrastructure/database/models/user.model';\nimport { RoleModel as Role } from '../infrastructure/database/models/role.model';\nimport { UserRoleModel as UserRole } from '../infrastructure/database/models/user_role.model';\nimport connectDB from '../infrastructure/database/mongodb';\nimport path from 'path';\n\ndotenv.config();\n\nasync function seedUsers() {\n  await connectDB();\n\n  // 1. Ensure Roles exist\n  const roleNames = ['admin', 'staff', 'teacher', 'student'];\n  const rolesMap: Record<string, any> = {};\n\n  for (const name of roleNames) {\n    let role = await Role.findOne({ role_name: name });\n    if (!role) {\n      role = await Role.create({ role_name: name });\n      console.log(`✅ Role ${name} created`);\n    }\n    rolesMap[name] = role;\n  }\n\n  // 2. Create Admin\n  const adminUsername = 'admin';\n  let admin = await User.findOne({ username: adminUsername });\n  if (!admin) {\n    const hashedPassword = await bcrypt.hash('password123', 10);\n    admin = await User.create({\n      username: adminUsername,\n      password: hashedPassword,\n      first_name: 'System',\n      last_name: 'Admin',\n      email: 'admin@example.com',\n      phone: '0987654321',\n      address: 'Hệ thống',\n      identity_card: '123456789',\n      gender: 'male',\n      status: 'active'\n    });\n    console.log('✅ Admin user created');\n  }\n\n  // 3. Create Teacher\n  const teacherUsername = 'teacher1';\n  let teacher = await User.findOne({ username: teacherUsername });\n  if (!teacher) {\n    const hashedPassword = await bcrypt.hash('password123', 10);\n    teacher = await User.create({\n      username: teacherUsername,\n      password: hashedPassword,\n      first_name: 'Thầy',\n      last_name: 'Giáo 01',\n      email: 'teacher1@example.com',\n      phone: '0123456789',\n      address: 'Hệ thống',\n      identity_card: '987654321',\n      gender: 'male',\n      status: 'active'\n    });\n    console.log('✅ Teacher user created');\n  }\n\n  // 4. Assign Roles\n  const userRoles = [\n    { user: admin, role: rolesMap['admin'] },\n    { user: teacher, role: rolesMap['teacher'] }\n  ];\n\n  for (const ur of userRoles) {\n    const existing = await UserRole.findOne({ user_id: ur.user._id, role_id: ur.role._id });\n    if (!existing) {\n      await UserRole.create({ user_id: ur.user._id, role_id: ur.role._id });\n      console.log(`✅ Role ${ur.role.role_name} assigned to ${ur.user.username}`);\n    }\n  }\n\n  await mongoose.disconnect();\n  console.log('✅ Seeding complete');\n}\n\nseedUsers().catch(console.error);"}],"details":{"status":"completed","exitCode":0,"durationMs":18,"aggregated":"import mongoose from 'mongoose';\nimport dotenv from 'dotenv';\nimport bcrypt from 'bcrypt';\nimport { UserModel as User } from '../infrastructure/database/models/user.model';\nimport { RoleModel as Role } from '../infrastructure/database/models/role.model';\nimport { UserRoleModel as UserRole } from '../infrastructure/database/models/user_role.model';\nimport connectDB from '../infrastructure/database/mongodb';\nimport path from 'path';\n\ndotenv.config();\n\nasync function seedUsers() {\n  await connectDB();\n\n  // 1. Ensure Roles exist\n  const roleNames = ['admin', 'staff', 'teacher', 'student'];\n  const rolesMap: Record<string, any> = {};\n\n  for (const name of roleNames) {\n    let role = await Role.findOne({ role_name: name });\n    if (!role) {\n      role = await Role.create({ role_name: name });\n      console.log(`✅ Role ${name} created`);\n    }\n    rolesMap[name] = role;\n  }\n\n  // 2. Create Admin\n  const adminUsername = 'admin';\n  let admin = await User.findOne({ username: adminUsername });\n  if (!admin) {\n    const hashedPassword = await bcrypt.hash('password123', 10);\n    admin = await User.create({\n      username: adminUsername,\n      password: hashedPassword,\n      first_name: 'System',\n      last_name: 'Admin',\n      email: 'admin@example.com',\n      phone: '0987654321',\n      address: 'Hệ thống',\n      identity_card: '123456789',\n      gender: 'male',\n      status: 'active'\n    });\n    console.log('✅ Admin user created');\n  }\n\n  // 3. Create Teacher\n  const teacherUsername = 'teacher1';\n  let teacher = await User.findOne({ username: teacherUsername });\n  if (!teacher) {\n    const hashedPassword = await bcrypt.hash('password123', 10);\n    teacher = await User.create({\n      username: teacherUsername,\n      password: hashedPassword,\n      first_name: 'Thầy',\n      last_name: 'Giáo 01',\n      email: 'teacher1@example.com',\n      phone: '0123456789',\n      address: 'Hệ thống',\n      identity_card: '987654321',\n      gender: 'male',\n      status: 'active'\n    });\n    console.log('✅ Teacher user created');\n  }\n\n  // 4. Assign Roles\n  const userRoles = [\n    { user: admin, role: rolesMap['admin'] },\n    { user: teacher, role: rolesMap['teacher'] }\n  ];\n\n  for (const ur of userRoles) {\n    const existing = await UserRole.findOne({ user_id: ur.user._id, role_id: ur.role._id });\n    if (!existing) {\n      await UserRole.create({ user_id: ur.user._id, role_id: ur.role._id });\n      console.log(`✅ Role ${ur.role.role_name} assigned to ${ur.user.username}`);\n    }\n  }\n\n  await mongoose.disconnect();\n  console.log('✅ Seeding complete');\n}\n\nseedUsers().catch(console.error);","cwd":"/root/.openclaw/workspaces2/v4-ecosystem-review/master-orchestrator"},"isError":false,"timestamp":1776309178492}}
