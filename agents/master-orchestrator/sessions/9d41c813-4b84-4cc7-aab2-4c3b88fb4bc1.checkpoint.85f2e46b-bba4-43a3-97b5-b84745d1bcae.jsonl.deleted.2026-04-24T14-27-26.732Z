{"type":"message","id":"b145fa8a","parentId":"a98490d5","timestamp":"2026-04-15T20:47:45.114Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Let me check the notification pages to see if they support channel selection (SMS, Zalo, FCM).","thinkingSignature":"5ab0209594865869b82314fdba567740723a8d32a5cfb426db6fb615cadca715"},{"type":"toolCall","id":"call_function_or8mci84kcyb_1","name":"exec","arguments":{"command":"cat /root/.openclaw/workspaces/teacher-driving-training-system.bootstrap-backup/ahv-qlhv-fe/src/app/notifications/page.tsx"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":149,"output":77,"cacheRead":81114,"cacheWrite":457,"totalTokens":81797,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776286060759,"responseId":"062f2c6ea89b5a37b762ae11692f1dc7"}}
{"type":"message","id":"ad510573","parentId":"b145fa8a","timestamp":"2026-04-15T20:47:45.194Z","message":{"role":"toolResult","toolCallId":"call_function_or8mci84kcyb_1","toolName":"exec","content":[{"type":"text","text":"'use client';\n\nimport React, { useState, useEffect, useMemo } from 'react';\nimport { \n  Bell, FileBadge, Wallet, Clock as ClockIcon, \n  CheckCircle2, AlertCircle, Filter, Trash2, Shield,\n  AlertTriangle, Settings\n} from 'lucide-react';\nimport { useRouter } from 'next/navigation';\nimport { getDashboardStats } from '@/src/services/dashboardService';\nimport { getNotifications, markAsRead, markAllNotificationsAsRead, Notification } from '@/src/services/notificationService';\nimport { useAuth } from '@/src/context/AuthContext';\nimport { toast } from 'sonner';\n\ntype CombinedItem = {\n  id: string;\n  source: 'database' | 'logic';\n  type: string;\n  title: string;\n  subTitle: string;\n  value?: string;\n  is_read: boolean;\n  created_at: string;\n  badge?: string;\n};\n\nexport default function NotificationsPage() {\n  const router = useRouter();\n  const { user } = useAuth();\n  const [dbNotifications, setDbNotifications] = useState<Notification[]>([]);\n  const [urgentTasks, setUrgentTasks] = useState<any[]>([]);\n  const [loading, setLoading] = useState(true);\n  const [activeTab, setActiveTab] = useState<'all' | 'urgent' | 'system'>('all');\n\n  const fetchData = async () => {\n    if (!user?.id) return;\n    setLoading(true);\n    try {\n      const [statsRes, notifyRes] = await Promise.all([\n        getDashboardStats(),\n        getNotifications(user.id, 1, 50)\n      ]);\n\n      if (statsRes.success && statsRes.data?.urgentTasks) {\n        setUrgentTasks(statsRes.data.urgentTasks);\n      }\n      \n      if (notifyRes.success && notifyRes.data?.data) {\n        setDbNotifications(notifyRes.data.data);\n      }\n    } catch (error) {\n      console.error('Failed to fetch notifications:', error);\n      toast.error('Không thể tải thông báo');\n    } finally {\n      setLoading(false);\n    }\n  };\n\n  useEffect(() => {\n    fetchData();\n  }, [user?.id]);\n\n  const items: CombinedItem[] = useMemo(() => {\n    const combined: CombinedItem[] = [];\n\n    // Map urgent tasks (source: logic)\n    urgentTasks.forEach((task, idx) => {\n      combined.push({\n        id: `tasks-${idx}`,\n        source: 'logic',\n        type: task.type,\n        title: task.title,\n        subTitle: task.subTitle,\n        value: task.value,\n        is_read: false,\n        created_at: new Date().toISOString(), // Tasks are fresh calc\n        badge: task.badge\n      });\n    });\n\n    // Map real notifications (source: database)\n    dbNotifications.forEach((n) => {\n      combined.push({\n        id: n.id || n._id,\n        source: 'database',\n        type: (n.category === 'system' || n.receive_type === 'teacher' || (n as any).targetGroup) ? 'system' : 'notif',\n        title: n.title,\n        subTitle: (n as any).content || n.body,\n        is_read: n.is_read || n.status === 'read',\n        created_at: n.created_at || (n as any).createdAt,\n      });\n    });\n\n    // Sort by date (Tasks first, then most recent notifications)\n    return combined.sort((a, b) => new Date(b.created_at).getTime() - new Date(a.created_at).getTime());\n  }, [urgentTasks, dbNotifications]);\n\n  const filteredItems = useMemo(() => {\n    if (activeTab === 'urgent') return items.filter(i => i.source === 'logic');\n    if (activeTab === 'system') return items.filter(i => (i.source === 'database' && i.type === 'system'));\n    return items;\n  }, [items, activeTab]);\n\n  const getIcon = (type: string) => {\n    switch (type) {\n      case 'debt': return <Wallet className=\"w-5 h-5 text-rose-600\" />;\n      case 'exam': return <FileBadge className=\"w-5 h-5 text-indigo-600\" />;\n      case 'dat': return <ClockIcon className=\"w-5 h-5 text-amber-600\" />;\n      case 'system': return <Settings className=\"w-5 h-5 text-blue-600\" />;\n      default: return <Bell className=\"w-5 h-5 text-emerald-600\" />;\n    }\n  };\n\n  const getBgColor = (type: string) => {\n    switch (type) {\n      case 'debt': return 'bg-rose-50 border-rose-100';\n      case 'exam': return 'bg-indigo-50 border-indigo-100';\n      case 'dat': return 'bg-amber-50 border-amber-100';\n      case 'system': return 'bg-blue-50 border-blue-100';\n      default: return 'bg-emerald-50 border-emerald-100';\n    }\n  };\n\n  const handleMarkAllRead = async () => {\n    if (!user?.id) return;\n    try {\n      await markAllNotificationsAsRead(user.id);\n      fetchData();\n      toast.success('Đã đánh dấu tất cả là đã đọc!');\n    } catch (e) {\n      toast.error('Thao tác thất bại');\n    }\n  };\n\n  const handleItemClick = async (item: CombinedItem) => {\n    if (item.source === 'database' && !item.is_read) {\n      await markAsRead(item.id, user?.id);\n      fetchData();\n    }\n    \n    toast.info(`Điều hướng xử lý: ${item.title}`);\n    if (item.type === 'debt') router.push('/tuition');\n    if (item.type === 'exam') router.push('/schedules');\n  };\n\n  return (\n    <div className=\"flex flex-col gap-6 animate-in fade-in slide-in-from-bottom-2 duration-700 pb-20 max-w-5xl mx-auto\">\n      \n      {/* Header */}\n      <div className=\"flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4\">\n        <div>\n          <div className=\"flex items-center gap-3\">\n            <div className=\"w-10 h-10 bg-indigo-600 rounded-xl flex items-center justify-center text-white shadow-lg shadow-indigo-600/20\">\n              <Bell className=\"w-5 h-5\" />\n            </div>\n            <h2 className=\"text-3xl font-extrabold text-gray-900 tracking-tight leading-tight uppercase\">Thông báo</h2>\n          </div>\n          <p className=\"text-gray-500 font-medium text-sm mt-2 uppercase tracking-widest text-[10px]\">Trung tâm quản lý thông báo và công việc</p>\n        </div>\n        <div className=\"flex gap-2\">\n          <button \n            onClick={fetchData}\n            className=\"p-2.5 bg-white border border-gray-200 text-gray-500 rounded-xl hover:bg-gray-50 transition-all\"\n          >\n            <ClockIcon className=\"w-4 h-4\" />\n          </button>\n          <button \n            onClick={handleMarkAllRead}\n            className=\"flex items-center gap-2 px-5 py-2.5 bg-gray-900 border border-gray-800 text-white font-bold rounded-xl hover:bg-gray-800 transition-all active:scale-95 text-xs uppercase tracking-widest shadow-lg shadow-gray-900/20\"\n          >\n            <CheckCircle2 className=\"w-4 h-4\" /> Đọc tất cả\n          </button>\n        </div>\n      </div>\n\n      {/* Tabs & Filters */}\n      <div className=\"bg-white border border-gray-100 rounded-2xl shadow-sm p-4 flex flex-wrap items-center justify-between gap-4\">\n        <div className=\"flex items-center gap-2\">\n          <button\n            onClick={() => setActiveTab('all')}\n            className={`px-4 py-2 rounded-xl text-xs font-black uppercase tracking-widest transition-all ${\n              activeTab === 'all' ? 'bg-indigo-600 text-white shadow-md shadow-indigo-600/20' : 'text-gray-500 hover:bg-gray-50'\n            }`}\n          >\n            Tất cả ({items.length})\n          </button>\n          <button\n            onClick={() => setActiveTab('urgent')}\n            className={`px-4 py-2 rounded-xl text-xs font-black uppercase tracking-widest transition-all ${\n              activeTab === 'urgent' ? 'bg-rose-600 text-white shadow-md shadow-rose-600/20' : 'text-gray-500 hover:bg-gray-50'\n            }`}\n          >\n            Công việc khẩn ({urgentTasks.length})\n          </button>\n          <button\n            onClick={() => setActiveTab('system')}\n            className={`px-4 py-2 rounded-xl text-xs font-black uppercase tracking-widest transition-all ${\n              activeTab === 'system' ? 'bg-emerald-600 text-white shadow-md shadow-emerald-600/20' : 'text-gray-500 hover:bg-gray-50'\n            }`}\n          >\n            Hệ thống ({items.filter(i => i.source === 'database' && i.type === 'system').length})\n          </button>\n        </div>\n        <button className=\"p-2 text-gray-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-lg transition-all\">\n          <Filter className=\"w-5 h-5\" />\n        </button>\n      </div>\n\n      {/* List */}\n      <div className=\"bg-white border border-gray-100 rounded-2xl shadow-sm overflow-hidden min-h-[50vh]\">\n        {loading ? (\n          <div className=\"flex flex-col items-center justify-center h-64 gap-3\">\n            <div className=\"w-8 h-8 border-4 border-indigo-600/20 border-t-indigo-600 rounded-full animate-spin\"></div>\n            <p className=\"text-[10px] font-black tracking-widest uppercase text-gray-400 animate-pulse\">Đang tải dữ liệu...</p>\n          </div>\n        ) : filteredItems.length === 0 ? (\n          <div className=\"flex flex-col items-center justify-center h-64 gap-4\">\n            <div className=\"w-16 h-16 bg-emerald-50 rounded-2xl flex items-center justify-center text-emerald-500\">\n              <Shield className=\"w-8 h-8\" />\n            </div>\n            <div className=\"text-center\">\n              <p className=\"text-sm font-black text-gray-900\">Mọi thứ đều hoàn hảo!</p>\n              <p className=\"text-[10px] text-gray-400 font-bold uppercase tracking-widest mt-1\">Bạn không có thông báo nào trong danh mục này</p>\n            </div>\n          </div>\n        ) : (\n          <div className=\"divide-y divide-gray-50\">\n            {filteredItems.map((item) => (\n              <div \n                key={item.id}\n                onClick={() => handleItemClick(item)}\n                className={`p-5 flex items-start gap-4 transition-colors cursor-pointer group hover:bg-gray-50 ${!item.is_read ? 'bg-indigo-50/10' : ''}`}\n              >\n                <div className={`w-12 h-12 rounded-2xl flex items-center justify-center shrink-0 border ${getBgColor(item.type)} transition-transform group-hover:scale-105 relative`}>\n                  {getIcon(item.type)}\n                  {!item.is_read && (\n                    <span className=\"absolute -top-1 -right-1 w-3 h-3 bg-red-500 border-2 border-white rounded-full\"></span>\n                  )}\n                </div>\n                <div className=\"flex-1\">\n                  <div className=\"flex items-start justify-between gap-4\">\n                    <div>\n                      <h4 className={`text-sm font-extrabold leading-tight tracking-tight uppercase transition-colors ${!item.is_read ? 'text-gray-900' : 'text-gray-500'}`}>\n                        {item.title}\n                      </h4>\n                      <p className={`text-xs mt-1 ${!item.is_read ? 'text-gray-600 font-medium' : 'text-gray-400'}`}>\n                        {item.subTitle}\n                      </p>\n                    </div>\n                    {item.value && (\n                      <span className=\"shrink-0 px-2.5 py-1 bg-rose-50 text-rose-600 text-[10px] font-black uppercase tracking-widest rounded-lg border border-rose-100\">\n                        {item.value}\n                      </span>\n                    )}\n                  </div>\n                  <div className=\"mt-3 flex items-center gap-4\">\n                    <span className=\"text-[10px] font-bold text-gray-400 uppercase tracking-widest\">\n                      {new Date(item.created_at).toLocaleDateString('vi-VN')} {new Date(item.created_at).toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' })}\n                    </span>\n                    <span className={`text-[10px] font-black uppercase tracking-widest ${item.source === 'logic' ? 'text-rose-600' : 'text-blue-600'}`}>\n                      • {item.source === 'logic' ? 'Khẩn cấp' : 'Hệ thống'}\n                    </span>\n                  </div>\n                </div>\n              </div>\n            ))}\n          </div>\n        )}\n      </div>\n    </div>\n  );\n}"}],"details":{"status":"completed","exitCode":0,"durationMs":27,"aggregated":"'use client';\n\nimport React, { useState, useEffect, useMemo } from 'react';\nimport { \n  Bell, FileBadge, Wallet, Clock as ClockIcon, \n  CheckCircle2, AlertCircle, Filter, Trash2, Shield,\n  AlertTriangle, Settings\n} from 'lucide-react';\nimport { useRouter } from 'next/navigation';\nimport { getDashboardStats } from '@/src/services/dashboardService';\nimport { getNotifications, markAsRead, markAllNotificationsAsRead, Notification } from '@/src/services/notificationService';\nimport { useAuth } from '@/src/context/AuthContext';\nimport { toast } from 'sonner';\n\ntype CombinedItem = {\n  id: string;\n  source: 'database' | 'logic';\n  type: string;\n  title: string;\n  subTitle: string;\n  value?: string;\n  is_read: boolean;\n  created_at: string;\n  badge?: string;\n};\n\nexport default function NotificationsPage() {\n  const router = useRouter();\n  const { user } = useAuth();\n  const [dbNotifications, setDbNotifications] = useState<Notification[]>([]);\n  const [urgentTasks, setUrgentTasks] = useState<any[]>([]);\n  const [loading, setLoading] = useState(true);\n  const [activeTab, setActiveTab] = useState<'all' | 'urgent' | 'system'>('all');\n\n  const fetchData = async () => {\n    if (!user?.id) return;\n    setLoading(true);\n    try {\n      const [statsRes, notifyRes] = await Promise.all([\n        getDashboardStats(),\n        getNotifications(user.id, 1, 50)\n      ]);\n\n      if (statsRes.success && statsRes.data?.urgentTasks) {\n        setUrgentTasks(statsRes.data.urgentTasks);\n      }\n      \n      if (notifyRes.success && notifyRes.data?.data) {\n        setDbNotifications(notifyRes.data.data);\n      }\n    } catch (error) {\n      console.error('Failed to fetch notifications:', error);\n      toast.error('Không thể tải thông báo');\n    } finally {\n      setLoading(false);\n    }\n  };\n\n  useEffect(() => {\n    fetchData();\n  }, [user?.id]);\n\n  const items: CombinedItem[] = useMemo(() => {\n    const combined: CombinedItem[] = [];\n\n    // Map urgent tasks (source: logic)\n    urgentTasks.forEach((task, idx) => {\n      combined.push({\n        id: `tasks-${idx}`,\n        source: 'logic',\n        type: task.type,\n        title: task.title,\n        subTitle: task.subTitle,\n        value: task.value,\n        is_read: false,\n        created_at: new Date().toISOString(), // Tasks are fresh calc\n        badge: task.badge\n      });\n    });\n\n    // Map real notifications (source: database)\n    dbNotifications.forEach((n) => {\n      combined.push({\n        id: n.id || n._id,\n        source: 'database',\n        type: (n.category === 'system' || n.receive_type === 'teacher' || (n as any).targetGroup) ? 'system' : 'notif',\n        title: n.title,\n        subTitle: (n as any).content || n.body,\n        is_read: n.is_read || n.status === 'read',\n        created_at: n.created_at || (n as any).createdAt,\n      });\n    });\n\n    // Sort by date (Tasks first, then most recent notifications)\n    return combined.sort((a, b) => new Date(b.created_at).getTime() - new Date(a.created_at).getTime());\n  }, [urgentTasks, dbNotifications]);\n\n  const filteredItems = useMemo(() => {\n    if (activeTab === 'urgent') return items.filter(i => i.source === 'logic');\n    if (activeTab === 'system') return items.filter(i => (i.source === 'database' && i.type === 'system'));\n    return items;\n  }, [items, activeTab]);\n\n  const getIcon = (type: string) => {\n    switch (type) {\n      case 'debt': return <Wallet className=\"w-5 h-5 text-rose-600\" />;\n      case 'exam': return <FileBadge className=\"w-5 h-5 text-indigo-600\" />;\n      case 'dat': return <ClockIcon className=\"w-5 h-5 text-amber-600\" />;\n      case 'system': return <Settings className=\"w-5 h-5 text-blue-600\" />;\n      default: return <Bell className=\"w-5 h-5 text-emerald-600\" />;\n    }\n  };\n\n  const getBgColor = (type: string) => {\n    switch (type) {\n      case 'debt': return 'bg-rose-50 border-rose-100';\n      case 'exam': return 'bg-indigo-50 border-indigo-100';\n      case 'dat': return 'bg-amber-50 border-amber-100';\n      case 'system': return 'bg-blue-50 border-blue-100';\n      default: return 'bg-emerald-50 border-emerald-100';\n    }\n  };\n\n  const handleMarkAllRead = async () => {\n    if (!user?.id) return;\n    try {\n      await markAllNotificationsAsRead(user.id);\n      fetchData();\n      toast.success('Đã đánh dấu tất cả là đã đọc!');\n    } catch (e) {\n      toast.error('Thao tác thất bại');\n    }\n  };\n\n  const handleItemClick = async (item: CombinedItem) => {\n    if (item.source === 'database' && !item.is_read) {\n      await markAsRead(item.id, user?.id);\n      fetchData();\n    }\n    \n    toast.info(`Điều hướng xử lý: ${item.title}`);\n    if (item.type === 'debt') router.push('/tuition');\n    if (item.type === 'exam') router.push('/schedules');\n  };\n\n  return (\n    <div className=\"flex flex-col gap-6 animate-in fade-in slide-in-from-bottom-2 duration-700 pb-20 max-w-5xl mx-auto\">\n      \n      {/* Header */}\n      <div className=\"flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4\">\n        <div>\n          <div className=\"flex items-center gap-3\">\n            <div className=\"w-10 h-10 bg-indigo-600 rounded-xl flex items-center justify-center text-white shadow-lg shadow-indigo-600/20\">\n              <Bell className=\"w-5 h-5\" />\n            </div>\n            <h2 className=\"text-3xl font-extrabold text-gray-900 tracking-tight leading-tight uppercase\">Thông báo</h2>\n          </div>\n          <p className=\"text-gray-500 font-medium text-sm mt-2 uppercase tracking-widest text-[10px]\">Trung tâm quản lý thông báo và công việc</p>\n        </div>\n        <div className=\"flex gap-2\">\n          <button \n            onClick={fetchData}\n            className=\"p-2.5 bg-white border border-gray-200 text-gray-500 rounded-xl hover:bg-gray-50 transition-all\"\n          >\n            <ClockIcon className=\"w-4 h-4\" />\n          </button>\n          <button \n            onClick={handleMarkAllRead}\n            className=\"flex items-center gap-2 px-5 py-2.5 bg-gray-900 border border-gray-800 text-white font-bold rounded-xl hover:bg-gray-800 transition-all active:scale-95 text-xs uppercase tracking-widest shadow-lg shadow-gray-900/20\"\n          >\n            <CheckCircle2 className=\"w-4 h-4\" /> Đọc tất cả\n          </button>\n        </div>\n      </div>\n\n      {/* Tabs & Filters */}\n      <div className=\"bg-white border border-gray-100 rounded-2xl shadow-sm p-4 flex flex-wrap items-center justify-between gap-4\">\n        <div className=\"flex items-center gap-2\">\n          <button\n            onClick={() => setActiveTab('all')}\n            className={`px-4 py-2 rounded-xl text-xs font-black uppercase tracking-widest transition-all ${\n              activeTab === 'all' ? 'bg-indigo-600 text-white shadow-md shadow-indigo-600/20' : 'text-gray-500 hover:bg-gray-50'\n            }`}\n          >\n            Tất cả ({items.length})\n          </button>\n          <button\n            onClick={() => setActiveTab('urgent')}\n            className={`px-4 py-2 rounded-xl text-xs font-black uppercase tracking-widest transition-all ${\n              activeTab === 'urgent' ? 'bg-rose-600 text-white shadow-md shadow-rose-600/20' : 'text-gray-500 hover:bg-gray-50'\n            }`}\n          >\n            Công việc khẩn ({urgentTasks.length})\n          </button>\n          <button\n            onClick={() => setActiveTab('system')}\n            className={`px-4 py-2 rounded-xl text-xs font-black uppercase tracking-widest transition-all ${\n              activeTab === 'system' ? 'bg-emerald-600 text-white shadow-md shadow-emerald-600/20' : 'text-gray-500 hover:bg-gray-50'\n            }`}\n          >\n            Hệ thống ({items.filter(i => i.source === 'database' && i.type === 'system').length})\n          </button>\n        </div>\n        <button className=\"p-2 text-gray-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-lg transition-all\">\n          <Filter className=\"w-5 h-5\" />\n        </button>\n      </div>\n\n      {/* List */}\n      <div className=\"bg-white border border-gray-100 rounded-2xl shadow-sm overflow-hidden min-h-[50vh]\">\n        {loading ? (\n          <div className=\"flex flex-col items-center justify-center h-64 gap-3\">\n            <div className=\"w-8 h-8 border-4 border-indigo-600/20 border-t-indigo-600 rounded-full animate-spin\"></div>\n            <p className=\"text-[10px] font-black tracking-widest uppercase text-gray-400 animate-pulse\">Đang tải dữ liệu...</p>\n          </div>\n        ) : filteredItems.length === 0 ? (\n          <div className=\"flex flex-col items-center justify-center h-64 gap-4\">\n            <div className=\"w-16 h-16 bg-emerald-50 rounded-2xl flex items-center justify-center text-emerald-500\">\n              <Shield className=\"w-8 h-8\" />\n            </div>\n            <div className=\"text-center\">\n              <p className=\"text-sm font-black text-gray-900\">Mọi thứ đều hoàn hảo!</p>\n              <p className=\"text-[10px] text-gray-400 font-bold uppercase tracking-widest mt-1\">Bạn không có thông báo nào trong danh mục này</p>\n            </div>\n          </div>\n        ) : (\n          <div className=\"divide-y divide-gray-50\">\n            {filteredItems.map((item) => (\n              <div \n                key={item.id}\n                onClick={() => handleItemClick(item)}\n                className={`p-5 flex items-start gap-4 transition-colors cursor-pointer group hover:bg-gray-50 ${!item.is_read ? 'bg-indigo-50/10' : ''}`}\n              >\n                <div className={`w-12 h-12 rounded-2xl flex items-center justify-center shrink-0 border ${getBgColor(item.type)} transition-transform group-hover:scale-105 relative`}>\n                  {getIcon(item.type)}\n                  {!item.is_read && (\n                    <span className=\"absolute -top-1 -right-1 w-3 h-3 bg-red-500 border-2 border-white rounded-full\"></span>\n                  )}\n                </div>\n                <div className=\"flex-1\">\n                  <div className=\"flex items-start justify-between gap-4\">\n                    <div>\n                      <h4 className={`text-sm font-extrabold leading-tight tracking-tight uppercase transition-colors ${!item.is_read ? 'text-gray-900' : 'text-gray-500'}`}>\n                        {item.title}\n                      </h4>\n                      <p className={`text-xs mt-1 ${!item.is_read ? 'text-gray-600 font-medium' : 'text-gray-400'}`}>\n                        {item.subTitle}\n                      </p>\n                    </div>\n                    {item.value && (\n                      <span className=\"shrink-0 px-2.5 py-1 bg-rose-50 text-rose-600 text-[10px] font-black uppercase tracking-widest rounded-lg border border-rose-100\">\n                        {item.value}\n                      </span>\n                    )}\n                  </div>\n                  <div className=\"mt-3 flex items-center gap-4\">\n                    <span className=\"text-[10px] font-bold text-gray-400 uppercase tracking-widest\">\n                      {new Date(item.created_at).toLocaleDateString('vi-VN')} {new Date(item.created_at).toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' })}\n                    </span>\n                    <span className={`text-[10px] font-black uppercase tracking-widest ${item.source === 'logic' ? 'text-rose-600' : 'text-blue-600'}`}>\n                      • {item.source === 'logic' ? 'Khẩn cấp' : 'Hệ thống'}\n                    </span>\n                  </div>\n                </div>\n              </div>\n            ))}\n          </div>\n        )}\n      </div>\n    </div>\n  );\n}","cwd":"/root/.openclaw/workspaces2/v4-ecosystem-review/master-orchestrator"},"isError":false,"timestamp":1776286065166}}
{"type":"message","id":"3afff3cb","parentId":"ad510573","timestamp":"2026-04-15T20:47:52.855Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"The FE notification page looks good - it shows notifications from both the dashboard stats (urgent tasks) and the database notifications. However, it doesn't have a channel indicator (SMS/Zalo/FCM badge). Let me check the settings notification page too.Now, let me check what's the subagent status and also look at what features are remaining in the system. Let me also look at the Confluence PRD.","thinkingSignature":"bf09395810e855305beee198bcba0187a1f56fc60509b2add27f3e9059de1249"},{"type":"toolCall","id":"call_function_rdxb0r6pazra_1","name":"exec","arguments":{"command":"cat /root/.openclaw/workspaces/teacher-driving-training-system.bootstrap-backup/ahv-qlhv-fe/src/app/settings/notifications/page.tsx"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":3175,"output":137,"cacheRead":81397,"cacheWrite":275,"totalTokens":84984,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776286065201,"responseId":"062f2c7228ec5bd5a809c172bd84e2e9"}}
{"type":"message","id":"0ef456f4","parentId":"3afff3cb","timestamp":"2026-04-15T20:47:53.135Z","message":{"role":"toolResult","toolCallId":"call_function_rdxb0r6pazra_1","toolName":"exec","content":[{"type":"text","text":"'use client';\n\nimport React, { useState } from 'react';\nimport { toast } from 'sonner';\nimport { \n  Bell, Send, Users, Clock, Plus, Search, \n  CheckCircle2, AlertCircle, Trash2, Mail, Phone,\n  Filter, MoreVertical, X, Loader2\n} from 'lucide-react';\nimport UnderDevelopment from '@/src/components/shared/UnderDevelopment';\nimport { getAnnouncements, createAnnouncement, updateAnnouncement, deleteAnnouncement, Announcement } from '@/src/services/announcementService';\nimport { ConfirmDeleteModal } from '@/src/app/settings/SettingsModals';\n\n/* --- DELETE MOCK NOTIFICATIONS --- */\n/* --- DELETE MOCK NOTIFICATIONS --- */\n\nexport default function NotificationsManagementPage() {\n  const [announcements, setAnnouncements] = useState<Announcement[]>([]);\n  const [loading, setLoading] = useState(true);\n  const [isComposeOpen, setIsComposeOpen] = useState(false);\n  const [search, setSearch] = useState('');\n  const [statusFilter, setStatusFilter] = useState('Tất cả trạng thái');\n  const [channels, setChannels] = useState({ app: true, email: false, sms: false });\n  const [title, setTitle] = useState('');\n  const [content, setContent] = useState('');\n  const [targetGroup, setTargetGroup] = useState('ALL');\n  const [scheduledAt, setScheduledAt] = useState('');\n  const [isSubmitting, setIsSubmitting] = useState(false);\n  \n  // UI Helpers\n  const [isDeleteModalOpen, setIsDeleteModalOpen] = useState(false);\n  const [itemToDelete, setItemToDelete] = useState<Announcement | null>(null);\n  const [editingItem, setEditingItem] = useState<Announcement | null>(null);\n  const [stats, setStats] = useState({ total_recipients: 0, total_sent: 0, total_scheduled: 0 });\n\n  const fetchAnnouncements = async () => {\n    try {\n      setLoading(true);\n      const res = await getAnnouncements({\n        search,\n        status: statusFilter,\n        page: 1,\n        limit: 50\n      });\n      if (res.success && res.data) {\n        setAnnouncements(res.data.data);\n        if (res.data.stats) {\n          setStats(res.data.stats);\n        }\n      }\n    } catch (error) {\n      console.error('Failed to fetch announcements:', error);\n      toast.error('Không thể tải danh sách thông báo');\n    } finally {\n      setLoading(false);\n    }\n  };\n\n  React.useEffect(() => {\n    const timer = setTimeout(() => {\n      fetchAnnouncements();\n    }, 500);\n    return () => clearTimeout(timer);\n  }, [search, statusFilter]);\n\n  const toggleChannel = (key: keyof typeof channels) => {\n    setChannels(prev => ({ ...prev, [key]: !prev[key] }));\n  };\n\n  const openCompose = (item?: Announcement) => {\n    if (item) {\n      setEditingItem(item);\n      setTitle(item.title);\n      setContent(item.content);\n      setTargetGroup(item.target_group);\n      setScheduledAt(item.scheduled_at ? new Date(item.scheduled_at).toISOString().slice(0, 16) : '');\n      setChannels({\n        app: item.channels.includes('APP'),\n        email: item.channels.includes('EMAIL'),\n        sms: item.channels.includes('SMS'),\n      });\n    } else {\n      setEditingItem(null);\n      setTitle('');\n      setContent('');\n      setScheduledAt('');\n      setTargetGroup('ALL');\n      setChannels({ app: true, email: false, sms: false });\n    }\n    setIsComposeOpen(true);\n  };\n\n  const handleBroadcast = async () => {\n    if (!title.trim()) { toast.warning('Vui lòng nhập tiêu đề thông báo!'); return; }\n    if (!content.trim()) { toast.warning('Vui lòng nhập nội dung thông báo!'); return; }\n    \n    const selectedChannels = [\n      channels.app && 'APP',\n      channels.email && 'EMAIL',\n      channels.sms && 'SMS',\n    ].filter(Boolean) as ('APP' | 'EMAIL' | 'SMS')[];\n\n    if (selectedChannels.length === 0) { toast.warning('Vui lòng chọn ít nhất một kênh phát tin!'); return; }\n\n    try {\n      setIsSubmitting(true);\n      const payload: Partial<Announcement> = {\n        title,\n        content,\n        target_group: targetGroup,\n        channels: selectedChannels,\n        status: (scheduledAt ? 'SCHEDULED' : 'SENT') as 'SENT' | 'SCHEDULED',\n        scheduled_at: scheduledAt ? new Date(scheduledAt).toISOString() : undefined\n      };\n\n      const res = editingItem \n        ? await updateAnnouncement(editingItem.id, payload)\n        : await createAnnouncement(payload);\n\n      if (res.success) {\n        toast.success(editingItem ? 'Đã cập nhật thông báo' : (scheduledAt ? 'Đã lên lịch thông báo thành công' : 'Đã gửi thông báo thành công'));\n        setIsComposeOpen(false);\n        fetchAnnouncements();\n      }\n    } catch (error) {\n      console.error('Failed to handle announcement:', error);\n      toast.error('Thực hiện thất bại. Vui lòng thử lại.');\n    } finally {\n      setIsSubmitting(false);\n    }\n  };\n\n  const handleDeleteClick = (id: string) => {\n    const item = announcements.find(a => a.id === id);\n    if (item) {\n      setItemToDelete(item);\n      setIsDeleteModalOpen(true);\n    }\n  };\n\n  const handleDeleteConfirm = async (item: Announcement) => {\n    try {\n      await deleteAnnouncement(item.id);\n      toast.success('Đã xóa thông báo');\n      fetchAnnouncements();\n    } catch (error) {\n      toast.error('Xóa thất bại');\n    }\n  };\n\n  const ChannelButton = ({\n    channelKey, icon: Icon, label,\n  }: { channelKey: keyof typeof channels; icon: React.ElementType; label: string }) => {\n    const active = channels[channelKey];\n    return (\n      <button\n        type=\"button\"\n        onClick={() => toggleChannel(channelKey)}\n        className={`flex items-center gap-4 p-4 border rounded-2xl cursor-pointer transition-all flex-1 min-w-[120px] sm:min-w-[150px] ${\n          active\n            ? 'bg-indigo-50 border-indigo-300 shadow-sm shadow-indigo-100'\n            : 'bg-gray-50 border-gray-100 hover:bg-white opacity-60 hover:opacity-100'\n        }`}\n      >\n        <div className={`w-5 h-5 rounded-lg border-2 flex items-center justify-center p-0.5 transition-all ${\n          active ? 'border-indigo-500 bg-indigo-600' : 'border-gray-300 bg-white'\n        }`}>\n          {active && <CheckCircle2 className=\"w-full h-full text-white\" />}\n        </div>\n        <div className=\"flex items-center gap-2\">\n          <Icon className={`w-4 h-4 ${active ? 'text-indigo-600' : 'text-gray-400'}`} />\n          <span className={`text-[10px] font-black uppercase tracking-widest ${active ? 'text-indigo-700' : 'text-gray-400'}`}>\n            {label}\n          </span>\n        </div>\n      </button>\n    );\n  };\n\n  return (\n    <div className=\"flex flex-col gap-6 animate-in fade-in slide-in-from-bottom-2 duration-700 pb-20\">\n      \n      {/* Header section */}\n      <div className=\"flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4\">\n        <div>\n          <h2 className=\"text-3xl font-extrabold text-gray-900 tracking-tight leading-tight uppercase\">QUẢN LÝ THÔNG BÁO</h2>\n          <p className=\"text-gray-500 font-medium text-sm mt-1 uppercase tracking-widest text-[10px]\">Announcement & Broadcast Management</p>\n        </div>\n        <button \n          onClick={() => openCompose()}\n          className=\"flex items-center gap-2 px-6 py-2.5 bg-indigo-600 text-white font-black rounded-xl shadow-lg shadow-indigo-600/20 hover:bg-indigo-700 transition-all active:scale-95 text-xs uppercase tracking-widest\"\n        >\n          <Plus className=\"w-4 h-4\" /> Tạo thông báo mới\n        </button>\n      </div>\n\n      <UnderDevelopment \n        featureName=\"Trung tâm thông báo\" \n        description=\"đang được tích hợp với hệ thống gửi tin SMS/Email!\"\n      />\n\n      {/* Stats Summary */}\n      <div className=\"grid grid-cols-1 md:grid-cols-3 gap-4\">\n        <div className=\"bg-white border border-gray-100 rounded-2xl p-5 shadow-sm\">\n          <div className=\"flex items-center gap-4\">\n            <div className=\"w-10 h-10 bg-indigo-50 rounded-xl flex items-center justify-center text-indigo-600\">\n              <Send className=\"w-5 h-5\" />\n            </div>\n            <div className=\"flex flex-col\">\n              <span className=\"text-xl font-black text-gray-900 leading-tight tracking-tighter\">\n                {stats.total_sent.toLocaleString()}\n              </span>\n              <span className=\"text-[10px] font-bold text-gray-400 uppercase tracking-tight\">Đã gửi thành công</span>\n            </div>\n          </div>\n        </div>\n        <div className=\"bg-white border border-gray-100 rounded-2xl p-5 shadow-sm\">\n          <div className=\"flex items-center gap-4\">\n            <div className=\"w-10 h-10 bg-amber-50 rounded-xl flex items-center justify-center text-amber-600\">\n              <Clock className=\"w-5 h-5\" />\n            </div>\n            <div className=\"flex flex-col\">\n              <span className=\"text-xl font-black text-gray-900 leading-tight tracking-tighter\">\n                {stats.total_scheduled.toLocaleString()}\n              </span>\n              <span className=\"text-[10px] font-bold text-gray-400 uppercase tracking-tight\">Đang chờ gửi</span>\n            </div>\n          </div>\n        </div>\n        <div className=\"bg-white border border-gray-100 rounded-2xl p-5 shadow-sm\">\n          <div className=\"flex items-center gap-4\">\n            <div className=\"w-10 h-10 bg-emerald-50 rounded-xl flex items-center justify-center text-emerald-600\">\n              <Users className=\"w-5 h-5\" />\n            </div>\n            <div className=\"flex flex-col\">\n              <span className=\"text-xl font-black text-gray-900 leading-tight tracking-tighter\">\n                {stats.total_recipients.toLocaleString()}\n              </span>\n              <span className=\"text-[10px] font-bold text-gray-400 uppercase tracking-tight\">Người nhận tin</span>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      {/* Filters & Search */}\n      <div className=\"bg-white border border-gray-100 rounded-2xl shadow-sm p-4 flex flex-wrap items-center justify-between gap-4\">\n        <div className=\"flex items-center gap-3\">\n          <div className=\"relative\">\n            <Search className=\"w-4 h-4 text-gray-400 absolute left-3 top-1/2 -translate-y-1/2\" />\n            <input \n              type=\"text\" \n              placeholder=\"Tìm thông báo...\"\n              value={search}\n              onChange={(e) => setSearch(e.target.value)}\n              className=\"pl-9 pr-4 py-2 bg-gray-50 border border-gray-100 rounded-xl text-xs font-bold focus:outline-none focus:ring-2 focus:ring-indigo-600/20 w-64\"\n            />\n          </div>\n          <select \n            value={statusFilter}\n            onChange={(e) => setStatusFilter(e.target.value)}\n            className=\"px-3 py-2 bg-gray-50 border border-gray-100 rounded-xl text-[11px] font-extrabold text-gray-500 focus:outline-none uppercase tracking-widest\"\n          >\n            <option>Tất cả trạng thái</option>\n            <option>Đã gửi</option>\n            <option>Chờ gửi</option>\n          </select>\n        </div>\n        <div className=\"flex items-center gap-2\">\n          <button className=\"p-2 text-gray-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-lg transition-all\"><Filter className=\"w-5 h-5\" /></button>\n          <button \n            onClick={() => toast.error('Tính năng xóa hàng loạt đang được phát triển')}\n            className=\"p-2 text-gray-400 hover:text-rose-500 hover:bg-rose-50 rounded-lg transition-all\"\n          >\n            <Trash2 className=\"w-5 h-5\" />\n          </button>\n        </div>\n      </div>\n\n      <div className=\"grid grid-cols-1 gap-4\">\n        {loading ? (\n          <div className=\"flex flex-col items-center justify-center py-20 bg-white border border-dashed border-gray-200 rounded-3xl gap-4\">\n            <Loader2 className=\"w-10 h-10 text-indigo-600 animate-spin\" />\n            <p className=\"text-xs font-black text-gray-400 uppercase tracking-widest\">Đang tải thông báo...</p>\n          </div>\n        ) : announcements.length === 0 ? (\n          <div className=\"flex flex-col items-center justify-center py-20 bg-white border border-dashed border-gray-200 rounded-3xl gap-4\">\n            <div className=\"w-16 h-16 bg-gray-50 rounded-2xl flex items-center justify-center text-gray-300\">\n              <Bell className=\"w-8 h-8\" />\n            </div>\n            <p className=\"text-xs font-black text-gray-400 uppercase tracking-widest\">Không có thông báo nào được tìm thấy</p>\n          </div>\n        ) : (\n          announcements.map((item) => (\n            <div key={item.id} className=\"group bg-white border border-gray-100 rounded-2xl p-5 hover:shadow-xl hover:shadow-indigo-500/5 hover:border-indigo-100 transition-all cursor-pointer\">\n              <div className=\"flex items-start justify-between\">\n                <div className=\"flex items-start gap-4\">\n                  <div className={`w-10 h-10 rounded-xl flex items-center justify-center shrink-0 ${\n                    item.status === 'SENT' ? 'bg-indigo-50 text-indigo-600' : 'bg-amber-50 text-amber-600'\n                  }`}>\n                    <Bell className=\"w-5 h-5\" />\n                  </div>\n                  <div className=\"flex flex-col gap-1\">\n                    <div className=\"flex items-center gap-2\">\n                      <span className=\"font-extrabold text-gray-900 tracking-tight text-sm uppercase\">{item.title}</span>\n                      <span className={`px-1.5 py-0.5 rounded text-[8px] font-black uppercase tracking-wider ${\n                        item.status === 'SENT' ? 'bg-indigo-100 text-indigo-700' : 'bg-amber-100 text-amber-700'\n                      }`}>\n                        {item.status === 'SENT' ? 'Đã gửi' : 'Đang chờ'}\n                      </span>\n                    </div>\n                    <p className=\"text-xs text-gray-400 font-bold overflow-hidden text-ellipsis line-clamp-1\">{item.content}</p>\n                    <div className=\"flex items-center gap-4 mt-2\">\n                      <span className=\"text-[9px] font-extrabold text-gray-400 uppercase tracking-widest flex items-center gap-1.5 bg-gray-50 px-2 py-0.5 rounded-lg border border-gray-100\">\n                        <Users className=\"w-3 h-3 opacity-60\" /> {item.target_group === 'ALL' ? 'Tất cả' : item.target_group}\n                      </span>\n                      <span className=\"text-[9px] font-extrabold text-gray-400 uppercase tracking-widest flex items-center gap-1.5 bg-gray-50 px-2 py-0.5 rounded-lg border border-gray-100\">\n                        <Clock className=\"w-3 h-3 opacity-60\" /> {new Date(item.createdAt).toLocaleDateString('vi-VN')}\n                      </span>\n                    </div>\n                  </div>\n                </div>\n                <div className=\"flex items-center gap-2\">\n                  <button \n                    onClick={(e) => { e.stopPropagation(); handleDeleteClick(item.id); }}\n                    className=\"p-2 text-gray-300 hover:text-rose-500 opacity-0 group-hover:opacity-100 transition-all\"\n                  >\n                    <Trash2 className=\"w-5 h-5\" />\n                  </button>\n                  <button \n                    onClick={(e) => { e.stopPropagation(); openCompose(item); }}\n                    className=\"p-2 text-gray-300 hover:text-indigo-600 opacity-0 group-hover:opacity-100 transition-all\"\n                  >\n                    <MoreVertical className=\"w-5 h-5\" />\n                  </button>\n                </div>\n              </div>\n            </div>\n          ))\n        )}\n      </div>\n\n      {/* Compose Modal */}\n      {isComposeOpen && (\n        <div className=\"fixed inset-0 z-[100] flex items-center justify-center p-4 bg-gray-900/40 backdrop-blur-sm animate-in fade-in duration-300\">\n          <div className=\"bg-white rounded-[2rem] shadow-2xl w-full max-w-2xl overflow-hidden animate-in zoom-in-95 duration-300 flex flex-col max-h-[90vh]\">\n            \n            {/* Modal Header */}\n            <div className=\"px-10 py-8 border-b border-gray-100 flex items-center justify-between bg-white relative\">\n              <div className=\"absolute top-0 right-10 w-20 h-1 bg-indigo-600 rounded-b-full\"></div>\n              <div className=\"flex items-center gap-5\">\n                <div className=\"w-14 h-14 bg-indigo-600 rounded-2xl flex items-center justify-center text-white shadow-xl shadow-indigo-600/20\">\n                  <Send className=\"w-7 h-7 rotate-[-15deg] mt-0.5\" />\n                </div>\n                <div>\n                  <h3 className=\"text-xl font-black text-gray-900 tracking-tight uppercase\">\n                    {editingItem ? 'Chỉnh sửa thông báo' : 'Soạn thông báo mới'}\n                  </h3>\n                  <p className=\"text-[10px] text-gray-400 font-extrabold uppercase tracking-[0.2em] mt-1\">\n                    {editingItem ? 'Edit Announcement' : 'Compose Announcement'}\n                  </p>\n                </div>\n              </div>\n              <button \n                onClick={() => setIsComposeOpen(false)}\n                className=\"p-3 text-gray-400 hover:text-rose-500 hover:bg-rose-50 rounded-2xl transition-all border border-transparent hover:border-rose-100\"\n              >\n                <X className=\"w-6 h-6\" />\n              </button>\n            </div>\n\n            {/* Modal Form */}\n            <div className=\"p-10 overflow-y-auto space-y-8 hide-scrollbar\">\n              \n              {/* Title */}\n              <div className=\"flex flex-col gap-2\">\n                <label className=\"text-[10px] font-black text-gray-400 uppercase tracking-[0.2em]\">TIÊU ĐỀ THÔNG BÁO</label>\n                <input \n                  type=\"text\"\n                  value={title}\n                  onChange={e => setTitle(e.target.value)}\n                  placeholder=\"Ví dụ: Thông báo nghỉ lễ 30/04 - 01/05\"\n                  className=\"w-full px-6 py-4 bg-gray-50 border border-gray-100 rounded-2xl text-sm font-black tracking-tight focus:outline-none focus:ring-2 focus:ring-indigo-600/10 focus:bg-white transition-all outline-none\"\n                />\n              </div>\n\n              {/* Target & Schedule */}\n              <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n                <div className=\"flex flex-col gap-2\">\n                  <label className=\"text-[10px] font-black text-gray-400 uppercase tracking-[0.2em]\">ĐỐI TƯỢNG NHẬN</label>\n                  <select \n                    value={targetGroup}\n                    onChange={e => setTargetGroup(e.target.value)}\n                    className=\"w-full px-6 py-4 bg-gray-50 border border-gray-100 rounded-2xl text-sm font-black tracking-tight focus:outline-none focus:ring-2 focus:ring-indigo-600/10 focus:bg-white transition-all outline-none uppercase font-bold\"\n                  >\n                    <option value=\"ALL\">Tất cả đối tượng</option>\n                    <option value=\"STUDENT\">Tất cả Học viên</option>\n                    <option value=\"TEACHER\">Đội ngũ giáo viên</option>\n                    <option value=\"STAFF\">Nhân viên văn phòng</option>\n                  </select>\n                </div>\n                <div className=\"flex flex-col gap-2\">\n                  <label className=\"text-[10px] font-black text-gray-400 uppercase tracking-[0.2em]\">HẸN GIỜ GỬI (TÙY CHỌN)</label>\n                  <div className=\"relative\">\n                    <Clock className=\"absolute left-6 top-1/2 -translate-y-1/2 w-4 h-4 text-indigo-400\" />\n                    <input \n                      type=\"datetime-local\"\n                      value={scheduledAt}\n                      onChange={e => setScheduledAt(e.target.value)}\n                      className=\"w-full pl-12 pr-6 py-4 bg-gray-50 border border-gray-100 rounded-2xl text-sm font-black tracking-tight focus:outline-none focus:ring-2 focus:ring-indigo-600/10 focus:bg-white transition-all outline-none\"\n                    />\n                  </div>\n                </div>\n              </div>\n\n              {/* Channel Selection — fully interactive */}\n              <div className=\"flex flex-col gap-3\">\n                <label className=\"text-[10px] font-black text-gray-400 uppercase tracking-[0.2em]\">KÊNH PHÁT TIN</label>\n                <div className=\"flex flex-wrap gap-3\">\n                  <ChannelButton channelKey=\"app\"   icon={Bell}  label=\"App Alert\" />\n                  <ChannelButton channelKey=\"email\" icon={Mail}  label=\"Email\" />\n                  <ChannelButton channelKey=\"sms\"   icon={Phone} label=\"SMS/Zalo\" />\n                </div>\n              </div>\n\n              {/* Content */}\n              <div className=\"flex flex-col gap-2\">\n                <div className=\"flex items-center justify-between\">\n                  <label className=\"text-[10px] font-black text-gray-400 uppercase tracking-[0.2em]\">NỘI DUNG THÔNG BÁO</label>\n                  <span className=\"text-[9px] font-extrabold text-indigo-400 uppercase tracking-widest\">Draft Saved</span>\n                </div>\n                <textarea \n                  rows={8}\n                  value={content}\n                  onChange={e => setContent(e.target.value)}\n                  placeholder=\"Nhập nội dung thông báo chi tiết...\"\n                  className=\"w-full px-6 py-5 bg-gray-50 border border-gray-100 rounded-[2rem] text-sm font-bold tracking-tight focus:outline-none focus:ring-2 focus:ring-indigo-600/10 focus:bg-white transition-all outline-none resize-none leading-relaxed\"\n                />\n              </div>\n            </div>\n\n            {/* Modal Footer */}\n            <div className=\"p-10 border-t border-gray-100 bg-white flex items-center justify-between\">\n              <div className=\"flex items-center gap-2 text-rose-400 group cursor-pointer\">\n                <AlertCircle className=\"w-4 h-4 group-hover:animate-pulse\" />\n                <span className=\"text-[9px] font-black uppercase tracking-widest\">Yêu cầu xác nhận gửi tin</span>\n              </div>\n              <div className=\"flex items-center gap-6\">\n                <button \n                  onClick={() => setIsComposeOpen(false)}\n                  className=\"text-[10px] font-black text-gray-400 hover:text-gray-900 transition-all uppercase tracking-[0.2em]\"\n                >\n                  Hủy bỏ\n                </button>\n                <button\n                  onClick={handleBroadcast}\n                  disabled={isSubmitting}\n                  className=\"flex items-center gap-3 px-10 py-3.5 bg-indigo-600 text-white font-black rounded-2xl shadow-2xl shadow-indigo-600/30 hover:bg-indigo-700 hover:scale-[1.02] active:scale-[0.98] transition-all uppercase tracking-[0.2em] text-xs disabled:opacity-50 disabled:cursor-not-allowed\"\n                >\n                  {isSubmitting ? <Loader2 className=\"w-4 h-4 animate-spin\" /> : <Send className=\"w-4 h-4 rotate-[-15deg]\" />} \n                  {isSubmitting ? 'Đang thực hiện...' : (editingItem ? 'Cập nhật ngay' : 'Phát tin ngay')}\n                </button>\n              </div>\n            </div>\n\n          </div>\n        </div>\n      )}\n\n      <ConfirmDeleteModal \n        isOpen={isDeleteModalOpen}\n        onClose={() => setIsDeleteModalOpen(false)}\n        item={itemToDelete}\n        onConfirm={handleDeleteConfirm}\n        message={`Bạn có chắc chắn muốn xóa thông báo \"${itemToDelete?.title}\"?`}\n      />\n    </div>\n  );\n}"}],"details":{"status":"completed","exitCode":0,"durationMs":137,"aggregated":"'use client';\n\nimport React, { useState } from 'react';\nimport { toast } from 'sonner';\nimport { \n  Bell, Send, Users, Clock, Plus, Search, \n  CheckCircle2, AlertCircle, Trash2, Mail, Phone,\n  Filter, MoreVertical, X, Loader2\n} from 'lucide-react';\nimport UnderDevelopment from '@/src/components/shared/UnderDevelopment';\nimport { getAnnouncements, createAnnouncement, updateAnnouncement, deleteAnnouncement, Announcement } from '@/src/services/announcementService';\nimport { ConfirmDeleteModal } from '@/src/app/settings/SettingsModals';\n\n/* --- DELETE MOCK NOTIFICATIONS --- */\n/* --- DELETE MOCK NOTIFICATIONS --- */\n\nexport default function NotificationsManagementPage() {\n  const [announcements, setAnnouncements] = useState<Announcement[]>([]);\n  const [loading, setLoading] = useState(true);\n  const [isComposeOpen, setIsComposeOpen] = useState(false);\n  const [search, setSearch] = useState('');\n  const [statusFilter, setStatusFilter] = useState('Tất cả trạng thái');\n  const [channels, setChannels] = useState({ app: true, email: false, sms: false });\n  const [title, setTitle] = useState('');\n  const [content, setContent] = useState('');\n  const [targetGroup, setTargetGroup] = useState('ALL');\n  const [scheduledAt, setScheduledAt] = useState('');\n  const [isSubmitting, setIsSubmitting] = useState(false);\n  \n  // UI Helpers\n  const [isDeleteModalOpen, setIsDeleteModalOpen] = useState(false);\n  const [itemToDelete, setItemToDelete] = useState<Announcement | null>(null);\n  const [editingItem, setEditingItem] = useState<Announcement | null>(null);\n  const [stats, setStats] = useState({ total_recipients: 0, total_sent: 0, total_scheduled: 0 });\n\n  const fetchAnnouncements = async () => {\n    try {\n      setLoading(true);\n      const res = await getAnnouncements({\n        search,\n        status: statusFilter,\n        page: 1,\n        limit: 50\n      });\n      if (res.success && res.data) {\n        setAnnouncements(res.data.data);\n        if (res.data.stats) {\n          setStats(res.data.stats);\n        }\n      }\n    } catch (error) {\n      console.error('Failed to fetch announcements:', error);\n      toast.error('Không thể tải danh sách thông báo');\n    } finally {\n      setLoading(false);\n    }\n  };\n\n  React.useEffect(() => {\n    const timer = setTimeout(() => {\n      fetchAnnouncements();\n    }, 500);\n    return () => clearTimeout(timer);\n  }, [search, statusFilter]);\n\n  const toggleChannel = (key: keyof typeof channels) => {\n    setChannels(prev => ({ ...prev, [key]: !prev[key] }));\n  };\n\n  const openCompose = (item?: Announcement) => {\n    if (item) {\n      setEditingItem(item);\n      setTitle(item.title);\n      setContent(item.content);\n      setTargetGroup(item.target_group);\n      setScheduledAt(item.scheduled_at ? new Date(item.scheduled_at).toISOString().slice(0, 16) : '');\n      setChannels({\n        app: item.channels.includes('APP'),\n        email: item.channels.includes('EMAIL'),\n        sms: item.channels.includes('SMS'),\n      });\n    } else {\n      setEditingItem(null);\n      setTitle('');\n      setContent('');\n      setScheduledAt('');\n      setTargetGroup('ALL');\n      setChannels({ app: true, email: false, sms: false });\n    }\n    setIsComposeOpen(true);\n  };\n\n  const handleBroadcast = async () => {\n    if (!title.trim()) { toast.warning('Vui lòng nhập tiêu đề thông báo!'); return; }\n    if (!content.trim()) { toast.warning('Vui lòng nhập nội dung thông báo!'); return; }\n    \n    const selectedChannels = [\n      channels.app && 'APP',\n      channels.email && 'EMAIL',\n      channels.sms && 'SMS',\n    ].filter(Boolean) as ('APP' | 'EMAIL' | 'SMS')[];\n\n    if (selectedChannels.length === 0) { toast.warning('Vui lòng chọn ít nhất một kênh phát tin!'); return; }\n\n    try {\n      setIsSubmitting(true);\n      const payload: Partial<Announcement> = {\n        title,\n        content,\n        target_group: targetGroup,\n        channels: selectedChannels,\n        status: (scheduledAt ? 'SCHEDULED' : 'SENT') as 'SENT' | 'SCHEDULED',\n        scheduled_at: scheduledAt ? new Date(scheduledAt).toISOString() : undefined\n      };\n\n      const res = editingItem \n        ? await updateAnnouncement(editingItem.id, payload)\n        : await createAnnouncement(payload);\n\n      if (res.success) {\n        toast.success(editingItem ? 'Đã cập nhật thông báo' : (scheduledAt ? 'Đã lên lịch thông báo thành công' : 'Đã gửi thông báo thành công'));\n        setIsComposeOpen(false);\n        fetchAnnouncements();\n      }\n    } catch (error) {\n      console.error('Failed to handle announcement:', error);\n      toast.error('Thực hiện thất bại. Vui lòng thử lại.');\n    } finally {\n      setIsSubmitting(false);\n    }\n  };\n\n  const handleDeleteClick = (id: string) => {\n    const item = announcements.find(a => a.id === id);\n    if (item) {\n      setItemToDelete(item);\n      setIsDeleteModalOpen(true);\n    }\n  };\n\n  const handleDeleteConfirm = async (item: Announcement) => {\n    try {\n      await deleteAnnouncement(item.id);\n      toast.success('Đã xóa thông báo');\n      fetchAnnouncements();\n    } catch (error) {\n      toast.error('Xóa thất bại');\n    }\n  };\n\n  const ChannelButton = ({\n    channelKey, icon: Icon, label,\n  }: { channelKey: keyof typeof channels; icon: React.ElementType; label: string }) => {\n    const active = channels[channelKey];\n    return (\n      <button\n        type=\"button\"\n        onClick={() => toggleChannel(channelKey)}\n        className={`flex items-center gap-4 p-4 border rounded-2xl cursor-pointer transition-all flex-1 min-w-[120px] sm:min-w-[150px] ${\n          active\n            ? 'bg-indigo-50 border-indigo-300 shadow-sm shadow-indigo-100'\n            : 'bg-gray-50 border-gray-100 hover:bg-white opacity-60 hover:opacity-100'\n        }`}\n      >\n        <div className={`w-5 h-5 rounded-lg border-2 flex items-center justify-center p-0.5 transition-all ${\n          active ? 'border-indigo-500 bg-indigo-600' : 'border-gray-300 bg-white'\n        }`}>\n          {active && <CheckCircle2 className=\"w-full h-full text-white\" />}\n        </div>\n        <div className=\"flex items-center gap-2\">\n          <Icon className={`w-4 h-4 ${active ? 'text-indigo-600' : 'text-gray-400'}`} />\n          <span className={`text-[10px] font-black uppercase tracking-widest ${active ? 'text-indigo-700' : 'text-gray-400'}`}>\n            {label}\n          </span>\n        </div>\n      </button>\n    );\n  };\n\n  return (\n    <div className=\"flex flex-col gap-6 animate-in fade-in slide-in-from-bottom-2 duration-700 pb-20\">\n      \n      {/* Header section */}\n      <div className=\"flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4\">\n        <div>\n          <h2 className=\"text-3xl font-extrabold text-gray-900 tracking-tight leading-tight uppercase\">QUẢN LÝ THÔNG BÁO</h2>\n          <p className=\"text-gray-500 font-medium text-sm mt-1 uppercase tracking-widest text-[10px]\">Announcement & Broadcast Management</p>\n        </div>\n        <button \n          onClick={() => openCompose()}\n          className=\"flex items-center gap-2 px-6 py-2.5 bg-indigo-600 text-white font-black rounded-xl shadow-lg shadow-indigo-600/20 hover:bg-indigo-700 transition-all active:scale-95 text-xs uppercase tracking-widest\"\n        >\n          <Plus className=\"w-4 h-4\" /> Tạo thông báo mới\n        </button>\n      </div>\n\n      <UnderDevelopment \n        featureName=\"Trung tâm thông báo\" \n        description=\"đang được tích hợp với hệ thống gửi tin SMS/Email!\"\n      />\n\n      {/* Stats Summary */}\n      <div className=\"grid grid-cols-1 md:grid-cols-3 gap-4\">\n        <div className=\"bg-white border border-gray-100 rounded-2xl p-5 shadow-sm\">\n          <div className=\"flex items-center gap-4\">\n            <div className=\"w-10 h-10 bg-indigo-50 rounded-xl flex items-center justify-center text-indigo-600\">\n              <Send className=\"w-5 h-5\" />\n            </div>\n            <div className=\"flex flex-col\">\n              <span className=\"text-xl font-black text-gray-900 leading-tight tracking-tighter\">\n                {stats.total_sent.toLocaleString()}\n              </span>\n              <span className=\"text-[10px] font-bold text-gray-400 uppercase tracking-tight\">Đã gửi thành công</span>\n            </div>\n          </div>\n        </div>\n        <div className=\"bg-white border border-gray-100 rounded-2xl p-5 shadow-sm\">\n          <div className=\"flex items-center gap-4\">\n            <div className=\"w-10 h-10 bg-amber-50 rounded-xl flex items-center justify-center text-amber-600\">\n              <Clock className=\"w-5 h-5\" />\n            </div>\n            <div className=\"flex flex-col\">\n              <span className=\"text-xl font-black text-gray-900 leading-tight tracking-tighter\">\n                {stats.total_scheduled.toLocaleString()}\n              </span>\n              <span className=\"text-[10px] font-bold text-gray-400 uppercase tracking-tight\">Đang chờ gửi</span>\n            </div>\n          </div>\n        </div>\n        <div className=\"bg-white border border-gray-100 rounded-2xl p-5 shadow-sm\">\n          <div className=\"flex items-center gap-4\">\n            <div className=\"w-10 h-10 bg-emerald-50 rounded-xl flex items-center justify-center text-emerald-600\">\n              <Users className=\"w-5 h-5\" />\n            </div>\n            <div className=\"flex flex-col\">\n              <span className=\"text-xl font-black text-gray-900 leading-tight tracking-tighter\">\n                {stats.total_recipients.toLocaleString()}\n              </span>\n              <span className=\"text-[10px] font-bold text-gray-400 uppercase tracking-tight\">Người nhận tin</span>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      {/* Filters & Search */}\n      <div className=\"bg-white border border-gray-100 rounded-2xl shadow-sm p-4 flex flex-wrap items-center justify-between gap-4\">\n        <div className=\"flex items-center gap-3\">\n          <div className=\"relative\">\n            <Search className=\"w-4 h-4 text-gray-400 absolute left-3 top-1/2 -translate-y-1/2\" />\n            <input \n              type=\"text\" \n              placeholder=\"Tìm thông báo...\"\n              value={search}\n              onChange={(e) => setSearch(e.target.value)}\n              className=\"pl-9 pr-4 py-2 bg-gray-50 border border-gray-100 rounded-xl text-xs font-bold focus:outline-none focus:ring-2 focus:ring-indigo-600/20 w-64\"\n            />\n          </div>\n          <select \n            value={statusFilter}\n            onChange={(e) => setStatusFilter(e.target.value)}\n            className=\"px-3 py-2 bg-gray-50 border border-gray-100 rounded-xl text-[11px] font-extrabold text-gray-500 focus:outline-none uppercase tracking-widest\"\n          >\n            <option>Tất cả trạng thái</option>\n            <option>Đã gửi</option>\n            <option>Chờ gửi</option>\n          </select>\n        </div>\n        <div className=\"flex items-center gap-2\">\n          <button className=\"p-2 text-gray-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-lg transition-all\"><Filter className=\"w-5 h-5\" /></button>\n          <button \n            onClick={() => toast.error('Tính năng xóa hàng loạt đang được phát triển')}\n            className=\"p-2 text-gray-400 hover:text-rose-500 hover:bg-rose-50 rounded-lg transition-all\"\n          >\n            <Trash2 className=\"w-5 h-5\" />\n          </button>\n        </div>\n      </div>\n\n      <div className=\"grid grid-cols-1 gap-4\">\n        {loading ? (\n          <div className=\"flex flex-col items-center justify-center py-20 bg-white border border-dashed border-gray-200 rounded-3xl gap-4\">\n            <Loader2 className=\"w-10 h-10 text-indigo-600 animate-spin\" />\n            <p className=\"text-xs font-black text-gray-400 uppercase tracking-widest\">Đang tải thông báo...</p>\n          </div>\n        ) : announcements.length === 0 ? (\n          <div className=\"flex flex-col items-center justify-center py-20 bg-white border border-dashed border-gray-200 rounded-3xl gap-4\">\n            <div className=\"w-16 h-16 bg-gray-50 rounded-2xl flex items-center justify-center text-gray-300\">\n              <Bell className=\"w-8 h-8\" />\n            </div>\n            <p className=\"text-xs font-black text-gray-400 uppercase tracking-widest\">Không có thông báo nào được tìm thấy</p>\n          </div>\n        ) : (\n          announcements.map((item) => (\n            <div key={item.id} className=\"group bg-white border border-gray-100 rounded-2xl p-5 hover:shadow-xl hover:shadow-indigo-500/5 hover:border-indigo-100 transition-all cursor-pointer\">\n              <div className=\"flex items-start justify-between\">\n                <div className=\"flex items-start gap-4\">\n                  <div className={`w-10 h-10 rounded-xl flex items-center justify-center shrink-0 ${\n                    item.status === 'SENT' ? 'bg-indigo-50 text-indigo-600' : 'bg-amber-50 text-amber-600'\n                  }`}>\n                    <Bell className=\"w-5 h-5\" />\n                  </div>\n                  <div className=\"flex flex-col gap-1\">\n                    <div className=\"flex items-center gap-2\">\n                      <span className=\"font-extrabold text-gray-900 tracking-tight text-sm uppercase\">{item.title}</span>\n                      <span className={`px-1.5 py-0.5 rounded text-[8px] font-black uppercase tracking-wider ${\n                        item.status === 'SENT' ? 'bg-indigo-100 text-indigo-700' : 'bg-amber-100 text-amber-700'\n                      }`}>\n                        {item.status === 'SENT' ? 'Đã gửi' : 'Đang chờ'}\n                      </span>\n                    </div>\n                    <p className=\"text-xs text-gray-400 font-bold overflow-hidden text-ellipsis line-clamp-1\">{item.content}</p>\n                    <div className=\"flex items-center gap-4 mt-2\">\n                      <span className=\"text-[9px] font-extrabold text-gray-400 uppercase tracking-widest flex items-center gap-1.5 bg-gray-50 px-2 py-0.5 rounded-lg border border-gray-100\">\n                        <Users className=\"w-3 h-3 opacity-60\" /> {item.target_group === 'ALL' ? 'Tất cả' : item.target_group}\n                      </span>\n                      <span className=\"text-[9px] font-extrabold text-gray-400 uppercase tracking-widest flex items-center gap-1.5 bg-gray-50 px-2 py-0.5 rounded-lg border border-gray-100\">\n                        <Clock className=\"w-3 h-3 opacity-60\" /> {new Date(item.createdAt).toLocaleDateString('vi-VN')}\n                      </span>\n                    </div>\n                  </div>\n                </div>\n                <div className=\"flex items-center gap-2\">\n                  <button \n                    onClick={(e) => { e.stopPropagation(); handleDeleteClick(item.id); }}\n                    className=\"p-2 text-gray-300 hover:text-rose-500 opacity-0 group-hover:opacity-100 transition-all\"\n                  >\n                    <Trash2 className=\"w-5 h-5\" />\n                  </button>\n                  <button \n                    onClick={(e) => { e.stopPropagation(); openCompose(item); }}\n                    className=\"p-2 text-gray-300 hover:text-indigo-600 opacity-0 group-hover:opacity-100 transition-all\"\n                  >\n                    <MoreVertical className=\"w-5 h-5\" />\n                  </button>\n                </div>\n              </div>\n            </div>\n          ))\n        )}\n      </div>\n\n      {/* Compose Modal */}\n      {isComposeOpen && (\n        <div className=\"fixed inset-0 z-[100] flex items-center justify-center p-4 bg-gray-900/40 backdrop-blur-sm animate-in fade-in duration-300\">\n          <div className=\"bg-white rounded-[2rem] shadow-2xl w-full max-w-2xl overflow-hidden animate-in zoom-in-95 duration-300 flex flex-col max-h-[90vh]\">\n            \n            {/* Modal Header */}\n            <div className=\"px-10 py-8 border-b border-gray-100 flex items-center justify-between bg-white relative\">\n              <div className=\"absolute top-0 right-10 w-20 h-1 bg-indigo-600 rounded-b-full\"></div>\n              <div className=\"flex items-center gap-5\">\n                <div className=\"w-14 h-14 bg-indigo-600 rounded-2xl flex items-center justify-center text-white shadow-xl shadow-indigo-600/20\">\n                  <Send className=\"w-7 h-7 rotate-[-15deg] mt-0.5\" />\n                </div>\n                <div>\n                  <h3 className=\"text-xl font-black text-gray-900 tracking-tight uppercase\">\n                    {editingItem ? 'Chỉnh sửa thông báo' : 'Soạn thông báo mới'}\n                  </h3>\n                  <p className=\"text-[10px] text-gray-400 font-extrabold uppercase tracking-[0.2em] mt-1\">\n                    {editingItem ? 'Edit Announcement' : 'Compose Announcement'}\n                  </p>\n                </div>\n              </div>\n              <button \n                onClick={() => setIsComposeOpen(false)}\n                className=\"p-3 text-gray-400 hover:text-rose-500 hover:bg-rose-50 rounded-2xl transition-all border border-transparent hover:border-rose-100\"\n              >\n                <X className=\"w-6 h-6\" />\n              </button>\n            </div>\n\n            {/* Modal Form */}\n            <div className=\"p-10 overflow-y-auto space-y-8 hide-scrollbar\">\n              \n              {/* Title */}\n              <div className=\"flex flex-col gap-2\">\n                <label className=\"text-[10px] font-black text-gray-400 uppercase tracking-[0.2em]\">TIÊU ĐỀ THÔNG BÁO</label>\n                <input \n                  type=\"text\"\n                  value={title}\n                  onChange={e => setTitle(e.target.value)}\n                  placeholder=\"Ví dụ: Thông báo nghỉ lễ 30/04 - 01/05\"\n                  className=\"w-full px-6 py-4 bg-gray-50 border border-gray-100 rounded-2xl text-sm font-black tracking-tight focus:outline-none focus:ring-2 focus:ring-indigo-600/10 focus:bg-white transition-all outline-none\"\n                />\n              </div>\n\n              {/* Target & Schedule */}\n              <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n                <div className=\"flex flex-col gap-2\">\n                  <label className=\"text-[10px] font-black text-gray-400 uppercase tracking-[0.2em]\">ĐỐI TƯỢNG NHẬN</label>\n                  <select \n                    value={targetGroup}\n                    onChange={e => setTargetGroup(e.target.value)}\n                    className=\"w-full px-6 py-4 bg-gray-50 border border-gray-100 rounded-2xl text-sm font-black tracking-tight focus:outline-none focus:ring-2 focus:ring-indigo-600/10 focus:bg-white transition-all outline-none uppercase font-bold\"\n                  >\n                    <option value=\"ALL\">Tất cả đối tượng</option>\n                    <option value=\"STUDENT\">Tất cả Học viên</option>\n                    <option value=\"TEACHER\">Đội ngũ giáo viên</option>\n                    <option value=\"STAFF\">Nhân viên văn phòng</option>\n                  </select>\n                </div>\n                <div className=\"flex flex-col gap-2\">\n                  <label className=\"text-[10px] font-black text-gray-400 uppercase tracking-[0.2em]\">HẸN GIỜ GỬI (TÙY CHỌN)</label>\n                  <div className=\"relative\">\n                    <Clock className=\"absolute left-6 top-1/2 -translate-y-1/2 w-4 h-4 text-indigo-400\" />\n                    <input \n                      type=\"datetime-local\"\n                      value={scheduledAt}\n                      onChange={e => setScheduledAt(e.target.value)}\n                      className=\"w-full pl-12 pr-6 py-4 bg-gray-50 border border-gray-100 rounded-2xl text-sm font-black tracking-tight focus:outline-none focus:ring-2 focus:ring-indigo-600/10 focus:bg-white transition-all outline-none\"\n                    />\n                  </div>\n                </div>\n              </div>\n\n              {/* Channel Selection — fully interactive */}\n              <div className=\"flex flex-col gap-3\">\n                <label className=\"text-[10px] font-black text-gray-400 uppercase tracking-[0.2em]\">KÊNH PHÁT TIN</label>\n                <div className=\"flex flex-wrap gap-3\">\n                  <ChannelButton channelKey=\"app\"   icon={Bell}  label=\"App Alert\" />\n                  <ChannelButton channelKey=\"email\" icon={Mail}  label=\"Email\" />\n                  <ChannelButton channelKey=\"sms\"   icon={Phone} label=\"SMS/Zalo\" />\n                </div>\n              </div>\n\n              {/* Content */}\n              <div className=\"flex flex-col gap-2\">\n                <div className=\"flex items-center justify-between\">\n                  <label className=\"text-[10px] font-black text-gray-400 uppercase tracking-[0.2em]\">NỘI DUNG THÔNG BÁO</label>\n                  <span className=\"text-[9px] font-extrabold text-indigo-400 uppercase tracking-widest\">Draft Saved</span>\n                </div>\n                <textarea \n                  rows={8}\n                  value={content}\n                  onChange={e => setContent(e.target.value)}\n                  placeholder=\"Nhập nội dung thông báo chi tiết...\"\n                  className=\"w-full px-6 py-5 bg-gray-50 border border-gray-100 rounded-[2rem] text-sm font-bold tracking-tight focus:outline-none focus:ring-2 focus:ring-indigo-600/10 focus:bg-white transition-all outline-none resize-none leading-relaxed\"\n                />\n              </div>\n            </div>\n\n            {/* Modal Footer */}\n            <div className=\"p-10 border-t border-gray-100 bg-white flex items-center justify-between\">\n              <div className=\"flex items-center gap-2 text-rose-400 group cursor-pointer\">\n                <AlertCircle className=\"w-4 h-4 group-hover:animate-pulse\" />\n                <span className=\"text-[9px] font-black uppercase tracking-widest\">Yêu cầu xác nhận gửi tin</span>\n              </div>\n              <div className=\"flex items-center gap-6\">\n                <button \n                  onClick={() => setIsComposeOpen(false)}\n                  className=\"text-[10px] font-black text-gray-400 hover:text-gray-900 transition-all uppercase tracking-[0.2em]\"\n                >\n                  Hủy bỏ\n                </button>\n                <button\n                  onClick={handleBroadcast}\n                  disabled={isSubmitting}\n                  className=\"flex items-center gap-3 px-10 py-3.5 bg-indigo-600 text-white font-black rounded-2xl shadow-2xl shadow-indigo-600/30 hover:bg-indigo-700 hover:scale-[1.02] active:scale-[0.98] transition-all uppercase tracking-[0.2em] text-xs disabled:opacity-50 disabled:cursor-not-allowed\"\n                >\n                  {isSubmitting ? <Loader2 className=\"w-4 h-4 animate-spin\" /> : <Send className=\"w-4 h-4 rotate-[-15deg]\" />} \n                  {isSubmitting ? 'Đang thực hiện...' : (editingItem ? 'Cập nhật ngay' : 'Phát tin ngay')}\n                </button>\n              </div>\n            </div>\n\n          </div>\n        </div>\n      )}\n\n      <ConfirmDeleteModal \n        isOpen={isDeleteModalOpen}\n        onClose={() => setIsDeleteModalOpen(false)}\n        item={itemToDelete}\n        onConfirm={handleDeleteConfirm}\n        message={`Bạn có chắc chắn muốn xóa thông 