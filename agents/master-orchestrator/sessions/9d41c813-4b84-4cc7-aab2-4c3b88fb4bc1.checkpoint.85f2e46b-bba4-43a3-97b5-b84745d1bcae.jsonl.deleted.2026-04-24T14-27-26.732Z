rap-backup/PRD.md\n/root/.openclaw/workspaces/teacher-driving-training-system.bootstrap-backup/PROJECT_CONTEXT_PACK.md\n/root/.openclaw/workspaces/teacher-driving-training-system.bootstrap-backup/README.md\n---\n/root/.openclaw/workspaces/teacher-driving-training-system.bootstrap-backup/ahv-qlhv-be/docs/SMOKE_TEST_CHECKLIST.md\n/root/.openclaw/workspaces/teacher-driving-training-system.bootstrap-backup/ahv-qlhv-be/docs/database_design.md\n/root/.openclaw/workspaces/teacher-driving-training-system.bootstrap-backup/ahv-qlhv-be/docs/CONTROLLER_LOGGING_CONVENTION.md\n/root/.openclaw/workspaces/teacher-driving-training-system.bootstrap-backup/ahv-qlhv-be/docs/MIGRATION_EXECUTION.md\n/root/.openclaw/workspaces/teacher-driving-training-system.bootstrap-backup/ahv-qlhv-be/docs/openspec/notification-migration-execution.md\n/root/.openclaw/workspaces/teacher-driving-training-system.bootstrap-backup/ahv-qlhv-be/docs/openspec/notification-migration-verification.md\n/root/.openclaw/workspaces/teacher-driving-training-system.bootstrap-backup/ahv-qlhv-be/docs/MIGRATION_4COLLECTION_ALIGNED.md\n/root/.openclaw/workspaces/teacher-driving-training-system.bootstrap-backup/ahv-qlhv-be/docs/MIGRATION_IMPLEMENTATION_CHECKLIST.md\n/root/.openclaw/workspaces/teacher-driving-training-system.bootstrap-backup/ahv-qlhv-be/docs/MIGRATION_NOTIFICATION_3COLLECTION.md","cwd":"/root/.openclaw/workspaces2/v4-ecosystem-review/master-orchestrator"},"isError":false,"timestamp":1776286276348}}
