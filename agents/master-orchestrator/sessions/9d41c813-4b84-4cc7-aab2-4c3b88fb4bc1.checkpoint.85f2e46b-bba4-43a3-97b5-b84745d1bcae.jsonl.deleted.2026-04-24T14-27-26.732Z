anged to preserve FE compatibility.\n */\nimport express from 'express';\nimport * as notifyController from '@/interface/controllers/notify.controller';\nimport { paginationMiddleware } from '@/interface/middlewares/pagination.middleware';\n\nconst router = express.Router();\n\n// GET /notifications/user/:userId\nrouter.get('/user/:userId', paginationMiddleware, notifyController.getNotificationsByUser);\n\n// PATCH /notifications/user/:userId/read-all\nrouter.patch('/user/:userId/read-all', notifyController.markAllAsRead);\n\n// POST /notifications/send\nrouter.post('/send', notifyController.sendNotification);\n\n// PATCH /notifications/:id/read\nrouter.patch('/:id/read', notifyController.markAsRead);\n\n// DELETE /notifications/:id\nrouter.delete('/:id', notifyController.deleteNotification);\n\nexport default router;\n\n=== FE notification components ===\n/root/.openclaw/workspaces/teacher-driving-training-system.bootstrap-backup/ahv-qlhv-fe/src/app/notifications\n/root/.openclaw/workspaces/teacher-driving-training-system.bootstrap-backup/ahv-qlhv-fe/src/app/settings/notifications\n/root/.openclaw/workspaces/teacher-driving-training-system.bootstrap-backup/ahv-qlhv-fe/src/services/notificationService.ts\n\n=== .env files ===\n/root/.openclaw/workspaces/teacher-driving-training-system.bootstrap-backup/ahv-qlhv-be/.env\n/root/.openclaw/workspaces/teacher-driving-training-system.bootstrap-backup/ahv-qlhv-be/.env.example","cwd":"/root/.openclaw/workspaces2/v4-ecosystem-review/master-orchestrator"},"isError":false,"timestamp":1776285615995}}
