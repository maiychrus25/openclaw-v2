  \"get\": {\n        \"tags\": [\"LicenseCategory\"],\n        \"summary\": \"Danh sách loại bằng lái\",\n        \"security\": [{ \"BearerAuth\": [] }],\n        \"parameters\": [{ \"$ref\": \"#/components/schemas/PaginationQuery\" }],\n        \"responses\": { \"200\": { \"description\": \"Danh sách license categories\" } }\n      },\n      \"post\": {\n        \"tags\": [\"LicenseCategory\"],\n        \"summary\": \"Tạo loại bằng lái\",\n        \"security\": [{ \"BearerAuth\": [] }],\n        \"requestBody\": { \"required\": true, \"content\": { \"application/json\": { \"schema\": { \"$ref\": \"#/components/schemas/LicenseCategory\" } } } },\n        \"responses\": { \"201\": { \"description\": \"Tạo thành công\" } }\n      }\n    },\n    \"/license-categories/{id}\": {\n      \"get\": {\n        \"tags\": [\"LicenseCategory\"],\n        \"summary\": \"Chi tiết loại bằng lái\",\n        \"security\": [{ \"BearerAuth\": [] }],\n        \"parameters\": [{ \"name\": \"id\", \"in\": \"path\", \"required\": true, \"schema\": { \"type\": \"string\" } }],\n        \"responses\": { \"200\": { \"description\": \"Chi tiết\" } }\n      },\n      \"put\": {\n        \"tags\": [\"LicenseCategory\"],\n        \"summary\": \"Cập nhật loại bằng lái\",\n        \"security\": [{ \"BearerAuth\": [] }],\n        \"parameters\": [{ \"name\": \"id\", \"in\": \"path\", \"required\": true, \"schema\": { \"type\": \"string\" } }],\n        \"requestBody\": { \"required\": true, \"content\": { \"application/json\": { \"schema\": { \"$ref\": \"#/components/schemas/LicenseCategory\" } } } },\n        \"responses\": { \"200\": { \"description\": \"Cập nhật thành công\" } }\n      },\n      \"delete\": {\n        \"tags\": [\"LicenseCategory\"],\n        \"summary\": \"Xóa loại bằng lái\",\n        \"security\": [{ \"BearerAuth\": [] }],\n        \"parameters\": [{ \"name\": \"id\", \"in\": \"path\", \"required\": true, \"schema\": { \"type\": \"string\" } }],\n        \"responses\": { \"200\": { \"description\": \"Xóa thành công\" } }\n      }\n    },\n    \"/dat/analytics\": {\n      \"get\": {\n        \"tags\": [\"DAT\"],\n        \"summary\": \"Phân tích dữ liệu Đào tạo thực hành (DAT)\",\n        \"security\": [{ \"BearerAuth\": [] }],\n        \"parameters\": [\n          { \"name\": \"from_date\", \"in\": \"query\", \"schema\": { \"type\": \"string\", \"format\": \"date\" } },\n          { \"name\": \"to_date\", \"in\": \"query\", \"schema\": { \"type\": \"string\", \"format\": \"date\" } }\n        ],\n        \"responses\": {\n          \"200\": { \"description\": \"Phân tích DAT\", \"content\": { \"application/json\": { \"schema\": { \"type\": \"object\", \"properties\": { \"success\": { \"type\": \"boolean\" }, \"data\": { \"$ref\": \"#/components/schemas/DATAnalytics\" } } } } } }\n        }\n      }\n    },\n    \"/dat/sessions\": {\n      \"post\": {\n        \"tags\": [\"DAT\"],\n        \"summary\": \"Ghi nhận buổi DAT mới\",\n        \"security\": [{ \"BearerAuth\": [] }],\n        \"requestBody\": {\n          \"required\": true,\n          \"content\": { \"application/json\": { \"schema\": { \"type\": \"object\", \"properties\": { \"student_id\": { \"type\": \"string\" }, \"stadium_id\": { \"type\": \"string\" }, \"date\": { \"type\": \"string\", \"format\": \"date-time\" }, \"duration_minutes\": { \"type\": \"integer\" }, \"note\": { \"type\": \"string\" } } } } }\n        },\n        \"responses\": { \"201\": { \"description\": \"Ghi nhận thành công\" } }\n      }\n    },\n    \"/dat/students/{studentId}/sessions\": {\n      \"get\": {\n        \"tags\": [\"DAT\"],\n        \"summary\": \"Lịch sử DAT của học viên\",\n        \"security\": [{ \"BearerAuth\": [] }],\n        \"parameters\": [\n          { \"name\": \"studentId\", \"in\": \"path\", \"required\": true, \"schema\": { \"type\": \"string\" } },\n          { \"$ref\": \"#/components/schemas/PaginationQuery\" }\n        ],\n        \"responses\": { \"200\": { \"description\": \"Lịch sử DAT\" } }\n      }\n    },\n    \"/data/export\": {\n      \"post\": {\n        \"tags\": [\"Data\"],\n        \"summary\": \"Export toàn bộ dữ liệu hệ thống\",\n        \"description\": \"Export tất cả collection ra file JSON. Chỉ admin mới được phép.\",\n        \"security\": [{ \"BearerAuth\": [] }],\n        \"requestBody\": {\n          \"content\": { \"application/json\": { \"schema\": { \"type\": \"object\", \"properties\": { \"collections\": { \"type\": \"array\", \"items\": { \"type\": \"string\" }, \"example\": [\"students\", \"courses\", \"payments\"] } } } } }\n        },\n        \"responses\": { \"200\": { \"description\": \"File JSON\", \"content\": { \"application/json\": {} } } }\n      }\n    },\n    \"/data/import\": {\n      \"post\": {\n        \"tags\": [\"Data\"],\n        \"summary\": \"Import dữ liệu vào hệ thống\",\n        \"description\": \"Import data từ file JSON. Chỉ admin mới được phép.\",\n        \"security\": [{ \"BearerAuth\": [] }],\n        \"requestBody\": {\n          \"required\": true,\n          \"content\": { \"application/json\": { \"schema\": { \"type\": \"object\", \"properties\": { \"collection\": { \"type\": \"string\", \"example\": \"students\" }, \"data\": { \"type\": \"array\", \"items\": { \"type\": \"object\" } }, \"mode\": { \"type\": \"string\", \"enum\": [\"upsert\", \"replace\"], \"default\": \"upsert\" } } } } }\n        },\n        \"responses\": { \"200\": { \"description\": \"Import thành công, trả về số bản ghi\" } }\n      }\n    }\n  }\n}\n"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":485,"output":17032,"cacheRead":62814,"cacheWrite":457,"totalTokens":80788,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776285887587,"responseId":"062f2bc17e1fdc24534aca77aa8c18f3"}}
