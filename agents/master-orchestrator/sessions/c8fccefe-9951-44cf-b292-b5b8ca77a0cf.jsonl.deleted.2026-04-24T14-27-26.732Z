/v4-ecosystem-review/ahv-dtlx-backend/src/modules/internalCosts/internalCosts.model.ts"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":1138,"output":434,"cacheRead":24341,"cacheWrite":1646,"totalTokens":27559,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776143037184,"responseId":"062cfdbea05a741b4b3db45fcc906d5c"}}
{"type":"message","id":"0d20733e","parentId":"23d0d88a","timestamp":"2026-04-14T05:04:06.247Z","message":{"role":"toolResult","toolCallId":"call_function_ru76ja6l2e4v_1","toolName":"read","content":[{"type":"text","text":"import mongoose, { Schema, Document } from 'mongoose';\nimport { IPaymentResponse } from './payments.interface';\n\nexport interface IPayment extends Document {\n    _id: Schema.Types.ObjectId;\n    course_student_id: Schema.Types.ObjectId;\n    sale_id: Schema.Types.ObjectId;\n    payment_date: Date;\n    type: string;\n    note?: string;\n    comfirmer_id: Schema.Types.ObjectId;\n    is_received: boolean;\n    received_fee: number;\n    created_at?: Date;\n    updated_at?: Date;\n\n    transform(): IPaymentResponse;\n}\n\nconst PaymentSchema: Schema<IPayment> = new Schema<IPayment>(\n    {\n        _id: { type: Schema.Types.ObjectId, auto: true },\n        course_student_id: { type: Schema.Types.ObjectId, index: true },\n        sale_id: { type: Schema.Types.ObjectId },\n        payment_date: { type: Date },\n        type: {\n            type: String,\n            enum: [\n                'tuition_fee',\n                'chip_registration_fee',\n                'pickup_fee',\n                'chip_deposit_fee',\n                're_exam_fee',\n                'theory_completed',\n                'practice_completed',\n                'graduation_exam',\n                'other',\n            ],\n        },\n        note: { type: String },\n        comfirmer_id: { type: Schema.Types.ObjectId },\n        is_received: { type: Boolean },\n        received_fee: { type: Number },\n    },\n    {\n        timestamps: {\n            createdAt: 'created_at',\n            updatedAt: 'updated_at',\n        },\n        versionKey: false,\n    },\n);\n\nPaymentSchema.index({ created_at: -1, course_student_id: 1 });\n\nPaymentSchema.methods.transform = function (): IPaymentResponse {\n    return {\n        id: this._id.toString(),\n        course_student_id: this.course_student_id?.toString(),\n        sale_id: this.sale_id?.toString(),\n        payment_date: this.payment_date,\n        type: this.type,\n        note: this.note,\n        comfirmer_id: this.comfirmer_id?.toString(),\n        is_received: this.is_received,\n        received_fee: this.received_fee,\n        created_at: this.created_at,\n        updated_at: this.updated_at,\n    };\n};\n\nexport default mongoose.model<IPayment>('Payments', PaymentSchema);\n"}],"isError":false,"timestamp":1776143046045}}
{"type":"message","id":"a0457f20","parentId":"0d20733e","timestamp":"2026-04-14T05:04:06.449Z","message":{"role":"toolResult","toolCallId":"call_function_ru76ja6l2e4v_2","toolName":"read","content":[{"type":"text","text":"import mongoose, { Schema, Document, Model } from 'mongoose';\n\nexport interface ICourseResponse {\n    id: string;\n    license_category_id: string | null;\n\n    code: string;\n    system_course_id?: number;\n    system_course_code?: string;\n    curriculum_id?: number;\n\n    management_record_number?: string;\n    description?: string;\n\n    report_start_date?: Date;\n    start_date?: Date;\n    end_date?: Date;\n    dat_date?: Date;\n    cabin_date?: Date;\n\n    student_number?: number;\n    decision_to_sign?: string;\n\n    duration?: number;\n    status: string;\n    course_fee?: number;\n\n    created_at?: Date;\n    updated_at?: Date;\n}\n\nexport interface ICourse extends Document {\n    _id: Schema.Types.ObjectId;\n    license_category_id?: Schema.Types.ObjectId;\n\n    code: string;\n    system_course_id?: number;\n    system_course_code?: string;\n    curriculum_id?: number;\n\n    management_record_number?: string;\n    description?: string;\n\n    report_start_date?: Date;\n    start_date?: Date;\n    end_date?: Date;\n    dat_date?: Date;\n    cabin_date?: Date;\n\n    decision_to_sign?: string;\n\n    duration?: number;\n    status: string;\n    course_fee?: number;\n\n    created_at?: Date;\n    updated_at?: Date;\n\n    transform(): ICourseResponse;\n}\n\nconst CourseSchema: Schema<ICourse> = new Schema<ICourse>(\n    {\n        _id: { type: Schema.Types.ObjectId, auto: true },\n\n        license_category_id: {\n            type: Schema.Types.ObjectId,\n            ref: 'LicenseCategories',\n            default: null,\n        },\n\n        code: { type: String, required: true, trim: true, unique: true },\n        system_course_id: { type: Number, default: undefined, min: 0 },\n        system_course_code: { type: String, trim: true, default: undefined },\n        curriculum_id: { type: Number, default: undefined, min: 0 },\n\n        management_record_number: {\n            type: String,\n            trim: true,\n            default: undefined,\n        },\n        description: { type: String, default: '' },\n\n        report_start_date: { type: Date, default: undefined },\n        start_date: { type: Date, default: undefined },\n        end_date: { type: Date, default: undefined },\n        dat_date: { type: Date, default: undefined },\n        cabin_date: { type: Date, default: undefined },\n\n        decision_to_sign: { type: String, trim: true, default: undefined },\n\n        duration: { type: Number, default: undefined, min: 0 },\n        status: { type: String, trim: true, default: undefined },\n        course_fee: { type: Number, default: 0, min: 0 },\n    },\n    {\n        timestamps: { createdAt: 'created_at', updatedAt: 'updated_at' },\n        versionKey: false,\n    },\n);\n\nCourseSchema.methods.transform = function (): ICourseResponse {\n    return {\n        id: this._id.toString(),\n        license_category_id: this.license_category_id ? this.license_category_id.toString() : null,\n\n        code: this.code,\n        system_course_id: this.system_course_id,\n        system_course_code: this.system_course_code,\n        curriculum_id: this.curriculum_id,\n\n        management_record_number: this.management_record_number,\n        description: this.description,\n\n        report_start_date: this.report_start_date,\n        start_date: this.start_date,\n        end_date: this.end_date,\n        dat_date: this.dat_date,\n        cabin_date: this.cabin_date,\n\n        decision_to_sign: this.decision_to_sign,\n\n        duration: this.duration,\n        status: this.status,\n        course_fee: this.course_fee,\n\n        created_at: this.created_at,\n        updated_at: this.updated_at,\n    };\n};\n\nconst Courses: Model<ICourse> = mongoose.model<ICourse>('Courses', CourseSchema);\nexport default Courses;\n"}],"isError":false,"timestamp":1776143046247}}
{"type":"message","id":"20dbb770","parentId":"a0457f20","timestamp":"2026-04-14T05:04:06.654Z","message":{"role":"toolResult","toolCallId":"call_function_ru76ja6l2e4v_3","toolName":"read","content":[{"type":"text","text":"import mongoose, { Model, Schema, Document } from 'mongoose';\nimport { ILessonResponse } from './lessons.interface';\n\nexport interface ILesson extends Document {\n    course_student_id?: mongoose.Types.ObjectId;\n    status: string;\n    teacher_id?: mongoose.Types.ObjectId;\n    name: string;\n    start_time: Date;\n    end_time: Date;\n    description: string;\n    lesson_type_id?: mongoose.Types.ObjectId;\n    vehicle_id?: mongoose.Types.ObjectId;\n    is_night_course: boolean;\n    is_automatic_course: boolean;\n    km?: number;\n    hour?: string;\n    vehicle_type: string;\n    stadium_id: mongoose.Types.ObjectId;\n    order: number;\n    confirmed?: boolean;\n    pickup_point: string;\n    is_pickup: boolean;\n    created_at: Date;\n    updated_at: Date;\n\n    transform(): ILessonResponse;\n}\n\nconst LessonSchema: Schema<ILesson> = new Schema(\n    {\n        course_student_id: {\n            type: Schema.Types.ObjectId,\n            ref: 'CourseStudents',\n            index: true,\n        },\n        status: {\n            type: String,\n            enum: ['pending', 'in_progress', 'completed', 'no_teacher', 'canceled_class', 'dropped_class', 'deleted'],\n            default: 'pending',\n            required: true,\n        },\n        teacher_id: {\n            type: Schema.Types.ObjectId,\n            ref: 'Users',\n        },\n        name: {\n            type: String,\n            required: true,\n        },\n        start_time: {\n            type: Date,\n            required: true,\n            index: true,\n        },\n        end_time: {\n            type: Date,\n            required: true,\n        },\n        description: {\n            type: String,\n            default: '',\n        },\n        lesson_type_id: {\n            type: Schema.Types.ObjectId,\n        },\n        vehicle_id: {\n            type: Schema.Types.ObjectId,\n        },\n        is_night_course: {\n            type: Boolean,\n            default: false,\n        },\n        is_automatic_course: {\n            type: Boolean,\n            default: false,\n        },\n        km: {\n            type: Number,\n            default: 0,\n        },\n        hour: {\n            type: String,\n            default: '00:00',\n        },\n        vehicle_type: {\n            type: String,\n            enum: ['car', 'motorbike'],\n            required: true,\n        },\n        pickup_point: {\n            type: String,\n        },\n        is_pickup: {\n            type: Boolean,\n            default: false,\n        },\n        stadium_id: {\n            type: Schema.Types.ObjectId,\n        },\n        order: {\n            type: Number,\n            default: 1,\n        },\n        confirmed: {\n            type: Boolean,\n            default: false,\n        },\n    },\n    {\n        timestamps: {\n            createdAt: 'created_at',\n            updatedAt: 'updated_at',\n        },\n    },\n);\n\nLessonSchema.methods.transform = function (): ILessonResponse {\n    const transformed: any = this.toJSON();\n    transformed.id = transformed._id.toString();\n\n    const fieldsToConvert = ['course_student_id', 'teacher_id', 'lesson_type_id', 'vehicle_id', 'stadium_id'];\n\n    fieldsToConvert.forEach((field) => {\n        if (transformed[field]) transformed[field] = transformed[field].toString();\n    });\n\n    return transformed;\n};\n\nconst Lesson: Model<ILesson> = mongoose.model<ILesson>('Lessons', LessonSchema);\n\nexport default Lesson;\n"}],"isError":false,"timestamp":1776143046449}}
{"type":"message","id":"03522c38","parentId":"20dbb770","timestamp":"2026-04-14T05:04:06.890Z","message":{"role":"toolResult","toolCallId":"call_function_ru76ja6l2e4v_4","toolName":"read","content":[{"type":"text","text":"import mongoose, { Schema, Document, Model, Types } from 'mongoose';\nimport { ExamResult, ExamType, IExamTypeResult } from './exams.interface';\n\nexport interface IExamResponse {\n    id: string;\n\n    course_student_id: string | null;\n    exam_types: Map<string, IExamTypeResult>;\n    stadium_id: string | null;\n    parent_id: string | null;\n\n    exam_type: string;\n    name: string;\n    status: string;\n\n    start_time?: Date;\n    end_time?: Date;\n\n    description?: string;\n    session?: string;\n    exam_number?: number;\n\n    is_pickup: boolean;\n    pickup_point?: string;\n    car_chip?: {\n        booked_chip_hour?: number;\n        gifted_chip_hour?: number;\n    };\n    result: string;\n    registration_number: string;\n\n    created_at?: Date;\n    updated_at?: Date;\n}\n\nexport interface IExam extends Document {\n    _id: Types.ObjectId;\n\n    course_student_id?: Types.ObjectId | null;\n    exam_types?: Map<string, IExamTypeResult>;\n    stadium_id?: Types.ObjectId | null;\n    parent_id?: Types.ObjectId | null;\n\n    name?: string;\n    status?: string;\n    exam_type?: ExamType;\n\n    start_time?: Date;\n    end_time?: Date;\n\n    description?: string;\n    session?: string;\n    exam_number?: number;\n\n    is_pickup?: boolean;\n    pickup_point?: string;\n    result?: ExamResult;\n    registration_number?: string;\n    created_at?: Date;\n    updated_at?: Date;\n\n    transform(): IExamResponse;\n}\n\nconst IExamTypeResultSchema = new Schema(\n    {\n        result: { type: String },\n        name: { type: String },\n        lesson_type_id: { type: String },\n        description: { type: String },\n    },\n    { _id: false },\n);\n\nconst examSchema = new Schema<IExam>(\n    {\n        _id: {\n            type: Schema.Types.ObjectId,\n        },\n        course_student_id: {\n            type: Schema.Types.ObjectId,\n            ref: 'CourseStudents',\n            default: null,\n            index: true,\n        },\n        exam_types: {\n            type: Map,\n            of: IExamTypeResultSchema,\n        },\n        stadium_id: {\n            type: Schema.Types.ObjectId,\n            ref: 'Stadiums',\n            default: null,\n        },\n        parent_id: {\n            type: Schema.Types.ObjectId,\n            ref: 'Exam',\n            default: null,\n        },\n        name: {\n            type: String,\n            trim: true,\n        },\n        status: {\n            type: String,\n            trim: true,\n        },\n        exam_type: String,\n        start_time: {\n            type: Date,\n            default: undefined,\n            index: true,\n        },\n        end_time: {\n            type: Date,\n            default: undefined,\n        },\n        description: {\n            type: String,\n            default: '',\n        },\n        session: {\n            type: String,\n            trim: true,\n            default: undefined,\n        },\n        exam_number: {\n            type: Number,\n            min: 0,\n            default: undefined,\n        },\n        is_pickup: {\n            type: Boolean,\n            default: false,\n        },\n        pickup_point: {\n            type: String,\n            trim: true,\n            default: undefined,\n        },\n        registration_number: String,\n        result: {\n            type: String,\n            trim: true,\n            default: ExamResult.NoResult,\n        },\n    },\n    {\n        timestamps: true,\n        versionKey: false,\n        toJSON: { virtuals: true },\n        toObject: { virtuals: true },\n    },\n);\n\n// INDEXES\nexamSchema.index({ course_student_id: 1 });\nexamSchema.index({ lesson_type_id: 1 });\nexamSchema.index({ stadium_id: 1 });\n\n// VIRTUALS\nexamSchema.virtual('course', {\n    ref: 'Course',\n    foreignField: 'course_student_id',\n    localField: '_id',\n});\n\nexamSchema.methods.transform = function (): IExamResponse {\n    const examTypesMap = this.exam_types as Map<string, any>;\n    const transformedExamTypes: Record<string, IExamTypeResult> = {};\n\n    examTypesMap?.forEach((value: any, key: string) => {\n        transformedExamTypes[key] = {\n            result: value.result,\n            name: value.name,\n            lesson_type_id: value.lesson_type_id,\n            description: value.description,\n        };\n    });\n\n    return {\n        id: this._id.toString(),\n        course_student_id: this.course_student_id ? this.course_student_id.toString() : null,\n        stadium_id: this.stadium_id ? this.stadium_id.toString() : null,\n        parent_id: this.parent_id ? this.parent_id.toString() : null,\n        exam_types: examTypesMap,\n        name: this.name,\n        status: this.status,\n        exam_type: this.exam_type,\n        result: this.result,\n\n        start_time: this.start_time,\n        end_time: this.end_time,\n\n        description: this.description,\n        session: this.session,\n        exam_number: this.exam_number,\n        registration_number: this.registration_number,\n\n        is_pickup: this.is_pickup,\n        pickup_point: this.pickup_point,\n\n        created_at: this.created_at,\n        updated_at: this.updated_at,\n    };\n};\n\nconst Exams: Model<IExam> = mongoose.model<IExam>('Exams', examSchema);\nexport default Exams;\n"}],"isError":false,"timestamp":1776143046654}}
{"type":"message","id":"75fdd968","parentId":"03522c38","timestamp":"2026-04-14T05:04:07.132Z","message":{"role":"toolResult","toolCallId":"call_function_ru76ja6l2e4v_5","toolName":"read","content":[{"type":"text","text":"import mongoose, { Schema, Model } from 'mongoose';\nimport { IVehicle } from './vehicles.interface';\n\nconst VehicleSchema = new Schema<IVehicle>(\n    {\n        license_plate: {\n            type: String,\n            trim: true,\n            required: [true, 'Biển số xe là bắt buộc'],\n            unique: true,\n            index: true,\n        },\n        vehicle_model: {\n            type: String,\n            trim: true,\n        },\n        license_category_id: {\n            type: Schema.Types.ObjectId,\n            ref: 'LicenseCategories',\n            index: true,\n            required: [true, 'Hạng bằng đào tạo là bắt buộc'],\n        },\n        type: {\n            type: String,\n            trim: true,\n        },\n        color: {\n            type: String,\n            trim: true,\n        },\n        training_license_number: {\n            type: String,\n            trim: true,\n            index: true,\n        },\n        manufacture_year: {\n            type: Number,\n        },\n        description: {\n            type: String,\n            trim: true,\n            default: '',\n        },\n    },\n    {\n        timestamps: { createdAt: 'created_at', updatedAt: 'updated_at' },\n        versionKey: false,\n        toJSON: {\n            virtuals: true,\n            transform: (doc, ret) => {\n                ret.id = ret._id.toString();\n                delete ret._id;\n                return ret;\n            },\n        },\n        toObject: { virtuals: true },\n    },\n);\n\nVehicleSchema.index({ license_plate: 'text' });\nVehicleSchema.index({ license_category_id: 1, training_license_number: 1 });\n\nVehicleSchema.method('transform', function () {\n    const obj = this.toObject();\n    return {\n        id: obj._id.toString(),\n        license_plate: obj.license_plate,\n        vehicle_model: obj.vehicle_model,\n        license_category_id: obj.license_category_id ? obj.license_category_id.toString() : null,\n        type: obj.type,\n        color: obj.color,\n        training_license_number: obj.training_license_number,\n        manufacture_year: obj.manufacture_year,\n        description: obj.description,\n        created_at: obj.created_at,\n        updated_at: obj.updated_at,\n    };\n});\n\nconst Vehicles: Model<IVehicle> = mongoose.models.Vehicles || mongoose.model<IVehicle>('Vehicles', VehicleSchema);\n\nexport default Vehicles;\n"}],"isError":false,"timestamp":1776143046891}}
{"type":"message","id":"2df18bbd","parentId":"75fdd968","timestamp":"2026-04-14T05:04:07.357Z","message":{"role":"toolResult","toolCallId":"call_function_ru76ja6l2e4v_6","toolName":"read","content":[{"type":"text","text":"import mongoose, { Schema, Model, Types, Document } from 'mongoose';\nimport { IStadium, IStadiumResponse } from './stadiums.interface';\n\nconst StadiumSchema = new Schema<IStadium>(\n    {\n        name: {\n            type: String,\n            required: [true, 'Tên sân vận động là bắt buộc'],\n            trim: true,\n        },\n        locate: {\n            type: String,\n            trim: true,\n            default: '',\n        },\n        note: {\n            type: String,\n            trim: true,\n            default: '',\n        },\n        status: {\n            type: String,\n            enum: ['active', 'inactive', 'maintenance'],\n            default: 'active',\n            trim: true,\n        },\n    },\n    {\n        timestamps: { createdAt: 'created_at', updatedAt: 'updated_at' },\n        versionKey: false,\n        toJSON: {\n            transform: (doc, ret) => {\n                ret.id = ret._id.toString();\n                delete ret._id;\n                return ret;\n            },\n        },\n    },\n);\n\nStadiumSchema.index({ name: 1 });\n\nStadiumSchema.methods.transform = function (this: IStadium): IStadiumResponse {\n    return {\n        id: this._id.toString(),\n        name: this.name,\n        locate: this.locate,\n        note: this.note,\n        status: this.status,\n        created_at: this.created_at,\n        updated_at: this.updated_at,\n    };\n};\n\nconst Stadiums = mongoose.model<IStadium>('Stadiums', StadiumSchema, 'stadium');\n\nexport default Stadiums;\n"}],"isError":false,"timestamp":1776143047133}}
{"type":"message","id":"e5fd1230","parentId":"2df18bbd","timestamp":"2026-04-14T05:04:07.696Z","message":{"role":"toolResult","toolCallId":"call_function_ru76ja6l2e4v_7","toolName":"read","content":[{"type":"text","text":"import mongoose, { Schema, Document, Model, Types } from 'mongoose';\n\nimport { CourseStudentStatusEnum } from './coursesStudents.interface';\n\nexport interface ICourseStudentResponse {\n    id: string;\n\n    student_id?: string | null;\n    course_id?: string | null;\n    stadium_id?: string | null;\n    teacher_id?: string | null;\n    sale_id?: string | null;\n\n    fee?: number;\n    paid_fee?: number;\n\n    booked_chip_hour?: string;\n    gifted_chip_hour?: string;\n    graduation_date?: Date;\n    health_check_date?: Date;\n    contract_date?: Date;\n\n    note?: string;\n\n    status?: string;\n    automatic_car_hour?: string;\n    day_time_hour?: string;\n    night_hour?: string;\n    hour?: string;\n    km?: number;\n\n    created_at?: Date;\n    updated_at?: Date;\n}\n\nexport enum CreateStatusEnum {\n    SUCCESS = 'success',\n    FAIL = 'fail',\n}\n\nexport interface ICourseStudentCreateResponse {\n    courseStudent: ICourseStudentResponse;\n    status: CreateStatusEnum;\n    message: string;\n}\n\nexport interface ICourseStudent extends Document {\n    _id: Types.ObjectId;\n\n    student_id?: Types.ObjectId;\n    course_id?: Types.ObjectId;\n    stadium_id?: Types.ObjectId;\n    teacher_id?: Types.ObjectId;\n    sale_id?: Types.ObjectId;\n\n    fee?: number;\n    paid_fee?: number;\n\n    booked_chip_hour?: string;\n    gifted_chip_hour?: string;\n    graduation_date?: Date;\n    health_check_date?: Date;\n    contract_date?: Date;\n\n    note?: string;\n\n    status?: string;\n    automatic_car_hour?: string;\n    day_time_hour?: string;\n    night_hour?: string;\n    hour?: string;\n    km?: number;\n\n    created_at?: Date;\n    updated_at?: Date;\n\n    transform(): ICourseStudentResponse;\n}\n\nconst CourseStudentSchema = new Schema<ICourseStudent>(\n    {\n        _id: { type: Schema.Types.ObjectId, auto: true },\n\n        student_id: {\n            type: Schema.Types.ObjectId,\n            ref: 'Users',\n            required: [true, 'Vui lòng cung cấp Student ID!'],\n            index: true,\n        },\n        course_id: {\n            type: Schema.Types.ObjectId,\n            ref: 'Courses',\n            required: [true, 'Vui lòng cung cấp Course ID!'],\n        },\n        stadium_id: {\n            type: Schema.Types.ObjectId,\n            ref: 'Stadiums',\n            required: [true, 'Vui lòng cung cấp Stadium ID!'],\n        },\n        teacher_id: {\n            type: Schema.Types.ObjectId,\n            ref: 'Users',\n            required: [true, 'Vui lòng cung cấp Teacher ID!'],\n        },\n        sale_id: {\n            type: Schema.Types.ObjectId,\n            ref: 'Users',\n            required: [true, 'Vui lòng cung cấp Sale ID!'],\n        },\n        fee: {\n            type: Number,\n            min: 0,\n            default: undefined,\n        },\n        paid_fee: {\n            type: Number,\n            min: 0,\n            default: undefined,\n        },\n        booked_chip_hour: {\n            type: String,\n            default: '00:00',\n        },\n        gifted_chip_hour: {\n            type: String,\n            default: '00:00',\n        },\n        graduation_date: {\n            type: Date,\n            default: undefined,\n        },\n        health_check_date: {\n            type: Date,\n            default: undefined,\n        },\n        contract_date: {\n            type: Date,\n            default: undefined,\n        },\n        note: {\n            type: String,\n            default: '',\n        },\n        status: {\n            type: String,\n            enum: [\n                CourseStudentStatusEnum.Unfinished,\n                CourseStudentStatusEnum.Cancelled,\n                CourseStudentStatusEnum.Completed,\n            ],\n            default: CourseStudentStatusEnum.Unfinished,\n        },\n        automatic_car_hour: {\n            type: String,\n            default: '00:00',\n        },\n        day_time_hour: {\n            type: String,\n            default: '00:00',\n        },\n        night_hour: {\n            type: String,\n            default: '00:00',\n        },\n        hour: {\n            type: String,\n            default: '00:00',\n        },\n        km: {\n            type: Number,\n            min: 0,\n            default: undefined,\n        },\n    },\n    {\n        timestamps: { createdAt: 'created_at', updatedAt: 'updated_at' },\n        versionKey: false,\n    },\n);\n\nCourseStudentSchema.index({ student_id: 1 });\nCourseStudentSchema.index({ created_at: -1 });\n\nCourseStudentSchema.methods.transform = function (): ICourseStudentResponse {\n    return {\n        id: `${this._id}`,\n        student_id: `${this.student_id}`,\n        course_id: this.course_id?.toString(),\n        stadium_id: this.stadium_id?.toString(),\n        teacher_id: this.teacher_id?.toString(),\n        sale_id: this.sale_id?.toString(),\n\n        fee: this.fee,\n        paid_fee: this.paid_fee,\n\n        booked_chip_hour: this.booked_chip_hour,\n        gifted_chip_hour: this.gifted_chip_hour,\n        graduation_date: this.graduation_date,\n        health_check_date: this.health_check_date,\n        contract_date: this.contract_date,\n\n        note: this.note,\n\n        status: this.status,\n        automatic_car_hour: this.automatic_car_hour,\n        day_time_hour: this.day_time_hour,\n        night_hour: this.night_hour,\n        hour: this.hour,\n        km: this.km,\n\n        created_at: this.created_at,\n        updated_at: this.updated_at,\n    };\n};\n\nconst CourseStudents: Model<ICourseStudent> = mongoose.model<ICourseStudent>('CourseStudents', CourseStudentSchema);\n\nexport default CourseStudents;\n"}],"isError":false,"timestamp":1776143047358}}
{"type":"message","id":"5d072539","parentId":"e5fd1230","timestamp":"2026-04-14T05:04:08.056Z","message":{"role":"toolResult","toolCallId":"call_function_ru76ja6l2e4v_8","toolName":"read","content":[{"type":"text","text":"// @common/stadiums/Stadium.ts\nimport mongoose, { Schema, Model, Types, Document } from 'mongoose';\nimport { IInternalCosts, IInternalCostsResponse } from './internalCosts.interface';\n\nconst InternalCostsSchema = new Schema<IInternalCosts>(\n    {\n        cost: {\n            type: Number,\n            default: 0,\n        },\n        type_id: {\n            type: Schema.Types.ObjectId,\n            ref: 'InternalCostTypes',\n            default: null,\n        },\n        payment_date: {\n            type: Date,\n            default: Date.now,\n        },\n        confirmed_id: {\n            type: Schema.Types.ObjectId,\n            ref: 'User',\n            default: null,\n            index: true,\n        },\n        is_paid: {\n            type: Boolean,\n            default: false,\n        },\n        note: {\n            type: String,\n            trim: true,\n            default: '',\n        },\n        resource_id: {\n            type: Schema.Types.ObjectId,\n            ref: 'Vehicles',\n            default: null,\n        },\n    },\n    {\n        timestamps: {\n            createdAt: 'created_at',\n            updatedAt: 'updated_at',\n        },\n        versionKey: false,\n    },\n);\n\nInternalCostsSchema.methods.transform = function (): IInternalCostsResponse {\n    return {\n        id: this._id.toString(),\n        cost: this.cost,\n        type_id: this.type_id,\n        payment_date: this.payment_date,\n        confirmed_id: this.confirmed_id,\n        is_paid: this.is_paid,\n        note: this.note,\n        resource_id: this.resource_id,\n    };\n};\n\nInternalCostsSchema.index({ confirmed_id: 1, created_at: -1 });\n\nconst InternalCosts: Model<IInternalCosts> = mongoose.model<IInternalCosts>(\n    'InternalCosts',\n    InternalCostsSchema,\n    'internalcosts',\n);\n\nexport default InternalCosts;\n"}],"isError":false,"timestamp":1776143047706}}
