{"type":"message","id":"44bac2ee","parentId":"ecfe655f","timestamp":"2026-04-14T05:02:44.899Z","message":{"role":"toolResult","toolCallId":"call_function_tz4dqac99wfu_1","toolName":"read","content":[{"type":"text","text":"import express from 'express';\nimport * as authMiddleware from './middlewares/auth.middleware';\n\nimport systemRoutes from './routes/v1/system.routes';\nimport educationRoutes from './routes/v1/education.routes';\nimport operationRoutes from './routes/v1/operation.routes';\nimport notificationRoutes from './routes/v1/notification.routes';\n\nimport authRoute from './modules/auth/auth.route';\nimport guestsRoute from './modules/guests/guests.route';\nimport DeviceRoute from './modules/devices/devices.route';\n\nconst router = express.Router();\n\nrouter.use('/auth', authRoute);\nrouter.use('/guests', guestsRoute);\nrouter.use('/devices', DeviceRoute);\n\nrouter.use(authMiddleware.auth());\n\nrouter.use(systemRoutes);\nrouter.use(educationRoutes);\nrouter.use(operationRoutes);\nrouter.use(notificationRoutes);\n\nexport default router;\n"}],"isError":false,"timestamp":1776142964702}}
{"type":"message","id":"b5ff7ca6","parentId":"44bac2ee","timestamp":"2026-04-14T05:02:45.102Z","message":{"role":"toolResult","toolCallId":"call_function_tz4dqac99wfu_2","toolName":"read","content":[{"type":"text","text":"import { Router } from 'express';\nimport * as authMiddleware from '../../middlewares/auth.middleware';\nimport { listenNotify } from '@common/notifications/notification.dispatcher';\n\nimport coursesRoute from '../../modules/courses/courses.route';\nimport lessonRoute from '../../modules/lessons/lessons.route';\nimport teacherRoute from '../../modules/teacherInfos/teacherInfos.route';\nimport teacherLicenseCategoryRoute from '../../modules/teacherLicenseCategories/teacherLicenseCategories.route';\nimport StudentInfoRoute from '../../modules/studentInfos/studentInfos.route';\nimport coursesStudents from '../../modules/coursesStudents/coursesStudents.route';\nimport workCalendarRoute from '../../modules/workCalendars/workCalendars.route';\nimport LessonTypeRoute from '../../modules/lessonTypes/lessonTypes.route';\nimport examsRoute from '../../modules/exams/exams.route';\nimport examResultsRoute from '../../modules/examResults/examResults.route';\nimport ExamSchedulesRoute from '../../modules/examSchedules/examSchedules.route';\nimport ExamRegistrationsRouter from '../../modules/examRegistrations/examRegistrations.route';\nimport StudentCommentRouter from '../../modules/studentComments/studentComments.route';\nimport TeacherCommentRouter from '../../modules/teacherComments/teacherComments.route';\n\nconst router = Router();\n\nrouter.use('/courses', listenNotify, coursesRoute);\nrouter.use('/courses-students', listenNotify, coursesStudents);\nrouter.use('/lessons', authMiddleware.checkPermissions, lessonRoute);\nrouter.use('/lesson-types', authMiddleware.checkPermissions, listenNotify, LessonTypeRoute);\nrouter.use('/teacher-infos', listenNotify, teacherRoute);\nrouter.use('/teacher-license-categories', authMiddleware.checkPermissions, listenNotify, teacherLicenseCategoryRoute);\nrouter.use('/work-calendars', authMiddleware.checkPermissions, listenNotify, workCalendarRoute);\nrouter.use('/student-infos', authMiddleware.checkPermissions, listenNotify, StudentInfoRoute);\nrouter.use('/exams', authMiddleware.checkPermissions, listenNotify, examsRoute);\nrouter.use('/exam-results', authMiddleware.checkPermissions, listenNotify, examResultsRoute);\nrouter.use('/exam-schedules', authMiddleware.checkPermissions, ExamSchedulesRoute);\nrouter.use('/exam-registrations', authMiddleware.checkPermissions, ExamRegistrationsRouter);\nrouter.use('/student-comments', StudentCommentRouter);\nrouter.use('/teacher-comments', TeacherCommentRouter);\n\nexport default router;\n"}],"isError":false,"timestamp":1776142964901}}
{"type":"message","id":"3aad0a8d","parentId":"b5ff7ca6","timestamp":"2026-04-14T05:02:45.324Z","message":{"role":"toolResult","toolCallId":"call_function_tz4dqac99wfu_3","toolName":"read","content":[{"type":"text","text":"import { Router } from 'express';\nimport * as authMiddleware from '../../middlewares/auth.middleware';\nimport { listenNotify } from '@common/notifications/notification.dispatcher';\n\nimport vehiclesRoute from '../../modules/vehicles/vehicles.route';\nimport licenseCategoriesRoute from '../../modules/licenseCategories/licenseCategories.route';\nimport paymentsRoute from '../../modules/payments/payments.route';\nimport stadiumsRoute from '../../modules/stadiums/stadiums.route';\nimport leadSourceRoute from '../../modules/leadSources/leadSources.route';\nimport leadInfoRoute from '../../modules/leadInfos/leadInfos.route';\nimport ImportRouter from '../../modules/imports/imports.route';\nimport InternalCostTypesRouter from '../../modules/internalCostTypes/internalCostTypes.route';\nimport InternalCostsRouter from '../../modules/internalCosts/internalCosts.route';\nimport DashBoardsRouter from '../../modules/dashboards/dashboards.route';\n\nconst router = Router();\n\nrouter.use('/vehicles', listenNotify, vehiclesRoute);\nrouter.use('/license-categories', listenNotify, licenseCategoriesRoute);\nrouter.use('/payments', authMiddleware.checkPermissions, listenNotify, paymentsRoute);\nrouter.use('/stadiums', authMiddleware.checkPermissions, listenNotify, stadiumsRoute);\nrouter.use('/lead-sources', authMiddleware.checkPermissions, listenNotify, leadSourceRoute);\nrouter.use('/lead-infos', authMiddleware.checkPermissions, listenNotify, leadInfoRoute);\nrouter.use('/imports', authMiddleware.checkPermissions, listenNotify, ImportRouter);\nrouter.use('/internal-cost-types', authMiddleware.checkPermissions, listenNotify, InternalCostTypesRouter);\nrouter.use('/internal-costs', authMiddleware.checkPermissions, listenNotify, InternalCostsRouter);\nrouter.use('/dashboards', authMiddleware.checkPermissions, listenNotify, DashBoardsRouter);\n\nexport default router;\n"}],"isError":false,"timestamp":1776142965103}}
{"type":"message","id":"0d6174f4","parentId":"3aad0a8d","timestamp":"2026-04-14T05:02:45.555Z","message":{"role":"toolResult","toolCallId":"call_function_tz4dqac99wfu_4","toolName":"read","content":[{"type":"text","text":"import { Router } from 'express';\nimport * as authMiddleware from '../../middlewares/auth.middleware';\n\nimport NotifyContentsRoute from '../../modules/notifyContents/notifyContents.route';\nimport NotifyConfigsRoute from '../../modules/notifyConfigs/notifyConfigs.route';\nimport NotifiesRoute from '../../modules/notifies/notifies.route';\nimport NotifyUserRoute from '../../modules/notifyUsers/notifyUsers.route';\nimport ConventionRoute from '../../modules/conventions/conventions.route';\n\nconst router = Router();\n\nrouter.use('/notify-contents', authMiddleware.checkPermissions, NotifyContentsRoute);\nrouter.use('/notify-users', authMiddleware.checkPermissions, NotifyUserRoute);\nrouter.use('/notify-configs', authMiddleware.checkPermissions, NotifyConfigsRoute);\nrouter.use('/notifies', authMiddleware.checkPermissions, NotifiesRoute);\nrouter.use('/conventions', authMiddleware.checkPermissions, ConventionRoute);\n\nexport default router;\n"}],"isError":false,"timestamp":1776142965325}}
{"type":"message","id":"1592287f","parentId":"0d6174f4","timestamp":"2026-04-14T05:02:45.789Z","message":{"role":"toolResult","toolCallId":"call_function_tz4dqac99wfu_5","toolName":"read","content":[{"type":"text","text":"import { Router } from 'express';\nimport * as authMiddleware from '../../middlewares/auth.middleware';\nimport { listenNotify } from '@common/notifications/notification.dispatcher';\n\nimport userRoute from '../../modules/users/users.route';\nimport userRoleRoute from '../../modules/userRoles/userRoles.route';\nimport rolesRoute from '../../modules/roles/roles.route';\nimport LogTaskRoute from '../../modules/logTasks/logTasks.route';\nimport AgentRouter from '../../modules/agents/agents.route';\n\nconst router = Router();\n\nrouter.use('/users', authMiddleware.checkPermissions, listenNotify, userRoute);\nrouter.use('/roles', listenNotify, rolesRoute);\nrouter.use('/user-role', listenNotify, userRoleRoute);\nrouter.use('/agents', listenNotify, AgentRouter);\nrouter.use('/log-tasks', authMiddleware.checkPermissions, LogTaskRoute);\n\nexport default router;\n"}],"isError":false,"timestamp":1776142965556}}
