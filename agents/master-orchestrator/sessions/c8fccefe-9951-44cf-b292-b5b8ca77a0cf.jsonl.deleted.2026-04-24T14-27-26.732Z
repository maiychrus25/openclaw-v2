{"type":"message","id":"a656656e","parentId":"da72cb46","timestamp":"2026-04-14T05:04:15.992Z","message":{"role":"toolResult","toolCallId":"call_function_s33c216fjthf_1","toolName":"read","content":[{"type":"text","text":"import mongoose, { Schema, Model } from 'mongoose';\nimport { IInternalCostTypes, IInternalCostTypesResponse } from './internalCostTypes.interface';\n\nconst InternalCostTypesSchema = new Schema<IInternalCostTypes>(\n    {\n        name: {\n            type: String,\n            trim: true,\n            default: undefined,\n        },\n        description: {\n            type: String,\n            trim: true,\n            default: '',\n        },\n        is_vehicle: {\n            type: Boolean,\n            default: false,\n        },\n    },\n    {\n        timestamps: {\n            createdAt: 'created_at',\n            updatedAt: 'updated_at',\n        },\n        versionKey: false,\n    },\n);\n\n// INDEXES\nInternalCostTypesSchema.index({ name: 1, is_vehicle: 1 });\n\n// METHODS\nInternalCostTypesSchema.methods.transform = function (): IInternalCostTypesResponse {\n    return {\n        id: this._id.toString(),\n        name: this.name,\n        description: this.description,\n        is_vehicle: this.is_vehicle,\n    };\n};\n\nconst InternalCostTypes: Model<IInternalCostTypes> = mongoose.model<IInternalCostTypes>(\n    'InternalCostTypes',\n    InternalCostTypesSchema,\n    'internalcosttypes',\n);\n\nexport default InternalCostTypes;\n"}],"isError":false,"timestamp":1776143055739}}
