{"type":"message","id":"e2657e00","parentId":"87bad9e8","timestamp":"2026-04-14T02:58:21.951Z","message":{"role":"toolResult","toolCallId":"call_function_o43y9memmig8_1","toolName":"read","content":[{"type":"text","text":"    }\n\n    /**\n     * Lấy danh sách lịch học theo bộ lọc (Sân tập, Giáo viên, Khoảng thời gian).\n     */\n    async getAllLessons(filter: any = {}): Promise<ILessonListResponse> {\n        const andQuery: any[] = [{ deleted_at: null }];\n        const page = filter.page || 1;\n        const limit = filter.limit || 10;\n        const skip = (page - 1) * limit;\n\n        const { stadium_id, teacher_id, start_date, end_date, ...queryLesson } = filter;\n\n        if (stadium_id) {\n            andQuery.push({ stadium_id });\n        }\n\n        if (teacher_id) {\n            andQuery.push({ teacher_id });\n        }\n\n        if (start_date && end_date) {\n            andQuery.push({\n                created_at: {\n                    $gte: start_date,\n                    $lte: end_date,\n                },\n            });\n        }\n\n        if (queryLesson.length) {\n            andQuery.push(queryLesson);\n        }\n\n        const finalQuery = { $and: andQuery };\n\n        logger.info(`[LessonsService] Fetching all lessons with filter: ${JSON.stringify(finalQuery)}`);\n\n        const [lessons, count] = await Promise.all([\n            Lessons.find(finalQuery).sort({ start_time: 1 }).skip(skip).limit(limit),\n            Lessons.countDocuments(finalQuery),\n        ]);\n\n        const data = lessons.map((lesson) => lesson.transform());\n\n        const meta = {\n            totalItems: count,\n            itemCount: data.length,\n            itemsPerPage: limit,\n            currentPage: page,\n\n[930 more lines in file. Use offset=115 to continue.]"}],"isError":false,"timestamp":1776135501761}}
