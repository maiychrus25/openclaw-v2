{"type":"message","id":"b3de4bb9","parentId":"ddb867aa","timestamp":"2026-04-14T02:58:07.950Z","message":{"role":"toolResult","toolCallId":"call_function_5bpetwpemvfw_1","toolName":"read","content":[{"type":"text","text":"import { Request, NextFunction, Response } from 'express';\nimport httpStatus from 'http-status';\nimport { lessonsService } from './lessons.service';\nimport { ILessonFilter, ILessonStatus } from '../lessons/lessons.interface';\nimport { courseStudentsService } from '../coursesStudents/coursesStudents.service';\nimport { coursesService } from '../courses/courses.service';\nimport { checkValidation, mapDataByField } from '@common/utils/checkTime';\nimport { lessonTypesService } from '../lessonTypes/lessonTypes.service';\nimport { userService } from '../users/users.service';\nimport { stadiumsService } from '../stadiums/stadiums.service';\nimport logger from '@common/logger';\nimport { licenseCategoriesService } from '../licenseCategories/licenseCategories.service';\nimport catchAsync from '@common/utils/catchAsync';\nimport AppError from '@common/utils/appError';\nimport { getLessonNotifyInfo } from './helpers/makeNotifiesLesson';\nimport { finalizeUpdate, updateStudentAccumulatedStats } from './helpers/lesson.helper';\nimport { sumStringHour } from '@modules/coursesStudents/coursesStudents.helper';\n\nclass LessonsController {\n    createLesson = catchAsync(async (req: Request, res: Response, next: NextFunction): Promise<any> => {\n        const { course_student_id, start_time, end_time } = req.body;\n\n        logger.info(`[LessonsController] Creating lesson for student_id: ${course_student_id}`);\n        const [teacherLessonData, vehicleLessonData, lessonData] = await Promise.all([\n            lessonsService.getAllLessons({ teacher_id: req.body.teacher_id }),\n            lessonsService.getAllLessons({ vehicle_id: req.body.vehicle_id }),\n            lessonsService.getAllLessons(),\n        ]);\n\n        const coursesStudent = await courseStudentsService.getCourseStudentById(course_student_id);\n        if (!coursesStudent) {\n            throw new AppError('Khóa học của học viên không tồn tại', httpStatus.BAD_REQUEST);\n        }\n\n        const course = await coursesService.getCourseById(String(coursesStudent.course_id));\n        if (!course) {\n            throw new AppError('Khóa học không tồn tại', httpStatus.BAD_REQUEST);\n        }\n\n        // 3. Kiểm tra logic thời gian của khóa học\n        const isNoCode = course.code.includes('NoCode');\n        const courseStart = new Date(course.start_date);\n        const courseEndLimit = new Date(course.end_date);\n\n        if (!isNoCode) {\n            // Cho phép học thêm 1 năm sau ngày kết thúc gốc\n            courseEndLimit.setFullYear(courseEndLimit.getFullYear() + 1);\n        }\n\n        const requestStart = new Date(start_time);\n\n[361 more lines in file. Use offset=51 to continue.]"}],"isError":false,"timestamp":1776135487759}}
