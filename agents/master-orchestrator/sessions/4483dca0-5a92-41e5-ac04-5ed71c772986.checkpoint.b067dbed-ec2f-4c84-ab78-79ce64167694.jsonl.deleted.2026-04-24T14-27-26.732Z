{"type":"message","id":"1cd8647e","parentId":"448e4c8b","timestamp":"2026-04-21T18:44:56.687Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me add a proper startup script for production deployment.","thinkingSignature":"785ca7206b6fad0283f70c59ef584910b6172e861a9d1637d6fef170c581b56c"},{"type":"text","text":"**Bước 8: Tạo startup script:**\n"},{"type":"toolCall","id":"call_function_clqhde10c9kr_1","name":"write","arguments":{"path":"/root/.openclaw/workspaces2/projects/s1-ppe-safety/devops/start.sh","content":"#!/bin/bash\n# ── S1 PPE Safety Monitor — Production Startup ──────────────────────────────────\n# Usage: ./start.sh\n\nset -e\n\n# Colors\nGREEN='\\033[0;32m'\nYELLOW='\\033[1;33m'\nRED='\\033[0;31m'\nNC='\\033[0m'\n\necho -e \"${GREEN}╔══════════════════════════════════════════════╗${NC}\"\necho -e \"${GREEN}║  S1 PPE Safety Monitor — Production        ║${NC}\"\necho -e \"${GREEN}╚══════════════════════════════════════════════╝${NC}\"\n\n# ── Check environment ──────────────────────────────────────────────────────────\nif [ ! -f .env ]; then\n    echo -e \"${YELLOW}⚠ .env not found. Copy .env.example and configure it.${NC}\"\n    cp backend/.env.example .env\n    echo -e \"${YELLOW}⚠ Created .env from .env.example — please edit it!${NC}\"\nfi\n\n# ── Install dependencies ──────────────────────────────────────────────────────\necho -e \"\\n${GREEN}[1/4] Installing dependencies...${NC}\"\n\nif [ ! -d \"backend/venv\" ]; then\n    python3 -m venv backend/venv\n    source backend/venv/bin/activate\n    pip install -r backend/requirements.txt\nelse\n    source backend/venv/bin/activate\nfi\n\nif [ ! -d \"frontend/node_modules\" ]; then\n    cd frontend && npm install && cd ..\nfi\n\n# ── Start Backend ─────────────────────────────────────────────────────────────\necho -e \"\\n${GREEN}[2/4] Starting Backend (Flask + Socket.IO)...${NC}\"\nsource backend/venv/bin/activate\nMONGO_URI=\"${MONGO_URI:-mongodb://localhost:27017}\" \\\nMONGO_DB=\"${MONGO_DB:-ppe_safety}\" \\\nDEBUG=false \\\nFPS_TARGET=\"${FPS_TARGET:-2}\" \\\nPORT=\"${PORT:-5000}\" \\\npython3 backend/app.py &\n\nBACKEND_PID=$!\necho -e \"${GREEN}✓ Backend started (PID: $BACKEND_PID)${NC}\"\n\n# ── Start Frontend ─────────────────────────────────────────────────────────────\necho -e \"\\n${GREEN}[3/4] Starting Frontend (Vite dev server)...${NC}\"\ncd frontend && npm run dev -- --host &\nFRONTEND_PID=$!\necho -e \"${GREEN}✓ Frontend started (PID: $FRONTEND_PID)${NC}\"\ncd ..\n\n# ── Health Check ─────────────────────────────────────────────────────────────\necho -e \"\\n${GREEN}[4/4] Health check...${NC}\"\nsleep 3\n\nif curl -sf http://localhost:5000/health > /dev/null 2>&1; then\n    echo -e \"${GREEN}✓ Backend: OK${NC}\"\nelse\n    echo -e \"${RED}✗ Backend: FAILED${NC}\"\nfi\n\nif curl -sf http://localhost:3003 > /dev/null 2>&1; then\n    echo -e \"${GREEN}✓ Frontend: OK${NC}\"\nelse\n    echo -e \"${YELLOW}⚠ Frontend: Still starting...${NC}\"\nfi\n\necho -e \"\"\"\n${GREEN}╔══════════════════════════════════════════════╗${NC}\n${GREEN}║  PPE Safety Monitor is running!                ║${NC}\n${GREEN}╠══════════════════════════════════════════════╣${NC}\n${GREEN}║  Dashboard:  http://localhost:3003           ║${NC}\n${GREEN}║  API:        http://localhost:5000           ║${NC}\n${GREEN}║  Health:     http://localhost:5000/health    ║${NC}\n${GREEN}╚══════════════════════════════════════════════╝${NC}\n\nPress Ctrl+C to stop.\n\"\"\"\n\n# Wait for Ctrl+C\ntrap \"echo 'Stopping...'; kill $BACKEND_PID $FRONTEND_PID 2>/dev/null; exit\" SIGINT SIGTERM\nwait\n"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":75,"output":943,"cacheRead":154355,"cacheWrite":577,"totalTokens":155950,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776797081637,"responseId":"0636f89b9d684e633fd36d3b306c7df6"}}
