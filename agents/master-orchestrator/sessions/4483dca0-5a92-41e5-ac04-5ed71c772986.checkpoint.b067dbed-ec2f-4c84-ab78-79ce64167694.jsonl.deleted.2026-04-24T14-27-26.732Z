{"type":"message","id":"d943dc4b","parentId":"34e6c1c2","timestamp":"2026-04-21T17:10:01.320Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"I need to replace lines 64-277 with the new VideoPlayer component. Let me read that section fully to know exactly what to replace.","thinkingSignature":"478db54256c05f34d67427f07840bb754f0ba69f173df803e20bcaace48ddf8f"},{"type":"toolCall","id":"call_function_octr64ow0u5k_1","name":"edit","arguments":{"path":"/root/.openclaw/workspaces2/projects/s1-ppe-safety/frontend/src/App.jsx","edits":[{"oldText":"function VideoPlayer({ onSummaryUpdate }) {\n  const videoRef = useRef(null)\n  const canvasRef = useRef(null)\n  const [detections, setDetections] = useState([])\n  const [summary, setSummary] = useState(null)\n  const [videoReady, setVideoReady] = useState(false)\n  const [videoError, setVideoError] = useState(null)\n  const [lastUpdate, setLastUpdate] = useState(null)\n  const [playing, setPlaying] = useState(false)\n  const animationRef = useRef(null)\n\n  // ── Draw boxes on canvas overlay ─────────────────────────────────────────\n  const drawDetections = useRef(null)\n\n  // ── Sync detections with video ────────────────────────────────────────────\n  useEffect(() => {\n    const video = videoRef.current\n    const canvas = canvasRef.current\n    if (!video || !canvas) return\n\n    const ctx = canvas.getContext('2d')\n\n    const draw = () => {\n      if (!video || !ctx) return\n\n      // Match canvas size to video display size\n      const vw = video.offsetWidth || 640\n      const vh = video.offsetHeight || 360\n\n      if (canvas.width !== vw || canvas.height !== vh) {\n        canvas.width = vw\n        canvas.height = vh\n      }\n\n      ctx.clearRect(0, 0, canvas.width, canvas.height)\n\n      const s = summary || {}\n      const dets = detections || []\n\n      // Scale factors (video is 1280x720)\n      const scaleX = canvas.width / 1280\n      const scaleY = canvas.height / 720\n\n      dets.forEach(d => {\n        const [x1, y1, x2, y2] = d.bbox\n        const sx1 = x1 * scaleX, sy1 = y1 * scaleY\n        const sx2 = x2 * scaleX, sy2 = y2 * scaleY\n        const sw = sx2 - sx1, sh = sy2 - sy1\n        const ppe = d.ppe_status\n\n        const color = ppe.compliant ? '#00c853' : '#ff1744'\n\n        // Box\n        ctx.strokeStyle = color\n        ctx.lineWidth = 2\n        ctx.strokeRect(sx1, sy1, sw, sh)\n\n        // Fill\n        ctx.fillStyle = ppe.compliant\n          ? 'rgba(0,200,83,0.12)'\n          : 'rgba(255,23,68,0.18)'\n        ctx.fillRect(sx1, sy1, sw, sh)\n\n        // Label\n        const label = ppe.compliant\n          ? 'OK'\n          : `${!ppe.has_helmet ? 'NO-HELMET' : ''} ${!ppe.has_vest ? 'NO-VEST' : ''}`.trim()`\n        ctx.fillStyle = color\n        ctx.font = 'bold 11px monospace'\n        const tw = ctx.measureText(label).width\n        ctx.fillStyle = 'rgba(0,0,0,0.7)'\n        ctx.fillRect(sx1, sy1 - 18, tw + 8, 17)\n        ctx.fillStyle = color\n        ctx.fillText(label, sx1 + 4, sy1 - 5)\n      })\n\n      animationRef.current = requestAnimationFrame(draw)\n    }\n\n    // Poll summary + detections\n    const poll = setInterval(async () => {\n      try {\n        const data = await fetchAPI('/api/summary')\n        if (data.summary) {\n          setSummary(data.summary)\n          onSummaryUpdate?.(data.summary)\n        }\n        if (data.detections) {\n          setDetections(data.detections)\n        }\n        setLastUpdate(new Date().toLocaleTimeString())\n      } catch {}\n    }, 500)\n\n    draw()\n\n    return () => {\n      clearInterval(poll)\n      if (animationRef.current) cancelAnimationFrame(animationRef.current)\n    }\n  }, [summary, detections])\n\n  const complianceColor = summary\n    ? (summary.compliance_rate >= 80 ? '#52c41a'\n      : summary.compliance_rate >= 50 ? '#faad14' : '#ff4d4f')\n    : '#888'\n\n  return (\n    <div style={{ position: 'relative', borderRadius: 12, overflow: 'hidden', background: '#000' }}>\n      {/* HTML5 Video */}\n      <div style={{ position: 'relative', lineHeight: 0 }}>\n        <video\n          ref={videoRef}\n          src={VIDEO_URL}\n          controls\n          autoPlay\n          loop\n          muted\n          playsInline\n          style={{\n            width: '100%',\n            display: 'block',\n            background: '#000',\n          }}\n          onCanPlay={() => setVideoReady(true)}\n          onError={(e) => setVideoError('Không thể tải video')}\n          onPlay={() => setPlaying(true)}\n          onPause={() => setPlaying(false)}\n        />\n\n        {/* Canvas overlay for bounding boxes */}\n        <canvas\n          ref={canvasRef}\n          style={{\n            position: 'absolute',\n            top: 0,\n            left: 0,\n            width: '100%',\n            height: '100%',\n            pointerEvents: 'none',\n          }}\n        />\n      </div>\n\n      {/* HUD — top right */}\n      <div style={{\n        position: 'absolute', top: 12, right: 12,\n        background: 'rgba(0,0,0,0.72)',\n        borderRadius: 6, padding: '6px 12px',\n        fontSize: 11, color: '#0f0',\n        fontFamily: 'monospace',\n      }}>\n        {playing ? '● LIVE' : '⏸ PAUSED'} · Edge+Blob\n      </div>\n\n      {/* HUD — top left */}\n      <div style={{\n        position: 'absolute', top: 12, left: 12,\n        background: 'rgba(0,0,0,0.6)',\n        borderRadius: 6, padding: '4px 10px',\n        fontSize: 10, color: '#aaa',\n        fontFamily: 'monospace',\n      }}>\n        Cập nhật: {lastUpdate || '...'}\n      </div>\n\n      {/* HUD — bottom left stats */}\n      {summary && (\n        <div style={{\n          position: 'absolute', bottom: 12, left: 12,\n          background: 'rgba(0,0,0,0.75)',\n          borderRadius: 8, padding: '10px 14px',\n          fontFamily: 'monospace', fontSize: 12,\n        }}>\n          <div style={{ color: '#fff', marginBottom: 4 }}>\n            👤 {summary.total_persons || 0} phát hiện\n          </div>\n          <div style={{ color: '#52c41a' }}>\n            ✅ Tuân thủ: {summary.compliant || 0}\n          </div>\n          <div style={{ color: '#ff4d4f' }}>\n            ❌ Vi phạm: {summary.violations || 0}\n          </div>\n          <div style={{ color: complianceColor, marginTop: 4 }}>\n            📊 Tỷ lệ: {summary.compliance_rate || 0}%\n          </div>\n        </div>\n      )}\n\n      {/* Error / Loading state */}\n      {videoError && (\n        <div style={{\n          position: 'absolute', inset: 0,\n          display: 'flex', alignItems: 'center', justifyContent: 'center',\n          background: 'rgba(0,0,0,0.8)', color: '#ff4d4f',\n        }}>\n          {videoError}\n        </div>\n      )}\n      {!videoReady && !videoError && (\n        <div style={{\n          position: 'absolute', inset: 0,\n          display: 'flex', alignItems: 'center', justifyContent: 'center',\n          background: 'rgba(0,0,0,0.7)', color: '#aaa',\n          flexDirection: 'column', gap: 8,\n        }}>\n          <LoadingOutlined style={{ fontSize: 32 }} />\n          <span>Đang tải video...</span>\n        </div>\n      )}\n    </div>\n  )\n}\n","newText":"// ── Annotated Frame Component ───────────────────────────────────────────────────\nfunction AnnotatedFrame({ summary }) {\n  const [imgSrc, setImgSrc] = useState(null)\n  const [lastUpdate, setLastUpdate] = useState(null)\n\n  useEffect(() => {\n    const poll = setInterval(async () => {\n      try {\n        const res = await fetch(`${API_BASE}/api/frame`, { cache: 'no-cache' })\n        if (res.ok) {\n          const blob = await res.blob()\n          setImgSrc(URL.createObjectURL(blob))\n          setLastUpdate(new Date().toLocaleTimeString())\n        }\n      } catch {}\n    }, 500)\n    return () => clearInterval(poll)\n  }, [])\n\n  const complianceColor = summary?.compliance_rate >= 80 ? '#52c41a'\n    : summary?.compliance_rate >= 50 ? '#faad14' : '#ff4d4f'\n\n  return (\n    <div style={{ position: 'relative', borderRadius: 12, overflow: 'hidden', background: '#000' }}>\n      {imgSrc ? (\n        <img\n          src={imgSrc}\n          alt=\"Detection frame\"\n          style={{ width: '100%', display: 'block', minHeight: 280 }}\n        />\n      ) : (\n        <div style={{\n          width: '100%', height: 280,\n          display: 'flex', alignItems: 'center', justifyContent: 'center',\n          background: '#1a1a2e', color: '#555', flexDirection: 'column', gap: 12,\n        }}>\n          <VideoCameraOutlined style={{ fontSize: 40 }} />\n          <span>Đang kết nối camera...</span>\n        </div>\n      )}\n\n      {/* HUD top left */}\n      <div style={{\n        position: 'absolute', top: 10, left: 10,\n        background: 'rgba(0,0,0,0.7)', borderRadius: 6, padding: '4px 10px',\n        fontSize: 10, color: '#aaa', fontFamily: 'monospace',\n      }}>\n        Cập nhật: {lastUpdate || '...'}\n      </div>\n\n      {/* HUD top right */}\n      <div style={{\n        position: 'absolute', top: 10, right: 10,\n        background: 'rgba(0,0,0,0.7)', borderRadius: 6, padding: '4px 10px',\n        fontSize: 10, color: '#0f0', fontFamily: 'monospace',\n      }}>\n        ● DETECTED FRAME\n      </div>\n\n      {/* HUD bottom */}\n      {summary && (\n        <div style={{\n          position: 'absolute', bottom: 10, left: 10,\n          background: 'rgba(0,0,0,0.8)', borderRadius: 8, padding: '8px 12px',\n          fontFamily: 'monospace', fontSize: 11,\n        }}>\n          <div style={{ color: '#fff' }}>👤 {summary.total_persons || 0} phát hiện</div>\n          <div style={{ color: '#52c41a' }}>✅ {summary.compliant || 0} | <span style={{ color: '#ff4d4f' }}>❌ {summary.violations || 0}</span></div>\n          <div style={{ color: complianceColor }}>📊 {summary.compliance_rate || 0}%</div>\n        </div>\n      )}\n    </div>\n  )\n}\n\n// ── Video Player with Detection Overlay ──────────────────────────────────────\nfunction VideoPlayer({ onSummaryUpdate }) {\n  const videoRef = useRef(null)\n  const canvasRef = useRef(null)\n  const [detections, setDetections] = useState([])\n  const [summary, setSummary] = useState(null)\n  const [videoReady, setVideoReady] = useState(false)\n  const [videoError, setVideoError] = useState(null)\n  const [lastUpdate, setLastUpdate] = useState(null)\n  const [playing, setPlaying] = useState(false)\n  const animationRef = useRef(null)\n\n  // ── Poll detections ─────────────────────────────────────────────────────────\n  useEffect(() => {\n    const poll = setInterval(async () => {\n      try {\n        const data = await fetchAPI('/api/summary')\n        if (data.summary) {\n          setSummary(data.summary)\n          onSummaryUpdate?.(data.summary)\n        }\n        if (data.detections) setDetections(data.detections)\n        setLastUpdate(new Date().toLocaleTimeString())\n      } catch {}\n    }, 500)\n    return () => clearInterval(poll)\n  }, [])\n\n  // ── Draw boxes overlay ─────────────────────────────────────────────────────\n  useEffect(() => {\n    const video = videoRef.current\n    const canvas = canvasRef.current\n    if (!video || !canvas) return\n    const ctx = canvas.getContext('2d')\n\n    const draw = () => {\n      if (!video || !ctx) return\n      const vw = video.offsetWidth || 640\n      const vh = video.offsetHeight || 360\n      if (canvas.width !== vw || canvas.height !== vh) {\n        canvas.width = vw\n        canvas.height = vh\n      }\n      ctx.clearRect(0, 0, canvas.width, canvas.height)\n      const scaleX = canvas.width / 1280\n      const scaleY = canvas.height / 720\n\n      detections.forEach(d => {\n        const [x1, y1, x2, y2] = d.bbox\n        const sx1 = x1 * scaleX, sy1 = y1 * scaleY\n        const sx2 = x2 * scaleX, sy2 = y2 * scaleY\n        const sw = sx2 - sx1, sh = sy2 - sy1\n        const ppe = d.ppe_status\n        const color = ppe.compliant ? '#00c853' : '#ff1744'\n        ctx.strokeStyle = color; ctx.lineWidth = 2\n        ctx.strokeRect(sx1, sy1, sw, sh)\n        ctx.fillStyle = ppe.compliant ? 'rgba(0,200,83,0.12)' : 'rgba(255,23,68,0.18)'\n        ctx.fillRect(sx1, sy1, sw, sh)\n        const label = ppe.compliant ? 'OK' : `${!ppe.has_helmet ? 'NO-HELMET' : ''} ${!ppe.has_vest ? 'NO-VEST' : ''}`.trim()`\n        ctx.font = 'bold 11px monospace'\n        const tw = ctx.measureText(label).width\n        ctx.fillStyle = 'rgba(0,0,0,0.7)'\n        ctx.fillRect(sx1, sy1 - 18, tw + 8, 17)\n        ctx.fillStyle = color\n        ctx.fillText(label, sx1 + 4, sy1 - 5)\n      })\n      animationRef.current = requestAnimationFrame(draw)\n    }\n    draw()\n    return () => { if (animationRef.current) cancelAnimationFrame(animationRef.current) }\n  }, [detections])\n\n  const complianceColor = summary?.compliance_rate >= 80 ? '#52c41a'\n    : summary?.compliance_rate >= 50 ? '#faad14' : '#ff4d4f'\n\n  return (\n    <div style={{ display: 'flex', flexDirection: 'column', gap: 12 }}>\n      {/* ── TOP: Real Video + Canvas Overlay ── */}\n      <div style={{ position: 'relative', borderRadius: 12, overflow: 'hidden', background: '#000' }}>\n        <div style={{ position: 'relative', lineHeight: 0 }}>\n          <video\n            ref={videoRef}\n            src={VIDEO_URL}\n            controls\n            autoPlay\n            loop\n            muted\n            playsInline\n            style={{ width: '100%', display: 'block', background: '#000' }}\n            onCanPlay={() => setVideoReady(true)}\n            onError={() => setVideoError('Lỗi tải video')}\n            onPlay={() => setPlaying(true)}\n            onPause={() => setPlaying(false)}\n          />\n          <canvas\n            ref={canvasRef}\n            style={{ position: 'absolute', top: 0, left: 0, width: '100%', height: '100%', pointerEvents: 'none' }}\n          />\n        </div>\n\n        <div style={{ position: 'absolute', top: 10, right: 10, background: 'rgba(0,0,0,0.7)', borderRadius: 6, padding: '4px 10px', fontSize: 10, color: '#0f0', fontFamily: 'monospace' }}>\n          {playing ? '● LIVE' : '⏸ PAUSED'}\n        </div>\n        <div style={{ position: 'absolute', top: 10, left: 10, background: 'rgba(0,0,0,0.6)', borderRadius: 6, padding: '4px 10px', fontSize: 10, color: '#aaa', fontFamily: 'monospace' }}>\n          📹 VIDEO THỰC\n        </div>\n\n        {videoError && (\n          <div style={{ position: 'absolute', inset: 0, display: 'flex', alignItems: 'center', justifyContent: 'center', background: 'rgba(0,0,0,0.8)', color: '#ff4d4f' }}>\n            {videoError}\n          </div>\n        )}\n        {!videoReady && !videoError && (\n          <div style={{ position: 'absolute', inset: 0, display: 'flex', alignItems: 'center', justifyContent: 'center', background: 'rgba(0,0,0,0.7)', color: '#aaa', flexDirection: 'column', gap: 8 }}>\n            <LoadingOutlined style={{ fontSize: 32 }} />\n            <span>Đang tải video...</span>\n          </div>\n        )}\n      </div>\n\n      {/* ── BOTTOM: Annotated Frame ── */}\n      <div>\n        <div style={{ fontSize: 11, color: '#666', marginBottom: 6, fontFamily: 'monospace' }}>\n          📷 KẾT QUẢ NHẬN DIỆN (Frame từ Backend)\n        </div>\n        <AnnotatedFrame summary={summary} />\n      </div>\n    </div>\n  )\n}\n"}]}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":65,"output":4630,"cacheRead":128452,"cacheWrite":253,"totalTokens":133400,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776791358061,"responseId":"0636e23f9495fae515111fe87bbdeafb"}}
{"type":"message","id":"cefac799","parentId":"d943dc4b","timestamp":"2026-04-21T17:10:01.423Z","message":{"role":"toolResult","toolCallId":"call_function_octr64ow0u5k_1","toolName":"edit","content":[{"type":"text","text":"{\n  \"status\": \"error\",\n  \"tool\": \"edit\",\n  \"error\": \"Could not find the exact text in /root/.openclaw/workspaces2/projects/s1-ppe-safety/frontend/src/App.jsx. The old text must match exactly including all whitespace and newlines.\\nCurrent file contents:\\nimport { useState, useEffect, useRef } from 'react'\\nimport { io } from 'socket.io-client'\\nimport {\\n  Layout, Card, Row, Col, Statistic, Tag, Badge,\\n  Button, Space, Typography, Alert, Progress, List, Tooltip\\n} from 'antd'\\nimport {\\n  SafetyOutlined, AlertOutlined, UserOutlined,\\n  CheckCircleOutlined, StopOutlined, PlayCircleOutlined,\\n  VideoCameraOutlined, ReloadOutlined, CameraOutlined, LoadingOutlined\\n} from '@ant-design/icons'\\n\\nconst { Header, Content, Sider } = Layout\\nconst { Title, Text } = Typography\\n\\nconst API_BASE = import.meta.env.VITE_API_BASE || ''\\n// Video served directly from Vite's public folder (supports Range requests for seeking)\\nconst VIDEO_URL = '/video/demo.mp4'\\n\\nasync function fetchAPI(path) {\\n  const res = await fetch(`${API_BASE}${path}`)\\n  if (!res.ok) throw new Erro\\n... (truncated)\"\n}"}],"details":{"status":"error","tool":"edit","error":"Could not find the exact text in /root/.openclaw/workspaces2/projects/s1-ppe-safety/frontend/src/App.jsx. The old text must match exactly including all whitespace and newlines.\nCurrent file contents:\nimport { useState, useEffect, useRef } from 'react'\nimport { io } from 'socket.io-client'\nimport {\n  Layout, Card, Row, Col, Statistic, Tag, Badge,\n  Button, Space, Typography, Alert, Progress, List, Tooltip\n} from 'antd'\nimport {\n  SafetyOutlined, AlertOutlined, UserOutlined,\n  CheckCircleOutlined, StopOutlined, PlayCircleOutlined,\n  VideoCameraOutlined, ReloadOutlined, CameraOutlined, LoadingOutlined\n} from '@ant-design/icons'\n\nconst { Header, Content, Sider } = Layout\nconst { Title, Text } = Typography\n\nconst API_BASE = import.meta.env.VITE_API_BASE || ''\n// Video served directly from Vite's public folder (supports Range requests for seeking)\nconst VIDEO_URL = '/video/demo.mp4'\n\nasync function fetchAPI(path) {\n  const res = await fetch(`${API_BASE}${path}`)\n  if (!res.ok) throw new Erro\n... (truncated)"},"isError":false,"timestamp":1776791401402}}
{"type":"message","id":"7dabd650","parentId":"cefac799","timestamp":"2026-04-21T17:10:50.708Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"The file was too long and got truncated. Let me rewrite the whole file from scratch with the split-screen layout.","thinkingSignature":"54742e61006463001de49422e24ac679dc1f0133223ccd8ce86a00390f17eb39"},{"type":"text","text":"Tôi sẽ viết lại toàn bộ file:\n"},{"type":"toolCall","id":"call_function_1qxecxhqa373_1","name":"write","arguments":{"path":"/root/.openclaw/workspaces2/projects/s1-ppe-safety/frontend/src/App.jsx","content":"import { useState, useEffect, useRef } from 'react'\nimport { io } from 'socket.io-client'\nimport {\n  Layout, Card, Row, Col, Statistic, Tag, Badge,\n  Button, Space, Typography, Alert, Progress, List, Tooltip\n} from 'antd'\nimport {\n  SafetyOutlined, AlertOutlined, UserOutlined,\n  CheckCircleOutlined, StopOutlined,\n  VideoCameraOutlined, ReloadOutlined, CameraOutlined, LoadingOutlined\n} from '@ant-design/icons'\n\nconst { Header, Content, Sider } = Layout\nconst { Title, Text } = Typography\n\nconst API_BASE = import.meta.env.VITE_API_BASE || ''\nconst VIDEO_URL = '/video/demo.mp4'\n\nasync function fetchAPI(path) {\n  const res = await fetch(`${API_BASE}${path}`)\n  if (!res.ok) throw new Error(`${path} → ${res.status}`)\n  return res.json()\n}\n\n// ── Annotated Frame ──────────────────────────────────────────────────────────\nfunction AnnotatedFrame({ summary }) {\n  const [imgSrc, setImgSrc] = useState(null)\n  const [lastUpdate, setLastUpdate] = useState(null)\n\n  useEffect(() => {\n    const poll = setInterval(async () => {\n      try {\n        const res = await fetch(`${API_BASE}/api/frame`, { cache: 'no-cache' })\n        if (res.ok) {\n          const blob = await res.blob()\n          setImgSrc(URL.createObjectURL(blob))\n          setLastUpdate(new Date().toLocaleTimeString())\n        }\n      } catch {}\n    }, 500)\n    return () => clearInterval(poll)\n  }, [])\n\n  const color = summary?.compliance_rate >= 80 ? '#52c41a'\n    : summary?.compliance_rate >= 50 ? '#faad14' : '#ff4d4f'\n\n  return (\n    <div style={{ position: 'relative', borderRadius: 12, overflow: 'hidden', background: '#000' }}>\n      {imgSrc ? (\n        <img src={imgSrc} alt=\"Detection\" style={{ width: '100%', display: 'block' }} />\n      ) : (\n        <div style={{\n          width: '100%', height: 300,\n          display: 'flex', alignItems: 'center', justifyContent: 'center',\n          background: '#1a1a2e', color: '#555', flexDirection: 'column', gap: 12,\n        }}>\n          <VideoCameraOutlined style={{ fontSize: 40 }} />\n          <span>Đang kết nối camera...</span>\n        </div>\n      )}\n      <div style={{\n        position: 'absolute', top: 10, left: 10,\n        background: 'rgba(0,0,0,0.7)', borderRadius: 6, padding: '4px 10px',\n        fontSize: 10, color: '#aaa', fontFamily: 'monospace',\n      }}>\n        Cập nhật: {lastUpdate || '...'}\n      </div>\n      <div style={{\n        position: 'absolute', top: 10, right: 10,\n        background: 'rgba(0,0,0,0.7)', borderRadius: 6, padding: '4px 10px',\n        fontSize: 10, color: '#0f0', fontFamily: 'monospace',\n      }}>\n        ● DETECTED FRAME\n      </div>\n      {summary && (\n        <div style={{\n          position: 'absolute', bottom: 10, left: 10,\n          background: 'rgba(0,0,0,0.8)', borderRadius: 8, padding: '8px 12px',\n          fontFamily: 'monospace', fontSize: 11,\n        }}>\n          <div style={{ color: '#fff' }}>👤 {summary.total_persons || 0} phát hiện</div>\n          <div style={{ color: '#52c41a' }}>\n            ✅ {summary.compliant || 0}\n            <span style={{ color: '#ff4d4f', marginLeft: 12 }}>❌ {summary.violations || 0}</span>\n          </div>\n          <div style={{ color, marginTop: 2 }}>📊 {summary.compliance_rate || 0}%</div>\n        </div>\n      )}\n    </div>\n  )\n}\n\n// ── Video Player ───────────────────────────────────────────────────────────────\nfunction VideoPlayer({ onSummaryUpdate }) {\n  const videoRef = useRef(null)\n  const canvasRef = useRef(null)\n  const [detections, setDetections] = useState([])\n  const [summary, setSummary] = useState(null)\n  const [videoReady, setVideoReady] = useState(false)\n  const [videoError, setVideoError] = useState(null)\n  const [playing, setPlaying] = useState(false)\n  const animRef = useRef(null)\n\n  // Poll detections\n  useEffect(() => {\n    const poll = setInterval(async () => {\n      try {\n        const data = await fetchAPI('/api/summary')\n        if (data.summary) {\n          setSummary(data.summary)\n          onSummaryUpdate?.(data.summary)\n        }\n        if (data.detections) setDetections(data.detections)\n      } catch {}\n    }, 500)\n    return () => clearInterval(poll)\n  }, [])\n\n  // Draw overlay\n  useEffect(() => {\n    const video = videoRef.current\n    const canvas = canvasRef.current\n    if (!video || !canvas) return\n    const ctx = canvas.getContext('2d')\n\n    const draw = () => {\n      if (!video || !ctx) return\n      const vw = video.offsetWidth || 640\n      const vh = video.offsetHeight || 360\n      if (canvas.width !== vw || canvas.height !== vh) {\n        canvas.width = vw; canvas.height = vh\n      }\n      ctx.clearRect(0, 0, canvas.width, canvas.height)\n      const sx = canvas.width / 1280\n      const sy = canvas.height / 720\n\n      detections.forEach(d => {\n        const [x1, y1, x2, y2] = d.bbox\n        const px1 = x1 * sx, py1 = y1 * sy, px2 = x2 * sx, py2 = y2 * sy\n        const pw = px2 - px1, ph = py2 - py1\n        const ok = d.ppe_status.compliant\n        const col = ok ? '#00c853' : '#ff1744'\n        ctx.strokeStyle = col; ctx.lineWidth = 2\n        ctx.strokeRect(px1, py1, pw, ph)\n        ctx.fillStyle = ok ? 'rgba(0,200,83,0.12)' : 'rgba(255,23,68,0.18)'\n        ctx.fillRect(px1, py1, pw, ph)\n        const label = ok ? 'OK' : `${!d.ppe_status.has_helmet ? 'NO-HELMET' : ''} ${!d.ppe_status.has_vest ? 'NO-VEST' : ''}`.trim()\n        ctx.font = 'bold 11px monospace'\n        const tw = ctx.measureText(label).width\n        ctx.fillStyle = 'rgba(0,0,0,0.7)'\n        ctx.fillRect(px1, py1 - 18, tw + 8, 17)\n        ctx.fillStyle = col\n        ctx.fillText(label, px1 + 4, py1 - 5)\n      })\n\n      animRef.current = requestAnimationFrame(draw)\n    }\n    draw()\n    return () => { if (animRef.current) cancelAnimationFrame(animRef.current) }\n  }, [detections])\n\n  const col = summary?.compliance_rate >= 80 ? '#52c41a'\n    : summary?.compliance_rate >= 50 ? '#faad14' : '#ff4d4f'\n\n  return (\n    <div style={{ display: 'flex', flexDirection: 'column', gap: 12 }}>\n\n      {/* ── TOP: Real Video + Boxes ── */}\n      <div style={{ position: 'relative', borderRadius: 12, overflow: 'hidden', background: '#000' }}>\n        <div style={{ position: 'relative', lineHeight: 0 }}>\n          <video\n            ref={videoRef}\n            src={VIDEO_URL}\n            controls autoPlay loop muted playsInline\n            style={{ width: '100%', display: 'block' }}\n            onCanPlay={() => setVideoReady(true)}\n            onError={() => setVideoError('Lỗi tải video')}\n            onPlay={() => setPlaying(true)}\n            onPause={() => setPlaying(false)}\n          />\n          <canvas\n            ref={canvasRef}\n            style={{ position: 'absolute', top: 0, left: 0, width: '100%', height: '100%', pointerEvents: 'none' }}\n          />\n        </div>\n\n        <div style={{\n          position: 'absolute', top: 10, right: 10,\n          background: 'rgba(0,0,0,0.7)', borderRadius: 6, padding: '4px 10px',\n          fontSize: 10, color: '#0f0', fontFamily: 'monospace',\n        }}>\n          {playing ? '● LIVE' : '⏸ PAUSED'}\n        </div>\n        <div style={{\n          position: 'absolute', top: 10, left: 10,\n          background: 'rgba(0,0,0,0.6)', borderRadius: 6, padding: '4px 10px',\n          fontSize: 10, color: '#aaa', fontFamily: 'monospace',\n        }}>\n          📹 VIDEO THỰC\n        </div>\n\n        {videoError && (\n          <div style={{\n            position: 'absolute', inset: 0, display: 'flex', alignItems: 'center',\n            justifyContent: 'center', background: 'rgba(0,0,0,0.8)', color: '#ff4d4f',\n          }}>\n            {videoError}\n          </div>\n        )}\n        {!videoReady && !videoError && (\n          <div style={{\n            position: 'absolute', inset: 0, display: 'flex', alignItems: 'center',\n            justifyContent: 'center', background: 'rgba(0,0,0,0.7)', color: '#aaa',\n            flexDirection: 'column', gap: 8,\n          }}>\n            <LoadingOutlined style={{ fontSize: 32 }} />\n            <span>Đang tải video...</span>\n          </div>\n        )}\n\n        {/* Stats overlay bottom */}\n        {summary && (\n          <div style={{\n            position: 'absolute', bottom: 10, left: 10,\n            background: 'rgba(0,0,0,0.8)', borderRadius: 8, padding: '8px 12px',\n            fontFamily: 'monospace', fontSize: 11,\n          }}>\n            <div style={{ color: '#fff' }}>👤 {summary.total_persons || 0} phát hiện</div>\n            <div style={{ color: '#52c41a' }}>✅ {summary.compliant || 0} <span style={{ color: '#ff4d4f' }}>❌ {summary.violations || 0}</span></div>\n            <div style={{ color: col }}>📊 {summary.compliance_rate || 0}%</div>\n          </div>\n        )}\n      </div>\n\n      {/* ── BOTTOM: Annotated Frame ── */}\n      <div>\n        <div style={{ fontSize: 11, color: '#666', marginBottom: 6, fontFamily: 'monospace', paddingLeft: 4 }}>\n          📷 KẾT QUẢ NHẬN DIỆN (Frame từ Backend)\n        </div>\n        <AnnotatedFrame summary={summary} />\n      </div>\n\n    </div>\n  )\n}\n\n// ── Alert Item ───────────────────────────────────────────────────────────────\nfunction AlertItem({ alert }) {\n  const d = alert.detection || {}\n  const ok = d.compliant\n  return (\n    <List.Item style={{ padding: '8px 0' }}>\n      <Space align=\"start\" style={{ width: '100%' }}>\n        <Badge status={ok ? 'success' : 'error'} />\n        <div style={{ flex: 1 }}>\n          <Space>\n            {d.has_helmet === false && <Tag color=\"red\">NO HELMET</Tag>}\n            {d.has_vest === false && <Tag color=\"orange\">NO VEST</Tag>}\n            {ok && <Tag color=\"green\">OK</Tag>}\n          </Space>\n          <div style={{ fontSize: 11, color: '#999', marginTop: 2 }}>\n            {alert.timestamp ? new Date(alert.timestamp).toLocaleTimeString() : '—'}\n            {' · conf: '}{d.confidence?.toFixed(2) || '—'}\n          </div>\n        </div>\n      </Space>\n    </List.Item>\n  )\n}\n\n// ── Stats Card ──────────────────────────────────────────────────────────────\nfunction StatsCard({ title, value, icon, color, sub }) {\n  return (\n    <Card size=\"small\" style={{ borderRadius: 12 }}>\n      <Statistic\n        title={<Text type=\"secondary\" style={{ fontSize: 13 }}>{title}</Text>}\n        value={value}\n        valueStyle={{ color, fontSize: 28, fontWeight: 700 }}\n        prefix={<span style={{ marginRight: 8 }}>{icon}</span>}\n      />\n      {sub && <div style={{ marginTop: 4, fontSize: 12, color: '#888' }}>{sub}</div>}\n    </Card>\n  )\n}\n\n// ── Main App ─────────────────────────────────────────────────────────────────\nexport default function App() {\n  const [summary, setSummary] = useState({\n    total_persons: 0, compliant: 0, violations: 0,\n    no_helmet: 0, no_vest: 0, compliance_rate: 100,\n  })\n  const [alerts, setAlerts] = useState([])\n  const [status, setStatus] = useState('connecting')\n  const [alertStats, setAlertStats] = useState({})\n\n  // Socket.IO\n  useEffect(() => {\n    const socket = io(API_BASE || window.location.origin, {\n      transports: ['websocket', 'polling'],\n      reconnectionAttempts: 5, reconnectionDelay: 2000,\n    })\n    socket.on('connect', () => {\n      socket.emit('subscribe', { camera_id: 'demo-camera' })\n      setStatus('live')\n    })\n    socket.on('disconnect', () => setStatus('stopped'))\n    socket.on('detection_summary', (data) => {\n      if (data.summary) setSummary(data.summary)\n    })\n    socket.on('ppe_alert', (alert) => {\n      setAlerts(prev => [alert, ...prev].slice(0, 100))\n      try {\n        const audio = new Audio(\n          'data:audio/wav;base64,'\n        )\n        audio.volume = 0.3\n        audio.play().catch(() => {})\n      } catch {}\n    })\n    return () => socket.disconnect()\n  }, [])\n\n  // Poll alerts\n  useEffect(() => {\n    const load = async () => {\n      try {\n        const [ad, sd] = await Promise.all([\n          fetchAPI('/api/alerts?limit=20'),\n          fetchAPI('/api/alerts/stats').catch(() => ({})),\n        ])\n        if (Array.isArray(ad)) setAlerts(ad)\n        if (sd && !sd.error) setAlertStats(sd)\n      } catch {}\n    }\n    load()\n    const iv = setInterval(load, 10000)\n    return () => clearInterval(iv)\n  }, [])\n\n  const col = summary.compliance_rate >= 80 ? '#52c41a'\n    : summary.compliance_rate >= 50 ? '#faad14' : '#ff4d4f'\n\n  return (\n    <Layout style={{ minHeight: '100vh', background: '#0f0f1a' }}>\n      <Header style={{\n        background: '#1a1a2e', borderBottom: '1px solid #2a2a4a',\n        display: 'flex', alignItems: 'center', justifyContent: 'space-between',\n        padding: '0 24px',\n      }}>\n        <Space>\n          <SafetyOutlined style={{ fontSize: 24, color: '#faad14' }} />\n          <Title level={4} style={{ color: '#fff', margin: 0 }}>PPE Safety Monitor</Title>\n          <Badge\n            status={status === 'live' ? 'processing' : 'error'}\n            text={<Text style={{ color: status === 'live' ? '#52c41a' : '#ff4d4f', fontSize: 12 }}>\n              {status === 'live' ? 'LIVE' : 'CONNECTING'}\n            </Text>}\n          />\n        </Space>\n        <Space>\n          <Tooltip title=\"Reload\">\n            <Button icon={<ReloadOutlined />} onClick={() => fetchAPI('/api/alerts?limit=20').then(d => Array.isArray(d) && setAlerts(d))}>\n              Reload\n            </Button>\n          </Tooltip>\n          <Tag icon={<CameraOutlined />} style={{ background: '#16213e', border: 'none', color: '#aaa' }}>\n            Demo Video\n          </Tag>\n        </Space>\n      </Header>\n\n      <Layout>\n        <Content style={{ padding: 20, background: '#0f0f1a' }}>\n          {/* Stats */}\n          <Row gutter={[16, 16]} style={{ marginBottom: 20 }}>\n            <Col xs={24} sm={12} md={6}>\n              <StatsCard title=\"Tổng người\" value={summary.total_persons} icon={<UserOutlined />} color=\"#1890ff\" />\n            </Col>\n            <Col xs={24} sm={12} md={6}>\n              <StatsCard title=\"Tuân thủ ✓\" value={summary.compliant} icon={<CheckCircleOutlined />} color=\"#52c41a\" />\n            </Col>\n            <Col xs={24} sm={12} md={6}>\n              <StatsCard title=\"Vi phạm ✗\" value={summary.violations} icon={<StopOutlined />} color=\"#ff4d4f\"\n                sub={summary.no_helmet > 0 ? `• Không mũ: ${summary.no_helmet}` : null}\n              />\n            </Col>\n            <Col xs={24} sm={12} md={6}>\n              <Card size=\"small\" style={{ borderRadius: 12 }}>\n                <Statistic\n                  title={<Text type=\"secondary\" style={{ fontSize: 13 }}>Tỷ lệ tuân thủ</Text>}\n                  value={summary.compliance_rate} suffix=\"%\"\n                  valueStyle={{ color: col, fontSize: 28, fontWeight: 700 }}\n                  prefix={<SafetyOutlined style={{ marginRight: 8 }} />}\n                />\n                <Progress percent={summary.compliance_rate} showInfo={false} strokeColor={col} style={{ marginTop: 8 }} />\n              </Card>\n            </Col>\n          </Row>\n\n          {/* Video + Alert */}\n          <Row gutter={[16, 16]}>\n            <Col xs={24} lg={14}>\n              <Card\n                title={<Space><VideoCameraOutlined />Camera Feed</Space>}\n                style={{ background: '#1a1a2e', border: '1px solid #2a2a4a' }}\n                styles={{ header: { color: '#fff', borderBottom: '1px solid #2a2a4a' } }}\n              >\n                <VideoPlayer onSummaryUpdate={setSummary} />\n                <Alert\n                  message=\"Trên: Video thực + bounding boxes. Dưới: Frame được xử lý từ Backend.\"\n                  type=\"info\" showIcon style={{ marginTop: 12 }}\n                />\n              </Card>\n            </Col>\n\n            <Col xs={24} lg={10}>\n              <Card\n                title={<Space><AlertOutlined style={{ color: '#ff4d4f' }} />Cảnh báo<Badge count={alerts.length} style={{ backgroundColor: '#ff4d4f' }} /></Space>}\n                style={{ background: '#1a1a2e', border: '1px solid #2a2a4a', height: '100%' }}\n                styles={{ header: { color: '#fff', borderBottom: '1px solid #2a2a4a' } }}\n                bodyStyle={{ maxHeight: 500, overflow: 'auto' }}\n              >\n                {alerts.length === 0 ? (\n                  <div style={{ textAlign: 'center', padding: 40, color: '#555' }}>\n                    <SafetyOutlined style={{ fontSize: 48, marginBottom: 12 }} />\n                    <div>Không có cảnh báo</div>\n                    <div style={{ fontSize: 12, marginTop: 4 }}>Hệ thống hoạt động bình thường</div>\n                  </div>\n                ) : (\n                  <List dataSource={alerts} renderItem={item => <AlertItem alert={item} />} locale={{ emptyText: 'Không có cảnh báo' }} />\n                )}\n              </Card>\n            </Col>\n          </Row>\n        </Content>\n\n        {/* Sidebar */}\n        <Sider width={240} style={{ background: '#1a1a2e', borderLeft: '1px solid #2a2a4a', padding: 16 }}>\n          <Title level={5} style={{ color: '#fff' }}>Thống kê 24h</Title>\n          <Space direction=\"vertical\" style={{ width: '100%' }} size={12}>\n            <Card size=\"small\" style={{ background: '#16213e' }}>\n              <Statistic title={<Text style={{ color: '#aaa', fontSize: 12 }}>Tổng cảnh báo</Text>}\n                value={alertStats.total || alerts.length} valueStyle={{ color: '#fff', fontSize: 24 }} />\n            </Card>\n            <Card size=\"small\" style={{ background: '#16213e' }}>\n              <Statistic title={<Text style={{ color: '#aaa', fontSize: 12 }}>Không đội mũ</Text>}\n                value={alertStats.no_helmet || 0} valueStyle={{ color: '#ff4d4f', fontSize: 24 }} />\n            </Card>\n            <Card size=\"small\" style={{ background: '#16213e' }}>\n              <Statistic title={<Text style={{ color: '#aaa', fontSize: 12 }}>Không áo phản quang</Text>}\n                value={alertStats.no_vest || 0} valueStyle={{ color: '#faad14', fontSize: 24 }} />\n            </Card>\n            <div style={{ marginTop: 16 }}>\n              <Title level={5} style={{ color: '#fff' }}>Camera</Title>\n              <Card size=\"small\" style={{ background: '#16213e' }}>\n                <Space><Badge status=\"success\" /><Text style={{ color: '#aaa', fontSize: 13 }}>demo-camera</Text></Space>\n                <div style={{ fontSize: 11, color: '#666', marginTop: 4 }}>1280×720 · Edge+Blob</div>\n              </Card>\n            </div>\n          </Space>\n        </Sider>\n      </Layout>\n    </Layout>\n  )\n}\n"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":351,"output":5569,"cacheRead":128612,"cacheWrite":4756,"totalTokens":139288,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776791401435,"responseId":"0636e26bc9b1096e52d20d6e45a63bd8"}}
