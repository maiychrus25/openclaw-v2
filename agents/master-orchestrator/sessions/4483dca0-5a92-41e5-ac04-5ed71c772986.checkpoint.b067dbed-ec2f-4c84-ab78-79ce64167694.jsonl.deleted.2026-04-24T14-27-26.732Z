2]\n+191         mask = np.zeros((h, w), dtype=np.uint8)\n+192         for cnt in contours:\n+193             area = cv2.contourArea(cnt)\n+194             if area < 200:  # too small\n+195                 continue\n+196             x, y, cw, ch = cv2.boundingRect(cnt)\n+197             aspect = ch / max(cw, 1)\n+198             # Skin region should be roughly vertical (head) or reasonable body proportion\n+199             if aspect < 0.4:  # reject wide flat regions (sky, ground)\n+200                 continue\n+201             if area > w * h * 0.3:  # reject huge regions\n+202                 continue\n+203             cv2.drawContours(mask, [cnt], -1, 255, -1)\n 194 \n+205         mask = cv2.dilate(mask, kernel, iterations=1)\n+206         return mask\n+207 \n 195     def _analyze_ppe(\n 196         self, frame: np.ndarray,\n 197         bx1: int, by1: int, bx2: int, by2: int,\n 198         bw: int, bh: int\n     ...","firstChangedLine":178},"isError":false,"timestamp":1776795401873}}
{"type":"message","id":"3b9c84d5","parentId":"f53b4a26","timestamp":"2026-04-21T18:17:09.095Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now also fix the detect_from_frame to use the motion mask more when skin detection is weak, and be more tolerant of different video types.\n\nAlso, I should add a \"hybrid\" mode where if skin detection finds nothing but motion is strong, we still detect based on motion + shape.\n\nLet me also adjust the min_area to be more reasonable for 720p video. 8000 pixels for a full person might be too high.Let me also rethink the approach: instead of requiring BOTH skin AND motion, I should use a scoring system where:- skin detection gives points- motion detection gives points\n- shape detection gives points- if total score is high enough, classify as person\n\n\nLet me start rewriting detect_from_frame with this hybrid approach.","thinkingSignature":"98be4f343ae6fa30a7d9444196efaf814b4db47e2b8b962cc10fcb5fbafe1774"},{"type":"toolCall","id":"call_function_dirjotg09se5_1","name":"edit","arguments":{"path":"/root/.openclaw/workspaces2/projects/s1-ppe-safety/backend/detector.py","edits":[{"oldText":"    def detect_from_frame(self, frame: np.ndarray) -> list[dict]:\n        h, w = frame.shape[:2]\n\n        # Step 1: Get motion/foreground regions (strict)\n        motion_mask = self._get_foreground(frame)\n\n        # Step 2: Find skin-toned regions (people have visible skin)\n        skin_mask = self._detect_skin(frame)\n\n        # Step 3: Combine — must have BOTH motion AND skin (or strong motion)\n        combined = cv2.bitwise_and(motion_mask, skin_mask)\n        # Also keep strong motion-only regions (when person is fully clothed)\n        strong_motion = cv2.threshold(motion_mask, 200, 255, cv2.THRESH_BINARY)[1]\n        combined = cv2.bitwise_or(combined, strong_motion)\n\n        # Step 4: Find contours from combined mask\n        contours, _ = cv2.findContours(combined, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)\n\n        detections = []\n        for cnt in contours:\n            x, y, cw, ch = cv2.boundingRect(cnt)\n            area = cw * ch\n            # ── Strict size filtering ────────────────────────────────────\n            if area < self.min_area:\n                continue\n            if ch < self.min_body_height or cw < self.min_body_width:\n                continue\n            if cw > self.max_body_width or ch > h * 0.9:\n                continue\n\n            # ── Aspect ratio: person is 2-5x taller than wide ───────────\n            aspect = ch / max(cw, 1)\n            if aspect < 1.4 or aspect > 8:\n                continue\n\n            # ── Solidity check: person is compact, not sparse ───────────\n            hull = cv2.convexHull(cnt)\n            hull_area = cv2.contourArea(hull)\n            solidity = area / max(hull_area, 1)\n            if solidity < 0.35:\n                continue\n\n            # ── Position check: person should be near ground ─────────────\n            # Reject objects in upper 15% (likely signs, sky elements)\n            if y < h * 0.15 and ch < h * 0.4:\n                continue\n\n            # ── Edge density check: real people have structured edges ─────\n            roi = frame[y:y+ch, x:x+cw]\n            if roi.size == 0:\n                continue\n            gray_roi = cv2.cvtColor(roi, cv2.COLOR_BGR2GRAY)\n            edges = cv2.Canny(gray_roi, 50, 150)\n            edge_density = cv2.countNonZero(edges) / max(edges.size, 1)\n            # People have structured edges (clothing, limbs), not too sparse or dense\n            if edge_density < 0.05 or edge_density > 0.55:\n                continue\n\n            # ── Color variance: person has varied colors, not uniform ─────\n            std = np.std(gray_roi)\n            if std < 8:\n                continue\n\n            # This looks like a person — analyze PPE\n            bx1, by1, bx2, by2 = x, y, x+cw, y+ch\n            ppe = self._analyze_ppe(frame, bx1, by1, bx2, by2, cw, ch)\n\n            # Confidence\n            conf = min(0.45 + solidity * 0.2 + (ch / h) * 0.15, 0.88)\n            if not ppe[\"has_helmet\"] and not ppe[\"has_vest\"]:\n                conf *= 0.85  # Penalize fully non-PPE\n\n            detections.append({\n                \"bbox\": [float(bx1), float(by1), float(bx2), float(by2)],\n                \"confidence\": round(conf, 3),\n                \"class_id\": 0,\n                \"class_name\": \"person\",\n                \"ppe_status\": {\n                    \"has_helmet\": ppe[\"has_helmet\"],\n                    \"has_vest\": ppe[\"has_vest\"],\n                    \"compliant\": ppe[\"has_helmet\"] and ppe[\"has_vest\"],\n                },\n                \"width\": float(cw),\n                \"height\": float(ch),\n                \"center_x\": float(bx1 + cw / 2),\n                \"center_y\": float(by1 + ch / 2),\n            })\n\n        # ── Merge overlapping detections ────────────────────────────────────\n        detections = self._nms(detections)\n        return detections","newText":"    def detect_from_frame(self, frame: np.ndarray) -> list[dict]:\n        h, w = frame.shape[:2]\n\n        # Get motion mask\n        motion_mask = self._get_foreground(frame)\n        _, motion_binary = cv2.threshold(motion_mask, 25, 255, cv2.THRESH_BINARY)\n\n        # Get skin mask\n        skin_mask = self._detect_skin(frame)\n\n        # Find contours from motion\n        contours, _ = cv2.findContours(motion_binary, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)\n\n        detections = []\n        for cnt in contours:\n            x, y, cw, ch = cv2.boundingRect(cnt)\n            area = cw * ch\n\n            # ── Size filtering ───────────────────────────────────────────\n            if area < self.min_area:\n                continue\n            if ch < self.min_body_height or cw < self.min_body_width:\n                continue\n            if cw > self.max_body_width or ch > h * 0.95:\n                continue\n\n            # ── Aspect ratio: person is 1.5-6x taller than wide ────────\n            aspect = ch / max(cw, 1)\n            if aspect < 1.5 or aspect > 7:\n                continue\n\n            # ── Solidity: person shapes are relatively compact ──────────\n            hull = cv2.convexHull(cnt)\n            hull_area = cv2.contourArea(hull)\n            solidity = area / max(hull_area, 1)\n            if solidity < 0.25:\n                continue\n\n            # ── Position: reject upper area if small (sky elements) ─────\n            if y < h * 0.10 and ch < h * 0.35:\n                continue\n\n            # ── Skin in region: person should have some skin or distinct color ─\n            region = frame[y:y+ch, x:x+cw]\n            if region.size == 0:\n                continue\n            gray_roi = cv2.cvtColor(region, cv2.COLOR_BGR2GRAY)\n            std = np.std(gray_roi)\n            if std < 5:\n                continue\n\n            # ── Edge density: people have structured edges ───────────────\n            edges = cv2.Canny(gray_roi, 50, 150)\n            edge_density = cv2.countNonZero(edges) / max(edges.size, 1)\n            if edge_density < 0.04 or edge_density > 0.60:\n                continue\n\n            # ── PPE analysis ────────────────────────────────────────────\n            bx1, by1, bx2, by2 = x, y, x+cw, y+ch\n            ppe = self._analyze_ppe(frame, bx1, by1, bx2, by2, cw, ch)\n\n            # Confidence based on multiple factors\n            skin_ratio = cv2.countNonZero(skin_mask[y:y+ch, x:x+cw]) / max(area, 1)\n            skin_score = min(skin_ratio * 5, 0.3)\n            conf = min(0.35 + solidity * 0.25 + (ch / h) * 0.20 + skin_score, 0.90)\n\n            detections.append({\n                \"bbox\": [float(bx1), float(by1), float(bx2), float(by2)],\n                \"confidence\": round(conf, 3),\n                \"class_id\": 0,\n                \"class_name\": \"person\",\n                \"ppe_status\": {\n                    \"has_helmet\": ppe[\"has_helmet\"],\n                    \"has_vest\": ppe[\"has_vest\"],\n                    \"compliant\": ppe[\"has_helmet\"] and ppe[\"has_vest\"],\n                },\n                \"width\": float(cw),\n                \"height\": float(ch),\n                \"center_x\": float(bx1 + cw / 2),\n                \"center_y\": float(by1 + ch / 2),\n            })\n\n        # ── NMS ────────────────────────────────────────────────────────\n        detections = self._nms(detections)\n        return detections"}]}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":76,"output":2263,"cacheRead":113685,"cacheWrite":1917,"totalTokens":117941,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776795401914,"responseId":"0636f20bdfae379d08ae6a594e1d30bc"}}
