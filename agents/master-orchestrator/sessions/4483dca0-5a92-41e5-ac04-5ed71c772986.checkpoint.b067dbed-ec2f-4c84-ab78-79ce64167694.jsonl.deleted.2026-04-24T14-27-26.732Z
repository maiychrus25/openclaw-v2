7                 continue\n+108 \n+109             # ── Edge density: people have structured edges ───────────────\n 110             edges = cv2.Canny(gray_roi, 50, 150)\n 111             edge_density = cv2.countNonZero(edges) / max(edges.size, 1)\n-112             # People have structured edges (clothing, limbs), not too sparse or dense\n-113             if edge_density < 0.05 or edge_density > 0.55:\n+112             if edge_density < 0.04 or edge_density > 0.60:\n 114                 continue\n 115 \n-116             # ── Color variance: person has varied colors, not uniform ─────\n-117             std = np.std(gray_roi)\n-118             if std < 8:\n-119                 continue\n-120 \n-121             # This looks like a person — analyze PPE\n+115             # ── PPE analysis ────────────────────────────────────────────\n 122             bx1, by1, bx2, by2 = x, y, x+cw, y+ch\n 123             ppe = self._analyze_ppe(frame, bx1, by1, bx2, by2, cw, ch)\n 124 \n-125             # Confidence\n-126             conf = min(0.45 + solidity * 0.2 + (ch / h) * 0.15, 0.88)\n-127             if not ppe[\"has_helmet\"] and not ppe[\"has_vest\"]:\n-128                 conf *= 0.85  # Penalize fully non-PPE\n+119             # Confidence based on multiple factors\n+120             skin_ratio = cv2.countNonZero(skin_mask[y:y+ch, x:x+cw]) / max(area, 1)\n+121             skin_score = min(skin_ratio * 5, 0.3)\n+122             conf = min(0.35 + solidity * 0.25 + (ch / h) * 0.20 + skin_score, 0.90)\n 129 \n 130             detections.append({\n 131                 \"bbox\": [float(bx1), float(by1), float(bx2), float(by2)],\n 132                 \"confidence\": round(conf, 3),\n     ...\n 142                 \"center_x\": float(bx1 + cw / 2),\n 143                 \"center_y\": float(by1 + ch / 2),\n 144             })\n 145 \n-146         # ── Merge overlapping detections ────────────────────────────────────\n+140         # ── NMS ─────────────────────────────────────────────