ons,\n+376             'annotated_frame': f'data:image/jpeg;base64,{b64}',\n+377             'summary': {\n+378                 'total_persons': total,\n+379                 'compliant': compliant,\n+380                 'violations': violations,\n+381                 'compliance_rate': rate,\n+382                 'no_helmet': sum(1 for d in detections if not d['ppe_status']['has_helmet']),\n+383                 'no_vest': sum(1 for d in detections if not d['ppe_status']['has_vest']),\n+384             },\n+385             'frame_width': frame.shape[1],\n+386             'frame_height': frame.shape[0],\n+387         })\n+388     except Exception as e:\n+389         print(f\"[ERROR] detect_frame: {e}\")\n+390         return jsonify({'error': str(e)}), 500\n+391 \n+392 \n+393 # ── Socket.IO Events ─────────────────────────────────────────────────────────\n+394 \n 290 @socketio.on(\"connect\")\n 291 def on_connect():\n 292     print(f\"[WS] Client connected: {request.sid}\")\n 293     emit(\"connected\", {\"sid\": request.sid, \"message\": \"Connected to PPE Safety Monitor\"})\n     ...","firstChangedLine":290},"isError":false,"timestamp":1776794738638}}
