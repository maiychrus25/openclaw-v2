{"type":"message","id":"c5e64949","parentId":"70a18ce5","timestamp":"2026-04-21T16:09:35.114Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me create the detection engine.","thinkingSignature":"6df7013084753f8f3ab75fcb2e74a05ecac4beaf909f4690e84e210f412a0e8f"},{"type":"toolCall","id":"call_function_4jf94h56rl1n_1","name":"write","arguments":{"path":"/root/.openclaw/workspaces2/projects/s1-ppe-safety/backend/detector.py","content":"\"\"\"\nYOLOv8 PPE Detection Engine\nDetects: person, helmet, safety-vest\nUses pretrained YOLOv8n for speed\n\"\"\"\nimport cv2\nimport numpy as np\nfrom ultralytics import YOLO\nfrom pathlib import Path\n\n# PPE Class mapping for custom model training later\n# Default YOLO pretrained classes we'll use as proxy:\n# 0=person, we'll map helmet/vest detections via custom model or rule-based\nCLASS_NAMES = {\n    0: \"person\",\n    # Custom classes (for fine-tuned model):\n    1: \"helmet\",\n    2: \"safety-vest\",\n    3: \"no-helmet\",\n    4: \"no-vest\",\n}\n\n# COCO pretrained: person=0, we detect PPE violations via overlay logic\n# For demo: we'll use a rule-based approach on the person detections\n# and simulate PPE detection using image brightness/color analysis as proxy\n\nclass PPEDetector:\n    def __init__(self, model_path: str = \"yolov8n.pt\"):\n        self.model = YOLO(model_path)\n        self.confidence_threshold = 0.5\n        self.iou_threshold = 0.4\n        # Class IDs for coco pretrained model\n        self.person_class = 0\n\n    def detect_from_frame(self, frame: np.ndarray) -> list[dict]:\n        \"\"\"\n        Run YOLO detection on a single frame.\n        Returns list of detections with bounding boxes.\n        \"\"\"\n        results = self.model.predict(\n            frame,\n            conf=self.confidence_threshold,\n            iou=self.iou_threshold,\n            verbose=False,\n            classes=[0],  # Only person class for speed\n        )\n\n        detections = []\n        if not results or len(results) == 0:\n            return detections\n\n        result = results[0]\n        boxes = result.boxes\n\n        for box in boxes:\n            x1, y1, x2, y2 = box.xyxy[0].cpu().numpy()\n            conf = float(box.conf[0].cpu().numpy())\n            cls_id = int(box.cls[0].cpu().numpy())\n\n            # Estimate PPE compliance from box region\n            ppe_status = self._estimate_ppe_status(frame, int(x1), int(y1), int(x2), int(y2))\n\n            detections.append({\n                \"bbox\": [float(x1), float(y1), float(x2), float(y2)],\n                \"confidence\": round(conf, 3),\n                \"class_id\": cls_id,\n                \"class_name\": CLASS_NAMES.get(cls_id, \"unknown\"),\n                \"ppe_status\": ppe_status,\n                \"width\": float(x2 - x1),\n                \"height\": float(y2 - y1),\n                \"center_x\": float((x1 + x2) / 2),\n                \"center_y\": float((y1 + y2) / 2),\n            })\n\n        return detections\n\n    def _estimate_ppe_status(self, frame: np.ndarray, x1: int, y1: int, x2: int, y2: int) -> dict:\n        \"\"\"\n        Estimate PPE compliance from the person's region.\n        Uses color analysis as a proxy for demo purposes.\n        Real implementation: use a fine-tuned PPE model.\n        \"\"\"\n        h, w = frame.shape[:2]\n        # Clamp coordinates\n        x1, y1 = max(0, x1), max(0, y1)\n        x2, y2 = min(w, x2), min(h, y2)\n\n        if x2 <= x1 or y2 <= y1:\n            return {\"has_helmet\": True, \"has_vest\": True, \"compliant\": True}\n\n        person_roi = frame[y1:y2, x1:x2]\n        if person_roi.size == 0:\n            return {\"has_helmet\": True, \"has_vest\": True, \"compliant\": True}\n\n        # Convert to HSV for color analysis\n        hsv = cv2.cvtColor(person_roi, cv2.COLOR_BGR2HSV)\n\n        # Head region (top 20% of person bounding box)\n        head_end = y1 + int((y2 - y1) * 0.2)\n        if head_end > y1:\n            head_roi = frame[y1:head_end, x1:x2]\n            if head_roi.size > 0:\n                head_hsv = cv2.cvtColor(head_roi, cv2.COLOR_BGR2HSV)\n                # Yellow/orange colors typical of construction helmets\n                lower_helmet = np.array([15, 40, 40])\n                upper_helmet = np.array([35, 255, 255])\n                helmet_mask = cv2.inRange(head_hsv, lower_helmet, upper_helmet)\n                helmet_ratio = cv2.countNonZero(helmet_mask) / max(helmet_mask.size, 1)\n                has_helmet = helmet_ratio > 0.03\n            else:\n                has_helmet = True\n        else:\n            has_helmet = True\n\n        # Vest region (middle 40% of person bounding box)\n        vest_top = y1 + int((y2 - y1) * 0.35)\n        vest_bottom = y1 + int((y2 - y1) * 0.75)\n        if vest_bottom > vest_top:\n            vest_roi = frame[vest_top:vest_bottom, x1:x2]\n            if vest_roi.size > 0:\n                vest_hsv = cv2.cvtColor(vest_roi, cv2.COLOR_BGR2HSV)\n                # Bright colors typical of safety vests (yellow, orange)\n                lower_vest = np.array([0, 20, 80])\n                upper_vest = np.array([40, 255, 255])\n                vest_mask = cv2.inRange(vest_hsv, lower_vest, upper_vest)\n                vest_ratio = cv2.countNonZero(vest_mask) / max(vest_mask.size, 1)\n                # Also check for reflective white/gray stripes\n                lower_reflective = np.array([0, 0, 180])\n                upper_reflective = np.array([180, 30, 255])\n                reflective_mask = cv2.inRange(vest_hsv, lower_reflective, upper_reflective)\n                reflective_ratio = cv2.countNonZero(reflective_mask) / max(reflective_mask.size, 1)\n                has_vest = vest_ratio > 0.08 or reflective_ratio > 0.15\n            else:\n                has_vest = True\n        else:\n            has_vest = True\n\n        compliant = has_helmet and has_vest\n\n        return {\n            \"has_helmet\": has_helmet,\n            \"has_vest\": has_vest,\n            \"compliant\": compliant,\n        }\n\n    def get_violations(self, detections: list[dict]) -> list[dict]:\n        \"\"\"Filter only non-compliant detections (violations).\"\"\"\n        return [\n            d for d in detections\n            if not d[\"ppe_status\"][\"compliant\"]\n        ]\n\n    def get_summary(self, detections: list[dict]) -> dict:\n        \"\"\"Get summary statistics from detections.\"\"\"\n        total = len(detections)\n        compliant = sum(1 for d in detections if d[\"ppe_status\"][\"compliant\"])\n        violations = total - compliant\n        no_helmet = sum(1 for d in detections if not d[\"ppe_status\"][\"has_helmet\"])\n        no_vest = sum(1 for d in detections if not d[\"ppe_status\"][\"has_vest\"])\n\n        return {\n            \"total_persons\": total,\n            \"compliant\": compliant,\n            \"violations\": violations,\n            \"no_helmet\": no_helmet,\n            \"no_vest\": no_vest,\n            \"compliance_rate\": round(compliant / total * 100, 1) if total > 0 else 100.0,\n        }\n"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":73,"output":1758,"cacheRead":30364,"cacheWrite":667,"totalTokens":32862,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776787754677,"responseId":"0636d42b0b569e0e8d7b9dd4d2790bf3"}}
{"type":"message","id":"3f3df541","parentId":"c5e64949","timestamp":"2026-04-21T16:09:35.149Z","message":{"role":"toolResult","toolCallId":"call_function_4jf94h56rl1n_1","toolName":"write","content":[{"type":"text","text":"Successfully wrote 6388 bytes to /root/.openclaw/workspaces2/projects/s1-ppe-safety/backend/detector.py"}],"isError":false,"timestamp":1776787775134}}
{"type":"message","id":"f6585292","parentId":"3f3df541","timestamp":"2026-04-21T16:09:54.955Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me create the video processor.","thinkingSignature":"504a586fc8b1fd377b2b2efe9e88da8f11cc9834dc2914c163741a17ec5ff2c9"},{"type":"toolCall","id":"call_function_tmi088idwi38_1","name":"write","arguments":{"path":"/root/.openclaw/workspaces2/projects/s1-ppe-safety/backend/video_processor.py","content":"\"\"\"\nVideo Processor — Reads video file frame by frame and emits detections.\nCan also use webcam for live input.\n\"\"\"\nimport cv2\nimport time\nimport threading\nfrom collections import deque\nfrom datetime import datetime\nfrom detector import PPEDetector\n\n\nclass VideoProcessor:\n    \"\"\"\n    Processes video files (or webcam) and yields detection results per frame.\n    Designed for real-time streaming mode.\n    \"\"\"\n\n    def __init__(self, video_path: str = None, use_webcam: bool = False, fps_target: int = 5):\n        self.video_path = video_path\n        self.use_webcam = use_webcam\n        self.fps_target = fps_target  # Process every Nth frame for performance\n        self.detector = PPEDetector()\n        self._running = False\n        self._thread = None\n        self._frame_count = 0\n        self._last_results = []\n        self._last_summary = {}\n        self._lock = threading.Lock()\n        # Callbacks\n        self.on_detection = None  # Called with (frame_rgb, detections, summary)\n        self.on_violation = None   # Called when violation detected\n\n    def start(self, on_detection=None, on_violation=None):\n        \"\"\"Start processing in a background thread.\"\"\"\n        self.on_detection = on_detection\n        self.on_violation = on_violation\n        self._running = True\n        self._thread = threading.Thread(target=self._process_loop, daemon=True)\n        self._thread.start()\n\n    def stop(self):\n        self._running = False\n        if self._thread:\n            self._thread.join(timeout=2)\n\n    def get_latest_results(self):\n        \"\"\"Thread-safe access to latest detection results.\"\"\"\n        with self._lock:\n            return {\n                \"detections\": list(self._last_results),\n                \"summary\": dict(self._last_summary),\n                \"frame_count\": self._frame_count,\n            }\n\n    def process_single_frame(self, frame):\n        \"\"\"\n        Process a single frame directly (for API use).\n        Returns (annotated_frame, detections, summary)\n        \"\"\"\n        rgb_frame = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)\n        detections = self.detector.detect_from_frame(rgb_frame)\n        summary = self.detector.get_summary(detections)\n        violations = self.detector.get_violations(detections)\n\n        # Annotate frame\n        annotated = self._annotate_frame(frame.copy(), detections)\n\n        return annotated, detections, summary, violations\n\n    def _process_loop(self):\n        \"\"\"Background processing loop.\"\"\"\n        if self.use_webcam:\n            cap = cv2.VideoCapture(0)\n        elif self.video_path:\n            cap = cv2.VideoCapture(self.video_path)\n        else:\n            return\n\n        if not cap.isOpened():\n            print(f\"[ERROR] Cannot open video source: {self.video_path}\")\n            return\n\n        frame_interval = max(1, int(cap.get(cv2.CAP_PROP_FPS) / self.fps_target))\n        fps_delay = 1.0 / self.fps_target\n\n        print(f\"[VideoProcessor] Started — source: {'webcam' if self.use_webcam else self.video_path}\")\n        print(f\"[VideoProcessor] Processing 1 in every {frame_interval} frames (target {self.fps_target} fps)\")\n\n        while self._running:\n            ret, frame = cap.read()\n            if not ret:\n                # Loop video\n                if not self.use_webcam and self.video_path:\n                    cap.set(cv2.CAP_PROP_POS_FRAMES, 0)\n                    continue\n                break\n\n            self._frame_count += 1\n\n            # Skip frames for performance\n            if self._frame_count % frame_interval != 0:\n                continue\n\n            try:\n                annotated, detections, summary, violations = self.process_single_frame(frame)\n\n                with self._lock:\n                    self._last_results = detections\n                    self._last_summary = summary\n\n                # Trigger callbacks\n                if self.on_detection:\n                    self.on_detection(frame, detections, summary)\n\n                if self.on_violation and violations:\n                    self.on_violation(violations, summary)\n\n            except Exception as e:\n                print(f\"[ERROR] Frame processing failed: {e}\")\n\n            time.sleep(fps_delay)\n\n        cap.release()\n        self._running = False\n        print(\"[VideoProcessor] Stopped\")\n\n    def _annotate_frame(self, frame, detections):\n        \"\"\"Draw bounding boxes and labels on frame.\"\"\"\n        for det in detections:\n            x1, y1, x2, y2 = [int(v) for v in det[\"bbox\"]]\n            ppe = det[\"ppe_status\"]\n\n            if ppe[\"compliant\"]:\n                color = (0, 200, 0)   # Green\n                label = \"OK\"\n            else:\n                color = (0, 0, 220)   # Red\n                labels = []\n                if not ppe[\"has_helmet\"]:\n                    labels.append(\"NO HELMET\")\n                if not ppe[\"has_vest\"]:\n                    labels.append(\"NO VEST\")\n                label = \" | \".join(labels) if labels else \"VIOLATION\"\n\n            # Draw box\n            cv2.rectangle(frame, (x1, y1), (x2, y2), color, 2)\n\n            # Draw label\n            font = cv2.FONT_HERSHEY_SIMPLEX\n            font_scale = 0.5\n            thickness = 1\n            (text_w, text_h), _ = cv2.getTextSize(label, font, font_scale, thickness)\n            cv2.rectangle(frame, (x1, y1 - text_h - 8), (x1 + text_w + 4, y1), color, -1)\n            cv2.putText(frame, label, (x1 + 2, y1 - 3), font, font_scale, (255, 255, 255), thickness)\n\n        return frame\n\n    @staticmethod\n    def frame_to_jpg_bytes(frame) -> bytes:\n        \"\"\"Encode frame as JPEG bytes.\"\"\"\n        _, buffer = cv2.imencode('.jpg', frame, [cv2.IMWRITE_JPEG_QUALITY, 75])\n        return buffer.tobytes()\n\n    @staticmethod\n    def frame_to_base64(frame) -> str:\n        \"\"\"Encode frame as base64 string for JSON responses.\"\"\"\n        import base64\n        _, buffer = cv2.imencode('.jpg', frame, [cv2.IMWRITE_JPEG_QUALITY, 60])\n        return base64.b64encode(buffer).decode('utf-8')\n"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":75,"output":1448,"cacheRead":30660,"cacheWrite":2170,"totalTokens":34353,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776787775153,"responseId":"0636d4406c04f5544de72c7233f98dc2"}}
{"type":"message","id":"1d0da696","parentId":"f6585292","timestamp":"2026-04-21T16:09:54.991Z","message":{"role":"toolResult","toolCallId":"call_function_tmi088idwi38_1","toolName":"write","content":[{"type":"text","text":"Successfully wrote 5976 bytes to /root/.openclaw/workspaces2/projects/s1-ppe-safety/backend/video_processor.py"}],"isError":false,"timestamp":1776787794975}}
{"type":"message","id":"9e5644b8","parentId":"1d0da696","timestamp":"2026-04-21T16:10:23.600Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me create the main Flask app with REST API and WebSocket.","thinkingSignature":"548c59b2fb09c9d1edaadb4949202c1eb8dbaac76c7587ed82f9c9ca0b417694"},{"type":"toolCall","id":"call_function_fjsamxdllyag_1","name":"write","arguments":{"path":"/root/.openclaw/workspaces2/projects/s1-ppe-safety/backend/app.py","content":"\"\"\"\nS1 PPE Safety Monitor — Flask Backend\nREST API + Socket.IO for real-time alerts\n\"\"\"\nimport os\nimport cv2\nimport base64\nimport threading\nfrom datetime import datetime\nfrom flask import Flask, jsonify, request, Response\nfrom flask_socketio import SocketIO, emit\nfrom flask_cors import CORS\nfrom dotenv import load_dotenv\nfrom bson import ObjectId\nfrom pymongo import MongoClient\n\nfrom detector import PPEDetector\nfrom video_processor import VideoProcessor\n\nload_dotenv()\n\n# ── Config ──────────────────────────────────────────────────────────────────\nMONGO_URI = os.getenv(\"MONGO_URI\", \"mongodb://localhost:27017\")\nMONGO_DB  = os.getenv(\"MONGO_DB\",  \"ppe_safety\")\nVIDEO_PATH = os.getenv(\"VIDEO_PATH\", \"demo.mp4\")\nFPS_TARGET = int(os.getenv(\"FPS_TARGET\", \"3\"))\nDEBUG = os.getenv(\"DEBUG\", \"true\").lower() == \"true\"\n\n# ── Flask Setup ─────────────────────────────────────────────────────────────\napp = Flask(__name__)\napp.config[\"SECRET\"] = os.getenv(\"SECRET\", \"ppe-safety-secret-key\")\nCORS(app, resources={r\"/*\": {\"origins\": \"*\"}})\nsocketio = SocketIO(\n    app,\n    cors_allowed_origins=\"*\",\n    async_mode=\"eventlet\",\n    ping_timeout=30,\n    ping_interval=10,\n)\n\n# ── MongoDB ─────────────────────────────────────────────────────────────────\nmongo_client = None\ndb = None\nalerts_collection = None\n\n\ndef init_db():\n    global mongo_client, db, alerts_collection\n    try:\n        mongo_client = MongoClient(MONGO_URI, serverSelectionTimeoutMS=3000)\n        mongo_client.admin.command(\"ping\")\n        db = mongo_client[MONGO_DB]\n        alerts_collection = db[\"alerts\"]\n        # Create indexes\n        alerts_collection.create_index(\"timestamp\")\n        alerts_collection.create_index(\"camera_id\")\n        alerts_collection.create_index([(\"timestamp\", -1)])\n        print(f\"[DB] Connected to MongoDB: {MONGO_DB}\")\n    except Exception as e:\n        print(f\"[DB] Warning: MongoDB not available ({e}). Running without persistence.\")\n\n\n# ── Detection Engine ────────────────────────────────────────────────────────\nprocessor = None\ndetector = PPEDetector()\n\n\ndef on_violation_detected(violations, summary):\n    \"\"\"Callback when PPE violations are found.\"\"\"\n    timestamp = datetime.utcnow().isoformat()\n\n    for v in violations:\n        alert = {\n            \"type\": \"ppe_violation\",\n            \"timestamp\": timestamp,\n            \"camera_id\": \"demo-camera\",\n            \"detection\": {\n                \"bbox\": v[\"bbox\"],\n                \"confidence\": v[\"confidence\"],\n                \"class_name\": v[\"class_name\"],\n                \"has_helmet\": v[\"ppe_status\"][\"has_helmet\"],\n                \"has_vest\": v[\"ppe_status\"][\"has_vest\"],\n                \"compliant\": v[\"ppe_status\"][\"compliant\"],\n            },\n            \"summary\": summary,\n        }\n\n        # Persist to MongoDB\n        if alerts_collection:\n            try:\n                alerts_collection.insert_one(alert)\n            except Exception as e:\n                print(f\"[DB] Failed to persist alert: {e}\")\n\n        # Emit via WebSocket\n        socketio.emit(\"ppe_alert\", alert)\n\n\ndef on_detection_results(frame, detections, summary):\n    \"\"\"Callback on every detection cycle.\"\"\"\n    # Send summary update to dashboard subscribers\n    socketio.emit(\"detection_summary\", {\n        \"summary\": summary,\n        \"timestamp\": datetime.utcnow().isoformat(),\n        \"camera_id\": \"demo-camera\",\n    })\n\n\n# ── Routes ───────────────────────────────────────────────────────────────────\n\n@app.route(\"/health\", methods=[\"GET\"])\ndef health():\n    return jsonify({\n        \"status\": \"ok\",\n        \"timestamp\": datetime.utcnow().isoformat(),\n        \"processor_running\": processor._running if processor else False,\n    })\n\n\n@app.route(\"/api/detect\", methods=[\"POST\"])\ndef detect_frame():\n    \"\"\"\n    Accept a base64-encoded image, return detection results.\n    Body: { \"image\": \"base64...\", \"camera_id\": \"cam1\" }\n    \"\"\"\n    try:\n        data = request.get_json()\n        image_b64 = data.get(\"image\", \"\")\n        camera_id = data.get(\"camera_id\", \"unknown\")\n\n        if not image_b64:\n            return jsonify({\"error\": \"No image provided\"}), 400\n\n        # Decode image\n        img_bytes = base64.b64decode(image_b64)\n        nparr = __import__(\"numpy\").frombuffer(img_bytes, dtype=\"uint8\")\n        frame = cv2.imdecode(nparr, cv2.IMREAD_COLOR)\n\n        if frame is None:\n            return jsonify({\"error\": \"Invalid image\"}), 400\n\n        # Detect\n        annotated, detections, summary, violations = processor.process_single_frame(frame)\n\n        # Annotate frame\n        annotated_b64 = VideoProcessor.frame_to_base64(annotated)\n\n        response = {\n            \"detections\": detections,\n            \"summary\": summary,\n            \"annotated_image\": annotated_b64,\n            \"camera_id\": camera_id,\n            \"timestamp\": datetime.utcnow().isoformat(),\n        }\n\n        # Log violations to DB\n        if violations and alerts_collection:\n            for v in violations:\n                alerts_collection.insert_one({\n                    \"type\": \"ppe_violation\",\n                    \"timestamp\": datetime.utcnow().isoformat(),\n                    \"camera_id\": camera_id,\n                    \"detection\": {\n                        \"bbox\": v[\"bbox\"],\n                        \"confidence\": v[\"confidence\"],\n                        \"has_helmet\": v[\"ppe_status\"][\"has_helmet\"],\n                        \"has_vest\": v[\"ppe_status\"][\"has_vest\"],\n                    },\n                })\n\n        return jsonify(response)\n\n    except Exception as e:\n        return jsonify({\"error\": str(e)}), 500\n\n\n@app.route(\"/api/summary\", methods=[\"GET\"])\ndef get_summary():\n    \"\"\"Get latest detection summary from running processor.\"\"\"\n    if not processor:\n        return jsonify({\"error\": \"Processor not initialized\"}), 503\n\n    results = processor.get_latest_results()\n    return jsonify({\n        **results,\n        \"timestamp\": datetime.utcnow().isoformat(),\n    })\n\n\n@app.route(\"/api/alerts\", methods=[\"GET\"])\ndef get_alerts():\n    \"\"\"Get recent alerts from MongoDB.\"\"\"\n    if not alerts_collection:\n        return jsonify([])\n\n    limit = int(request.args.get(\"limit\", 50))\n    cursor = alerts_collection.find(\n        {},\n        {\"_id\": 0}\n    ).sort(\"timestamp\", -1).limit(limit)\n\n    alerts = list(cursor)\n    return jsonify(alerts)\n\n\n@app.route(\"/api/alerts/stats\", methods=[\"GET\"])\ndef get_alert_stats():\n    \"\"\"Get aggregated alert statistics.\"\"\"\n    if not alerts_collection:\n        return jsonify({\"error\": \"DB not available\"}), 503\n\n    from datetime import timedelta\n    now = datetime.utcnow()\n    last_24h = now - timedelta(hours=24)\n\n    pipeline = [\n        {\"$match\": {\"timestamp\": {\"$gte\": last_24h.isoformat()}}},\n        {\"$group\": {\n            \"_id\": None,\n            \"total\": {\"$sum\": 1},\n            \"no_helmet\": {\n                \"$sum\": {\"$cond\": [{\"$eq\": [\"$detection.has_helmet\", False]}, 1, 0]}\n            },\n            \"no_vest\": {\n                \"$sum\": {\"$cond\": [{\"$eq\": [\"$detection.has_vest\", False]}, 1, 0]}\n            },\n        }}\n    ]\n\n    try:\n        result = list(alerts_collection.aggregate(pipeline))\n        if result:\n            stats = result[0]\n            del stats[\"_id\"]\n            return jsonify(stats)\n        return jsonify({\"total\": 0, \"no_helmet\": 0, \"no_vest\": 0})\n    except Exception as e:\n        return jsonify({\"error\": str(e)}), 500\n\n\n@app.route(\"/api/start\", methods=[\"POST\"])\ndef start_processor():\n    \"\"\"Start the video processor.\"\"\"\n    global processor\n    if processor and processor._running:\n        return jsonify({\"status\": \"already_running\"})\n\n    use_webcam = request.json.get(\"use_webcam\", False) if request.is_json else False\n    video_path = request.json.get(\"video_path\", VIDEO_PATH) if request.is_json else VIDEO_PATH\n\n    processor = VideoProcessor(\n        video_path=video_path,\n        use_webcam=use_webcam,\n        fps_target=FPS_TARGET,\n    )\n    processor.start(\n        on_detection=on_detection_results,\n        on_violation=on_violation_detected,\n    )\n\n    return jsonify({\"status\": \"started\", \"video_path\": video_path, \"use_webcam\": use_webcam})\n\n\n@app.route(\"/api/stop\", methods=[\"POST\"])\ndef stop_processor():\n    \"\"\"Stop the video processor.\"\"\"\n    global processor\n    if processor:\n        processor.stop()\n        return jsonify({\"status\": \"stopped\"})\n    return jsonify({\"status\": \"not_running\"})\n\n\n# ── Socket.IO Events ────────────────────────────────────────────────────────\n\n@socketio.on(\"connect\")\ndef on_connect():\n    print(f\"[WS] Client connected: {request.sid}\")\n    emit(\"connected\", {\"sid\": request.sid, \"message\": \"Connected to PPE Safety Monitor\"})\n\n\n@socketio.on(\"disconnect\")\ndef on_disconnect():\n    print(f\"[WS] Client disconnected: {request.sid}\")\n\n\n@socketio.on(\"subscribe\")\ndef on_subscribe(data):\n    camera_id = data.get(\"camera_id\", \"demo-camera\") if data else \"demo-camera\"\n    print(f\"[WS] Client {request.sid} subscribed to {camera_id}\")\n    emit(\"subscribed\", {\"camera_id\": camera_id})\n\n\n# ── Startup ─────────────────────────────────────────────────────────────────\n\nif __name__ == \"__main__\":\n    init_db()\n\n    # Auto-start processor with video file if path exists\n    default_video = os.path.join(os.path.dirname(__file__), \"demo.mp4\")\n    if os.path.exists(default_video):\n        print(f\"[START] Auto-starting with video: {default_video}\")\n        processor = VideoProcessor(video_path=default_video, fps_target=FPS_TARGET)\n        processor.start(\n            on_detection=on_detection_results,\n            on_violation=on_violation_detected,\n        )\n    else:\n        print(\"[START] No video file found — use /api/start to start processing\")\n        processor = VideoProcessor()\n\n    print(\"[APP] PPE Safety Monitor ready on http://0.0.0.0:5000\")\n    socketio.run(app, host=\"0.0.0.0\", port=5000, debug=DEBUG)\n"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":74,"output":2337,"cacheRead":31067,"cacheWrite":3254,"totalTokens":36732,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776787794994,"responseId":"0636d45302f2cb58ecd50bced1eb4978"}}
