{"type":"message","id":"a0d1528e","parentId":"f105c63f","timestamp":"2026-04-23T16:51:55.905Z","message":{"role":"toolResult","toolCallId":"call_function_lbxssog7bpqu_1","toolName":"read","content":[{"type":"text","text":"import type {} from '../types/express.d';\nimport { Request, Response } from 'express';\nimport { CourseService } from '@/application/services/course.service';\nimport { catchAsync } from '@/interface/middlewares/catchAsync.middleware';\nimport { ctrlLogger } from '@/infrastructure/logging/controller-logger';\n\nconst courseService = new CourseService();\n\nexport const getAllCourses = catchAsync(async (req: Request, res: Response) => {\n  const log = ctrlLogger('course.get_all', req);\n  const filters = { ...req.query };\n\n  const courses = await courseService.getAllCourses(filters, (req as any).pagination, (req as any).user);\n  log.success(res, courses, 'Lấy danh sách khóa học thành công');\n});\n\nexport const getCourseById = catchAsync(async (req: Request, res: Response) => {\n  const log = ctrlLogger('course.get_by_id', req);\n  const idStr = typeof req.params.id === 'string' ? req.params.id : req.params.id[0];\n  log.start({ courseId: idStr });\n\n[96 more lines in file. Use offset=21 to continue.]"}],"isError":false,"timestamp":1776963115899}}
