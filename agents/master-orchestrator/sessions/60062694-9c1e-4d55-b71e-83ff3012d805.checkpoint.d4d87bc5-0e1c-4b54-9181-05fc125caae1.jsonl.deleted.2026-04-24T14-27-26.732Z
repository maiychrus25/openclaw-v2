g thể thêm buổi DAT.' : 'Thêm buổi DAT'}\n                            className={`inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg font-bold text-[11px] shadow-sm active:scale-95 transition-colors ${\n                              item.enrollment_id || item.enrollment?._id\n                                ? 'bg-indigo-600 text-white hover:bg-indigo-700 shadow-indigo-600/25'\n                                : 'bg-gray-100 text-gray-400 cursor-not-allowed shadow-none'\n                            }`}\n                          >\n                            <Plus className=\"w-3.5 h-3.5\" /> Thêm DAT\n                          </button>\n                          {!(item.enrollment_id || item.enrollment?._id) && (\n                            <span className=\"text-[10px] text-amber-600 font-medium italic\">\n                              Chưa vào khóa\n                            </span>\n                          )}\n                        </div>\n                      </td>\n"}]}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-TroLy","usage":{"input":5613,"output":605,"cacheRead":97152,"cacheWrite":0,"totalTokens":103370,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776941718207,"responseId":"1776941720075"}}
