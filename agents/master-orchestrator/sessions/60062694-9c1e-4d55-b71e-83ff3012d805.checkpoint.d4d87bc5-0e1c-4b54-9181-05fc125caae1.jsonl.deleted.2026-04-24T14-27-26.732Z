ter] = useState('Tất cả');\n  const [debouncedSearch, setDebouncedSearch] = useState('');\n\n  const [isAddModalOpen, setIsAddModalOpen] = useState(false);\n  const [courseToEdit, setCourseToEdit] = useState<any>(null);\n  const [courseToDelete, setCourseToDelete] = useState<any>(null);\n  const [selectedStudents, setSelectedStudents] = useState<string[]>([]);\n  const [selectedStudent, setSelectedStudent] = useState<any>(null);\n  const [targetCourse, setTargetCourse] = useState('');\n  const [isAssigning, setIsAssigning] = useState(false);\n  const [isExporting, setIsExporting] = useState(false);\n  const [isImporting, setIsImporting] = useState(false);\n  const [isUtilsMenuOpen, setIsUtilsMenuOpen] = useState(false);\n  const fileInputRef = React.useRef<HTMLInputElement>(null);\n\n  // Course Student List Drawer State\n  const [selectedCourseForList, setSelectedCourseForList] = useState<string | null>(null);\n  const [selectedCourseName, setSelectedCourseName] = useState('');\n  const [selectedCourseEndDate, setSelectedCourseEndDate] = useState<string | null>(null);\n\n  const handleSelectAll = (e: React.ChangeEvent<HTMLInputElement>) => {\n    if (e.target.checked) {\n      setSelectedStudents(unassignedList.map((s) => s._id));\n    } else {\n      setSelectedStudents([]);\n    }\n  };\n\n  const handleSelectStudent = (id: string) => {\n    if (selectedStudents.includes(id)) {\n      setSelectedStudents(selectedStudents.filter((sId) => sId !== id));\n    } else {\n      setSelectedStudents([...selectedStudents, id]);\n    }\n  };\n\n  const handleAssign = async (studentId?: string) => {\n    if (!targetCourse || targetCourse === '— Chọn khóa —') {\n      toast.warning('Vui lòng chọn khóa đích trước!');\n      return;\n    }\n\n    const idsToAssign = studentId ? [studentId] : selectedStudents;\n\n    if (idsToAssign.length === 0) {\n      toast.warning('Vui lòng chọn ít nhất một học viên!');\n      return;\n    }\n\n    setIsAssigning(true);\n    try {\n      await assignStudentsToCourse(targetCourse, idsToAssign);\n      toast.success(`Đã gán thành công ${idsToAssign.length} học viên`);\n\n      // Refresh both lists\n      fetchCourses();\n      fetchUnassignedStudents();\n\n      // Reset selection\n      if (!studentId) setSelectedStudents([]);\n\n[753 more lines in file. Use offset=130 to continue.]"}],"isError":false,"timestamp":1776966963446}}
