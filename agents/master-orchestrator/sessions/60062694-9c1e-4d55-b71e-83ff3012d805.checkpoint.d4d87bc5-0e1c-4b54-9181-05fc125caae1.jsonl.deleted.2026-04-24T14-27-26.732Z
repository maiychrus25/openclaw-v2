{"type":"message","id":"0d0833e0","parentId":"5f9feed8","timestamp":"2026-04-23T17:55:14.494Z","message":{"role":"toolResult","toolCallId":"call_function_51nqtdyjsump_1","toolName":"read","content":[{"type":"text","text":"\n  async getStats(currentUser?: any): Promise<any> {\n    const now = new Date();\n    const match: any = {};\n    if (currentUser) {\n      Object.assign(match, addOwnershipFilter(currentUser));\n    }\n\n    const stats = await CourseModel.aggregate([\n      { $match: match },\n      {\n        $group: {\n          _id: null,\n          total: { $sum: 1 },\n          draft: {\n            $sum: {\n              $cond: [{ $eq: ['$status', 'draft'] }, 1, 0],\n            },\n          },\n          ongoing: {\n            $sum: {\n              $cond: [\n                {\n                  $and: [{ $eq: ['$status', 'ongoing'] }, { $gt: ['$end_date', now] }],\n                },\n                1,\n                0,\n              ],\n            },\n          },\n          completed: {\n            $sum: {\n              $cond: [\n                {\n                  $or: [\n                    { $eq: ['$status', 'completed'] },\n                    {\n                      $and: [{ $eq: ['$status', 'ongoing'] }, { $lte: ['$end_date', now] }],\n                    },\n                  ],\n                },\n                1,\n                0,\n              ],\n            },\n          },\n        },\n      },\n    ]);\n\n\n[4 more lines in file. Use offset=205 to continue.]"}],"isError":false,"timestamp":1776966914488}}
