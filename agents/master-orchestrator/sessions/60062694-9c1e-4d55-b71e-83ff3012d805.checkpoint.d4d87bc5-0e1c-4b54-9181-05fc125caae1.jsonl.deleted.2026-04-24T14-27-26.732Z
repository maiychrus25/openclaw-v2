{"type":"message","id":"e632ff37","parentId":"a68202da","timestamp":"2026-04-23T17:30:47.884Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Let me create a demo page.","thinkingSignature":"0fa10f8315813b688f9cd92bd54a85bc9d088f678af26a272d905661cc0d4e9c"},{"type":"toolCall","id":"call_function_8kie5fldpv1j_1","name":"write","arguments":{"path":"/root/.openclaw/workspaces2/projects/ahv-qlhv-fe/src/app/demo-banner/page.tsx","content":"'use client';\n\nimport React, { useState } from 'react';\nimport { CalendarCheck, CalendarX, Zap, Eye, X, CheckCircle2, Loader2 } from 'lucide-react';\nimport { toast } from 'sonner';\n\ninterface CourseMilestone {\n  _id: string;\n  name: string;\n  start_date?: string;\n  end_date?: string;\n  student_count: number;\n}\n\ninterface Milestones {\n  openingCourses: CourseMilestone[];\n  closingCourses: CourseMilestone[];\n  openingCount: number;\n  closingCount: number;\n}\n\n// Demo milestones for testing\nconst DEMO_MILESTONES: Milestones = {\n  openingCourses: [\n    { _id: '1', name: 'Khóa B2 - Sáng thứ 2', start_date: new Date().toISOString(), student_count: 28 },\n    { _id: '2', name: 'Khóa B1 - Tối thứ 2', start_date: new Date().toISOString(), student_count: 35 },\n  ],\n  closingCourses: [\n    { _id: '3', name: 'Khóa A1 - Sáng thứ 7', end_date: new Date().toISOString(), student_count: 22 },\n  ],\n  openingCount: 2,\n  closingCount: 1,\n};\n\nexport default function DemoBannerPage() {\n  const [milestones] = useState<Milestones>(DEMO_MILESTONES);\n  const [processing, setProcessing] = useState(false);\n  const [showReviewModal, setShowReviewModal] = useState(false);\n  const [reviewTab, setReviewTab] = useState<'opening' | 'closing'>('opening');\n  const [selectedCourses, setSelectedCourses] = useState<Set<string>>(new Set());\n  const [updated, setUpdated] = useState(false);\n\n  const handleAutoUpdate = async () => {\n    setProcessing(true);\n    await new Promise((r) => setTimeout(r, 1500));\n    setProcessing(false);\n    setUpdated(true);\n    toast.success('Đã cập nhật 3 khóa học tự động!');\n  };\n\n  const handleManualUpdate = () => {\n    setSelectedCourses(new Set());\n    setShowReviewModal(true);\n    setReviewTab(milestones.openingCount > 0 ? 'opening' : 'closing');\n  };\n\n  const handleSubmitManual = async () => {\n    if (selectedCourses.size === 0) {\n      toast.error('Vui lòng chọn ít nhất một khóa học.');\n      return;\n    }\n    setProcessing(true);\n    await new Promise((r) => setTimeout(r, 1000));\n    setProcessing(false);\n    setShowReviewModal(false);\n    setUpdated(true);\n    toast.success(`Đã cập nhật ${selectedCourses.size} khóa học!`);\n  };\n\n  const toggleCourse = (id: string) => {\n    setSelectedCourses((prev) => {\n      const next = new Set(prev);\n      if (next.has(id)) next.delete(id);\n      else next.add(id);\n      return next;\n    });\n  };\n\n  const currentCourses = reviewTab === 'opening' ? milestones.openingCourses : milestones.closingCourses;\n\n  return (\n    <div className=\"min-h-screen bg-gray-100 p-8\">\n      <div className=\"max-w-4xl mx-auto\">\n        <div className=\"mb-6\">\n          <h1 className=\"text-2xl font-black text-gray-900\">Demo: Banner Cột Mốc Khóa Học</h1>\n          <p className=\"text-gray-500 text-sm mt-1\">\n            Đây là demo hiển thị banner như khi thầy giáo đăng nhập vào dashboard\n          </p>\n        </div>\n\n        {/* Simulated Dashboard area */}\n        <div className=\"bg-white rounded-2xl p-6 shadow-sm border border-gray-100 mb-6\">\n          <h2 className=\"text-lg font-bold text-gray-800 mb-1\">Dashboard — Tổng quan</h2>\n          <p className=\"text-xs text-gray-400\">Ngày: {new Date().toLocaleDateString('vi-VN', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' })}</p>\n        </div>\n\n        {updated ? (\n          <div className=\"bg-emerald-50 border border-emerald-200 rounded-2xl p-6 text-center\">\n            <CheckCircle2 className=\"w-12 h-12 text-emerald-500 mx-auto mb-2\" />\n            <p className=\"text-emerald-800 font-bold\">Đã cập nhật thành công!</p>\n            <p className=\"text-emerald-600 text-sm mt-1\">Banner sẽ không hiện lại trong phiên này.</p>\n            <button onClick={() => setUpdated(false)} className=\"mt-4 px-4 py-2 bg-emerald-600 text-white rounded-xl text-sm font-bold hover:bg-emerald-700\">\n              Xem lại banner\n            </button>\n          </div>\n        ) : (\n          <div className=\"bg-gradient-to-r from-indigo-50 via-purple-50 to-indigo-50 border border-indigo-100 rounded-2xl p-5 shadow-sm\">\n            <div className=\"flex items-start gap-4\">\n              <div className=\"flex flex-col gap-2 flex-1 min-w-0\">\n                <div className=\"flex items-center gap-2 flex-wrap\">\n                  <div className=\"flex items-center gap-1.5 bg-indigo-600 text-white px-3 py-1.5 rounded-xl text-xs font-black shadow-sm\">\n                    <CalendarCheck className=\"w-4 h-4\" />\n                    <span>{milestones.openingCount} khóa khai giảng hôm nay</span>\n                  </div>\n                  <div className=\"flex items-center gap-1.5 bg-rose-600 text-white px-3 py-1.5 rounded-xl text-xs font-black shadow-sm\">\n                    <CalendarX className=\"w-4 h-4\" />\n                    <span>{milestones.closingCount} khóa kết thúc hôm nay</span>\n                  </div>\n                </div>\n                <p className=\"text-xs text-gray-500 font-medium\">\n                  Một số khóa học của bạn có cột mốc quan trọng trong ngày hôm nay.\n                </p>\n                <div className=\"flex items-center gap-2 pt-1\">\n                  <button\n                    onClick={handleAutoUpdate}\n                    disabled={processing}\n                    className=\"flex items-center gap-1.5 px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-xl text-xs font-bold transition-all active:scale-95 disabled:opacity-60 shadow-sm\"\n                  >\n                    {processing ? <Loader2 className=\"w-3.5 h-3.5 animate-spin\" /> : <Zap className=\"w-3.5 h-3.5\" />}\n                    Tự động cập nhật\n                  </button>\n                  <button\n                    onClick={handleManualUpdate}\n                    disabled={processing}\n                    className=\"flex items-center gap-1.5 px-4 py-2 bg-white hover:bg-gray-50 text-gray-700 border border-gray-200 rounded-xl text-xs font-bold transition-all active:scale-95 disabled:opacity-60\"\n                  >\n                    <Eye className=\"w-3.5 h-3.5\" />\n                    Cập nhật bằng tay\n                  </button>\n                </div>\n              </div>\n            </div>\n          </div>\n        )}\n\n        {/* Modal */}\n        {showReviewModal && (\n          <div className=\"fixed inset-0 z-[100] flex items-center justify-center p-4 bg-gray-900/50 backdrop-blur-sm animate-in fade-in duration-300\">\n            <div className=\"bg-white rounded-3xl w-full max-w-lg shadow-2xl overflow-hidden animate-in zoom-in-95 duration-300\">\n              <div className=\"px-6 py-5 border-b border-gray-100 flex items-center justify-between bg-gray-50/50\">\n                <div>\n                  <h3 className=\"text-lg font-black text-gray-900\">Cập nhật trạng thái khóa học</h3>\n                  <p className=\"text-[10px] text-gray-400 font-bold uppercase tracking-widest mt-0.5\">\n                    Chọn các khóa học bạn muốn cập nhật\n                  </p>\n                </div>\n                <button onClick={() => setShowReviewModal(false)} className=\"p-2 text-gray-400 hover:text-rose-500 hover:bg-rose-50 rounded-full transition-colors\">\n                  <X className=\"w-5 h-5\" />\n                </button>\n              </div>\n\n              <div className=\"flex border-b border-gray-100\">\n                {milestones.openingCount > 0 && (\n                  <button\n                    onClick={() => { setReviewTab('opening'); setSelectedCourses(new Set()); }}\n                    className={`flex-1 px-4 py-3 text-xs font-bold uppercase tracking-widest transition-colors ${\n                      reviewTab === 'opening' ? 'text-indigo-600 border-b-2 border-indigo-600 bg-indigo-50/50' : 'text-gray-400 hover:text-gray-600'\n                    }`}\n                  >\n                    Khai giảng ({milestones.openingCount})\n                  </button>\n                )}\n                {milestones.closingCount > 0 && (\n                  <button\n                    onClick={() => { setReviewTab('closing'); setSelectedCourses(new Set()); }}\n                    className={`flex-1 px-4 py-3 text-xs font-bold uppercase tracking-widest transition-colors ${\n                      reviewTab === 'closing' ? 'text-rose-600 border-b-2 border-rose-600 bg-rose-50/50' : 'text-gray-400 hover:text-gray-600'\n                    }`}\n                  >\n                    Kết thúc ({milestones.closingCount})\n                  </button>\n                )}\n              </div>\n\n              <div className=\"p-4 max-h-80 overflow-y-auto flex flex-col gap-2\">\n                {currentCourses.map((course) => (\n                  <label\n                    key={course._id}\n                    className={`flex items-center gap-3 p-3 rounded-xl border cursor-pointer transition-all ${\n                      selectedCourses.has(course._id) ? 'border-indigo-400 bg-indigo-50' : 'border-gray-100 hover:border-gray-200 hover:bg-gray-50'\n                    }`}\n                  >\n                    <input\n                      type=\"checkbox\"\n                      checked={selectedCourses.has(course._id)}\n                      onChange={() => toggleCourse(course._id)}\n                      className=\"w-4 h-4 rounded border-gray-300 text-indigo-600\"\n                    />\n                    <div className=\"flex-1 min-w-0\">\n                      <p className=\"text-sm font-bold text-gray-800 truncate\">{course.name}</p>\n                      <p className=\"text-[10px] text-gray-400 font-medium\">\n                        {course.student_count} học viên\n                        {reviewTab === 'opening' && course.start_date && (\n                          <span> · KKG: {new Date(course.start_date).toLocaleDateString('vi-VN')}</span>\n                        )}\n                        {reviewTab === 'closing' && course.end_date && (\n                          <span> · Kết thúc: {new Date(course.end_date).toLocaleDateString('vi-VN')}</span>\n                        )}\n                      </p>\n                    </div>\n                    {selectedCourses.has(course._id) && <CheckCircle2 className=\"w-4 h-4 text-indigo-500 shrink-0\" />}\n                  </label>\n                ))}\n              </div>\n\n              <div className=\"px-6 py-5 flex justify-end gap-3 border-t border-gray-100 bg-gray-50/50\">\n                <button\n                  onClick={() => setShowReviewModal(false)}\n                  className=\"px-5 py-2.5 text-xs font-bold uppercase tracking-widest text-gray-500 hover:text-gray-900 hover:bg-gray-200/50 rounded-xl transition-all\"\n                >\n                  Hủy\n                </button>\n                <button\n                  onClick={handleSubmitManual}\n                  disabled={processing || selectedCourses.size === 0}\n                  className=\"flex items-center gap-2 px-6 py-2.5 text-xs font-bold uppercase tracking-widest text-white bg-indigo-600 hover:bg-indigo-700 rounded-xl transition-all disabled:opacity-50\"\n                >\n                  {processing && <Loader2 className=\"w-3.5 h-3.5 animate-spin\" />}\n                  Cập nhật {selectedCourses.size > 0 ? `(${selectedCourses.size})` : ''}\n                </button>\n              </div>\n            </div>\n          </div>\n        )}\n      </div>\n    </div>\n  );\n}\n"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":77,"output":2972,"cacheRead":113515,"cacheWrite":1112,"totalTokens":117676,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776965420361,"responseId":"06398a2daba382842a983cf0f8f7279e"}}
