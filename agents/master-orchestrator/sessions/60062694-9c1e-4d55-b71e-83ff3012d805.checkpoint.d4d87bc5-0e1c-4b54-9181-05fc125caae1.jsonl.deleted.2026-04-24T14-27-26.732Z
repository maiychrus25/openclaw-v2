{"type":"message","id":"a7380a06","parentId":"f8db01b2","timestamp":"2026-04-23T16:38:36.762Z","message":{"role":"toolResult","toolCallId":"call_function_1a775da8u6c5_2","toolName":"read","content":[{"type":"text","text":"  }, [searchTerm]);\n\n  // 3. Data Fetching\n  const fetchStudents = useCallback(\n    async (page = 1, limit = 10) => {\n      const requestId = ++latestRequestIdRef.current;\n      setIsLoading(true);\n\n      try {\n        const filters = {\n          search: debouncedSearch,\n          status: toBeStatus(statusFilter),\n          vehicle_type: vehicleFilter,\n          license_category_id: selectedRank,\n          region_id: selectedRegion,\n          course_id: selectedCourse,\n          from_date: fromDate,\n          to_date: toDate,\n          debt_status: debtFilter === 'Tất cả' ? null : debtFilter,\n          simple: true,\n        };\n\n        const res = await getStudents(page, limit, filters);\n        if (requestId !== latestRequestIdRef.current) return;\n\n        if (res.success && res.data) {\n          setStudents(res.data.data || []);\n          setMeta(res.data.meta);\n        }\n      } catch {\n        if (requestId === latestRequestIdRef.current) {\n          toast.error('Lỗi khi tải danh sách học viên');\n        }\n      } finally {\n        if (requestId === latestRequestIdRef.current) {\n          setIsLoading(false);\n        }\n      }\n    },\n    [\n      debouncedSearch,\n      statusFilter,\n      vehicleFilter,\n      selectedRank,\n      selectedRegion,\n      selectedCourse,\n      fromDate,\n      toDate,\n      debtFilter,\n    ],\n  );\n\n  useEffect(() => {\n    fetchStudents(1, 10);\n    setSelectedIds([]); // Reset selection on filter change\n  }, [fetchStudents]);\n\n  // 4. Real-time Refresh Listener\n  useEffect(() => {\n    const handleRefresh = () => {\n      fetchStudents(1, 10);\n      fetchManagementStats();\n    };\n    window.addEventListener('refresh-student-list', handleRefresh);\n    return () => window.removeEventListener('refresh-student-list', handleRefresh);\n  }, [fetchStudents, fetchManagementStats]);\n\n  // 5. Data Mapping (Memoized for performance)\n  const mappedStudents = useMemo(() => {\n    return students.map((item: any) => ({\n      id: item._id,\n      student_id: item.student_id || `HV${item._id.slice(-4).toUpperCase()}`,\n      name:\n        item.fullName ||\n        (item.user_id?.last_name ? `${item.user_id.last_name} ${item.user_id.first_name || ''}` : 'Không rõ'),\n      phone: item.user_id?.phone || item.phone || '--',\n      email: item.user_id?.email || '--',\n      rank: item.license_category_name || item.license_category_id || 'B2',\n      region: item.region_id?.name || 'Nội thành',\n      status: item.status_detail || item.status || 'Chờ KSK',\n\n[290 more lines in file. Use offset=215 to continue.]"}],"isError":false,"timestamp":1776962316756}}
