{"type":"message","id":"ab1c2f9a","parentId":"db59441c","timestamp":"2026-04-23T16:33:38.808Z","message":{"role":"toolResult","toolCallId":"call_function_gfqatd1h15ey_1","toolName":"read","content":[{"type":"text","text":"              {activeTab === 'khamsk' &&\n                (!fullData ? (\n                  <div className=\"flex justify-center items-center h-40\">\n                    <div className=\"w-8 h-8 border-4 border-indigo-200 border-t-indigo-600 rounded-full animate-spin\"></div>\n                  </div>\n                ) : (\n                  <form\n                    className=\"flex flex-col gap-6 animate-in fade-in slide-in-from-bottom-2 duration-300\"\n                    onSubmit={async (e) => {\n                      e.preventDefault();\n                      try {\n                        const { status, date, hospital, note } = healthCheckState;\n                        // Update: The backend StudentService.updateStudent expects flat fields for health_check sync\n                        const res = await updateStudent(student.id, {\n                          health_check_status: status,\n                          health_check_date: date,\n                          hospital_id: hospital,\n                          health_check_note: note,\n                        });\n                        if (res.success) {\n                          toast.success('Đã cập nhật thông tin khám sức khỏe.');\n                          setFullData((prev: any) => ({\n                            ...prev,\n                            health_check: { status, date, hospital, note },\n                          }));\n                          onRefresh?.();\n                        }\n                      } catch {\n                        toast.error('Có lỗi xảy ra khi lưu thông tin.');\n                      }\n                    }}\n                  >\n                    <div className=\"grid grid-cols-2 gap-x-6 gap-y-5\">\n                      <FieldWrapper label=\"Trạng thái khám SK\">\n                        <select\n                          name=\"status\"\n                          value={healthCheckState.status}\n                          onChange={(e) =>\n                            setHealthCheckState((prev) => ({\n                              ...prev,\n                              status: e.target.value,\n                            }))\n                          }\n                          className=\"w-full px-3 py-2 bg-white border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-600/20 text-sm font-bold text-gray-700\"\n                        >\n                          <option value=\"Chờ khám\">Chờ khám</option>\n                          <option value=\"Đủ điều kiện\">Đã khám - Đủ điều kiện</option>\n                          <option value=\"Không đủ điều kiện\">Không đủ điều kiện</option>\n                        </select>\n                      </FieldWrapper>\n                      <FieldWrapper label=\"Ngày khám\">\n                        <ViDateInput\n                          name=\"date\"\n                          value={healthCheckState.date}\n                          onChange={(val) => setHealthCheckState((prev) => ({ ...prev, date: val }))}\n                          className=\"w-full px-3 py-2 bg-white border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-600/20 text-sm font-medium\"\n                        />\n                      </FieldWrapper>\n                      <FieldWrapper label=\"Phòng khám / Bệnh viện\" colSpan={2}>\n                        <div className=\"flex gap-2\">\n                          <input\n                            name=\"hospital\"\n                            type=\"text\"\n                            value={healthCheckState.hospital}\n                            onChange={(e) =>\n                              setHealthCheckState((prev) => ({\n                                ...prev,\n                                hospital: e.target.value,\n                              }))\n                            }\n                            placeholder=\"Nhập hoặc chọn bệnh viện...\"\n                            className=\"flex-1 px-3 py-2 bg-white border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-600/20 text-sm font-medium\"\n                          />\n                          <button\n                            type=\"button\"\n                            onClick={() => {\n                              setHospitalDraft(healthCheckState.hospital);\n                              setHospitalModalOpen(true);\n                            }}\n                            className=\"px-3 py-2 bg-indigo-50 hover:bg-indigo-100 text-indigo-600 border border-indigo-200 rounded-lg text-xs font-bold shrink-0 transition-colors\"\n\n[1181 more lines in file. Use offset=1300 to continue.]"}],"isError":false,"timestamp":1776962018802}}
