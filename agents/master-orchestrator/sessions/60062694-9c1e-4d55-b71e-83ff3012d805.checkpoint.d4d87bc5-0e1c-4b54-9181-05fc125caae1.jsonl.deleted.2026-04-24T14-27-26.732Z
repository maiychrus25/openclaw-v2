{"type":"message","id":"61edf4dc","parentId":"f552e0c8","timestamp":"2026-04-23T11:18:37.181Z","message":{"role":"toolResult","toolCallId":"call_YJXlDrYG1q5YKYKvPUwcjCM1","toolName":"read","content":[{"type":"text","text":"import React, { useState } from 'react';\nimport ViDateInput from '@/src/components/shared/ViDateInput';\nimport { X, Calendar, Clock, MapPin, Save, Loader2 } from 'lucide-react';\nimport { toast } from 'sonner';\nimport { addDatSession } from '@/src/services/datService';\n\ninterface DatSessionModalProps {\n  isOpen: boolean;\n  onClose: () => void;\n  enrollmentId: string;\n  onSuccess: () => void;\n}\n\nconst DatSessionModal: React.FC<DatSessionModalProps> = ({ isOpen, onClose, enrollmentId, onSuccess }) => {\n  const [loading, setLoading] = useState(false);\n  const [formData, setFormData] = useState({\n    date: new Date().toISOString().split('T')[0],\n    startTime: '08:00',\n    endTime: '10:00',\n    duration: '120', // Default 120 minutes (2 hours)\n    distance: '',\n    notes: '',\n  });\n\n  const syncDuration = (startStr: string, endStr: string) => {\n    try {\n      const [sh, sm] = startStr.split(':').map(Number);\n      const [eh, em] = endStr.split(':').map(Number);\n      const diffMinutes = eh * 60 + em - (sh * 60 + sm);\n      return Math.max(0, diffMinutes).toString();\n    } catch {\n      return '0';\n    }\n  };\n\n  const syncEndTime = (startStr: string, durationStr: string) => {\n    try {\n      const [sh, sm] = startStr.split(':').map(Number);\n      const totalMinutes = sh * 60 + sm + parseInt(durationStr || '0');\n      const eh = Math.floor(totalMinutes / 60) % 24;\n      const em = totalMinutes % 60;\n      return `${eh.toString().padStart(2, '0')}:${em.toString().padStart(2, '0')}`;\n    } catch {\n      return startStr;\n    }\n  };\n\n  if (!isOpen) return null;\n\n  const handleSubmit = async (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!formData.distance || isNaN(parseFloat(formData.distance))) {\n      toast.error('Vui lòng nhập quãng đường hợp lệ.');\n      return;\n    }\n    if (!formData.duration || isNaN(parseInt(formData.duration))) {\n      toast.error('Vui lòng nhập số phút học hợp lệ.');\n      return;\n    }\n\n    setLoading(true);\n    try {\n      const start = new Date(`${formData.date}T${formData.startTime}:00`);\n      const end = new Date(`${formData.date}T${formData.endTime}:00`);\n\n      if (end <= start) {\n        toast.error('Thời gian kết thúc phải sau thời gian bắt đầu.');\n        setLoading(false);\n        return;\n      }\n\n      const res = await addDatSession({\n        course_student_id: enrollmentId,\n        session_type: 'dat',\n        start_time: start.toISOString(),\n        end_time: end.toISOString(),\n        distance_km: parseFloat(formData.distance),\n        notes: formData.notes,\n      });\n\n      if (res.success) {\n        toast.success('Đã thêm buổi DAT thành công!');\n        onSuccess();\n        onClose();\n      } else {\n        toast.error(res.message || 'Có lỗi xảy ra.');\n      }\n    } catch (error) {\n      toast.error('Lỗi khi kết nối đến máy chủ.');\n    } finally {\n      setLoading(false);\n    }\n  };\n\n  return (\n    <div className=\"fixed inset-0 z-[100] flex items-center justify-center p-4 bg-black/50 backdrop-blur-sm animate-in fade-in duration-200\">\n      <div className=\"bg-white w-full max-w-md rounded-2xl shadow-2xl overflow-hidden animate-in zoom-in-95 duration-200\">\n        <div className=\"px-6 py-4 border-b border-gray-100 flex justify-between items-center bg-indigo-50/30\">\n          <h3 className=\"font-black text-gray-900 flex items-center gap-2\">\n            <div className=\"p-1.5 bg-indigo-100 text-indigo-600 rounded-lg\">\n              <Clock className=\"w-4 h-4\" />\n            </div>\n            Thêm buổi DAT mới\n          </h3>\n          <button onClick={onClose} className=\"p-2 hover:bg-gray-100 rounded-full transition-colors\">\n            <X className=\"w-5 h-5 text-gray-400\" />\n          </button>\n        </div>\n\n        <form onSubmit={handleSubmit} className=\"p-6 flex flex-col gap-5\">\n          <div className=\"flex flex-col gap-1.5\">\n            <label className=\"text-xs font-bold text-gray-500 uppercase flex items-center gap-1.5\">\n              <Calendar className=\"w-3 h-3\" /> Ngày học\n            </label>\n            <ViDateInput\n              required\n              value={formData.date}\n              onChange={(val) => setFormData((prev) => ({ ...prev, date: val }))}\n              className=\"w-full px-4 py-2.5 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-600/20 text-sm font-medium\"\n            />\n          </div>\n\n          <div className=\"grid grid-cols-1 gap-4\">\n            <div className=\"flex flex-col gap-1.5 p-4 bg-indigo-50/50 border border-indigo-100 rounded-2xl\">\n              <label className=\"text-[10px] font-black text-indigo-600 uppercase flex items-center gap-1.5 tracking-widest\">\n                <Clock className=\"w-3 h-3\" strokeWidth={3} /> Thời lượng học (Phút)\n              </label>\n              <div className=\"relative mt-1\">\n                <input\n                  type=\"number\"\n                  required\n                  min=\"1\"\n                  placeholder=\"VD: 120\"\n                  value={formData.duration}\n                  onChange={(e) => {\n                    const newDur = e.target.value;\n                    setFormData((prev) => ({\n                      ...prev,\n                      duration: newDur,\n                      endTime: syncEndTime(prev.startTime, newDur),\n                    }));\n                  }}\n                  className=\"w-full px-0 py-1 bg-transparent border-none focus:ring-0 text-2xl font-black text-indigo-600 placeholder:text-indigo-200\"\n                />\n                <span className=\"absolute right-0 top-1/2 -translate-y-1/2 text-xs font-bold text-indigo-400 uppercase\">phút</span>\n              </div>\n            </div>\n          </div>\n\n          <div className=\"grid grid-cols-2 gap-4 bg-gray-50/50 p-4 rounded-2xl border border-gray-100\">\n            <div className=\"flex flex-col gap-1.5\">\n              <label className=\"text-[10px] font-black text-gray-400 uppercase flex items-center gap-1.5 tracking-widest\">\n                <Clock className=\"w-3 h-3\" /> Bắt đầu\n              </label>\n              <input\n                type=\"time\"\n                required\n                value={formData.startTime}\n                onChange={(e) => {\n                  const newStart = e.target.value;\n                  setFormData((prev) => ({\n                    ...prev,\n                    startTime: newStart,\n                    duration: syncDuration(newStart, prev.endTime),\n                  }));\n                }}\n                className=\"w-full bg-transparent border-none p-0 text-sm font-black text-gray-700 focus:ring-0\"\n              />\n            </div>\n            <div className=\"flex flex-col gap-1.5 border-l border-gray-200 pl-4\">\n              <label className=\"text-[10px] font-black text-gray-400 uppercase flex items-center gap-1.5 tracking-widest\">\n                <Clock className=\"w-3 h-3\" /> Kết thúc\n              </label>\n              <input\n                type=\"time\"\n                required\n                value={formData.endTime}\n                onChange={(e) => {\n                  const newEnd = e.target.value;\n                  setFormData((prev) => ({\n                    ...prev,\n                    endTime: newEnd,\n                    duration: syncDuration(prev.startTime, newEnd),\n                  }));\n                }}\n                className=\"w-full bg-transparent border-none p-0 text-sm font-black text-gray-700 focus:ring-0\"\n              />\n            </div>\n          </div>\n\n          <div className=\"flex flex-col gap-1.5\">\n            <label className=\"text-[10px] font-black text-gray-400 uppercase flex items-center gap-1.5 tracking-widest\">\n              <MapPin className=\"w-3 h-3\" /> Quãng đường (KM)\n            </label>\n            <div className=\"relative\">\n              <input\n                type=\"number\"\n                step=\"0.1\"\n                required\n                placeholder=\"VD: 25.5\"\n                value={formData.distance}\n                onChange={(e) => setFormData((prev) => ({ ...prev, distance: e.target.value }))}\n                className=\"w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-600/20 text-sm font-black text-gray-900 outline-none\"\n              />\n              <span className=\"absolute right-4 top-1/2 -translate-y-1/2 text-[10px] font-black text-gray-400 uppercase\">km</span>\n            </div>\n          </div>\n\n          <div className=\"flex flex-col gap-1.5\">\n            <label className=\"text-xs font-bold text-gray-500 uppercase\">Ghi chú (Tùy chọn)</label>\n            <textarea\n              rows={2}\n              placeholder=\"Thông tin thêm về buổi học...\"\n              value={formData.notes}\n              onChange={(e) => setFormData((prev) => ({ ...prev, notes: e.target.value }))}\n              className=\"w-full px-4 py-2.5 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-600/20 text-sm font-medium resize-none\"\n            />\n          </div>\n\n          <div className=\"flex gap-3 mt-2\">\n            <button\n              type=\"button\"\n              onClick={onClose}\n              disabled={loading}\n              className=\"flex-1 px-6 py-2.5 border border-gray-200 text-gray-600 rounded-xl text-sm font-bold hover:bg-gray-50 transition-all\"\n            >\n              Hủy\n            </button>\n            <button\n              type=\"submit\"\n              disabled={loading}\n              className=\"flex-1 flex items-center justify-center gap-2 px-6 py-2.5 bg-indigo-600 text-white rounded-xl text-sm font-black shadow-lg shadow-indigo-600/20 hover:bg-indigo-700 transition-all disabled:opacity-50\"\n            >\n              {loading ? <Loader2 className=\"w-4 h-4 animate-spin\" /> : <Save className=\"w-4 h-4\" />}\n              Lưu buổi học\n            </button>\n          </div>\n        </form>\n      </div>\n    </div>\n  );\n};\n\nexport default DatSessionModal;\n"}],"isError":false,"timestamp":1776943117175}}
{"type":"message","id":"b871ae46","parentId":"61edf4dc","timestamp":"2026-04-23T11:18:37.188Z","message":{"role":"toolResult","toolCallId":"call_B18BcwU9XRuVobWGO8pLLLHa","toolName":"read","content":[{"type":"text","text":"'use client';\n\nimport React, { useState, useEffect } from 'react';\nimport { X, Calendar, MapPin, User, Save, Clock, Ruler } from 'lucide-react';\nimport { toast } from 'sonner';\nimport { addDatSession } from '@/src/services/datService';\nimport ViDateInput from '@/src/components/shared/ViDateInput';\n\ninterface AddDatModalProps {\n  isOpen: boolean;\n  onClose: () => void;\n  studentName?: string;\n  enrollmentId?: string;\n  onSuccess?: () => void;\n}\n\ninterface DatFormData {\n  date: string;\n  timeStart: string;\n  timeEnd: string;\n  duration: string;\n  distance: string;\n  note: string;\n}\n\nconst initialState: DatFormData = {\n  date: new Date().toISOString().split('T')[0],\n  timeStart: '',\n  timeEnd: '',\n  duration: '',\n  distance: '',\n  note: '',\n};\n\nconst FieldWrapper = ({\n  label,\n  required,\n  children,\n  field,\n  touched,\n  errors,\n  icon: Icon,\n}: {\n  label: string;\n  required?: boolean;\n  children: React.ReactNode;\n  field: string;\n  touched: Record<string, boolean>;\n  errors: Record<string, string>;\n  icon?: any;\n}) => {\n  const hasError = touched[field] && errors[field];\n  return (\n    <div className=\"flex flex-col gap-1.5\">\n      <label\n        className={`text-[10px] font-black uppercase tracking-widest flex items-center gap-1.5 transition-colors ${hasError ? 'text-rose-500' : 'text-gray-400'}`}\n      >\n        {Icon && <Icon className=\"w-3.5 h-3.5 text-indigo-500\" />}\n        {label} {required && <span className=\"text-rose-500\">*</span>}\n      </label>\n      <div className=\"relative group\">{children}</div>\n      {hasError && (\n        <p className=\"text-[10px] font-bold text-rose-500 mt-1 ml-1 animate-in fade-in slide-in-from-top-1\">\n          {errors[field]}\n        </p>\n      )}\n    </div>\n  );\n};\n\nexport default function AddDatModal({ isOpen, onClose, studentName = '', enrollmentId, onSuccess }: AddDatModalProps) {\n  const [loading, setLoading] = useState(false);\n  const [form, setForm] = useState<DatFormData>({ ...initialState });\n  const [errors, setErrors] = useState<Record<string, string>>({});\n  const [touched, setTouched] = useState<Record<string, boolean>>({});\n\n  useEffect(() => {\n    if (isOpen) {\n      setForm({ ...initialState, date: new Date().toISOString().split('T')[0] });\n      setErrors({});\n      setTouched({});\n    }\n  }, [isOpen]);\n\n  if (!isOpen) return null;\n\n  const validate = (data = form) => {\n    const errs: Record<string, string> = {};\n    if (!data.date) errs.date = 'Vui lòng chọn ngày học.';\n    if (!data.duration.trim()) errs.duration = 'Vui lòng nhập thời lượng.';\n    else if (isNaN(parseInt(data.duration)) || parseInt(data.duration) <= 0)\n      errs.duration = 'Thời lượng phải là số dương.';\n\n    if (!data.distance.trim()) errs.distance = 'Vui lòng nhập quãng đường.';\n    else if (isNaN(parseFloat(data.distance)) || parseFloat(data.distance) <= 0)\n      errs.distance = 'Quãng đường phải là số dương.';\n\n    setErrors(errs);\n    return errs;\n  };\n\n  const handleChange = (field: string, value: string) => {\n    const updated = { ...form, [field]: value };\n    setForm(updated);\n    if (touched[field]) {\n      validate(updated);\n    }\n  };\n\n  const handleBlur = (field: string) => {\n    setTouched((prev) => ({ ...prev, [field]: true }));\n    validate();\n  };\n\n  const handleSubmit = async (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!enrollmentId) {\n      toast.error('Không tìm thấy thông tin đăng ký của học viên.');\n      return;\n    }\n\n    const allTouched = { date: true, duration: true, distance: true, timeStart: true, timeEnd: true };\n    setTouched(allTouched);\n\n    const errs = validate();\n    if (Object.keys(errs).length > 0) {\n      toast.error('Vui lòng kiểm tra lại thông tin buổi DAT');\n      return;\n    }\n\n    setLoading(true);\n    try {\n      const startTime = form.timeStart || '08:00';\n      const endTime = form.timeEnd || '10:00';\n\n      const start = new Date(`${form.date}T${startTime}:00`);\n      const end = new Date(`${form.date}T${endTime}:00`);\n\n      if (end <= start) {\n        toast.error('Thời gian kết thúc phải sau thời gian bắt đầu.');\n        setLoading(false);\n        return;\n      }\n\n      const res = await addDatSession({\n        course_student_id: enrollmentId,\n        session_type: 'dat',\n        start_time: start.toISOString(),\n        end_time: end.toISOString(),\n        distance_km: parseFloat(form.distance),\n        notes: form.note,\n      });\n\n      if (res.success) {\n        toast.success(`Đã lưu thành công buổi DAT ${form.distance}km cho ${studentName}!`);\n        onSuccess?.();\n        onClose();\n      } else {\n        toast.error(res.message || 'Lỗi khi lưu dữ liệu DAT.');\n      }\n    } catch (error) {\n      toast.error('Lỗi khi kết nối đến máy chủ.');\n    } finally {\n      setLoading(false);\n    }\n  };\n\n  const getInputClass = (field: string) => {\n    const base =\n      'w-full px-4 py-2.5 bg-white border rounded-xl focus:outline-none focus:ring-4 transition-all text-sm font-medium';\n    if (touched[field] && errors[field]) {\n      return `${base} border-rose-300 bg-rose-50/20 text-rose-900 focus:ring-rose-500/10 focus:border-rose-500`;\n    }\n    return `${base} border-gray-200 focus:ring-indigo-500/10 focus:border-indigo-500`;\n  };\n\n  return (\n    <div className=\"fixed inset-0 z-50 flex items-center justify-center p-4 bg-gray-900/40 backdrop-blur-sm animate-in fade-in duration-300\">\n      <div className=\"bg-white/95 backdrop-blur-xl rounded-[2rem] w-full max-w-md shadow-2xl overflow-hidden animate-in zoom-in-95 duration-300 border border-white/20\">\n        {/* Header */}\n        <div className=\"px-8 py-6 border-b border-gray-100 flex items-center justify-between bg-gray-50/50\">\n          <div>\n            <h2 className=\"text-xl font-black text-gray-900 tracking-tight\">THÊM BUỔI DAT</h2>\n            <p className=\"text-[10px] font-bold text-gray-400 uppercase tracking-widest mt-0.5\">\n              Ghi nhận tiến độ đào tạo DAT\n            </p>\n          </div>\n          <button\n            onClick={onClose}\n            className=\"p-2 text-gray-400 hover:text-rose-500 hover:bg-rose-50 rounded-full transition-colors\"\n          >\n            <X className=\"w-5 h-5\" />\n          </button>\n        </div>\n\n        {/* Body */}\n        <div className=\"p-8\">\n          <form id=\"add-dat-form\" onSubmit={handleSubmit} className=\"flex flex-col gap-6\" noValidate>\n            {/* Student info tag */}\n            <div className=\"px-5 py-3 bg-indigo-50/50 border border-indigo-100 text-indigo-800 rounded-2xl flex items-center gap-3 font-extrabold text-sm shadow-sm ring-1 ring-indigo-500/10\">\n              <User className=\"w-4 h-4 text-indigo-500 shrink-0\" />\n              <span className=\"truncate\">{studentName}</span>\n            </div>\n\n            <FieldWrapper label=\"NGÀY HỌC\" required field=\"date\" touched={touched} errors={errors} icon={Calendar}>\n              <ViDateInput\n                className={getInputClass('date')}\n                value={form.date}\n                onChange={(val) => handleChange('date', val)}\n              />\n            </FieldWrapper>\n\n            <div className=\"grid grid-cols-2 gap-4\">\n              <FieldWrapper label=\"GIỜ BẮT ĐẦU\" field=\"timeStart\" touched={touched} errors={errors} icon={Clock}>\n                <input\n                  type=\"time\"\n                  className={getInputClass('timeStart')}\n                  value={form.timeStart}\n                  onChange={(e) => handleChange('timeStart', e.target.value)}\n                  onBlur={() => handleBlur('timeStart')}\n                />\n              </FieldWrapper>\n\n              <FieldWrapper label=\"GIỜ KẾT THÚC\" field=\"timeEnd\" touched={touched} errors={errors} icon={Clock}>\n                <input\n                  type=\"time\"\n                  className={getInputClass('timeEnd')}\n                  value={form.timeEnd}\n                  onChange={(e) => handleChange('timeEnd', e.target.value)}\n                  onBlur={() => handleBlur('timeEnd')}\n                />\n              </FieldWrapper>\n            </div>\n\n            <div className=\"grid grid-cols-2 gap-4\">\n              <FieldWrapper\n                label=\"THỜI LƯỢNG (PHÚT)\"\n                required\n                field=\"duration\"\n                touched={touched}\n                errors={errors}\n                icon={Clock}\n              >\n                <div className=\"relative\">\n                  <input\n                    type=\"text\"\n                    placeholder=\"VD: 180\"\n                    className={getInputClass('duration')}\n                    value={form.duration}\n                    onChange={(e) => handleChange('duration', e.target.value)}\n                    onBlur={() => handleBlur('duration')}\n                  />\n                  <span className=\"absolute right-4 top-1/2 -translate-y-1/2 text-[10px] font-black text-gray-400 uppercase tracking-tight\">\n                    phút\n                  </span>\n                </div>\n              </FieldWrapper>\n\n              <FieldWrapper\n                label=\"QUÃNG ĐƯỜNG (KM)\"\n\n[62 more lines in file. Use offset=261 to continue.]"}],"isError":false,"timestamp":1776943117181}}
{"type":"message","id":"ab10777a","parentId":"b871ae46","timestamp":"2026-04-23T11:18:43.002Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"call_ZNQv9weJKvTuIkUaRaE4EfQf","name":"read","arguments":{"path":"/root/.openclaw/workspaces2/projects/ahv-qlhv-fe/src/components/progress/AddDatModal.tsx","offset":261,"limit":140}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-TroLy","usage":{"input":8169,"output":50,"cacheRead":54784,"cacheWrite":0,"totalTokens":63003,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776943117192,"responseId":"1776943118727"}}
{"type":"message","id":"84ddc0a5","parentId":"ab10777a","timestamp":"2026-04-23T11:18:43.022Z","message":{"role":"toolResult","toolCallId":"call_ZNQv9weJKvTuIkUaRaE4EfQf","toolName":"read","content":[{"type":"text","text":"                required\n                field=\"distance\"\n                touched={touched}\n                errors={errors}\n                icon={Ruler}\n              >\n                <div className=\"relative\">\n                  <input\n                    type=\"text\"\n                    placeholder=\"VD: 84.5\"\n                    className={getInputClass('distance')}\n                    value={form.distance}\n                    onChange={(e) => handleChange('distance', e.target.value)}\n                    onBlur={() => handleBlur('distance')}\n                  />\n                  <span className=\"absolute right-4 top-1/2 -translate-y-1/2 text-[10px] font-black text-gray-400 uppercase tracking-tight\">\n                    km\n                  </span>\n                </div>\n              </FieldWrapper>\n            </div>\n\n            <FieldWrapper label=\"GHI CHÚ\" field=\"note\" touched={touched} errors={errors} icon={MapPin}>\n              <input\n                type=\"text\"\n                placeholder=\"Tuyến đường, giáo viên, xe tập...\"\n                className={getInputClass('note')}\n                value={form.note}\n                onChange={(e) => handleChange('note', e.target.value)}\n              />\n            </FieldWrapper>\n          </form>\n        </div>\n\n        {/* Footer */}\n        <div className=\"px-8 py-6 flex justify-end gap-3 rounded-b-2xl border-t border-gray-100 bg-gray-50/50\">\n          <button\n            type=\"button\"\n            onClick={onClose}\n            className=\"px-6 py-3 text-xs font-black uppercase tracking-widest text-gray-500 hover:text-gray-900 hover:bg-gray-200/50 rounded-2xl transition-all\"\n          >\n            Hủy bỏ\n          </button>\n          <button\n            type=\"submit\"\n            form=\"add-dat-form\"\n            disabled={loading}\n            className=\"px-8 py-3 text-xs font-black uppercase tracking-widest text-white bg-indigo-600 hover:bg-indigo-700 rounded-2xl transition-all shadow-xl shadow-indigo-600/20 active:scale-95 flex items-center gap-2.5 disabled:opacity-50\"\n          >\n            {loading ? (\n              <div className=\"w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin\" />\n            ) : (\n              <Save className=\"w-4 h-4\" />\n            )}\n            Lưu dữ liệu\n          </button>\n        </div>\n      </div>\n    </div>\n  );\n}\n"}],"isError":false,"timestamp":1776943123015}}
{"type":"message","id":"3b5b1718","parentId":"84ddc0a5","timestamp":"2026-04-23T11:18:53.741Z","message":{"role":"assistant","content":[{"type":"text","text":"Mình sẽ đồng bộ `DatSessionModal` theo cấu trúc của `AddDatModal`, nhưng giữ nguyên props/logic Student Detail (`enrollmentId`, `onSuccess`)."},{"type":"toolCall","id":"call_UcpA3C9qoz0AYkpRwiBLz6mm","name":"exec","arguments":{"command":"grep -RIn \"<DatSessionModal\\|DatSessionModal\" src/components src/app --exclude-dir=node_modules","workdir":"/root/.openclaw/workspaces2/projects/ahv-qlhv-fe","yieldMs":10000,"timeout":30}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-TroLy","usage":{"input":2738,"output":152,"cacheRead":60800,"cacheWrite":0,"totalTokens":63690,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776943123026,"responseId":"1776943124536"}}
{"type":"message","id":"621835df","parentId":"3b5b1718","timestamp":"2026-04-23T11:18:53.793Z","message":{"role":"toolResult","toolCallId":"call_UcpA3C9qoz0AYkpRwiBLz6mm","toolName":"exec","content":[{"type":"text","text":"src/components/students/StudentDetailDrawer.tsx:41:import DatSessionModal from './modules/DatSessionModal';\nsrc/components/students/StudentDetailDrawer.tsx:2040:          <DatSessionModal\nsrc/components/students/modules/DatSessionModal.tsx:7:interface DatSessionModalProps {\nsrc/components/students/modules/DatSessionModal.tsx:14:const DatSessionModal: React.FC<DatSessionModalProps> = ({ isOpen, onClose, enrollmentId, onSuccess }) => {\nsrc/components/students/modules/DatSessionModal.tsx:244:export default DatSessionModal;"}],"details":{"status":"completed","exitCode":0,"durationMs":32,"aggregated":"src/components/students/StudentDetailDrawer.tsx:41:import DatSessionModal from './modules/DatSessionModal';\nsrc/components/students/StudentDetailDrawer.tsx:2040:          <DatSessionModal\nsrc/components/students/modules/DatSessionModal.tsx:7:interface DatSessionModalProps {\nsrc/components/students/modules/DatSessionModal.tsx:14:const DatSessionModal: React.FC<DatSessionModalProps> = ({ isOpen, onClose, enrollmentId, onSuccess }) => {\nsrc/components/students/modules/DatSessionModal.tsx:244:export default DatSessionModal;","cwd":"/root/.openclaw/workspaces2/projects/ahv-qlhv-fe"},"isError":false,"timestamp":1776943133785}}
{"type":"message","id":"530235fa","parentId":"621835df","timestamp":"2026-04-23T11:21:49.897Z","message":{"role":"assistant","content":[{"type":"text","text":"Mình sửa trực tiếp modal Student Detail cho giống progress form về UI/field/validation/default value."},{"type":"toolCall","id":"call_vjBtj0HbhMDkYcHzDe6VGnqL","name":"write","arguments":{"path":"/root/.openclaw/workspaces2/projects/ahv-qlhv-fe/src/components/students/modules/DatSessionModal.tsx","content":"'use client';\n\nimport React, { useEffect, useState } from 'react';\nimport ViDateInput from '@/src/components/shared/ViDateInput';\nimport { X, Calendar, MapPin, Save, Clock, Ruler } from 'lucide-react';\nimport { toast } from 'sonner';\nimport { addDatSession } from '@/src/services/datService';\n\ninterface DatSessionModalProps {\n  isOpen: boolean;\n  onClose: () => void;\n  enrollmentId: string;\n  onSuccess: () => void;\n}\n\ninterface DatFormData {\n  date: string;\n  timeStart: string;\n  timeEnd: string;\n  duration: string;\n  distance: string;\n  note: string;\n}\n\nconst initialState: DatFormData = {\n  date: new Date().toISOString().split('T')[0],\n  timeStart: '',\n  timeEnd: '',\n  duration: '',\n  distance: '',\n  note: '',\n};\n\nconst syncDuration = (startStr: string, endStr: string) => {\n  if (!startStr || !endStr) return '';\n  try {\n    const [sh, sm] = startStr.split(':').map(Number);\n    const [eh, em] = endStr.split(':').map(Number);\n    const diffMinutes = eh * 60 + em - (sh * 60 + sm);\n    return diffMinutes > 0 ? diffMinutes.toString() : '';\n  } catch {\n    return '';\n  }\n};\n\nconst syncEndTime = (startStr: string, durationStr: string) => {\n  if (!startStr || !durationStr || isNaN(parseInt(durationStr))) return '';\n  try {\n    const [sh, sm] = startStr.split(':').map(Number);\n    const totalMinutes = sh * 60 + sm + parseInt(durationStr || '0');\n    const eh = Math.floor(totalMinutes / 60) % 24;\n    const em = totalMinutes % 60;\n    return `${eh.toString().padStart(2, '0')}:${em.toString().padStart(2, '0')}`;\n  } catch {\n    return '';\n  }\n};\n\nconst FieldWrapper = ({\n  label,\n  required,\n  children,\n  field,\n  touched,\n  errors,\n  icon: Icon,\n}: {\n  label: string;\n  required?: boolean;\n  children: React.ReactNode;\n  field: string;\n  touched: Record<string, boolean>;\n  errors: Record<string, string>;\n  icon?: any;\n}) => {\n  const hasError = touched[field] && errors[field];\n  return (\n    <div className=\"flex flex-col gap-1.5\">\n      <label\n        className={`text-[10px] font-black uppercase tracking-widest flex items-center gap-1.5 transition-colors ${hasError ? 'text-rose-500' : 'text-gray-400'}`}\n      >\n        {Icon && <Icon className=\"w-3.5 h-3.5 text-indigo-500\" />}\n        {label} {required && <span className=\"text-rose-500\">*</span>}\n      </label>\n      <div className=\"relative group\">{children}</div>\n      {hasError && (\n        <p className=\"text-[10px] font-bold text-rose-500 mt-1 ml-1 animate-in fade-in slide-in-from-top-1\">\n          {errors[field]}\n        </p>\n      )}\n    </div>\n  );\n};\n\nconst DatSessionModal: React.FC<DatSessionModalProps> = ({ isOpen, onClose, enrollmentId, onSuccess }) => {\n  const [loading, setLoading] = useState(false);\n  const [form, setForm] = useState<DatFormData>({ ...initialState });\n  const [errors, setErrors] = useState<Record<string, string>>({});\n  const [touched, setTouched] = useState<Record<string, boolean>>({});\n\n  useEffect(() => {\n    if (isOpen) {\n      setForm({ ...initialState, date: new Date().toISOString().split('T')[0] });\n      setErrors({});\n      setTouched({});\n    }\n  }, [isOpen]);\n\n  if (!isOpen) return null;\n\n  const validate = (data = form) => {\n    const errs: Record<string, string> = {};\n\n    if (!data.date) errs.date = 'Vui lòng chọn ngày học.';\n    if (!data.duration.trim()) errs.duration = 'Vui lòng nhập thời lượng.';\n    else if (isNaN(parseInt(data.duration)) || parseInt(data.duration) <= 0) {\n      errs.duration = 'Thời lượng phải là số dương.';\n    }\n\n    if (!data.distance.trim()) errs.distance = 'Vui lòng nhập quãng đường.';\n    else if (isNaN(parseFloat(data.distance)) || parseFloat(data.distance) <= 0) {\n      errs.distance = 'Quãng đường phải là số dương.';\n    }\n\n    setErrors(errs);\n    return errs;\n  };\n\n  const handleChange = (field: keyof DatFormData, value: string) => {\n    setForm((prev) => {\n      const updated = { ...prev, [field]: value };\n\n      if (field === 'timeStart') {\n        if (updated.timeEnd) {\n          updated.duration = syncDuration(value, updated.timeEnd);\n        } else if (updated.duration) {\n          updated.timeEnd = syncEndTime(value, updated.duration);\n        }\n      }\n\n      if (field === 'timeEnd') {\n        updated.duration = syncDuration(updated.timeStart, value);\n      }\n\n      if (field === 'duration') {\n        updated.timeEnd = syncEndTime(updated.timeStart, value);\n      }\n\n      if (touched[field]) {\n        validate(updated);\n      }\n\n      return updated;\n    });\n  };\n\n  const handleBlur = (field: string) => {\n    setTouched((prev) => ({ ...prev, [field]: true }));\n    validate();\n  };\n\n  const getInputClass = (field: string) => {\n    const base =\n      'w-full px-4 py-2.5 bg-white border rounded-xl focus:outline-none focus:ring-4 transition-all text-sm font-medium';\n    if (touched[field] && errors[field]) {\n      return `${base} border-rose-300 bg-rose-50/20 text-rose-900 focus:ring-rose-500/10 focus:border-rose-500`;\n    }\n    return `${base} border-gray-200 focus:ring-indigo-500/10 focus:border-indigo-500`;\n  };\n\n  const handleSubmit = async (e: React.FormEvent) => {\n    e.preventDefault();\n\n    if (!enrollmentId) {\n      toast.error('Không tìm thấy thông tin đăng ký của học viên.');\n      return;\n    }\n\n    const allTouched = { date: true, duration: true, distance: true, timeStart: true, timeEnd: true };\n    setTouched(allTouched);\n\n    const errs = validate();\n    if (Object.keys(errs).length > 0) {\n      toast.error('Vui lòng kiểm tra lại thông tin buổi DAT');\n      return;\n    }\n\n    setLoading(true);\n    try {\n      const startTime = form.timeStart || '08:00';\n      const endTime = form.timeEnd || '10:00';\n\n      const start = new Date(`${form.date}T${startTime}:00`);\n      const end = new Date(`${form.date}T${endTime}:00`);\n\n      if (end <= start) {\n        toast.error('Thời gian kết thúc phải sau thời gian bắt đầu.');\n        setLoading(false);\n        return;\n      }\n\n      const res = await addDatSession({\n        course_student_id: enrollmentId,\n        session_type: 'dat',\n        start_time: start.toISOString(),\n        end_time: end.toISOString(),\n        distance_km: parseFloat(form.distance),\n        notes: form.note,\n      });\n\n      if (res.success) {\n        toast.success('Đã lưu thành công buổi DAT!');\n        onSuccess();\n        onClose();\n      } else {\n        toast.error(res.message || 'Lỗi khi lưu dữ liệu DAT.');\n      }\n    } catch (error) {\n      toast.error('Lỗi khi kết nối đến máy chủ.');\n    } finally {\n      setLoading(false);\n    }\n  };\n\n  return (\n    <div className=\"fixed inset-0 z-[100] flex items-center justify-center p-4 bg-gray-900/40 backdrop-blur-sm animate-in fade-in duration-300\">\n      <div className=\"bg-white/95 backdrop-blur-xl rounded-[2rem] w-full max-w-md shadow-2xl overflow-hidden animate-in zoom-in-95 duration-300 border border-white/20\">\n        <div className=\"px-8 py-6 border-b border-gray-100 flex items-center justify-between bg-gray-50/50\">\n          <div>\n            <h2 className=\"text-xl font-black text-gray-900 tracking-tight\">THÊM BUỔI DAT</h2>\n            <p className=\"text-[10px] font-bold text-gray-400 uppercase tracking-widest mt-0.5\">\n              Ghi nhận tiến độ đào tạo DAT\n            </p>\n          </div>\n          <button\n            onClick={onClose}\n            className=\"p-2 text-gray-400 hover:text-rose-500 hover:bg-rose-50 rounded-full transition-colors\"\n          >\n            <X className=\"w-5 h-5\" />\n          </button>\n        </div>\n\n        <div className=\"p-8\">\n          <form id=\"student-detail-dat-form\" onSubmit={handleSubmit} className=\"flex flex-col gap-6\" noValidate>\n            <FieldWrapper label=\"NGÀY HỌC\" required field=\"date\" touched={touched} errors={errors} icon={Calendar}>\n              <ViDateInput\n                className={getInputClass('date')}\n                value={form.date}\n                onChange={(val) => handleChange('date', val)}\n              />\n            </FieldWrapper>\n\n            <div className=\"grid grid-cols-2 gap-4\">\n              <FieldWrapper label=\"GIỜ BẮT ĐẦU\" field=\"timeStart\" touched={touched} errors={errors} icon={Clock}>\n                <input\n                  type=\"time\"\n                  className={getInputClass('timeStart')}\n                  value={form.timeStart}\n                  onChange={(e) => handleChange('timeStart', e.target.value)}\n                  onBlur={() => handleBlur('timeStart')}\n                />\n              </FieldWrapper>\n\n              <FieldWrapper label=\"GIỜ KẾT THÚC\" field=\"timeEnd\" touched={touched} errors={errors} icon={Clock}>\n                <input\n                  type=\"time\"\n                  className={getInputClass('timeEnd')}\n                  value={form.timeEnd}\n                  onChange={(e) => handleChange('timeEnd', e.target.value)}\n                  onBlur={() => handleBlur('timeEnd')}\n                />\n              </FieldWrapper>\n            </div>\n\n            <div className=\"grid grid-cols-2 gap-4\">\n              <FieldWrapper\n                label=\"THỜI LƯỢNG (PHÚT)\"\n                required\n                field=\"duration\"\n                touched={touched}\n                errors={errors}\n                icon={Clock}\n              >\n                <div className=\"relative\">\n                  <input\n                    type=\"text\"\n                    placeholder=\"VD: 180\"\n                    className={getInputClass('duration')}\n                    value={form.duration}\n                    onChange={(e) => handleChange('duration', e.target.value)}\n                    onBlur={() => handleBlur('duration')}\n                  />\n                  <span className=\"absolute right-4 top-1/2 -translate-y-1/2 text-[10px] font-black text-gray-400 uppercase tracking-tight\">\n                    phút\n                  </span>\n                </div>\n              </FieldWrapper>\n\n              <FieldWrapper\n                label=\"QUÃNG ĐƯỜNG (KM)\"\n                required\n                field=\"distance\"\n                touched={touched}\n                errors={errors}\n                icon={Ruler}\n              >\n                <div className=\"relative\">\n                  <input\n                    type=\"text\"\n                    placeholder=\"VD: 84.5\"\n                    className={getInputClass('distance')}\n                    value={form.distance}\n                    onChange={(e) => handleChange('distance', e.target.value)}\n                    onBlur={() => handleBlur('distance')}\n                  />\n                  <span className=\"absolute right-4 top-1/2 -translate-y-1/2 text-[10px] font-black text-gray-400 uppercase tracking-tight\">\n                    km\n                  </span>\n                </div>\n              </FieldWrapper>\n            </div>\n\n            <FieldWrapper label=\"GHI CHÚ\" field=\"note\" touched={touched} errors={errors} icon={MapPin}>\n              <input\n                type=\"text\"\n                placeholder=\"Tuyến đường, giáo viên, xe tập...\"\n                className={getInputClass('note')}\n                value={form.note}\n                onChange={(e) => handleChange('note', e.target.value)}\n              />\n            </FieldWrapper>\n          </form>\n        </div>\n\n        <div className=\"px-8 py-6 flex justify-end gap-3 rounded-b-2xl border-t border-gray-100 bg-gray-50/50\">\n          <button\n            type=\"button\"\n            onClick={onClose}\n            className=\"px-6 py-3 text-xs font-black uppercase tracking-widest text-gray-500 hover:text-gray-900 hover:bg-gray-200/50 rounded-2xl transition-all\"\n          >\n            Hủy bỏ\n          </button>\n          <button\n            type=\"submit\"\n            form=\"student-detail-dat-form\"\n            disabled={loading}\n            className=\"px-8 py-3 text-xs font-black uppercase tracking-widest text-white bg-indigo-600 hover:bg-indigo-700 rounded-2xl transition-all shadow-xl shadow-indigo-600/20 active:scale-95 flex items-center gap-2.5 disabled:opacity-50\"\n          >\n            {loading ? (\n              <div className=\"w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin\" />\n            ) : (\n              <Save className=\"w-4 h-4\" />\n            )}\n            Lưu dữ liệu\n          </button>\n        </div>\n      </div>\n    </div>\n  );\n};\n\nexport default DatSessionModal;\n"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-TroLy","usage":{"input":2351,"output":3602,"cacheRead":61440,"cacheWrite":0,"totalTokens":67393,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776943133796,"responseId":"1776943135916"}}
