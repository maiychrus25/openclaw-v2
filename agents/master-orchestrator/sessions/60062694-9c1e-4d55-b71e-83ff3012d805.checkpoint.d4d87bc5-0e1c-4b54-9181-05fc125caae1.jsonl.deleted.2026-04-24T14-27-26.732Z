{"type":"message","id":"320604d8","parentId":"8323afb0","timestamp":"2026-04-23T16:51:51.061Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me add the new methods to the CourseService. I'll add them before the closing brace of the class.","thinkingSignature":"d4c9acc90ed97bcaf414d20ff8dfc84e5620515e7fdd05cfa9ef9c4a7ac961d2"},{"type":"toolCall","id":"call_function_v51f0h3wyhhu_1","name":"edit","arguments":{"path":"/root/.openclaw/workspaces2/projects/ahv-qlhv-be/src/application/services/course.service.ts","edits":[{"oldText":"    runImport();\n    return { message: 'Quá trình nhập dữ liệu đã bắt đầu chạy ngầm' };\n  }\n}\n","newText":"    runImport();\n    return { message: 'Quá trình nhập dữ liệu đã bắt đầu chạy ngầm' };\n  }\n\n  async getTodayMilestones(teacherId: string) {\n    const teacherOid = new mongoose.Types.ObjectId(teacherId);\n    const today = new Date();\n    today.setHours(0, 0, 0, 0);\n    const tomorrow = new Date(today);\n    tomorrow.setDate(tomorrow.getDate() + 1);\n\n    // Courses starting today (Sắp KG -> Đang học)\n    const openingCourses = await CourseStudentModel.aggregate([\n      { $match: { teacher_id: teacherOid } },\n      {\n        $lookup: {\n          from: 'courseinfos',\n          localField: 'course_id',\n          foreignField: '_id',\n          as: 'course',\n        },\n      },\n      { $unwind: { path: '$course', preserveNullAndEmptyArrays: false } },\n      {\n        $match: {\n          'course.start_date': { $gte: today, $lt: tomorrow },\n          'course.status': 'draft',\n        },\n      },\n      {\n        $project: {\n          _id: '$course._id',\n          name: '$course.name',\n          start_date: '$course.start_date',\n          end_date: '$course.end_date',\n          status: '$course.status',\n          student_count: 1,\n        },\n      },\n    ]);\n\n    // Courses ending today (Đang học -> Đã kết thúc)\n    const closingCourses = await CourseStudentModel.aggregate([\n      { $match: { teacher_id: teacherOid } },\n      {\n        $lookup: {\n          from: 'courseinfos',\n          localField: 'course_id',\n          foreignField: '_id',\n          as: 'course',\n        },\n      },\n      { $unwind: { path: '$course', preserveNullAndEmptyArrays: false } },\n      {\n        $match: {\n          'course.end_date': { $gte: today, $lt: tomorrow },\n          'course.status': 'ongoing',\n        },\n      },\n      {\n        $project: {\n          _id: '$course._id',\n          name: '$course.name',\n          start_date: '$course.start_date',\n          end_date: '$course.end_date',\n          status: '$course.status',\n          student_count: 1,\n        },\n      },\n    ]);\n\n    return {\n      openingCourses,\n      closingCourses,\n      openingCount: openingCourses.length,\n      closingCount: closingCourses.length,\n    };\n  }\n\n  async bulkUpdateCourseStatus(courseIds: string[], newStatus: string, teacherId: string) {\n    const teacherOid = new mongoose.Types.ObjectId(teacherId);\n    const validStatuses = ['draft', 'ongoing', 'completed', 'canceled'];\n    if (!validStatuses.includes(newStatus)) {\n      throw new AppError('Trạng thái không hợp lệ', 400);\n    }\n\n    // Verify teacher owns these courses before updating\n    const courseOids = courseIds.map((id) => new mongoose.Types.ObjectId(id));\n    const enrolledCourses = await CourseStudentModel.distinct('course_id', {\n      teacher_id: teacherOid,\n      course_id: { $in: courseOids },\n    });\n\n    const validCourseIds = enrolledCourses.map((id) => id.toString());\n    const unauthorized = courseIds.filter((id) => !validCourseIds.includes(id));\n    if (unauthorized.length > 0) {\n      throw new AppError('Bạn không có quyền cập nhật một số khóa học', 403);\n    }\n\n    const result = await CourseStudentModel.model.collection.database\n      .collection('courseinfos')\n      .updateMany({ _id: { $in: courseOids } }, { $set: { status: newStatus, updated_at: new Date() } });\n\n    return { updated: result.modifiedCount, courseIds: validCourseIds };\n  }\n}\n"}]}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":94,"output":1139,"cacheRead":95168,"cacheWrite":524,"totalTokens":96925,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776963097461,"responseId":"0639811a3fde10df64880a70d4422d1a"}}
