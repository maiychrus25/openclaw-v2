cDelete} />;\n    case 'dao-tao': return <CarTrainingConfig practiceTargetMinutes={practiceTargetMinutes} onSave={onTrainingSave} />;\n    case 'san-thi': return <ExamCenterManagement stadiums={stadiums} onAdd={onCenterAdd} onEdit={onCenterEdit} onDelete={onCenterDelete} />;\n    case 'trung-tam': return <CenterInfoManagement />;\n    default: return (\n      <div className=\"bg-white border border-gray-100 rounded-3xl p-10 flex flex-col items-center gap-3 text-gray-400 shadow-sm border-dashed text-center\">\n        {React.createElement(CHUNG_SUBTABS.find(t => t.id === activeSubTab)?.icon || Sliders, { className: \"w-10 h-10 opacity-20\" })}\n        <p className=\"font-semibold\">{CHUNG_SUBTABS.find(t => t.id === activeSubTab)?.label} - Sẽ sớm xuất hiện</p>\n      </div>\n    );\n  }\n}\n\n\n/* 1. Region Management */\nfunction RegionManagement({ regions, onDelete, onAdd, onEdit }: { regions: City[], onDelete: (id: string) => void, onAdd: () => void, onEdit: (city: City) => void }) {\n  return (\n    <div className=\"bg-white border border-gray-100 rounded-[2.5rem] p-8 shadow-sm flex flex-col gap-6 animate-in fade-in duration-300 max-w-4xl\">\n      <div className=\"flex items-center justify-between px-2\">\n        <h3 className=\"text-base font-black text-gray-800 flex items-center gap-2 tracking-tight uppercase\">\n          <MapPin className=\"w-4 h-4 text-indigo-600\" /> Khu vực tuyển sinh\n        </h3>\n        <button \n          onClick={onAdd}\n          className=\"flex items-center gap-2 px-4 py-1.5 bg-indigo-600 text-white font-bold rounded-xl shadow-lg shadow-indigo-600/20 hover:bg-indigo-700 transition-all text-xs\"\n        >\n          <Plus className=\"w-3.5 h-3.5\" /> Thêm\n        </button>\n      </div>\n\n      <div className=\"flex flex-col gap-3\">\n        {regions.length === 0 ? (\n          <div className=\"p-10 text-center text-gray-300 font-medium opacity-50 border-2 border-dashed border-gray-50 rounded-2xl\">Chưa có khu vực nào</div>\n        ) : regions.map(r => (\n\n[1048 more lines in file. Use offset=910 to continue.]"}],"isError":false,"timestamp":1776942703987}}
