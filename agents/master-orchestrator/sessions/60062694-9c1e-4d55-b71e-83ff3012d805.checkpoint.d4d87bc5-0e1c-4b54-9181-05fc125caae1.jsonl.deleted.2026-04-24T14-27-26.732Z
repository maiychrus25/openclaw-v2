{"type":"message","id":"efb3df6d","parentId":"e6ac2edf","timestamp":"2026-04-23T11:06:31.171Z","message":{"role":"toolResult","toolCallId":"call_IqhiEjrbonPraD4TvF7k5vVi","toolName":"read","content":[{"type":"text","text":"const getBaseUrl = () => {\n  if (typeof window !== 'undefined') {\n    const hostname = window.location.hostname;\n    if (hostname === 'localhost' || hostname === '127.0.0.1') {\n      return `http://${hostname}:5002/api/v1`;\n    }\n  }\n  return process.env.NEXT_PUBLIC_API_URL || 'http://127.0.0.1:5002/api/v1';\n};\n\nconst BASE_URL = getBaseUrl();\n\nlet isRefreshing = false;\nlet refreshSubscribers: { resolve: (token: string) => void; reject: (err: any) => void }[] = [];\n\nconst subscribeTokenRefresh = (resolve: (token: string) => void, reject: (err: any) => void) => {\n  refreshSubscribers.push({ resolve, reject });\n};\n\nconst onTokenRefreshed = (token: string | null, err: any = null) => {\n  refreshSubscribers.forEach((sub) => {\n    if (err) sub.reject(err);\n    else if (token) sub.resolve(token);\n  });\n  refreshSubscribers = [];\n};\n\nconst pendingRequests = new Map<string, Promise<any>>();\nconst responseCache = new Map<string, { expiresAt: number; data: any }>();\nconst DEFAULT_GET_CACHE_TTL_MS = 3000;\n\nexport interface ApiOptions extends RequestInit {\n  responseType?: 'json' | 'blob';\n  cacheTtlMs?: number;\n}\n\nexport const apiClient = async <T = any>(endpoint: string, options: ApiOptions = {}): Promise<T> => {\n  const method = (options.method || 'GET').toUpperCase();\n  const requestKey = `${method}:${endpoint}:${options.body ? JSON.stringify(options.body) : ''}`;\n  const shouldUseResponseCache = method === 'GET' && options.responseType !== 'blob';\n  const cacheTtlMs = options.cacheTtlMs ?? DEFAULT_GET_CACHE_TTL_MS;\n\n  if (shouldUseResponseCache) {\n    const cached = responseCache.get(requestKey);\n    if (cached && cached.expiresAt > Date.now()) {\n      return cached.data;\n    }\n  }\n\n  if (pendingRequests.has(requestKey)) {\n    return pendingRequests.get(requestKey);\n  }\n\n  const fetchPromise = (async () => {\n    try {\n      const result = await executeRequest(endpoint, options);\n      if (shouldUseResponseCache) {\n        responseCache.set(requestKey, {\n          data: result,\n          expiresAt: Date.now() + cacheTtlMs,\n        });\n      }\n      return result;\n    } finally {\n      setTimeout(() => pendingRequests.delete(requestKey), 100);\n    }\n  })();\n\n  pendingRequests.set(requestKey, fetchPromise);\n  return fetchPromise;\n};\n\nconst executeRequest = async (endpoint: string, options: ApiOptions = {}): Promise<any> => {\n  const token = typeof window !== 'undefined' ? localStorage.getItem('token') : null;\n\n  const headers: any = {\n    ...(token ? { Authorization: `Bearer ${token}` } : {}),\n    ...options.headers,\n  };\n\n  // Only set application/json if not sending FormData (to allow browser to set boundary)\n  if (!(options.body instanceof FormData)) {\n    headers['Content-Type'] = 'application/json';\n  }\n\n  const defaultOptions: RequestInit = {\n    ...options,\n    credentials: 'include',\n    headers,\n  };\n\n  try {\n    const response = await fetch(`${BASE_URL}${endpoint}`, defaultOptions);\n\n    if (response.status === 401 && !endpoint.includes('/auth/refresh') && !endpoint.includes('/auth/login')) {\n      if (!isRefreshing) {\n        isRefreshing = true;\n        try {\n          const refreshRes = await fetch(`${BASE_URL}/auth/refresh`, {\n            method: 'POST',\n            credentials: 'include',\n            headers: { 'Content-Type': 'application/json' },\n          });\n\n          if (refreshRes.ok) {\n            const { data } = await refreshRes.json();\n            const newToken = data.token;\n            localStorage.setItem('token', newToken);\n            isRefreshing = false;\n            onTokenRefreshed(newToken);\n          } else {\n            const error = new Error('Session expired');\n            isRefreshing = false;\n            onTokenRefreshed(null, error);\n            localStorage.removeItem('token');\n            if (typeof window !== 'undefined') window.location.href = '/login';\n            throw error;\n          }\n        } catch (err) {\n          isRefreshing = false;\n          onTokenRefreshed(null, err);\n          throw err;\n        }\n      }\n\n      return new Promise((resolve, reject) => {\n        subscribeTokenRefresh(\n          (newToken: string) => {\n            resolve(\n              apiClient(endpoint, {\n                ...options,\n                headers: {\n                  ...options.headers,\n                  Authorization: `Bearer ${newToken}`,\n                },\n              }),\n            );\n          },\n          (err: any) => {\n            reject(err);\n\n[25 more lines in file. Use offset=141 to continue.]"}],"isError":false,"timestamp":1776942391162}}
