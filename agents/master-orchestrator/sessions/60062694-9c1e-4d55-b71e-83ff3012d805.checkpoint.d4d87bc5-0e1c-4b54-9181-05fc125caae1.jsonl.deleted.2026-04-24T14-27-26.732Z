{"type":"message","id":"710f8ad6","parentId":"761563a2","timestamp":"2026-04-23T10:50:38.496Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"call_T8cSExHOTP2NzeAnnSSrnyip","name":"read","arguments":{"path":"/root/.openclaw/workspaces2/projects/ahv-qlhv-fe/src/components/students/AddStudentModal.tsx","offset":1,"limit":260}},{"type":"toolCall","id":"call_8R7HzjR1MIsDlMkPQxN4Ark4","name":"read","arguments":{"path":"/root/.openclaw/workspaces2/projects/ahv-qlhv-fe/src/components/students/AddStudentModal.tsx","offset":260,"limit":380}},{"type":"toolCall","id":"call_qg0y8RvbjTNN6cA0eKJMSTs0","name":"read","arguments":{"path":"/root/.openclaw/workspaces2/projects/ahv-qlhv-fe/src/components/shared/CourseSelectDropdown.tsx","offset":1,"limit":220}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-TroLy","usage":{"input":2255,"output":158,"cacheRead":86272,"cacheWrite":0,"totalTokens":88685,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776941426594,"responseId":"1776941428580"}}
{"type":"message","id":"586d8d8f","parentId":"710f8ad6","timestamp":"2026-04-23T10:50:38.536Z","message":{"role":"toolResult","toolCallId":"call_T8cSExHOTP2NzeAnnSSrnyip","toolName":"read","content":[{"type":"text","text":"'use client';\n\nimport React, { useState, useEffect } from 'react';\nimport {\n  X,\n  HelpCircle,\n  Save,\n  User,\n  Phone,\n  Calendar,\n  CreditCard,\n  MapPin,\n  GraduationCap,\n  Stethoscope,\n  CheckCircle2,\n  Info,\n} from 'lucide-react';\nimport { toast } from 'sonner';\nimport { getCities, City } from '@/src/services/cityService';\nimport { getLicenseCategories, getLeads } from '@/src/services/studentService';\nimport { getSystemSettings } from '@/src/services/settingsService';\nimport CourseSelectDropdown from '@/src/components/shared/CourseSelectDropdown';\nimport ViDateInput from '@/src/components/shared/ViDateInput';\nimport { formatNumberWithDots, parseNumberFromDots } from '@/src/utils/currencyUtils';\nimport { useAuth } from '@/src/context/AuthContext';\n\ninterface AddStudentModalProps {\n  isOpen: boolean;\n  onClose: () => void;\n}\n\ninterface StudentFormData {\n  name: string;\n  phone: string;\n  referrer: string;\n  dob: string;\n  cccd: string;\n  rank: string;\n  course: string;\n  regDate: string;\n  tuition: string;\n  city: string;\n  ward: string;\n  existing_license_num: string;\n  existing_license_rank: string;\n  lead_manager: string;\n  student_code: string;\n}\n\nconst empty: StudentFormData = {\n  name: '',\n  phone: '',\n  referrer: '',\n  dob: '',\n  cccd: '',\n  rank: '',\n  course: '',\n  regDate: new Date().toISOString().split('T')[0],\n  tuition: '',\n  city: '',\n  ward: '',\n  existing_license_num: '',\n  existing_license_rank: '',\n  lead_manager: '',\n  student_code: '',\n};\n\nconst FieldWrapper = ({\n  label,\n  required,\n  children,\n  colSpan = 1,\n  field,\n  touched,\n  errors,\n  icon: Icon,\n  description,\n}: {\n  label: string;\n  required?: boolean;\n  children: React.ReactNode;\n  colSpan?: number;\n  field: keyof StudentFormData;\n  touched: Record<string, boolean>;\n  errors: Record<string, string>;\n  icon?: any;\n  description?: string;\n}) => {\n  const hasError = touched[field] && errors[field];\n  return (\n    <div className={`flex flex-col gap-1.5 ${colSpan === 2 ? 'md:col-span-2' : ''}`}>\n      <div className=\"flex items-center justify-between px-1\">\n        <div className=\"flex flex-col gap-0.5\">\n          <label\n            className={`text-[10px] font-black uppercase tracking-widest flex items-center gap-1.5 transition-colors ${hasError ? 'text-rose-500' : 'text-gray-400'}`}\n          >\n            {Icon && <Icon className=\"w-3 h-3\" />}\n            {label} {required && <span className=\"text-rose-500\">*</span>}\n          </label>\n          {description && <p className=\"text-[9px] font-medium text-gray-400 italic\">({description})</p>}\n        </div>\n        <HelpCircle className=\"w-3 h-3 text-gray-300 hover:text-indigo-500 transition-colors cursor-help\" />\n      </div>\n      {children}\n      {hasError && (\n        <p className=\"text-[10px] font-bold text-rose-500 mt-0.5 ml-1 animate-in fade-in slide-in-from-top-1\">\n          {errors[field]}\n        </p>\n      )}\n    </div>\n  );\n};\n\nconst AddStudentModal: React.FC<AddStudentModalProps> = ({ isOpen, onClose }) => {\n  const { user } = useAuth();\n  const [form, setForm] = useState<StudentFormData>(empty);\n  const [errors, setErrors] = useState<Record<string, string>>({});\n  const [touched, setTouched] = useState<Record<string, boolean>>({});\n  const [cities, setCities] = useState<City[]>([]);\n  const [licenseCats, setLicenseCats] = useState<any[]>([]);\n  const [leads, setLeads] = useState<any[]>([]);\n  const [requiredFields, setRequiredFields] = useState<string[]>([]);\n  const [loadingLeads, setLoadingLeads] = useState(false);\n  const [isFeeManuallySet, setIsFeeManuallySet] = useState(false);\n  const [showKskReminder, setShowKskReminder] = useState(false);\n\n  useEffect(() => {\n    const fetchData = async () => {\n      try {\n        const [cats, cityData, settings] = await Promise.all([\n          getLicenseCategories(),\n          getCities(),\n          getSystemSettings()\n        ]);\n        setLicenseCats(cats.data || []);\n        setCities(cityData.data || []);\n        setRequiredFields(settings?.data?.requiredFields || []);\n      } catch (error) {\n        console.error('Error fetching modal data:', error);\n      }\n    };\n    fetchData();\n  }, []);\n\n  useEffect(() => {\n    if (isOpen) {\n      setForm({ ...empty, regDate: new Date().toISOString().split('T')[0] });\n      setErrors({});\n      setTouched({});\n    }\n  }, [isOpen]);\n\n  if (!isOpen) return null;\n\n  const validate = (data = form) => {\n    const errs: Record<string, string> = {};\n    if (!data.name.trim()) {\n      errs.name = 'Vui lòng nhập họ và tên học viên.';\n    } else if (data.name.trim().split(' ').length < 2) {\n      errs.name = 'Vui lòng nhập đầy đủ họ và tên.';\n    }\n\n    if (!data.phone.trim()) {\n      errs.phone = 'Vui lòng nhập số điện thoại.';\n    } else if (!/^\\d{10,11}$/.test(data.phone.trim())) {\n      errs.phone = 'Số điện thoại không hợp lệ (10-11 chữ số).';\n    }\n\n    if (requiredFields.includes('dob') && !data.dob) errs.dob = 'Vui lòng chọn ngày sinh.';\n    \n    if (requiredFields.includes('cccd') || data.cccd.trim()) {\n      if (!data.cccd.trim()) {\n        if (requiredFields.includes('cccd')) errs.cccd = 'Vui lòng nhập số CCCD / CMND.';\n      } else if (!/^\\d{12}$/.test(data.cccd.trim())) {\n        errs.cccd = 'Số CCCD không hợp lệ (phải có đúng 12 chữ số).';\n      }\n    }\n\n    if (requiredFields.includes('region') && !data.city) errs.city = 'Vui lòng chọn Tỉnh / Thành phố.';\n    if (requiredFields.includes('address') && !data.ward.trim()) errs.ward = 'Vui lòng nhập địa chỉ chi tiết.';\n    if (requiredFields.includes('rank') && !data.rank) errs.rank = 'Vui lòng chọn hạng bằng.';\n    if (requiredFields.includes('course') && !data.course) errs.course = 'Vui lòng chọn khóa học.';\n    if (requiredFields.includes('tuition') && (!data.tuition || data.tuition === '0')) errs.tuition = 'Vui lòng nhập học phí.';\n    if (requiredFields.includes('regDate') && !data.regDate) errs.regDate = 'Vui lòng chọn ngày đăng ký.';\n    if (requiredFields.includes('intro') && !data.lead_manager?.trim()) errs.lead_manager = 'Vui lòng nhập người giới thiệu.';\n\n    setErrors(errs);\n    return errs;\n  };\n\n  const resolveTuition = (rankId: string, courseObj: any, currentIsManual: boolean) => {\n    if (currentIsManual) return form.tuition;\n\n    // 1. Priority: Course Fee\n    if (courseObj && courseObj.course_fee) {\n      return courseObj.course_fee.toString();\n    }\n\n    // 2. Priority: Rank Fee\n    if (rankId) {\n      const selectedCat = licenseCats.find((lc) => lc._id === rankId);\n      if (selectedCat && selectedCat.fee) {\n        return selectedCat.fee.replace(/[^0-9]/g, '');\n      }\n    }\n\n    return '';\n  };\n\n  const handleChange = (field: keyof StudentFormData, value: string) => {\n    const updated = { ...form, [field]: value };\n\n    if (field === 'tuition') {\n      const formatted = formatNumberWithDots(value);\n      updated.tuition = formatted;\n      setIsFeeManuallySet(formatted.trim() !== '' && formatted.trim() !== '0');\n    }\n\n    // Auto-fill tuition logic for Rank change\n    if (field === 'rank' && !isFeeManuallySet) {\n      // When rank changes, we might need a specific course lookup if one is already selected\n      // but usually rank change happens first. If a course is selected, it should have been\n      // filtered by rank anyway.\n      updated.tuition = resolveTuition(value, null, false);\n    }\n\n    setForm(updated);\n    if (touched[field]) {\n      validate(updated);\n    }\n  };\n\n  const handleBlur = (field: keyof StudentFormData) => {\n    setTouched((prev) => ({ ...prev, [field]: true }));\n    validate();\n  };\n\n  const handleSubmit = async (e: React.FormEvent) => {\n    e.preventDefault();\n    const allTouched = Object.keys(form).reduce((acc, key) => ({ ...acc, [key]: true }), {});\n    setTouched(allTouched as Record<string, boolean>);\n\n    const errs = validate();\n    if (Object.keys(errs).length > 0) {\n      toast.error('Vui lòng điền đầy đủ các trường bắt buộc!');\n      return;\n    }\n\n    const { createStudent } = await import('@/src/services/studentService');\n\n    const nameParts = form.name.trim().split(' ');\n    const last_name = nameParts.length > 1 ? nameParts.shift() : form.name.trim();\n    const first_name = nameParts.length > 0 ? nameParts.join(' ') : form.name.trim();\n\n    const payload = {\n      first_name: first_name,\n      last_name: last_name,\n      phone: form.phone,\n      identity_card: form.cccd,\n      dob: form.dob,\n\n[437 more lines in file. Use offset=261 to continue.]"}],"isError":false,"timestamp":1776941438531}}
{"type":"message","id":"bef106dc","parentId":"586d8d8f","timestamp":"2026-04-23T10:50:38.552Z","message":{"role":"toolResult","toolCallId":"call_8R7HzjR1MIsDlMkPQxN4Ark4","toolName":"read","content":[{"type":"text","text":"      dob: form.dob,\n      address: form.ward,\n      region_id: form.city,\n      license_category_id: form.rank,\n      course_id: form.course,\n      contract_date: form.regDate,\n      fee: parseNumberFromDots(form.tuition || '0'),\n      status_detail: form.course ? 'Đã vào khóa' : 'Chờ KSK',\n      existing_license_num: form.existing_license_num,\n      existing_license_rank: form.existing_license_rank,\n      lead_manager: form.lead_manager || null,\n      teacher_id: user?.role === 'teacher' ? user.id : undefined,\n    };\n\n    const promise = createStudent(payload);\n\n    toast.promise(promise, {\n      loading: 'Đang tạo hồ sơ học viên...',\n      success: () => {\n        // window.dispatchEvent(new CustomEvent('refresh-student-list'));\n\n        // KSK Reminder Popup if course is assigned\n        if (form.course) {\n          setShowKskReminder(true);\n        } else {\n          onClose();\n          setTimeout(() => {\n            window.dispatchEvent(new CustomEvent('refresh-student-list'));\n          }, 300);\n        }\n\n        return 'Thêm học viên mới thành công!';\n      },\n      error: (err) => {\n        if (err.response?.data?.errors) {\n          const serverErrs: any = {};\n          err.response.data.errors.forEach((e: any) => {\n            let path = e.path.split('.').pop();\n            // Map common backend names to frontend form keys\n            if (path === 'first_name' || path === 'last_name') path = 'name';\n            if (path === 'identity_card') path = 'cccd';\n            if (path === 'license_category_id') path = 'rank';\n            if (path === 'course_id') path = 'course';\n            serverErrs[path] = e.message;\n          });\n          setErrors((prev) => ({ ...prev, ...serverErrs }));\n          return 'Lỗi xác thực dữ liệu từ máy chủ.';\n        }\n        return 'Lỗi khi thêm học viên: ' + (err.message || 'Lỗi không xác định');\n      },\n    });\n  };\n\n  const getInputClass = (field: keyof StudentFormData) => {\n    const base =\n      'w-full px-4 py-2.5 bg-white border rounded-xl focus:outline-none focus:ring-4 transition-all text-sm font-medium';\n    if (touched[field] && errors[field]) {\n      return `${base} border-rose-300 bg-rose-50/20 text-rose-900 focus:ring-rose-500/10 focus:border-rose-500`;\n    }\n    return `${base} border-gray-200 focus:ring-indigo-500/10 focus:border-indigo-500`;\n  };\n\n  return (\n    <div className=\"fixed inset-0 z-50 flex items-center justify-center p-4 bg-gray-900/40 backdrop-blur-sm animate-in fade-in duration-300\">\n      {/* Modal Content */}\n      <div className=\"relative w-full max-w-2xl bg-white/95 backdrop-blur-xl rounded-[2rem] shadow-2xl border border-white/20 overflow-hidden flex flex-col animate-in zoom-in-95 duration-300\">\n        {/* Header */}\n        <div className=\"flex items-center justify-between px-8 py-6 border-b border-gray-100 bg-gray-50/50\">\n          <div>\n            <h2 className=\"text-xl font-black text-gray-900 tracking-tight\">THÊM HỌC VIÊN MỚI</h2>\n            <p className=\"text-[10px] font-bold text-gray-400 uppercase tracking-widest mt-0.5\">\n              Khởi tạo hồ sơ đào tạo lái xe\n            </p>\n          </div>\n          <button\n            onClick={onClose}\n            className=\"p-2 text-gray-400 hover:text-rose-500 hover:bg-rose-50 rounded-full transition-colors\"\n          >\n            <X className=\"w-5 h-5\" />\n          </button>\n        </div>\n\n        {/* Body - Form Fields */}\n        <div className=\"p-8 overflow-y-auto max-h-[75vh] hide-scrollbar\">\n          <form\n            id=\"add-student-form\"\n            onSubmit={handleSubmit}\n            className=\"grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-5\"\n            noValidate\n          >\n            <FieldWrapper \n              label=\"Họ và tên\" \n              required={requiredFields.includes('name')} \n              field=\"name\" \n              touched={touched} \n              errors={errors} \n              icon={User}\n            >\n              <input\n                type=\"text\"\n                placeholder=\"Nguyễn Văn A\"\n                className={getInputClass('name')}\n                value={form.name}\n                onChange={(e) => handleChange('name', e.target.value)}\n                onBlur={() => handleBlur('name')}\n              />\n            </FieldWrapper>\n\n            <FieldWrapper \n              label=\"Số điện thoại\" \n              required={requiredFields.includes('phone')} \n              field=\"phone\" \n              touched={touched} \n              errors={errors} \n              icon={Phone}\n            >\n              <input\n                type=\"text\"\n                placeholder=\"10 chữ số\"\n                className={getInputClass('phone')}\n                value={form.phone}\n                onChange={(e) => handleChange('phone', e.target.value)}\n                onBlur={() => handleBlur('phone')}\n              />\n            </FieldWrapper>\n\n            <FieldWrapper \n              label=\"Ngày sinh\" \n              required={requiredFields.includes('dob')} \n              field=\"dob\" \n              touched={touched} \n              errors={errors} \n              icon={Calendar}\n            >\n              <ViDateInput\n                className={getInputClass('dob')}\n                value={form.dob}\n                onChange={(val) => handleChange('dob', val)}\n              />\n            </FieldWrapper>\n\n            <FieldWrapper \n              label=\"CCCD / CMND\" \n              required={requiredFields.includes('cccd')} \n              field=\"cccd\" \n              touched={touched} \n              errors={errors} \n              icon={CreditCard}\n            >\n              <input\n                type=\"text\"\n                placeholder=\"12 chữ số\"\n                className={getInputClass('cccd')}\n                value={form.cccd}\n                onChange={(e) => handleChange('cccd', e.target.value)}\n                onBlur={() => handleBlur('cccd')}\n              />\n            </FieldWrapper>\n\n            <FieldWrapper \n              label=\"Hạng bằng\" \n              required={requiredFields.includes('rank')}\n              field=\"rank\" \n              touched={touched} \n              errors={errors} \n              icon={GraduationCap}\n            >\n              <select\n                className={getInputClass('rank')}\n                value={form.rank}\n                onChange={(e) => handleChange('rank', e.target.value)}\n                onBlur={() => handleBlur('rank')}\n              >\n                <option value=\"\">-- Chọn hạng --</option>\n                {licenseCats.map((lc) => (\n                  <option key={lc._id} value={lc._id}>\n                    {lc.name}\n                  </option>\n                ))}\n              </select>\n            </FieldWrapper>\n\n            <FieldWrapper\n              label=\"Tỉnh / Thành phố\"\n              required={requiredFields.includes('region')}\n              field=\"city\"\n              touched={touched}\n              errors={errors}\n              icon={MapPin}\n            >\n              <select\n                className={getInputClass('city')}\n                value={form.city}\n                onChange={(e) => handleChange('city', e.target.value)}\n                onBlur={() => handleBlur('city')}\n              >\n                <option value=\"\">-- Chọn Tỉnh/TP --</option>\n                {cities.map((c) => (\n                  <option key={c._id} value={c._id}>\n                    {c.name}\n                  </option>\n                ))}\n              </select>\n            </FieldWrapper>\n\n            <div className=\"grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-5 md:col-span-2\">\n              <FieldWrapper \n                label=\"Địa chỉ chi tiết\" \n                required={requiredFields.includes('address')} \n                field=\"ward\" \n                touched={touched} \n                errors={errors}\n              >\n                <input\n                  type=\"text\"\n                  placeholder=\"VD: Số 123, Đường ABC...\"\n                  className={getInputClass('ward')}\n                  value={form.ward}\n                  onChange={(e) => handleChange('ward', e.target.value)}\n                  onBlur={() => handleBlur('ward')}\n                />\n              </FieldWrapper>\n\n              <FieldWrapper \n                label=\"Ngày Đăng ký\" \n                required={requiredFields.includes('regDate')}\n                field=\"regDate\" \n                touched={touched} \n                errors={errors} \n                icon={Calendar}\n              >\n                <ViDateInput\n                  className={getInputClass('regDate')}\n                  value={form.regDate}\n                  onChange={(val) => handleChange('regDate', val)}\n                />\n              </FieldWrapper>\n            </div>\n\n            {/* Student Code */}\n            <FieldWrapper label=\"Mã học viên\" field=\"student_code\" touched={touched} errors={errors} icon={CreditCard}>\n              <input\n                type=\"text\"\n                className=\"w-full px-4 py-3 bg-gray-50 border-2 border-transparent rounded-xl focus:bg-white focus:border-indigo-500/20 focus:ring-4 focus:ring-indigo-500/5 transition-all text-sm font-bold placeholder:text-gray-300 outline-none\"\n                placeholder=\"Nhập mã học viên...\"\n                value={form.student_code}\n                onChange={(e) => setForm({ ...form, student_code: e.target.value })}\n              />\n            </FieldWrapper>\n\n            <FieldWrapper\n              label=\"Số GPLX đã có\"\n              field=\"existing_license_num\"\n              touched={touched}\n              errors={errors}\n              icon={CreditCard}\n              description=\"Mã số trên giấy tờ, không phải số lượng hạng\"\n            >\n              <input\n                type=\"text\"\n                placeholder=\"Nhập mã số GPLX (VD: 7901...)\"\n                className={getInputClass('existing_license_num')}\n                value={form.existing_license_num}\n                onChange={(e) => handleChange('existing_license_num', e.target.value)}\n              />\n            </FieldWrapper>\n\n            <FieldWrapper\n              label=\"Hạng GPLX đã có\"\n              field=\"existing_license_rank\"\n              touched={touched}\n              errors={errors}\n              icon={GraduationCap}\n            >\n              <input\n                type=\"text\"\n                placeholder=\"VD: A1, B1\"\n                className={getInputClass('existing_license_rank')}\n                value={form.existing_license_rank}\n                onChange={(e) => handleChange('existing_license_rank', e.target.value)}\n              />\n            </FieldWrapper>\n\n            <FieldWrapper \n              label=\"Khóa học\" \n              required={requiredFields.includes('course')}\n              field=\"course\" \n              touched={touched} \n              errors={errors} \n              icon={GraduationCap}\n            >\n              <CourseSelectDropdown\n                name=\"course\"\n                className={getInputClass('course')}\n                value={form.course}\n                onChange={(val) => handleChange('course', val)}\n                onCourseSelect={(course) => {\n                  if (course) {\n                    setForm((prev) => {\n                      const updated = { ...prev };\n                      // Auto-map rank if currently empty\n                      if (!prev.rank && course.license_category_id) {\n                        updated.rank = course.license_category_id;\n                      }\n                      // Resolve tuition\n                      if (!isFeeManuallySet) {\n                        updated.tuition = resolveTuition(updated.rank, course, false);\n                      }\n                      return updated;\n                    });\n                  }\n                }}\n                filters={{ license_category_id: form.rank }}\n              />\n            </FieldWrapper>\n\n            <FieldWrapper\n              label=\"Người giới thiệu\"\n              required={requiredFields.includes('intro')}\n              field=\"lead_manager\"\n              touched={touched}\n              errors={errors}\n              icon={User}\n              description=\"Tên nhân viên/Quản lý phụ trách hồ sơ\"\n            >\n              <input\n                type=\"text\"\n                placeholder=\"Nhập họ và tên người quản lý\"\n                className={getInputClass('lead_manager')}\n                value={form.lead_manager}\n                onChange={(e) => handleChange('lead_manager', e.target.value)}\n                onBlur={() => handleBlur('lead_manager')}\n              />\n            </FieldWrapper>\n\n            <FieldWrapper \n              label=\"Học phí (VNĐ)\" \n              field=\"tuition\" \n              touched={touched} \n              errors={errors}\n            >\n              <div className=\"relative\">\n                <input\n                  type=\"text\"\n                  placeholder=\"0\"\n                  className={getInputClass('tuition')}\n                  value={form.tuition}\n                  onChange={(e) => handleChange('tuition', e.target.value)}\n                />\n                <span className=\"absolute right-4 top-1/2 -translate-y-1/2 text-[10px] font-black text-gray-400\">\n                  VNĐ\n                </span>\n              </div>\n            </FieldWrapper>\n\n            <div className=\"md:col-span-2 p-4 bg-gray-50 rounded-2xl border border-gray-100 flex items-center justify-between\">\n              <div>\n                <p className=\"text-[10px] font-black text-gray-400 uppercase tracking-widest\">\n                  Trạng thái hồ sơ dự kiến\n                </p>\n                <p className=\"text-xs font-bold text-gray-600 mt-1\">\n                  Hệ thống sẽ tự động gán trạng thái này sau khi lưu\n                </p>\n              </div>\n              <div\n                className={`px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest border shadow-sm transition-all duration-300 ${\n                  form.course\n                    ? 'bg-emerald-50 text-emerald-700 border-emerald-200'\n                    : 'bg-orange-50 text-orange-600 border-orange-200'\n                }`}\n              >\n                {form.course ? 'Đã vào khóa' : 'Chờ KSK'}\n              </div>\n            </div>\n          </form>\n        </div>\n\n        {/* Footer */}\n        <div className=\"flex items-center justify-end gap-3 px-8 py-6 border-t border-gray-100 bg-gray-50/50\">\n          <button\n\n[58 more lines in file. Use offset=640 to continue.]"}],"isError":false,"timestamp":1776941438542}}
{"type":"message","id":"49520203","parentId":"bef106dc","timestamp":"2026-04-23T10:50:38.563Z","message":{"role":"toolResult","toolCallId":"call_qg0y8RvbjTNN6cA0eKJMSTs0","toolName":"read","content":[{"type":"text","text":"'use client';\n\nimport React, { useState, useEffect, useRef } from 'react';\nimport { Search, Loader2, Check, ChevronDown } from 'lucide-react';\nimport { getCourses } from '@/src/services/courseService';\n\ninterface Course {\n  _id: string;\n  name?: string;\n  code?: string;\n  course_fee?: number;\n  license_category_id?: string;\n  license_category_name?: string;\n}\n\ninterface CourseSelectDropdownProps {\n  value?: string;\n  defaultValue?: string;\n  onChange?: (val: string) => void;\n  onCourseSelect?: (course: Course | null) => void;\n  className?: string;\n  placeholder?: string;\n  initialCourseName?: string;\n  name?: string;\n  filters?: Record<string, any>;\n}\n\nexport default function CourseSelectDropdown({\n  value,\n  defaultValue = '',\n  onChange,\n  onCourseSelect,\n  className = '',\n  placeholder = '-- Chọn khóa học --',\n  initialCourseName = '',\n  name,\n  filters = {},\n}: CourseSelectDropdownProps) {\n  const [isOpen, setIsOpen] = useState(false);\n  const [internalValue, setInternalValue] = useState(defaultValue);\n  const [search, setSearch] = useState('');\n  const [courses, setCourses] = useState<Course[]>([]);\n  const [page, setPage] = useState(1);\n  const [hasMore, setHasMore] = useState(true);\n  const [isLoading, setIsLoading] = useState(false);\n  const [selectedName, setSelectedName] = useState(initialCourseName);\n\n  const dropdownRef = useRef<HTMLDivElement>(null);\n  const searchTimeout = useRef<NodeJS.Timeout | null>(null);\n  const isFetchingRef = useRef(false);\n  const sentinelRef = useRef<HTMLDivElement>(null);\n\n  const fetchCourses = async (p: number, q: string, append = false) => {\n    if (isFetchingRef.current) return;\n    isFetchingRef.current = true;\n    setIsLoading(true);\n\n    try {\n      const apiFilters = { search: q, ...filters };\n      const res = await getCourses(p, 10, apiFilters);\n\n      if (res.success && res.data) {\n        let newDocs: Course[] = [];\n        if (Array.isArray(res.data.docs)) newDocs = res.data.docs as Course[];\n        else if (Array.isArray(res.data.data)) newDocs = res.data.data as Course[];\n        else if (Array.isArray(res.data)) newDocs = res.data as Course[];\n\n        setCourses((prev) => {\n          const all = append ? [...prev, ...newDocs] : newDocs;\n          const unique = Array.from(new Map(all.map((item: Course) => [item._id, item])).values()) as Course[];\n          return unique;\n        });\n\n        const totalPages = res.data.meta?.total_pages || res.data.meta?.totalPages || 1;\n        setHasMore(p < totalPages);\n        setPage(p);\n      }\n    } catch (err) {\n      console.error('Lỗi lấy danh sách khóa học', err);\n    } finally {\n      setIsLoading(false);\n      isFetchingRef.current = false;\n    }\n  };\n\n  // Infinite Scroll via Intersection Observer\n  useEffect(() => {\n    if (!isOpen || !hasMore || isLoading) return;\n\n    const observer = new IntersectionObserver(\n      (entries) => {\n        if (entries[0].isIntersecting && !isFetchingRef.current) {\n          fetchCourses(page + 1, search, true);\n        }\n      },\n      { threshold: 0.1, rootMargin: '50px' },\n    );\n\n    const currentSentinel = sentinelRef.current;\n    if (currentSentinel) observer.observe(currentSentinel);\n\n    return () => {\n      if (currentSentinel) observer.unobserve(currentSentinel);\n    };\n  }, [isOpen, hasMore, isLoading, page, search, filters]);\n\n  // Initial fetch/sync\n  useEffect(() => {\n    const valObj = value !== undefined ? value : internalValue;\n    const shouldFetch = isOpen || (valObj && courses.length === 0 && !selectedName);\n    if (shouldFetch && !isFetchingRef.current && courses.length === 0) {\n      fetchCourses(1, '');\n    }\n  }, [isOpen, value, internalValue]);\n\n  // Sync selected name\n  useEffect(() => {\n    if (initialCourseName && !selectedName) setSelectedName(initialCourseName);\n  }, [initialCourseName]);\n\n  useEffect(() => {\n    const valObj = value !== undefined ? value : internalValue;\n    if (valObj) {\n      if (courses.length > 0) {\n        const c = courses.find((x) => x._id === valObj);\n        if (c) {\n          setSelectedName(c.name || c.code || '');\n        }\n      } else if (initialCourseName) {\n        setSelectedName(initialCourseName);\n      }\n    } else {\n      setSelectedName('');\n    }\n  }, [value, internalValue, courses, initialCourseName]);\n\n  // Click outside closure\n  useEffect(() => {\n    const handleClickOutside = (e: MouseEvent) => {\n      if (dropdownRef.current && !dropdownRef.current.contains(e.target as Node)) setIsOpen(false);\n    };\n    document.addEventListener('mousedown', handleClickOutside);\n    return () => document.removeEventListener('mousedown', handleClickOutside);\n  }, []);\n\n  const handleSearchChange = (val: string) => {\n    setSearch(val);\n    if (searchTimeout.current) clearTimeout(searchTimeout.current);\n    searchTimeout.current = setTimeout(() => {\n      setHasMore(true);\n      fetchCourses(1, val, false);\n    }, 400);\n  };\n\n  const handleSelect = (course?: Course) => {\n    const newVal = course ? course._id : '';\n    if (onChange) onChange(newVal);\n    if (onCourseSelect) onCourseSelect(course || null);\n    if (value === undefined) {\n      setInternalValue(newVal);\n    }\n    // Set name immediately for immediate UI feedback\n    setSelectedName(course ? course.name || course.code || '' : '');\n    setIsOpen(false);\n  };\n\n  const displayValue = value !== undefined ? value : internalValue;\n\n  return (\n    <div className=\"relative w-full\" ref={dropdownRef}>\n      {name && <input type=\"hidden\" name={name} value={displayValue} />}\n\n      <div\n        onClick={() => setIsOpen(!isOpen)}\n        className={`flex items-center justify-between px-3 py-2.5 bg-white border border-gray-200 rounded-xl cursor-pointer hover:border-indigo-300 transition-colors ${className}`}\n      >\n        <span className={`text-sm font-medium truncate ${displayValue ? 'text-gray-900' : 'text-gray-400'}`}>\n          {displayValue ? selectedName || placeholder : placeholder}\n        </span>\n        <ChevronDown\n          className={`w-4 h-4 text-gray-400 transition-transform duration-300 ${isOpen ? 'rotate-180 text-indigo-500' : ''}`}\n        />\n      </div>\n\n      {isOpen && (\n        <div className=\"absolute top-full left-0 right-0 mt-2 bg-white border border-gray-100 rounded-2xl shadow-xl z-[9999] overflow-hidden animate-in fade-in slide-in-from-top-2 duration-200 min-w-full\">\n          <div className=\"p-3 border-b border-gray-50 bg-gray-50/50\">\n            <div className=\"relative\">\n              <Search className=\"absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400\" />\n              <input\n                autoFocus\n                type=\"text\"\n                className=\"w-full pl-9 pr-3 py-2 bg-white border border-gray-200 rounded-xl text-sm font-medium focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all outline-none\"\n                placeholder=\"Tìm khóa học...\"\n                value={search}\n                onChange={(e) => handleSearchChange(e.target.value)}\n              />\n            </div>\n          </div>\n\n          <div className=\"max-h-[220px] overflow-y-auto overscroll-contain py-2 bg-white custom-scrollbar\">\n            <div\n              onClick={() => handleSelect(undefined)}\n              className={`px-4 py-2.5 flex items-center justify-between cursor-pointer transition-colors ${!displayValue ? 'bg-indigo-50 text-indigo-700 font-bold' : 'text-gray-600 hover:bg-gray-50'}`}\n            >\n              <span className=\"text-sm italic\">-- Chưa vào khóa --</span>\n              {!displayValue && <Check className=\"w-4 h-4\" />}\n            </div>\n\n            {courses.length > 0 ? (\n              courses.map((c) => (\n                <div\n                  key={c._id}\n                  onClick={() => handleSelect(c)}\n                  className={`px-4 py-2.5 flex items-center justify-between cursor-pointer transition-colors ${\n                    displayValue === c._id ? 'bg-indigo-50 text-indigo-700 font-bold' : 'text-gray-700 hover:bg-gray-50'\n                  }`}\n                >\n                  <span className=\"text-sm\">{c.name || c.code}</span>\n                  {displayValue === c._id && <Check className=\"w-4 h-4 text-indigo-600\" />}\n\n[21 more lines in file. Use offset=221 to continue.]"}],"isError":false,"timestamp":1776941438553}}
{"type":"message","id":"9a749a76","parentId":"49520203","timestamp":"2026-04-23T10:51:30.335Z","message":{"role":"assistant","content":[{"type":"text","text":"Đã rõ: form thêm học viên đang luôn truyền filter `license_category_id: form.rank`, nên khi đã chọn hạng thì list khóa bị lọc; phần auto-map từ khóa → hạng chỉ chạy khi `rank` đang rỗng. Mình sẽ đổi logic để đúng ý bạn: chưa chọn hạng thì hiện tất cả; chọn khóa thì luôn map hạng theo khóa; chọn hạng thì chỉ lọc khóa nếu user thật sự đang muốn lọc theo hạng, và sẽ reset khóa nếu không còn khớp."},{"type":"toolCall","id":"call_tEJeTeRLraXjNy6CAl1pJCBP","name":"edit","arguments":{"path":"/root/.openclaw/workspaces2/projects/ahv-qlhv-fe/src/components/students/AddStudentModal.tsx","edits":[{"oldText":"  const handleChange = (field: keyof StudentFormData, value: string) => {\n    const updated = { ...form, [field]: value };\n\n    if (field === 'tuition') {\n      const formatted = formatNumberWithDots(value);\n      updated.tuition = formatted;\n      setIsFeeManuallySet(formatted.trim() !== '' && formatted.trim() !== '0');\n    }\n\n    // Auto-fill tuition logic for Rank change\n    if (field === 'rank' && !isFeeManuallySet) {\n      // When rank changes, we might need a specific course lookup if one is already selected\n      // but usually rank change happens first. If a course is selected, it should have been\n      // filtered by rank anyway.\n      updated.tuition = resolveTuition(value, null, false);\n    }\n\n    setForm(updated);\n    if (touched[field]) {\n      validate(updated);\n    }\n  };\n","newText":"  const handleChange = (field: keyof StudentFormData, value: string) => {\n    const updated = { ...form, [field]: value };\n\n    if (field === 'tuition') {\n      const formatted = formatNumberWithDots(value);\n      updated.tuition = formatted;\n      setIsFeeManuallySet(formatted.trim() !== '' && formatted.trim() !== '0');\n    }\n\n    if (field === 'rank') {\n      if (form.course) {\n        updated.course = '';\n      }\n\n      if (!isFeeManuallySet) {\n        updated.tuition = resolveTuition(value, null, false);\n      }\n    }\n\n    setForm(updated);\n    if (touched[field]) {\n      validate(updated);\n    }\n  };\n"},{"oldText":"                onCourseSelect={(course) => {\n                  if (course) {\n                    setForm((prev) => {\n                      const updated = { ...prev };\n                      // Auto-map rank if currently empty\n                      if (!prev.rank && course.license_category_id) {\n                        updated.rank = course.license_category_id;\n                      }\n                      // Resolve tuition\n                      if (!isFeeManuallySet) {\n                        updated.tuition = resolveTuition(updated.rank, course, false);\n                      }\n                      return updated;\n                    });\n                  }\n                }}\n","newText":"                onCourseSelect={(course) => {\n                  setForm((prev) => {\n                    const updated = { ...prev };\n\n                    if (course) {\n                      if (course.license_category_id) {\n                        updated.rank = course.license_category_id;\n                      }\n\n                      if (!isFeeManuallySet) {\n                        updated.tuition = resolveTuition(updated.rank, course, false);\n                      }\n                    } else {\n                      if (!isFeeManuallySet) {\n                        updated.tuition = resolveTuition(updated.rank, null, false);\n                      }\n                    }\n\n                    return updated;\n                  });\n                }}\n"}]}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-TroLy","usage":{"input":9582,"output":1022,"cacheRead":86528,"cacheWrite":0,"totalTokens":97132,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776941438571,"responseId":"1776941440392"}}
