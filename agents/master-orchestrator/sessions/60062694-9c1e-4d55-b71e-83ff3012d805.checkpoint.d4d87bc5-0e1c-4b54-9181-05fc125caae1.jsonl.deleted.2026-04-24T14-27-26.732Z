{"type":"message","id":"7128ab99","parentId":"0eb329e1","timestamp":"2026-04-23T16:54:46.730Z","message":{"role":"toolResult","toolCallId":"call_function_s7swuzad0ykq_1","toolName":"edit","content":[{"type":"text","text":"Successfully replaced 1 block(s) in /root/.openclaw/workspaces2/projects/ahv-qlhv-fe/src/services/courseService.ts."}],"details":{"diff":"    ...\n 83   a.click();\n 84   window.URL.revokeObjectURL(url);\n 85   document.body.removeChild(a);\n 86 };\n+87 \n+88 export const getTodayMilestones = () => apiClient('/courses/today-milestones');\n+89 \n+90 export const bulkUpdateCourseStatus = (courseIds: string[], status: string) =>\n+91   apiClient('/courses/bulk-update-status', {\n+92     method: 'POST',\n+93     body: JSON.stringify({ courseIds, status }),\n+94   });","firstChangedLine":87},"isError":false,"timestamp":1776963286723}}
{"type":"message","id":"9345309d","parentId":"7128ab99","timestamp":"2026-04-23T16:55:19.792Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me create the `CourseMilestoneBanner.tsx` component.","thinkingSignature":"2d7aec8704df20befe745f109f115944cbf9d1f915020abe41a8bee9de4e479a"},{"type":"toolCall","id":"call_function_wq01lbnelrw7_1","name":"write","arguments":{"path":"/root/.openclaw/workspaces2/projects/ahv-qlhv-fe/src/components/dashboard/CourseMilestoneBanner.tsx","content":"'use client';\n\nimport React, { useState, useEffect } from 'react';\nimport { CalendarCheck, CalendarX, Zap, Eye, X, CheckCircle2, Loader2 } from 'lucide-react';\nimport { toast } from 'sonner';\nimport { getTodayMilestones, bulkUpdateCourseStatus } from '@/src/services/courseService';\n\ninterface CourseMilestone {\n  _id: string;\n  name: string;\n  start_date?: string;\n  end_date?: string;\n  student_count: number;\n}\n\ninterface Milestones {\n  openingCourses: CourseMilestone[];\n  closingCourses: CourseMilestone[];\n  openingCount: number;\n  closingCount: number;\n}\n\ninterface CourseMilestoneBannerProps {\n  teacherId?: string;\n}\n\nconst CourseMilestoneBanner: React.FC<CourseMilestoneBannerProps> = () => {\n  const [milestones, setMilestones] = useState<Milestones | null>(null);\n  const [loading, setLoading] = useState(true);\n  const [processing, setProcessing] = useState(false);\n  const [showReviewModal, setShowReviewModal] = useState(false);\n  const [reviewTab, setReviewTab] = useState<'opening' | 'closing'>('opening');\n  const [selectedCourses, setSelectedCourses] = useState<Set<string>>(new Set());\n  const [dismissed, setDismissed] = useState(false);\n\n  useEffect(() => {\n    // Only show for teacher role\n    const stored = localStorage.getItem('user');\n    if (!stored) return;\n    try {\n      const user = JSON.parse(stored);\n      if (user?.role !== 'teacher') return;\n    } catch {\n      return;\n    }\n\n    getTodayMilestones()\n      .then((res: any) => {\n        if (res?.success && (res.data?.openingCount > 0 || res.data?.closingCount > 0)) {\n          setMilestones(res.data);\n        }\n      })\n      .catch(() => {})\n      .finally(() => setLoading(false));\n  }, []);\n\n  if (loading || dismissed) return null;\n  if (!milestones || (milestones.openingCount === 0 && milestones.closingCount === 0)) return null;\n\n  const handleAutoUpdate = async () => {\n    setProcessing(true);\n    try {\n      const promises: Promise<any>[] = [];\n\n      if (milestones.openingCount > 0) {\n        const ids = milestones.openingCourses.map((c) => c._id);\n        promises.push(\n          bulkUpdateCourseStatus(ids, 'ongoing').then((res) => {\n            if (!res?.success) throw new Error(res?.message || 'Lỗi cập nhật khai giảng');\n          })\n        );\n      }\n\n      if (milestones.closingCount > 0) {\n        const ids = milestones.closingCourses.map((c) => c._id);\n        promises.push(\n          bulkUpdateCourseStatus(ids, 'completed').then((res) => {\n            if (!res?.success) throw new Error(res?.message || 'Lỗi cập nhật kết thúc');\n          })\n        );\n      }\n\n      await Promise.all(promises);\n      toast.success('Đã cập nhật trạng thái khóa học tự động!');\n      setDismissed(true);\n      window.dispatchEvent(new CustomEvent('refresh-dashboard'));\n    } catch (err: any) {\n      toast.error(err?.message || 'Có lỗi xảy ra khi cập nhật.');\n    } finally {\n      setProcessing(false);\n    }\n  };\n\n  const handleManualUpdate = () => {\n    setSelectedCourses(new Set());\n    setShowReviewModal(true);\n    setReviewTab(milestones.openingCount > 0 ? 'opening' : 'closing');\n  };\n\n  const handleSubmitManual = async () => {\n    if (selectedCourses.size === 0) {\n      toast.error('Vui lòng chọn ít nhất một khóa học để cập nhật.');\n      return;\n    }\n\n    const newStatus = reviewTab === 'opening' ? 'ongoing' : 'completed';\n    setProcessing(true);\n    try {\n      const res: any = await bulkUpdateCourseStatus(Array.from(selectedCourses), newStatus);\n      if (res?.success) {\n        toast.success('Đã cập nhật trạng thái khóa học!');\n        setShowReviewModal(false);\n        setDismissed(true);\n        window.dispatchEvent(new CustomEvent('refresh-dashboard'));\n      } else {\n        toast.error(res?.message || 'Có lỗi xảy ra.');\n      }\n    } catch (err: any) {\n      toast.error(err?.message || 'Có lỗi xảy ra khi cập nhật.');\n    } finally {\n      setProcessing(false);\n    }\n  };\n\n  const toggleCourse = (id: string) => {\n    setSelectedCourses((prev) => {\n      const next = new Set(prev);\n      if (next.has(id)) next.delete(id);\n      else next.add(id);\n      return next;\n    });\n  };\n\n  const currentCourses = reviewTab === 'opening' ? milestones.openingCourses : milestones.closingCourses;\n\n  return (\n    <>\n      <div className=\"bg-gradient-to-r from-indigo-50 via-purple-50 to-indigo-50 border border-indigo-100 rounded-2xl p-4 animate-in fade-in slide-in-from-bottom-2\">\n        <div className=\"flex items-start gap-4\">\n          <div className=\"flex flex-col gap-2 flex-1 min-w-0\">\n            <div className=\"flex items-center gap-2 flex-wrap\">\n              {milestones.openingCount > 0 && (\n                <div className=\"flex items-center gap-1.5 bg-indigo-600 text-white px-3 py-1.5 rounded-xl text-xs font-black\">\n                  <CalendarCheck className=\"w-4 h-4\" />\n                  <span>{milestones.openingCount} khóa khai giảng hôm nay</span>\n                </div>\n              )}\n              {milestones.closingCount > 0 && (\n                <div className=\"flex items-center gap-1.5 bg-rose-600 text-white px-3 py-1.5 rounded-xl text-xs font-black\">\n                  <CalendarX className=\"w-4 h-4\" />\n                  <span>{milestones.closingCount} khóa kết thúc hôm nay</span>\n                </div>\n              )}\n              <button\n                onClick={() => setDismissed(true)}\n                className=\"ml-auto p-1.5 text-gray-400 hover:text-gray-600 hover:bg-gray-200 rounded-lg transition-colors\"\n              >\n                <X className=\"w-4 h-4\" />\n              </button>\n            </div>\n            <p className=\"text-xs text-gray-500 font-medium\">\n              Một số khóa học của bạn có cột mốc quan trọng trong ngày hôm nay.\n            </p>\n            <div className=\"flex items-center gap-2 pt-1\">\n              <button\n                onClick={handleAutoUpdate}\n                disabled={processing}\n                className=\"flex items-center gap-1.5 px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-xl text-xs font-bold transition-all active:scale-95 disabled:opacity-60 shadow-sm\"\n              >\n                {processing ? <Loader2 className=\"w-3.5 h-3.5 animate-spin\" /> : <Zap className=\"w-3.5 h-3.5\" />}\n                Tự động cập nhật\n              </button>\n              <button\n                onClick={handleManualUpdate}\n                disabled={processing}\n                className=\"flex items-center gap-1.5 px-4 py-2 bg-white hover:bg-gray-50 text-gray-700 border border-gray-200 rounded-xl text-xs font-bold transition-all active:scale-95 disabled:opacity-60\"\n              >\n                <Eye className=\"w-3.5 h-3.5\" />\n                Cập nhật bằng tay\n              </button>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      {/* Manual Review Modal */}\n      {showReviewModal && milestones && (\n        <div className=\"fixed inset-0 z-[100] flex items-center justify-center p-4 bg-gray-900/50 backdrop-blur-sm animate-in fade-in duration-300\">\n          <div className=\"bg-white rounded-3xl w-full max-w-lg shadow-2xl overflow-hidden animate-in zoom-in-95 duration-300\">\n            <div className=\"px-6 py-5 border-b border-gray-100 flex items-center justify-between bg-gray-50/50\">\n              <div>\n                <h3 className=\"text-lg font-black text-gray-900\">Cập nhật trạng thái khóa học</h3>\n                <p className=\"text-[10px] text-gray-400 font-bold uppercase tracking-widest mt-0.5\">\n                  Chọn các khóa học bạn muốn cập nhật\n                </p>\n              </div>\n              <button\n                onClick={() => setShowReviewModal(false)}\n                className=\"p-2 text-gray-400 hover:text-rose-500 hover:bg-rose-50 rounded-full transition-colors\"\n              >\n                <X className=\"w-5 h-5\" />\n              </button>\n            </div>\n\n            {/* Tabs */}\n            <div className=\"flex border-b border-gray-100\">\n              {milestones.openingCount > 0 && (\n                <button\n                  onClick={() => { setReviewTab('opening'); setSelectedCourses(new Set()); }}\n                  className={`flex-1 px-4 py-3 text-xs font-bold uppercase tracking-widest transition-colors ${\n                    reviewTab === 'opening'\n                      ? 'text-indigo-600 border-b-2 border-indigo-600 bg-indigo-50/50'\n                      : 'text-gray-400 hover:text-gray-600'\n                  }`}\n                >\n                  Khai giảng ({milestones.openingCount})\n                </button>\n              )}\n              {milestones.closingCount > 0 && (\n                <button\n                  onClick={() => { setReviewTab('closing'); setSelectedCourses(new Set()); }}\n                  className={`flex-1 px-4 py-3 text-xs font-bold uppercase tracking-widest transition-colors ${\n                    reviewTab === 'closing'\n                      ? 'text-rose-600 border-b-2 border-rose-600 bg-rose-50/50'\n                      : 'text-gray-400 hover:text-gray-600'\n                  }`}\n                >\n                  Kết thúc ({milestones.closingCount})\n                </button>\n              )}\n            </div>\n\n            {/* Course list */}\n            <div className=\"p-4 max-h-80 overflow-y-auto flex flex-col gap-2\">\n              {currentCourses.map((course) => (\n                <label\n                  key={course._id}\n                  className={`flex items-center gap-3 p-3 rounded-xl border cursor-pointer transition-all ${\n                    selectedCourses.has(course._id)\n                      ? 'border-indigo-400 bg-indigo-50'\n                      : 'border-gray-100 hover:border-gray-200 hover:bg-gray-50'\n                  }`}\n                >\n                  <input\n                    type=\"checkbox\"\n                    checked={selectedCourses.has(course._id)}\n                    onChange={() => toggleCourse(course._id)}\n                    className=\"w-4 h-4 rounded border-gray-300 text-indigo-600\"\n                  />\n                  <div className=\"flex-1 min-w-0\">\n                    <p className=\"text-sm font-bold text-gray-800 truncate\">{course.name}</p>\n                    <p className=\"text-[10px] text-gray-400 font-medium\">\n                      {course.student_count} học viên\n                      {reviewTab === 'opening' && course.start_date && (\n                        <span> · KKG: {new Date(course.start_date).toLocaleDateString('vi-VN')}\n                        </span>\n                      )}\n                      {reviewTab === 'closing' && course.end_date && (\n                        <span> · Kết thúc: {new Date(course.end_date).toLocaleDateString('vi-VN')}\n                        </span>\n                      )}\n                    </p>\n                  </div>\n                  {selectedCourses.has(course._id) && (\n                    <CheckCircle2 className=\"w-4 h-4 text-indigo-500 shrink-0\" />\n                  )}\n                </label>\n              ))}\n            </div>\n\n            <div className=\"px-6 py-5 flex justify-end gap-3 border-t border-gray-100 bg-gray-50/50\">\n              <button\n                onClick={() => setShowReviewModal(false)}\n                className=\"px-5 py-2.5 text-xs font-bold uppercase tracking-widest text-gray-500 hover:text-gray-900 hover:bg-gray-200/50 rounded-xl transition-all\"\n              >\n                Hủy\n              </button>\n              <button\n                onClick={handleSubmitManual}\n                disabled={processing || selectedCourses.size === 0}\n                className=\"flex items-center gap-2 px-6 py-2.5 text-xs font-bold uppercase tracking-widest text-white bg-indigo-600 hover:bg-indigo-700 rounded-xl transition-all disabled:opacity-50\"\n              >\n                {processing ? <Loader2 className=\"w-3.5 h-3.5 animate-spin\" /> : null}\n                Cập nhật {selectedCourses.size > 0 ? `(${selectedCourses.size})` : ''}\n              </button>\n            </div>\n          </div>\n        </div>\n      )}\n    </>\n  );\n};\n\nexport default CourseMilestoneBanner;\n"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":105,"output":3104,"cacheRead":103395,"cacheWrite":462,"totalTokens":107066,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776963286742,"responseId":"063981d8574a9b39035983c00039f1e9"}}
