{"type":"message","id":"65b93116","parentId":"59cb78db","timestamp":"2026-04-23T15:09:35.663Z","message":{"role":"toolResult","toolCallId":"call_eJWSgyseW5kwSuslJpm62vg1","toolName":"exec","content":[{"type":"text","text":"Switched to a new branch 'fix/dat-duration-independent-validation-20260423'"}],"details":{"status":"completed","exitCode":0,"durationMs":28,"aggregated":"Switched to a new branch 'fix/dat-duration-independent-validation-20260423'","cwd":"/root/.openclaw/workspaces2/projects/ahv-qlhv-fe"},"isError":false,"timestamp":1776956975655}}
{"type":"message","id":"66f583a6","parentId":"65b93116","timestamp":"2026-04-23T15:09:35.670Z","message":{"role":"toolResult","toolCallId":"call_BtM7y9AUCVHFMd4a84W0bXZa","toolName":"read","content":[{"type":"text","text":"'use client';\n\nimport React, { useState, useEffect } from 'react';\nimport { X, Calendar, MapPin, User, Save, Clock, Ruler } from 'lucide-react';\nimport { toast } from 'sonner';\nimport { addDatSession } from '@/src/services/datService';\nimport ViDateInput from '@/src/components/shared/ViDateInput';\n\ninterface AddDatModalProps {\n  isOpen: boolean;\n  onClose: () => void;\n  studentName?: string;\n  enrollmentId?: string;\n  onSuccess?: () => void;\n}\n\ninterface DatFormData {\n  date: string;\n  timeStart: string;\n  timeEnd: string;\n  duration: string;\n  distance: string;\n  note: string;\n}\n\nconst initialState: DatFormData = {\n  date: new Date().toISOString().split('T')[0],\n  timeStart: '',\n  timeEnd: '',\n  duration: '',\n  distance: '',\n  note: '',\n};\n\nconst FieldWrapper = ({\n  label,\n  required,\n  children,\n  field,\n  touched,\n  errors,\n  icon: Icon,\n}: {\n  label: string;\n  required?: boolean;\n  children: React.ReactNode;\n  field: string;\n  touched: Record<string, boolean>;\n  errors: Record<string, string>;\n  icon?: any;\n}) => {\n  const hasError = touched[field] && errors[field];\n  return (\n    <div className=\"flex flex-col gap-1.5\">\n      <label\n        className={`text-[10px] font-black uppercase tracking-widest flex items-center gap-1.5 transition-colors ${hasError ? 'text-rose-500' : 'text-gray-400'}`}\n      >\n        {Icon && <Icon className=\"w-3.5 h-3.5 text-indigo-500\" />}\n        {label} {required && <span className=\"text-rose-500\">*</span>}\n      </label>\n      <div className=\"relative group\">{children}</div>\n      {hasError && (\n        <p className=\"text-[10px] font-bold text-rose-500 mt-1 ml-1 animate-in fade-in slide-in-from-top-1\">\n          {errors[field]}\n        </p>\n      )}\n    </div>\n  );\n};\n\nexport default function AddDatModal({ isOpen, onClose, studentName = '', enrollmentId, onSuccess }: AddDatModalProps) {\n  const [loading, setLoading] = useState(false);\n  const [form, setForm] = useState<DatFormData>({ ...initialState });\n  const [errors, setErrors] = useState<Record<string, string>>({});\n  const [touched, setTouched] = useState<Record<string, boolean>>({});\n\n  useEffect(() => {\n    if (isOpen) {\n      setForm({ ...initialState, date: new Date().toISOString().split('T')[0] });\n      setErrors({});\n      setTouched({});\n    }\n  }, [isOpen]);\n\n  if (!isOpen) return null;\n\n  const validate = (data = form) => {\n    const errs: Record<string, string> = {};\n    if (!data.date) errs.date = 'Vui lòng chọn ngày học.';\n    if (!data.duration.trim()) errs.duration = 'Vui lòng nhập thời lượng.';\n    else if (isNaN(parseInt(data.duration)) || parseInt(data.duration) <= 0)\n      errs.duration = 'Thời lượng phải là số dương.';\n\n    if (!data.distance.trim()) errs.distance = 'Vui lòng nhập quãng đường.';\n    else if (isNaN(parseFloat(data.distance)) || parseFloat(data.distance) <= 0)\n      errs.distance = 'Quãng đường phải là số dương.';\n\n    setErrors(errs);\n    return errs;\n  };\n\n  const handleChange = (field: string, value: string) => {\n    const updated = { ...form, [field]: value };\n    setForm(updated);\n    if (touched[field]) {\n      validate(updated);\n    }\n  };\n\n  const handleBlur = (field: string) => {\n    setTouched((prev) => ({ ...prev, [field]: true }));\n    validate();\n  };\n\n  const handleSubmit = async (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!enrollmentId) {\n      toast.error('Không tìm thấy thông tin đăng ký của học viên.');\n      return;\n    }\n\n    const allTouched = { date: true, duration: true, distance: true, timeStart: true, timeEnd: true };\n    setTouched(allTouched);\n\n    const errs = validate();\n    if (Object.keys(errs).length > 0) {\n      toast.error('Vui lòng kiểm tra lại thông tin buổi DAT');\n      return;\n    }\n\n    setLoading(true);\n    try {\n      const startTime = form.timeStart || '08:00';\n      const endTime = form.timeEnd || '10:00';\n\n      const start = new Date(`${form.date}T${startTime}:00`);\n      const end = new Date(`${form.date}T${endTime}:00`);\n\n      if (end <= start) {\n        toast.error('Thời gian kết thúc phải sau thời gian bắt đầu.');\n        setLoading(false);\n        return;\n      }\n\n      const res = await addDatSession({\n        course_student_id: enrollmentId,\n        session_type: 'dat',\n        start_time: start.toISOString(),\n        end_time: end.toISOString(),\n        distance_km: parseFloat(form.distance),\n        notes: form.note,\n      });\n\n      if (res.success) {\n        toast.success(`Đã lưu thành công buổi DAT ${form.distance}km cho ${studentName}!`);\n        onSuccess?.();\n        onClose();\n      } else {\n        toast.error(res.message || 'Lỗi khi lưu dữ liệu DAT.');\n      }\n    } catch (error) {\n      toast.error('Lỗi khi kết nối đến máy chủ.');\n    } finally {\n      setLoading(false);\n    }\n  };\n\n  const getInputClass = (field: string) => {\n    const base =\n      'w-full px-4 py-2.5 bg-white border rounded-xl focus:outline-none focus:ring-4 transition-all text-sm font-medium';\n    if (touched[field] && errors[field]) {\n      return `${base} border-rose-300 bg-rose-50/20 text-rose-900 focus:ring-rose-500/10 focus:border-rose-500`;\n    }\n    return `${base} border-gray-200 focus:ring-indigo-500/10 focus:border-indigo-500`;\n  };\n\n  return (\n    <div className=\"fixed inset-0 z-50 flex items-center justify-center p-4 bg-gray-900/40 backdrop-blur-sm animate-in fade-in duration-300\">\n      <div className=\"bg-white/95 backdrop-blur-xl rounded-[2rem] w-full max-w-md shadow-2xl overflow-hidden animate-in zoom-in-95 duration-300 border border-white/20\">\n        {/* Header */}\n        <div className=\"px-8 py-6 border-b border-gray-100 flex items-center justify-between bg-gray-50/50\">\n          <div>\n            <h2 className=\"text-xl font-black text-gray-900 tracking-tight\">THÊM BUỔI DAT</h2>\n            <p className=\"text-[10px] font-bold text-gray-400 uppercase tracking-widest mt-0.5\">\n              Ghi nhận tiến độ đào tạo DAT\n            </p>\n          </div>\n          <button\n            onClick={onClose}\n            className=\"p-2 text-gray-400 hover:text-rose-500 hover:bg-rose-50 rounded-full transition-colors\"\n          >\n            <X className=\"w-5 h-5\" />\n          </button>\n        </div>\n\n        {/* Body */}\n        <div className=\"p-8\">\n          <form id=\"add-dat-form\" onSubmit={handleSubmit} className=\"flex flex-col gap-6\" noValidate>\n            {/* Student info tag */}\n            <div className=\"px-5 py-3 bg-indigo-50/50 border border-indigo-100 text-indigo-800 rounded-2xl flex items-center gap-3 font-extrabold text-sm shadow-sm ring-1 ring-indigo-500/10\">\n              <User className=\"w-4 h-4 text-indigo-500 shrink-0\" />\n              <span className=\"truncate\">{studentName}</span>\n            </div>\n\n            <FieldWrapper label=\"NGÀY HỌC\" required field=\"date\" touched={touched} errors={errors} icon={Calendar}>\n              <ViDateInput\n                className={getInputClass('date')}\n                value={form.date}\n                onChange={(val) => handleChange('date', val)}\n              />\n            </FieldWrapper>\n\n            <div className=\"grid grid-cols-2 gap-4\">\n              <FieldWrapper label=\"GIỜ BẮT ĐẦU\" field=\"timeStart\" touched={touched} errors={errors} icon={Clock}>\n                <input\n                  type=\"time\"\n                  className={getInputClass('timeStart')}\n                  value={form.timeStart}\n                  onChange={(e) => handleChange('timeStart', e.target.value)}\n                  onBlur={() => handleBlur('timeStart')}\n                />\n              </FieldWrapper>\n\n              <FieldWrapper label=\"GIỜ KẾT THÚC\" field=\"timeEnd\" touched={touched} errors={errors} icon={Clock}>\n                <input\n                  type=\"time\"\n                  className={getInputClass('timeEnd')}\n                  value={form.timeEnd}\n                  onChange={(e) => handleChange('timeEnd', e.target.value)}\n                  onBlur={() => handleBlur('timeEnd')}\n                />\n              </FieldWrapper>\n            </div>\n\n            <div className=\"grid grid-cols-2 gap-4\">\n              <FieldWrapper\n                label=\"THỜI LƯỢNG (PHÚT)\"\n                required\n                field=\"duration\"\n                touched={touched}\n                errors={errors}\n                icon={Clock}\n              >\n                <div className=\"relative\">\n                  <input\n                    type=\"text\"\n                    placeholder=\"VD: 180\"\n                    className={getInputClass('duration')}\n                    value={form.duration}\n                    onChange={(e) => handleChange('duration', e.target.value)}\n                    onBlur={() => handleBlur('duration')}\n                  />\n                  <span className=\"absolute right-4 top-1/2 -translate-y-1/2 text-[10px] font-black text-gray-400 uppercase tracking-tight\">\n                    phút\n                  </span>\n                </div>\n              </FieldWrapper>\n\n              <FieldWrapper\n                label=\"QUÃNG ĐƯỜNG (KM)\"\n\n[62 more lines in file. Use offset=261 to continue.]"}],"isError":false,"timestamp":1776956975663}}
{"type":"message","id":"420ffe9d","parentId":"66f583a6","timestamp":"2026-04-23T15:09:35.677Z","message":{"role":"toolResult","toolCallId":"call_t8xW0ulgif0lBLkuSNivlQuT","toolName":"read","content":[{"type":"text","text":"'use client';\n\nimport React, { useEffect, useState } from 'react';\nimport ViDateInput from '@/src/components/shared/ViDateInput';\nimport { X, Calendar, MapPin, Save, Clock, Ruler } from 'lucide-react';\nimport { toast } from 'sonner';\nimport { addDatSession } from '@/src/services/datService';\n\ninterface DatSessionModalProps {\n  isOpen: boolean;\n  onClose: () => void;\n  enrollmentId: string;\n  onSuccess: () => void;\n}\n\ninterface DatFormData {\n  date: string;\n  timeStart: string;\n  timeEnd: string;\n  duration: string;\n  distance: string;\n  note: string;\n}\n\nconst initialState: DatFormData = {\n  date: new Date().toISOString().split('T')[0],\n  timeStart: '',\n  timeEnd: '',\n  duration: '',\n  distance: '',\n  note: '',\n};\n\nconst syncDuration = (startStr: string, endStr: string) => {\n  if (!startStr || !endStr) return '';\n  try {\n    const [sh, sm] = startStr.split(':').map(Number);\n    const [eh, em] = endStr.split(':').map(Number);\n    const diffMinutes = eh * 60 + em - (sh * 60 + sm);\n    return diffMinutes > 0 ? diffMinutes.toString() : '';\n  } catch {\n    return '';\n  }\n};\n\nconst syncEndTime = (startStr: string, durationStr: string) => {\n  if (!startStr || !durationStr || isNaN(parseInt(durationStr))) return '';\n  try {\n    const [sh, sm] = startStr.split(':').map(Number);\n    const totalMinutes = sh * 60 + sm + parseInt(durationStr || '0');\n    const eh = Math.floor(totalMinutes / 60) % 24;\n    const em = totalMinutes % 60;\n    return `${eh.toString().padStart(2, '0')}:${em.toString().padStart(2, '0')}`;\n  } catch {\n    return '';\n  }\n};\n\nconst FieldWrapper = ({\n  label,\n  required,\n  children,\n  field,\n  touched,\n  errors,\n  icon: Icon,\n}: {\n  label: string;\n  required?: boolean;\n  children: React.ReactNode;\n  field: string;\n  touched: Record<string, boolean>;\n  errors: Record<string, string>;\n  icon?: any;\n}) => {\n  const hasError = touched[field] && errors[field];\n  return (\n    <div className=\"flex flex-col gap-1.5\">\n      <label\n        className={`text-[10px] font-black uppercase tracking-widest flex items-center gap-1.5 transition-colors ${hasError ? 'text-rose-500' : 'text-gray-400'}`}\n      >\n        {Icon && <Icon className=\"w-3.5 h-3.5 text-indigo-500\" />}\n        {label} {required && <span className=\"text-rose-500\">*</span>}\n      </label>\n      <div className=\"relative group\">{children}</div>\n      {hasError && (\n        <p className=\"text-[10px] font-bold text-rose-500 mt-1 ml-1 animate-in fade-in slide-in-from-top-1\">\n          {errors[field]}\n        </p>\n      )}\n    </div>\n  );\n};\n\nconst DatSessionModal: React.FC<DatSessionModalProps> = ({ isOpen, onClose, enrollmentId, onSuccess }) => {\n  const [loading, setLoading] = useState(false);\n  const [form, setForm] = useState<DatFormData>({ ...initialState });\n  const [errors, setErrors] = useState<Record<string, string>>({});\n  const [touched, setTouched] = useState<Record<string, boolean>>({});\n\n  useEffect(() => {\n    if (isOpen) {\n      setForm({ ...initialState, date: new Date().toISOString().split('T')[0] });\n      setErrors({});\n      setTouched({});\n    }\n  }, [isOpen]);\n\n  if (!isOpen) return null;\n\n  const validate = (data = form) => {\n    const errs: Record<string, string> = {};\n\n    if (!data.date) errs.date = 'Vui lòng chọn ngày học.';\n    if (!data.duration.trim()) errs.duration = 'Vui lòng nhập thời lượng.';\n    else if (isNaN(parseInt(data.duration)) || parseInt(data.duration) <= 0) {\n      errs.duration = 'Thời lượng phải là số dương.';\n    }\n\n    if (!data.distance.trim()) errs.distance = 'Vui lòng nhập quãng đường.';\n    else if (isNaN(parseFloat(data.distance)) || parseFloat(data.distance) <= 0) {\n      errs.distance = 'Quãng đường phải là số dương.';\n    }\n\n    setErrors(errs);\n    return errs;\n  };\n\n  const handleChange = (field: keyof DatFormData, value: string) => {\n    setForm((prev) => {\n      const updated = { ...prev, [field]: value };\n\n      if (field === 'timeStart') {\n        if (updated.timeEnd) {\n          updated.duration = syncDuration(value, updated.timeEnd);\n        } else if (updated.duration) {\n          updated.timeEnd = syncEndTime(value, updated.duration);\n        }\n      }\n\n      if (field === 'timeEnd') {\n        updated.duration = syncDuration(updated.timeStart, value);\n      }\n\n      if (field === 'duration') {\n        updated.timeEnd = syncEndTime(updated.timeStart, value);\n      }\n\n      if (touched[field]) {\n        validate(updated);\n      }\n\n      return updated;\n    });\n  };\n\n  const handleBlur = (field: string) => {\n    setTouched((prev) => ({ ...prev, [field]: true }));\n    validate();\n  };\n\n  const getInputClass = (field: string) => {\n    const base =\n      'w-full px-4 py-2.5 bg-white border rounded-xl focus:outline-none focus:ring-4 transition-all text-sm font-medium';\n    if (touched[field] && errors[field]) {\n      return `${base} border-rose-300 bg-rose-50/20 text-rose-900 focus:ring-rose-500/10 focus:border-rose-500`;\n    }\n    return `${base} border-gray-200 focus:ring-indigo-500/10 focus:border-indigo-500`;\n  };\n\n  const handleSubmit = async (e: React.FormEvent) => {\n    e.preventDefault();\n\n    if (!enrollmentId) {\n      toast.error('Không tìm thấy thông tin đăng ký của học viên.');\n      return;\n    }\n\n    const allTouched = { date: true, duration: true, distance: true, timeStart: true, timeEnd: true };\n    setTouched(allTouched);\n\n    const errs = validate();\n    if (Object.keys(errs).length > 0) {\n      toast.error('Vui lòng kiểm tra lại thông tin buổi DAT');\n      return;\n    }\n\n    setLoading(true);\n    try {\n      const startTime = form.timeStart || '08:00';\n      const endTime = form.timeEnd || '10:00';\n\n      const start = new Date(`${form.date}T${startTime}:00`);\n      const end = new Date(`${form.date}T${endTime}:00`);\n\n      if (end <= start) {\n        toast.error('Thời gian kết thúc phải sau thời gian bắt đầu.');\n        setLoading(false);\n        return;\n      }\n\n      const res = await addDatSession({\n        course_student_id: enrollmentId,\n        session_type: 'dat',\n        start_time: start.toISOString(),\n        end_time: end.toISOString(),\n        distance_km: parseFloat(form.distance),\n        notes: form.note,\n      });\n\n      if (res.success) {\n        toast.success('Đã lưu thành công buổi DAT!');\n        onSuccess();\n        onClose();\n      } else {\n        toast.error(res.message || 'Lỗi khi lưu dữ liệu DAT.');\n      }\n    } catch (error) {\n      toast.error('Lỗi khi kết nối đến máy chủ.');\n    } finally {\n      setLoading(false);\n    }\n  };\n\n  return (\n    <div className=\"fixed inset-0 z-[100] flex items-center justify-center p-4 bg-gray-900/40 backdrop-blur-sm animate-in fade-in duration-300\">\n      <div className=\"bg-white/95 backdrop-blur-xl rounded-[2rem] w-full max-w-md shadow-2xl overflow-hidden animate-in zoom-in-95 duration-300 border border-white/20\">\n        <div className=\"px-8 py-6 border-b border-gray-100 flex items-center justify-between bg-gray-50/50\">\n          <div>\n            <h2 className=\"text-xl font-black text-gray-900 tracking-tight\">THÊM BUỔI DAT</h2>\n            <p className=\"text-[10px] font-bold text-gray-400 uppercase tracking-widest mt-0.5\">\n              Ghi nhận tiến độ đào tạo DAT\n            </p>\n          </div>\n          <button\n            onClick={onClose}\n            className=\"p-2 text-gray-400 hover:text-rose-500 hover:bg-rose-50 rounded-full transition-colors\"\n          >\n            <X className=\"w-5 h-5\" />\n          </button>\n        </div>\n\n        <div className=\"p-8\">\n          <form id=\"student-detail-dat-form\" onSubmit={handleSubmit} className=\"flex flex-col gap-6\" noValidate>\n            <FieldWrapper label=\"NGÀY HỌC\" required field=\"date\" touched={touched} errors={errors} icon={Calendar}>\n              <ViDateInput\n                className={getInputClass('date')}\n                value={form.date}\n                onChange={(val) => handleChange('date', val)}\n              />\n            </FieldWrapper>\n\n            <div className=\"grid grid-cols-2 gap-4\">\n              <FieldWrapper label=\"GIỜ BẮT ĐẦU\" field=\"timeStart\" touched={touched} errors={errors} icon={Clock}>\n                <input\n                  type=\"time\"\n                  className={getInputClass('timeStart')}\n                  value={form.timeStart}\n                  onChange={(e) => handleChange('timeStart', e.target.value)}\n                  onBlur={() => handleBlur('timeStart')}\n\n[103 more lines in file. Use offset=261 to continue.]"}],"isError":false,"timestamp":1776956975670}}
