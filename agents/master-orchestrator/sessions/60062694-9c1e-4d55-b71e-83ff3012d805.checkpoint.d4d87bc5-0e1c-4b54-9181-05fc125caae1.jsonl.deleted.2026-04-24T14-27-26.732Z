00 font-bold uppercase tracking-tighter\">\n                  <Info className=\"w-3.5 h-3.5\" />\n                  Vui lòng kiểm tra kỹ thông tin trước khi lưu.\n                </div>\n                <button\n                  type=\"submit\"\n                  form={activeTab === 'hoso' ? 'hoso-form' : undefined}\n                  className=\"flex items-center gap-2 px-6 py-2.5 bg-indigo-600 text-white rounded-xl text-sm font-extrabold shadow-lg shadow-indigo-600/20 hover:bg-indigo-700 transition-all active:scale-95\"\n                >\n                  <Save className=\"w-4 h-4\" />\n                  Lưu hồ sơ\n                </button>\n              </div>\n            )}\n          </div>\n\n          <DatSessionModal\n            isOpen={isDatModalOpen}\n            onClose={() => setIsDatModalOpen(false)}\n            enrollmentId={fullData?.enrollment?._id}\n            onSuccess={handleDatSuccess}\n          />\n\n          {/* Hospital Selection Modal */}\n          {hospitalModalOpen && (\n            <div\n              className=\"fixed inset-0 z-[200] flex items-center justify-center bg-black/40 backdrop-blur-sm\"\n              onClick={() => setHospitalModalOpen(false)}\n            >\n              <div\n                className=\"bg-white rounded-2xl shadow-2xl w-full max-w-md mx-4 overflow-hidden\"\n                onClick={(e) => e.stopPropagation()}\n              >\n                <div className=\"flex items-center justify-between px-5 py-4 border-b border-gray-100 bg-gray-50\">\n                  <h3 className=\"text-base font-extrabold text-gray-900\">Chọn bệnh viện</h3>\n                  <button\n                    onClick={() => setHospitalModalOpen(false)}\n                    className=\"p-1.5 hover:bg-gray-200 rounded-lg transition-colors\"\n                  >\n                    <X className=\"w-4 h-4 text-gray-500\" />\n                  </button>\n                </div>\n                <div className=\"p-4 max-h-80 overflow-y-auto\">\n                  <input\n                    autoFocus\n                    type=\"text\"\n                    value={hospitalDraft}\n                    onChange={(e) => setHospitalDraft(e.target.value)}\n                    placeholder=\"Tìm hoặc nhập bệnh viện mới...\"\n                    className=\"w-full px-3 py-2.5 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-400 text-sm mb-3\"\n                  />\n                  <div className=\"space-y-1\">\n                    {(settings?.clinic_list || [])\n                      .filter((c: any) => c.name.toLowerCase().includes(hospitalDraft.toLowerCase()))\n                      .map((clinic: any, idx: number) => (\n                        <button\n                          key={idx}\n                          onClick={() => {\n                            setHealthCheckState((prev) => ({\n                              ...prev,\n                              hospital: clinic.name,\n\n[391 more lines in file. Use offset=2070 to continue.]"}],"isError":false,"timestamp":1776941198441}}
