{"type":"message","id":"1f8660de","parentId":"26db07e9","timestamp":"2026-04-23T16:15:17.607Z","message":{"role":"toolResult","toolCallId":"call_function_74xsd59wu8aw_2","toolName":"read","content":[{"type":"text","text":"  const validateProfile = (data: any) => {\n    const errs: Record<string, string> = {};\n    const requiredConfig = settings?.requiredFields || [];\n\n    requiredConfig.forEach((f) => {\n      const keyMap: Record<string, string> = { cccd: 'identity_number' };\n      const payloadKey = keyMap[f] || f;\n\n      if (f === 'address') {\n        if (!data.city && !data.region_id) errs.city = 'Vui lòng chọn khu vực tuyển sinh (Tỉnh/Thành phố).';\n        if (!data.address?.trim()) errs.address = 'Vui lòng nhập địa chỉ chi tiết.';\n      } else if (f === 'region' || f === 'city') {\n        if (!data.city && !data.region_id) errs[f] = 'Vui lòng chọn khu vực tuyển sinh (Tỉnh/Thành phố).';\n      } else {\n        if (!data[payloadKey] || (typeof data[payloadKey] === 'string' && !data[payloadKey].trim())) {\n          const labels: Record<string, string> = {\n            name: 'Họ và tên',\n            dob: 'Ngày sinh',\n            phone: 'Số điện thoại',\n            cccd: 'Số CCCD',\n            rank: 'Hạng bằng',\n            course: 'Khóa học',\n            region: 'Khu vực tuyển sinh',\n            city: 'Tỉnh/Thành phố',\n            address: 'Địa chỉ chi tiết'\n          };\n          const action = (f === 'rank' || f === 'course' || f === 'region' || f === 'city') ? 'chọn' : 'nhập';\n          errs[f] = `Vui lòng ${action} ${labels[f] || f}.`;\n        }\n      }\n    });\n\n    if (data.lead_id) {\n      // Optional: add validation if needed\n    }\n\n    // Format validation\n    if (data.phone && !/^\\d{10}$/.test(data.phone.trim())) {\n      errs.phone = 'Số điện thoại phải có đúng 10 chữ số.';\n    }\n    if (data.identity_number && !/^\\d{12}$/.test(data.identity_number.trim())) {\n      errs.cccd = 'Số CCCD phải có đúng 12 chữ số.';\n    }\n\n    return errs;\n  };\n\n  const { user } = useAuth();\n\n  // Fetch settings if not loaded (for clinic_list)\n\n[2021 more lines in file. Use offset=455 to continue.]"}],"isError":false,"timestamp":1776960917600}}
