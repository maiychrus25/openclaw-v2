                   updated.rank = course.license_category_id;\n                       }\n-                      // Resolve tuition\n+\n                       if (!isFeeManuallySet) {\n                         updated.tuition = resolveTuition(updated.rank, course, false);\n                       }\n-                      return updated;\n-                    });\n-                  }\n+                    } else {\n+                      if (!isFeeManuallySet) {\n+                        updated.tuition = resolveTuition(updated.rank, null, false);\n+                      }\n+                    }\n+\n+                    return updated;\n+                  });\n                 }}\n                 filters={{ license_category_id: form.rank }}\n               />"}],"details":{"status":"completed","exitCode":0,"durationMs":25,"aggregated":"diff --git a/src/components/students/AddStudentModal.tsx b/src/components/students/AddStudentModal.tsx\nindex bc72f78..836c32f 100644\n--- a/src/components/students/AddStudentModal.tsx\n+++ b/src/components/students/AddStudentModal.tsx\n@@ -216,12 +216,14 @@ const AddStudentModal: React.FC<AddStudentModalProps> = ({ isOpen, onClose }) =>\n       setIsFeeManuallySet(formatted.trim() !== '' && formatted.trim() !== '0');\n     }\n \n-    // Auto-fill tuition logic for Rank change\n-    if (field === 'rank' && !isFeeManuallySet) {\n-      // When rank changes, we might need a specific course lookup if one is already selected\n-      // but usually rank change happens first. If a course is selected, it should have been\n-      // filtered by rank anyway.\n-      updated.tuition = resolveTuition(value, null, false);\n+    if (field === 'rank') {\n+      if (form.course) {\n+        updated.course = '';\n+      }\n+\n+      if (!isFeeManuallySet) {\n+        updated.tuition = resolveTuition(value, null, false);\n+      }\n     }\n \n     setForm(updated);\n@@ -554,20 +556,25 @@ const AddStudentModal: React.FC<AddStudentModalProps> = ({ isOpen, onClose }) =>\n                 value={form.course}\n                 onChange={(val) => handleChange('course', val)}\n                 onCourseSelect={(course) => {\n-                  if (course) {\n-                    setForm((prev) => {\n-                      const updated = { ...prev };\n-                      // Auto-map rank if currently empty\n-                      if (!prev.rank && course.license_category_id) {\n+                  setForm((prev) => {\n+                    const updated = { ...prev };\n+\n+                    if (course) {\n+                      if (course.license_category_id) {\n                         updated.rank = course.license_category_id;\n                       }\n-                      // Resolve tuition\n+\n                       if (!isFeeManuallySet) {\n                         updated.tuition = resolveTuition(updated.rank, course, false);\n                       }\n-                      return updated;\n-                    });\n-                  }\n+                    } else {\n+                      if (!isFeeManuallySet) {\n+                        updated.tuition = resolveTuition(updated.rank, null, false);\n+                      }\n+                    }\n+\n+                    return updated;\n+                  });\n                 }}\n                 filters={{ license_category_id: form.rank }}\n               />","cwd":"/root/.openclaw/workspaces2/projects/ahv-qlhv-fe"},"isError":false,"timestamp":1776941503203}}
