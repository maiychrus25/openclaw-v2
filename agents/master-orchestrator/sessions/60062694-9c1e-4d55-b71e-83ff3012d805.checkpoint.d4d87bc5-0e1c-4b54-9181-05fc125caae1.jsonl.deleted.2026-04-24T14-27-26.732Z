{"type":"message","id":"935dd814","parentId":"3333f8ff","timestamp":"2026-04-23T16:41:28.861Z","message":{"role":"toolResult","toolCallId":"call_function_9ku39rdxb77z_1","toolName":"read","content":[{"type":"text","text":"    baseFilters.is_deleted = false;\n\n    try {\n      const results = await StudentModel.aggregate([\n        { $match: baseFilters }, // Root match uses relaxed filters + is_deleted:false + RBAC\n\n        // Lookup user role to filter out teacher accounts stored as students\n        {\n          $lookup: {\n            from: 'users',\n            localField: 'user_id',\n            foreignField: '_id',\n            as: '_user',\n          },\n        },\n        { $unwind: { path: '$_user', preserveNullAndEmptyArrays: false } },\n        // Exclude records whose underlying user is a teacher\n        { $match: { '_user.role': { $ne: 'teacher' } } },\n\n        // Hoist multi-enrollment data for root filtering and listing\n        {\n          $lookup: {\n            from: 'coursestudents',\n            let: { studentId: '$_id' },\n            pipeline: [{ $match: { $expr: { $eq: ['$student_id', '$$studentId'] } } }, { $sort: { created_at: 1 } }],\n            as: 'enrollments',\n          },\n        },\n        { $addFields: { latest_enrollment: { $arrayElemAt: ['$enrollments', -1] } } }, // Fetch latest\n        {\n          $addFields: {\n            status_detail: {\n              $ifNull: ['$latest_enrollment.status_detail', { $ifNull: ['$status_detail', 'Chờ KSK'] }],\n            },\n            progress_flags: {\n              $ifNull: [\n                '$latest_enrollment.progress_flags',\n                {\n                  theory_completed: false,\n                  sand_yard_completed: false,\n                  simulation_completed: false,\n                  dat_completed: false,\n                  cabin_completed: false,\n                  graduation_eligible: false,\n                },\n              ],\n            },\n         