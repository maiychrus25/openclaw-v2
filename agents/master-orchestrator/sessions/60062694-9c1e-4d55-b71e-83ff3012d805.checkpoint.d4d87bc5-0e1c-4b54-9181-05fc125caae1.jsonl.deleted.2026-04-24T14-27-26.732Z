(courseIds, status, user.id || user._id);\n  log.success(res, result, `Đã cập nhật ${result.updated} khóa học`);\n});\n"}]}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":222,"output":555,"cacheRead":96908,"cacheWrite":457,"totalTokens":98142,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776963120757,"responseId":"063981322499c126755f39ca2825eb36"}}
