{"type":"message","id":"aff42d7d","parentId":"0a7e6d52","timestamp":"2026-04-23T16:22:21.570Z","message":{"role":"toolResult","toolCallId":"call_function_uied9i56zq1y_1","toolName":"read","content":[{"type":"text","text":"      // If graduation_eligible is true, and status is still a training status, advance it to 'Đang thi'\n      if (\n        courseUpdate.progress_flags.graduation_eligible &&\n        ['Đang học', 'Đang học LT', 'Đang học TH', 'Đã KSK', 'Nộp HS'].includes(latestEnrollment.status_detail)\n      ) {\n        courseUpdate.status_detail = 'Đang thi';\n      }\n    }\n  }\n\n  private async validateRequiredFields(data: any, userId: string) {\n    const settings = await this.settingsRepository.findByUserId(userId);\n    if (!settings || !settings.requiredFields || settings.requiredFields.length === 0) return;\n\n    const MAPPING: Record<string, { field: string; label: string }> = {\n      name: { field: 'name', label: 'Họ và tên' }, // Custom handling for name\n      phone: { field: 'phone', label: 'Số điện thoại' },\n      intro: { field: 'lead_manager', label: 'Người giới thiệu' },\n      dob: { field: 'dob', label: 'Ngày sinh' },\n      cccd: { field: 'identity_card', label: 'CCCD / CMND' },\n      address: { field: 'address', label: 'Địa chỉ chi tiết' },\n      rank: { field: 'license_category_id', label: 'Hạng bằng' },\n      region: { field: 'region_id', label: 'Tỉnh / Thành phố' },\n      course: { field: 'course_id', label: 'Khóa học' },\n      regDate: { field: 'contract_date', label: 'Ngày đăng ký' },\n    };\n\n    for (const fieldId of settings.requiredFields) {\n      const mapping = MAPPING[fieldId];\n      if (!mapping) continue;\n\n      if (fieldId === 'name') {\n        if (!data.first_name || !data.last_name) {\n          throw new AppError(`Trường [${mapping.label}] là bắt buộc`, 400);\n        }\n      } else {\n        const value = data[mapping.field];\n        if (value === undefined || value === null || value === '') {\n          throw new AppError(`Trường [${mapping.label}] là bắt buộc`, 400);\n        }\n      }\n    }\n  }\n\n  async createStudent(data: any, currentUser?: any) {\n    const {\n      phone,\n      identity_card,\n      user_id,\n      region_id,\n      course_id,\n      fee,\n      status_detail,\n      license_category_id,\n      amount,\n      installment,\n      lead_manager,\n      student_code,\n      teacher_id,\n      contract_date,\n      existing_license_num,\n      existing_license_rank,\n    } = data;\n\n    // Dynamic settings validation\n    if (currentUser?.id) {\n      await this.validateRequiredFields(data, currentUser.id);\n    }\n\n    logger.info(`[StudentService.createStudent] Payload check:`, {\n      teacher_id,\n      phone,\n      identity_card,\n      existing_license_num,\n      existing_license_rank\n    });\n\n    let targetUserId = user_id;\n\n    // Sanitize status_detail\n\n[457 more lines in file. Use offset=400 to continue.]"}],"isError":false,"timestamp":1776961341563}}
