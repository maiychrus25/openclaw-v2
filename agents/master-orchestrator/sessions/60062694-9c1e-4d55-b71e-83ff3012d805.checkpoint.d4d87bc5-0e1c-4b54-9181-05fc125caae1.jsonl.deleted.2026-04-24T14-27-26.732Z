{"type":"message","id":"8c48a2fc","parentId":"b4b1c8a1","timestamp":"2026-04-23T18:04:39.625Z","message":{"role":"toolResult","toolCallId":"call_function_0tacouujrke6_1","toolName":"read","content":[{"type":"text","text":"                <div className=\"flex items-center gap-1.5 bg-indigo-600 text-white px-3 py-1.5 rounded-xl text-xs font-black\">\n                  <CalendarCheck className=\"w-4 h-4\" />\n                  <span>{milestones.openingCount} khóa khai giảng hôm nay</span>\n                </div>\n              )}\n              {milestones.closingCount > 0 && (\n                <div className=\"flex items-center gap-1.5 bg-rose-600 text-white px-3 py-1.5 rounded-xl text-xs font-black\">\n                  <CalendarX className=\"w-4 h-4\" />\n                  <span>{milestones.closingCount} khóa kết thúc hôm nay</span>\n                </div>\n              )}\n              <button\n                onClick={() => setDismissed(true)}\n                className=\"ml-auto p-1.5 text-gray-400 hover:text-gray-600 hover:bg-gray-200 rounded-lg transition-colors\"\n              >\n                <X className=\"w-4 h-4\" />\n              </button>\n            </div>\n            <p className=\"text-xs text-gray-500 font-medium\">\n              Một số khóa học của bạn có cột mốc quan trọng trong ngày hôm nay.\n            </p>\n            <div className=\"flex items-center gap-2 pt-1\">\n              <button\n                onClick={handleAutoUpdate}\n                disabled={processing}\n                className=\"flex items-center gap-1.5 px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-xl text-xs font-bold transition-all active:scale-95 disabled:opacity-60 shadow-sm\"\n              >\n                {processing ? <Loader2 className=\"w-3.5 h-3.5 animate-spin\" /> : <Zap className=\"w-3.5 h-3.5\" />}\n                Tự động cập nhật\n              </button>\n              <button\n                onClick={handleManualUpdate}\n                disabled={processing}\n                className=\"flex items-center gap-1.5 px-4 py-2 bg-white hover:bg-gray-50 text-gray-700 border border-gray-200 rounded-xl text-xs font-bold transition-all active:scale-95 disabled:opacity-60\"\n              >\n                <Eye className=\"w-3.5 h-3.5\" />\n                Cập nhật bằng tay\n              </button>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      {/* Manual Review Modal */}\n      {showReviewModal && milestones && (\n        <div className=\"fixed inset-0 z-[100] flex items-center justify-center p-4 bg-gray-900/50 backdrop-blur-sm animate-in fade-in duration-300\">\n          <div className=\"bg-white rounded-3xl w-full max-w-lg shadow-2xl overflow-hidden animate-in zoom-in-95 duration-300\">\n            <div className=\"px-6 py-5 border-b border-gray-100 flex items-center justify-between bg-gray-50/50\">\n              <div>\n                <h3 className=\"text-lg font-black text-gray-900\">Cập nhật trạng thái khóa học</h3>\n                <p className=\"text-[10px] text-gray-400 font-bold uppercase tracking-widest mt-0.5\">\n                  Chọn các khóa học bạn muốn cập nhật\n                </p>\n              </div>\n              <button\n                onClick={() => setShowReviewModal(false)}\n                className=\"p-2 text-gray-400 hover:text-rose-500 hover:bg-rose-50 rounded-full transition-colors\"\n              >\n                <X className=\"w-5 h-5\" />\n              </button>\n            </div>\n\n            {/* Tabs */}\n            <div className=\"flex border-b border-gray-100\">\n              {milestones.openingCount > 0 && (\n                <button\n                  onClick={() => { setReviewTab('opening'); setSelectedCourses(new Set()); }}\n                  className={`flex-1 px-4 py-3 text-xs font-bold uppercase tracking-widest transition-colors ${\n                    reviewTab === 'opening'\n                      ? 'text-indigo-600 border-b-2 border-indigo-600 bg-indigo-50/50'\n                      : 'text-gray-400 hover:text-gray-600'\n                  }`}\n                >\n                  Khai giảng ({milestones.openingCount})\n                </button>\n              )}\n              {milestones.closingCount > 0 && (\n                <button\n                  onClick={() => { setReviewTab('closing'); setSelectedCourses(new Set()); }}\n                  className={`flex-1 px-4 py-3 text-xs font-bold uppercase tracking-widest transition-colors ${\n\n[73 more lines in file. Use offset=245 to continue.]"}],"isError":false,"timestamp":1776967479619}}
