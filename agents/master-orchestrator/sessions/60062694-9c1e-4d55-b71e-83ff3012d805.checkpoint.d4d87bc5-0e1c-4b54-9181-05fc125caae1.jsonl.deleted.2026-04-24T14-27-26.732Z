{"type":"message","id":"51ffa916","parentId":"1dff3d93","timestamp":"2026-04-23T17:55:28.181Z","message":{"role":"toolResult","toolCallId":"call_function_m7pl4rx6zsrm_1","toolName":"read","content":[{"type":"text","text":"    return await this.courseRepository.delete(id);\n  }\n\n  async assignStudentsToCourse(courseId: string, studentIds: string[]) {\n    if (!studentIds || studentIds.length === 0) {\n      throw new Error('Vui lòng chọn học viên');\n    }\n    const records = studentIds.map((sid) => ({\n      student_id: sid,\n      course_id: courseId,\n      status: 'unfinished',\n    }));\n    return await CourseStudentModel.insertMany(records);\n  }\n\n  async getUnassignedStudents(filters = {}, options: PaginationOptions = { page: 1, limit: 100 }, currentUser?: any) {\n    return await this.studentRepository.findUnassigned(filters, options, currentUser);\n  }\n\n  async exportCoursesToExcel(res: Response, filters: any, currentUser?: any): Promise<void> {\n    const { data } = await this.courseRepository.findAll(filters, { page: 1, limit: 1000 }, currentUser);\n\n    const { workbook, worksheet } = this.excelHelper.createWorkbook('Danh sách khóa học');\n\n    this.excelHelper.applyHeaderStyle(worksheet, [\n      { header: 'Mã khóa học', key: 'code', width: 15 },\n      { header: 'Tên khóa học', key: 'name', width: 30 },\n      { header: 'Hạng GPLX', key: 'license', width: 12 },\n      { header: 'Hệ đào tạo', key: 'system', width: 20 },\n      { header: 'Ngày khai giảng', key: 'start_date', width: 18 },\n      { header: 'Ngày bế giảng', key: 'end_date', width: 18 },\n      { header: 'Trạng thái', key: 'status', width: 15 },\n    ]);\n\n    data.forEach((c: any) => {\n      worksheet.addRow({\n        code: c.code || '',\n        name: c.name || '',\n        license: c.license_category_name || c.license_category_code || '',\n        system: c.course_type || COURSE_TYPES.DIRECT,\n        start_date: c.start_date ? new Date(c.start_date).toLocaleDateString('vi-VN') : '',\n        end_date: c.end_date ? new Date(c.end_date).toLocaleDateString('vi-VN') : '',\n        status: COURSE_STATUS_DISPLAY[c.status as keyof typeof COURSE_STATUS_DISPLAY] || c.status,\n      });\n    });\n\n    this.excelHelper.applyRowStyle(worksheet);\n    await this.excelHelper.sendWorkbook(res, workbook, 'danh_sach_khoa_hoc');\n  }\n\n  async getCourseImportTemplate(res: Response) {\n    return await this.excelHelper.getCourseImportTemplate(res);\n  }\n\n  async getCourseStats(currentUser?: any) {\n    return await this.courseRepository.getStats(currentUser);\n  }\n\n  async importCoursesFromExcel(filePath: string, userId: string, userRole: string = 'user') {\n    const runImport = async () => {\n\n[204 more lines in file. Use offset=140 to continue.]"}],"isError":false,"timestamp":1776966928172}}
