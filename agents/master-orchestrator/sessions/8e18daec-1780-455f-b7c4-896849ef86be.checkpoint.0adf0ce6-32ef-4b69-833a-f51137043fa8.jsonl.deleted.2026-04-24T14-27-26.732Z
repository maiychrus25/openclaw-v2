{"type":"message","id":"51bc2796","parentId":"00f654a4","timestamp":"2026-04-14T10:08:07.489Z","message":{"role":"toolResult","toolCallId":"call_function_76l6hgqdhgdx_1","toolName":"exec","content":[{"type":"text","text":"import { Joi } from 'express-validation';\nimport { IVehicleApply } from '../lessonTypes/lessonTypes.interface';\n\nconst isString = Joi.string().optional();\nconst stringRequire = Joi.string().required();\nconst isNumber = Joi.number().optional();\nconst numberRequire = Joi.number().required();\nconst objectIdPattern = /^[0-9a-fA-F]{24}$/;\nconst isObjectID = stringRequire.pattern(objectIdPattern);\nconst isObjectIDOptional = Joi.string().pattern(objectIdPattern).optional();\n\nconst createRankingBody = Joi.object({\n    name: stringRequire.messages({\n        'any.required': 'Tên hạng bằng không được để trống',\n        'string.empty': 'Tên hạng bằng không được để trống',\n    }),\n\n    fee: numberRequire.precision(2).min(0).messages({\n        'any.required': 'Học phí là bắt buộc',\n        'number.base': 'Học phí phải là một số',\n        'number.min': 'Học phí không được nhỏ hơn 0',\n    }),\n\n    vehicle_type: Joi.string()\n        .valid(...Object.values(IVehicleApply))\n        .default(IVehicleApply.All)\n        .messages({\n            'any.only': 'Loại xe không hợp lệ',\n        }),\n\n    lessons: Joi.array().items(isObjectID).min(0).messages({\n        'array.base': 'Danh sách bài học phải là một mảng',\n    }),\n\n    min_automatic_car_hour: isString.messages({\n        'string.base': 'Định mức giờ xe tự động phải là chuỗi (vd: 00:00)',\n    }),\n\n    min_night_hour: isString.messages({\n        'string.base': 'Định mức giờ ban đêm phải là chuỗi (vd: 00:00)',\n    }),\n\n    min_hour: isString.messages({\n        'string.base': 'Tổng định mức giờ phải là chuỗi (vd: 00:00)',\n    }),\n\n    min_km: isNumber.precision(3).min(0).optional().messages({\n        'number.min': 'Định mức Km không được nhỏ hơn 0',\n    }),\n\n    descripti