{"type":"message","id":"5fd92db6","parentId":"56332ff3","timestamp":"2026-04-14T10:09:28.070Z","message":{"role":"toolResult","toolCallId":"call_function_lvxir8cikt7l_1","toolName":"exec","content":[{"type":"text","text":"import { WorkCalendarStatus, WorkCalendarType } from './workCalendars.interface';\n\nconst objectIdPattern = /^[0-9a-fA-F]{24}$/;\nconst msgObjectId = (field: string) => ({\n    'string.pattern.base': `${field} không đúng định dạng ID hệ thống`,\n    'any.required': `${field} là bắt buộc`,\n});\n\nconst objectId = Joi.string().pattern(objectIdPattern);\nconst objectIdRequired = objectId.required();\n\nconst baseBody = Joi.object({\n    name: Joi.string().trim().min(1).messages({\n        'string.empty': 'Tên lịch làm việc không được để trống',\n        'string.min': 'Tên lịch làm việc phải có ít nhất 1 ký tự',\n    }),\n    lead_id: objectId.allow(null, '').messages(msgObjectId('ID khách hàng tiềm năng')),\n    sale_id: objectId.allow(null, '').messages(msgObjectId('ID nhân viên Sale')),\n\n    type: Joi.string()\n        .valid(...Object.values(WorkCalendarType))\n        .required()\n        .messages({\n            'any.only': 'Loại lịch không hợp lệ',\n            'any.required': 'Loại lịch là trường bắt buộc',\n        }),\n\n    start_time: Joi.date().required().messages({\n        'date.base': 'Thời gian bắt đầu không đúng định dạng ngày tháng',\n        'any.required': 'Thời gian bắt đầu là bắt buộc',\n===\n21:export enum WorkCalendarType {\n27:export enum WorkCalendarStatus {\n59:export type IWorkCalendarUpdate = Partial<IWorkCalendarCreate>;"}],"details":{"status":"completed","exitCode":0,"durationMs":412,"aggregated":"import { WorkCalendarStatus, WorkCalendarType } from './workCalendars.interface';\n\nconst objectIdPattern = /^[0-9a-fA-F]{24}$/;\nconst msgObjectId = (field: string) => ({\n    'string.pattern.base': `${field} không đúng định dạng ID hệ thống`,\n    'any.required': `${field} là bắt buộc`,\n});\n\nconst objectId = Joi.string().pattern(objectIdPattern);\nconst objectIdRequired = objectId.required();\n\nconst baseBody = Joi.object({\n    name: Joi.string().trim().min(1).messages({\n        'string.empty': 'Tên lịch làm việc không được để trống',\n        'string.min': 'Tên lịch làm việc phải có ít nhất 1 ký tự',\n    }),\n    lead_id: objectId.allow(null, '').messages(msgObjectId('ID khách hàng tiềm năng')),\n    sale_id: objectId.allow(null, '').messages(msgObjectId('ID nhân viên Sale')),\n\n    type: Joi.string()\n        .valid(...Object.values(WorkCalendarType))\n        .required()\n        .messages({\n            'any.only': 'Loại lịch không hợp lệ',\n            'any.required': 'Loại lịch là trường bắt buộc',\n        }),\n\n    start_time: Joi.date().required().messages({\n        'date.base': 'Thời gian bắt đầu không đúng định dạng ngày tháng',\n        'any.required': 'Thời gian bắt đầu là bắt buộc',\n===\n21:export enum WorkCalendarType {\n27:export enum WorkCalendarStatus {\n59:export type IWorkCalendarUpdate = Partial<IWorkCalendarCreate>;","cwd":"/root/.openclaw/workspaces2/v4-ecosystem-review/master-orchestrator"},"isError":false,"timestamp":1776161367906}}
