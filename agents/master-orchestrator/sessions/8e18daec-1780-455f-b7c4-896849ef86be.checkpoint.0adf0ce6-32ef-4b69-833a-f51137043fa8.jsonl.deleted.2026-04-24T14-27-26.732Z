se {}\n    details = err.get(\"details\",\"\") if isinstance(err,dict) else \"\"\n    print(f\"{name}: {s} | {details or r.get('message','')}\")\nPYEOF","timeout":15}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":848,"output":495,"cacheRead":82961,"cacheWrite":1329,"totalTokens":85633,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776150022974,"responseId":"062d1909b07a3615deeae58eb706f3b9"}}
