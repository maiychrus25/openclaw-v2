validate(V.createComment), studentCommentsController.createComment, notifyCreateStudentComments);\n\nrouter\n    .route('/:id')\n    .get(validate(V.getById, { context: true }), studentCommentsController.getStudentComments)\n    .patch(validate(V.updateComment, { context: true }), studentCommentsController.updateComment)\n    .delete(validate(V.deleteComment, { context: true }), studentCommentsController.deleteComment);\n\nexport default router;\n===\nimport { Router } from 'express';\nimport { validate } from 'express-validation';\nimport * as teacherCommentsValidation from './teacherComments.validation';\nimport { teacherCommentsController } from './teacherComments.controller';\nimport { notifyCreateTeacherComments } from './notifies/notifyTeacherComments';\n\nconst router = Router();\n\nrouter.post(\n    '/',\n    validate(teacherCommentsValidation.createComment, { context: true }),\n    teacherCommentsController.createComment,\n    notifyCreateTeacherComments,\n);\n\nrouter.get(\n    '/',\n    validate(teacherCommentsValidation.listComments, { context: true }),\n    teacherCommentsController.getTeacherComments,\n);\n\nrouter.get(\n    '/:id',\n    validate(teacherCommentsValidation.getByIdOrDelete, { context: true }),\n    teacherCommentsController.getCommentDetail,\n);\n\nrouter.patch(\n    '/:id',\n    validate(teacherCommentsValidation.updateComment, { context: true }),\n    teacherCommentsController.updateComment,\n);\n\nrouter.delete(\n    '/:id',\n    validate(teacherCommentsValidation.getByIdOrDelete, { context: true }),\n    teacherCommentsController.deleteComment,\n);\n\nexport default router;"}],"details":{"status":"completed","exitCode":0,"durationMs":57,"aggregated":"import express from 'express';\nimport { validate } from 'express-validation';\nimport * as teacherInfosValidation from './teacherInfos.validation';\nimport { teacherInfosController } from './teacherInfos.controller';\n\nconst router = express.Router();\n\nrouter.post(\n    '/',\n    val