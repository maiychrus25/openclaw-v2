{"type":"message","id":"ea9833be","parentId":"6595c521","timestamp":"2026-04-14T06:57:23.435Z","message":{"role":"toolResult","toolCallId":"call_function_fvy2xshc41hn_1","toolName":"exec","content":[{"type":"text","text":"import { Joi } from 'express-validation';\n\nconst objectIdPattern = /^[0-9a-fA-F]{24}$/;\nconst objectId = Joi.string().pattern(objectIdPattern);\nconst objectIdRequired = objectId.required();\n\n// status là string trong schema Courses\nconst courseStatus = Joi.string().trim();\n\nconst courseCreateBody = Joi.object({\n    license_category_id: objectId.allow(null, '').optional(),\n\n    code: Joi.string().trim().required(),\n\n    system_course_id: Joi.number(),\n    system_course_code: Joi.string().trim(),\n    curriculum_id: Joi.number(),\n\n    management_record_number: Joi.string().trim(),\n    description: Joi.string().allow('').default(''),\n\n    report_start_date: Joi.date(),\n    start_date: Joi.date(),\n    end_date: Joi.date(),\n    dat_date: Joi.date().allow(null),\n    cabin_date: Joi.date().allow(null),\n\n    // 🚫 không cho phép client gửi\n    student_number: Joi.forbidden(),\n\n    decision_to_sign: Joi.string().trim(),\n\n    duration: Joi.number().integer().min(0), // server sẽ overwrite nếu có start/end\n    status: courseStatus,\n    course_fee: Joi.number().precision(2).min(0),\n    agent_id: Joi.string().allow('').optional(),\n}).unknown(false); // tùy chọn: chặn field lạ\n\nconst courseUpdateBody = Joi.object({\n    license_category_id: objectId.allow(null, '').optional(),\n\n    code: Joi.string().trim(),\n\n    system_course_id: Joi.number().integer().min(0),\n    system_course_code: Joi.string().trim(),\n    curriculum_id: Joi.number().integer().min(0),\n\n    management_record_number: Joi.string().trim(),\n    description: Joi.string().allow(''),\n\n    report_start_date: Joi.date(),\n    start_date: Joi.date(),\n    end_date: Joi.date(),\n    dat_date: Joi.date(),\n    cabin_date: Joi.date(),\n\n    // 🚫 không cho phé