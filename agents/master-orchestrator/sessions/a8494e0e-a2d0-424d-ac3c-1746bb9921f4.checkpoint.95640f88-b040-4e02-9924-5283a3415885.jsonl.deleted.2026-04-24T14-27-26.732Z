{"type":"message","id":"5239d5b0","parentId":"43f9c3ee","timestamp":"2026-04-20T00:55:05.666Z","message":{"role":"toolResult","toolCallId":"call_function_jyxedynin83r_1","toolName":"exec","content":[{"type":"text","text":"import React from \"react\";\nimport { Card, Row, Col } from \"antd\";\nimport GaugeChart from \"../RevenueChart/GaugeChart\";\nimport { useSelector } from \"react-redux\";\nimport { formatNumber } from \"../../../../utils/formatVND\";\n\nconst ListCard = () => {\n  const { total } = useSelector((state) => state.dashboards);\n  const cardContentStyle = {\n    display: \"flex\",\n    alignItems: \"center\",\n    justifyContent: \"center\",\n    minHeight: \"80px\",\n    fontSize: 20,\n    fontWeight: \"bold\",\n    textAlign: \"center\",\n  };\n\n  return (\n    <Row gutter={[16, 16]} align=\"stretch\">\n      <Col xs={24} sm={12} md={8} lg={6} xl={4}>\n        <Card\n          title={<b>Doanh thu</b>}\n          style={{ height: \"100%\", textAlign: \"center\" }}\n        >\n          <div style={cardContentStyle}>\n            {\" \"}\n            {formatNumber(total?.totalRevenue)} VND\n          </div>\n        </Card>\n      </Col>\n\n      <Col xs={24} sm={12} md={8} lg={6} xl={4}>\n        <Card\n          title={<b>Chi phí</b>}\n          style={{ height: \"100%\", textAlign: \"center\" }}\n        >\n          <div style={cardContentStyle}>\n            {formatNumber(total?.totalExpense)} VND\n          </div>\n        </Card>\n      </Col>\n\n      <Col xs={24} sm={12} md={8} lg={6} xl={4}>\n        <Card\n          title={<b>Lợi nhuận</b>}\n          style={{ height: \"100%\", textAlign: \"center\" }}\n        >\n          <div style={cardContentStyle}>\n            {formatNumber(total?.totalProfits)} VND\n          </div>\n        </Card>\n      </Col>\n\n      <Col xs={24} sm={12} md={8} lg={6} xl={4}>\n        <Card\n          title={<b>Công nợ</b>}\n          style={{ height: \"100%\", textAlign: \"center\" }}\n        >\n          <div style={cardContentStyle}>{formatNumber(total?.totalAr)} VND</div>"}],"details":{"status":"completed","exitCode":0,"durationMs":76,"aggregated":"import React from \"react\";\nimport { Card, Row, Col } from \"antd\";\nimport GaugeChart from \"../RevenueChart/GaugeChart\";\nimport { useSelector } from \"react-redux\";\nimport { formatNumber } from \"../../../../utils/formatVND\";\n\nconst ListCard = () => {\n  const { total } = useSelector((state) => state.dashboards);\n  const cardContentStyle = {\n    display: \"flex\",\n    alignItems: \"center\",\n    justifyContent: \"center\",\n    minHeight: \"80px\",\n    fontSize: 20,\n    fontWeight: \"bold\",\n    textAlign: \"center\",\n  };\n\n  return (\n    <Row gutter={[16, 16]} align=\"stretch\">\n      <Col xs={24} sm={12} md={8} lg={6} xl={4}>\n        <Card\n          title={<b>Doanh thu</b>}\n          style={{ height: \"100%\", textAlign: \"center\" }}\n        >\n          <div style={cardContentStyle}>\n            {\" \"}\n            {formatNumber(total?.totalRevenue)} VND\n          </div>\n        </Card>\n      </Col>\n\n      <Col xs={24} sm={12} md={8} lg={6} xl={4}>\n        <Card\n          title={<b>Chi phí</b>}\n          style={{ height: \"100%\", textAlign: \"center\" }}\n        >\n          <div style={cardContentStyle}>\n            {formatNumber(total?.totalExpense)} VND\n          </div>\n        </Card>\n      </Col>\n\n      <Col xs={24} sm={12} md={8} lg={6} xl={4}>\n        <Card\n          title={<b>Lợi nhuận</b>}\n          style={{ height: \"100%\", textAlign: \"center\" }}\n        >\n          <div style={cardContentStyle}>\n            {formatNumber(total?.totalProfits)} VND\n          </div>\n        </Card>\n      </Col>\n\n      <Col xs={24} sm={12} md={8} lg={6} xl={4}>\n        <Card\n          title={<b>Công nợ</b>}\n          style={{ height: \"100%\", textAlign: \"center\" }}\n        >\n          <div style={cardContentStyle}>{formatNumber(total?.totalAr)} VND</div>","cwd"