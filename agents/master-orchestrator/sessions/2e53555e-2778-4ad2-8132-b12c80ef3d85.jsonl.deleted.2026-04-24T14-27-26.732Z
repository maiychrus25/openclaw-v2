active non-cron sessions. Night silence doesn't apply yet. Pipeline healthy."},{"type":"text","text":"HEARTBEAT_OK"}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":1784,"output":30,"totalTokens":58513,"cacheRead":0,"cacheWrite":56699,"cost":{"total":0}},"stopReason":"stop","timestamp":1776165332908,"responseId":"062d54d6ffe475ecdb9227ad3daa3f6c","__openclaw":{"id":"086e2ad1","seq":103}}]},{"key":"agent:master-orchestrator:cron:ac986a8d-2425-40c7-835b-ed9b101b0bff","kind":"other","channel":"unknown","label":"Cron: Send this exact message to Telegram group -5163901258:","displayName":"Cron: Send this exact message to Telegram group -5163901258:","updatedAt":1776156272410,"sessionId":"d6d5ae17-2a68-46a3-beb9-a2a98cf2f1b5","model":"AHV-Holding-DEV","contextTokens":200000,"totalTokens":15116,"estimatedCostUsd":0,"status":"running","startedAt":1776156271891,"systemSent":true,"abortedLastRun":false,"transcriptPath":"/root/.openclaw/agents/master-orchestrator/sessions/d6d5ae17-2a68-46a3-beb9-a2a98cf2f1b5.jsonl","messages":[{"role":"assistant","content":[{"type":"thinking","thinking":"The OpenClaw CLI commands seem to be aborted. Let me try with sessions_send directly to the Telegram session."},{"type":"toolCall","id":"call_function_6p6s89cpkzn1_1","name":"sessions_list","arguments":{"limit":20,"activeMinutes":60,"messageLimit":1}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":123,"output":72,"totalTokens":15188,"cacheRead":14852,"cacheWrite":141,"cost":{"total":0}},"stopReason":"toolUse","timestamp":1776156293444,"responseId":"062d31864644cf5396b77d7a2f24dc21","__openclaw":{"id":"7f3db44c","seq":12}}]},{"key":"agent:master-orchestrator:subagent:8bffa95f-1686-4571-a0ed-e69d265eb964","kind":"other","channel":"webchat","spawnedBy":"agent:master-orchestrator:telegram:direct:6053576134","label":"DTLX Full API Test v2","displayName":"webchat:g-agent-master-orchestrator-subagent-8bffa9