{"type":"message","id":"7a7ac9b7","parentId":"5945f2ec","timestamp":"2026-04-21T16:16:28.215Z","message":{"role":"toolResult","toolCallId":"call_function_wa5iie6fdp35_1","toolName":"exec","content":[{"type":"text","text":"Filesystem      Size  Used Avail Use% Mounted on\n/dev/vda1        34G   33G  1.2G  97% /\n55M\t/tmp/node-compile-cache\n11M\t/tmp/v8-compile-cache-0\n4.0M\t/tmp/openclaw\n2.2M\t/tmp/jiti\n112K\t/tmp/tsx-0\n72K\t/tmp/api_profits.json\n56K\t/tmp/api_expenses.json\n40K\t/tmp/maiy-dev.log\n36K\t/tmp/openclaw-vps5.json\n36K\t/tmp/openclaw-vps2-clean.json"}],"details":{"status":"completed","exitCode":0,"durationMs":306,"aggregated":"Filesystem      Size  Used Avail Use% Mounted on\n/dev/vda1        34G   33G  1.2G  97% /\n55M\t/tmp/node-compile-cache\n11M\t/tmp/v8-compile-cache-0\n4.0M\t/tmp/openclaw\n2.2M\t/tmp/jiti\n112K\t/tmp/tsx-0\n72K\t/tmp/api_profits.json\n56K\t/tmp/api_expenses.json\n40K\t/tmp/maiy-dev.log\n36K\t/tmp/openclaw-vps5.json\n36K\t/tmp/openclaw-vps2-clean.json","cwd":"/root/.openclaw/workspaces2/v4-ecosystem-review/master-orchestrator"},"isError":false,"timestamp":1776788188194}}
{"type":"message","id":"700f7fbc","parentId":"7a7ac9b7","timestamp":"2026-04-21T16:17:16.825Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Only 1.2GB free. The CUDA packages are very large. Let me try a different approach - use OpenCV's DNN module with a pre-downloaded ONNX YOLO model. This is much lighter than ultralytics + CUDA.Alternatively, I could:1. Use a pre-converted YOLO ONNX model\n2. Use a much lighter alternative like MediaPipe\n\nLet me update the detector to use ONNX + OpenCV DNN instead of ultralytics. This is much lighter (~50MB vs ~3GB).","thinkingSignature":"1077762c9ea1fda6495d9befe5dbb425c9ae0c512433e1aac413a538a5caad4e"},{"type":"text","text":"Disk 97% — ultralytics CUDA quá nặng. Chuyển sang **ONNX + OpenCV DNN** (nhẹ hơn 50x):\n"},{"type":"toolCall","id":"call_function_sk3mm6fo8uya_1","name":"write","arguments":{"path":"/root/.openclaw/workspaces2/projects/s1-ppe-safety/backend/detector.py","content":"\"\"\"\nYOLOv8 PPE Detection Engine — ONNX + OpenCV DNN (CPU-only, ~50MB)\nDetects: person, helmet, safety-vest using a lightweight ONNX model.\n\"\"\"\nimport cv2\nimport numpy as np\nimport urllib.request\nimport os\nfrom pathlib import Path\n\nCLASS_NAMES = {\n    0: \"person\",\n    1: \"helmet\",\n    2: \"safety-vest\",\n    3: \"no-helmet\",\n    4: \"no-vest\",\n}\n\n\nclass YOLOWrapper:\n    \"\"\"\n    Lightweight YOLO wrapper using OpenCV DNN with ONNX model.\n    Works on CPU without any GPU/CUDA dependencies.\n    \"\"\"\n\n    def __init__(self, model_path: str = \"yolov8n.onnx\", conf_thresh: float = 0.5, iou_thresh: float = 0.4):\n        self.conf_thresh = conf_thresh\n        self.iou_thresh = iou_thresh\n        self.net = cv2.dnn.readNetFromONNX(model_path)\n        # Use CPU backend\n        self.net.setPreferableBackend(cv2.dnn.DNN_BACKEND_OPENCV)\n        self.net.setPreferableTarget(cv2.dnn.DNN_TARGET_CPU)\n\n        # Get input shape from model\n        self.input_shape = (640, 640)  # YOLOv8n default\n\n    def predict(self, frame: np.ndarray) -> list[dict]:\n        \"\"\"Run inference on a BGR frame, return list of detections.\"\"\"\n        # Resize + normalize\n        blob = cv2.dnn.blobFromImage(\n            frame,\n            scalefactor=1 / 255.0,\n            size=self.input_shape,\n            swapRB=True,\n            crop=False,\n        )\n        self.net.setInput(blob)\n        outputs = self.net.forward(self.net.getUnconnectedOutLayersNames())\n        return self._postprocess(outputs, frame.shape)\n\n    def _postprocess(self, outputs, img_shape):\n        \"\"\"Convert raw model outputs to structured detections.\"\"\"\n        detections = []\n        # YOLOv8 output: [1, 84, 8400] (COCO: 84 = 4(box) + 80(classes))\n        # Or for custom PPE model: [1, 5, 8400] (5 = 4(box) + 1(class))\n        output = outputs[0]  # (84, 8400) or (5, 8400)\n\n        if output.shape[0] == 84:  # COCO pretrained\n            # Transpose: (8400, 84)\n            output = output.T\n            for row in output:\n                box = row[:4]\n                class_scores = row[4:]\n                cls_id = int(np.argmax(class_scores))\n                conf = float(np.max(class_scores))\n\n                if cls_id != 0 or conf < self.conf_thresh:\n                    continue\n\n                # xywh → xyxy\n                cx, cy, w, h = box\n                x1 = cx - w / 2\n                y1 = cy - h / 2\n                x2 = cx + w / 2\n                y2 = cy + h / 2\n\n                # Scale to original image\n                orig_h, orig_w = img_shape[:2]\n                scale_x = orig_w / self.input_shape[0]\n                scale_y = orig_h / self.input_shape[1]\n\n                detections.append({\n                    \"bbox\": [float(x1 * scale_x), float(y1 * scale_y),\n                             float(x2 * scale_x), float(y2 * scale_y)],\n                    \"confidence\": round(conf, 3),\n                    \"class_id\": cls_id,\n                    \"class_name\": CLASS_NAMES.get(cls_id, \"unknown\"),\n                    \"width\": float(w * scale_x),\n                    \"height\": float(h * scale_y),\n                    \"center_x\": float(cx * scale_x),\n                    \"center_y\": float(cy * scale_y),\n                })\n\n        elif output.shape[0] == 5:  # Custom PPE model (1 class + 4 coords)\n            output = output.T\n            for row in output:\n                box = row[:4]\n                conf = float(row[4])\n\n                if conf < self.conf_thresh:\n                    continue\n\n                cx, cy, w, h = box\n                x1, y1 = cx - w / 2, cy - h / 2\n                x2, y2 = cx + w / 2, cy + h / 2\n\n                orig_h, orig_w = img_shape[:2]\n                scale_x = orig_w / self.input_shape[0]\n                scale_y = orig_h / self.input_shape[1]\n\n                detections.append({\n                    \"bbox\": [float(x1 * scale_x), float(y1 * scale_y),\n                             float(x2 * scale_x), float(y2 * scale_y)],\n                    \"confidence\": round(conf, 3),\n                    \"class_id\": 0,\n                    \"class_name\": \"person\",\n                    \"width\": float(w * scale_x),\n                    \"height\": float(h * scale_y),\n                    \"center_x\": float(cx * scale_x),\n                    \"center_y\": float(cy * scale_y),\n                })\n\n        return detections\n\n\nclass PPEDetector:\n    \"\"\"\n    PPE detection using either:\n    1. ONNX YOLOv8 (CPU) — if model file exists\n    2. OpenCV Haar Cascade (fallback) — always available\n    3. Color analysis (demo mode) — works with any image\n    \"\"\"\n\n    def __init__(self, model_path: str = \"yolov8n.onnx\"):\n        self.model_path = model_path\n        self.confidence_threshold = 0.5\n        self.iou_threshold = 0.4\n\n        # Try ONNX model first\n        self.yolo = None\n        if os.path.exists(model_path):\n            try:\n                self.yolo = YOLOWrapper(model_path, conf_thresh=self.confidence_threshold)\n                print(f\"[Detector] ONNX model loaded: {model_path}\")\n            except Exception as e:\n                print(f\"[Detector] ONNX load failed: {e}, using demo mode\")\n        else:\n            print(f\"[Detector] ONNX model not found ({model_path}), using demo mode\")\n\n        # Haar cascades (shipped with OpenCV)\n        self.face_cascade = cv2.CascadeClassifier(\n            cv2.data.haarcascades + \"haarcascade_fullbody.xml\"\n        )\n        if self.face_cascade.empty():\n            self.face_cascade = cv2.CascadeClassifier(\n                cv2.data.haarcascades + \"haarcascade_upperbody.xml\"\n            )\n\n    def detect_from_frame(self, frame: np.ndarray) -> list[dict]:\n        \"\"\"\n        Run detection on a single frame.\n        Priority: ONNX YOLO > Haar Cascade > Color analysis\n        \"\"\"\n        if self.yolo:\n            try:\n                detections = self.yolo.predict(frame)\n                # Add PPE status to each detection\n                for d in detections:\n                    d[\"ppe_status\"] = self._estimate_ppe_status(\n                        frame, d[\"class_id\"], d[\"bbox\"]\n                    )\n                return detections\n            except Exception as e:\n                print(f\"[Detector] YOLO failed: {e}\")\n\n        # Fallback: color-based detection\n        return self._color_based_detection(frame)\n\n    def _color_based_detection(self, frame: np.ndarray) -> list[dict]:\n        \"\"\"\n        Demo mode: detect people using body color analysis.\n        This works without any ML model for demonstration.\n        \"\"\"\n        hsv = cv2.cvtColor(frame, cv2.COLOR_BGR2HSV)\n        orig_h, orig_w = frame.shape[:2]\n\n        # Lower body detection (simple motion-color blob detection)\n        # Detect bright/colorful regions as potential people\n        gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)\n        blurred = cv2.GaussianBlur(gray, (21, 21), 0)\n        _, thresh = cv2.threshold(blurred, 80, 255, cv2.THRESH_BINARY)\n\n        # Find contours\n        contours, _ = cv2.findContours(thresh, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)\n\n        detections = []\n        min_area = (orig_h * orig_w) * 0.01  # At least 1% of image\n\n        for cnt in contours:\n            area = cv2.contourArea(cnt)\n            if area < min_area:\n                continue\n\n            x, y, w, h = cv2.boundingRect(cnt)\n            aspect = h / max(w, 1)\n\n            # Filter for vertical-ish shapes (people-like)\n            if aspect < 1.2 or h < orig_h * 0.1:\n                continue\n\n            # Estimate PPE from color\n            person_roi = frame[y:y+h, x:x+w]\n            ppe_status = self._estimate_ppe_status(\n                frame, class_id=0, bbox=[x, y, x+w, y+h]\n            )\n\n            detections.append({\n                \"bbox\": [float(x), float(y), float(x+w), float(y+h)],\n                \"confidence\": round(min(area / (orig_h * orig_w) * 3, 0.95), 3),\n                \"class_id\": 0,\n                \"class_name\": \"person\",\n                \"ppe_status\": ppe_status,\n                \"width\": float(w),\n                \"height\": float(h),\n                \"center_x\": float(x + w/2),\n                \"center_y\": float(y + h/2),\n            })\n\n        return detections\n\n    def _estimate_ppe_status(self, frame: np.ndarray, class_id: int, bbox: list) -> dict:\n        \"\"\"Estimate PPE compliance from person's region using color analysis.\"\"\"\n        x1, y1, x2, y2 = [int(v) for v in bbox]\n        h, w = frame.shape[:2]\n        x1, y1 = max(0, x1), max(0, y1)\n        x2, y2 = min(w, x2), min(h, y2)\n\n        if x2 <= x1 or y2 <= y1:\n            return {\"has_helmet\": True, \"has_vest\": True, \"compliant\": True}\n\n        person_roi = frame[y1:y2, x1:x2]\n        if person_roi.size == 0:\n            return {\"has_helmet\": True, \"has_vest\": True, \"compliant\": True}\n\n        hsv = cv2.cvtColor(person_roi, cv2.COLOR_BGR2HSV)\n\n        # ── Helmet detection (top 20% of person box) ──────────────────────────\n        head_end = min(y1 + int((y2 - y1) * 0.22), h)\n        has_helmet = False\n        if head_end > y1:\n            head_roi = frame[y1:head_end, x1:x2]\n            if head_roi.size > 0:\n                head_hsv = cv2.cvtColor(head_roi, cv2.COLOR_BGR2HSV)\n                # Construction helmet colors: yellow (#FFDD00), orange (#FF6600)\n                lower_helmet = np.array([10, 40, 60])\n                upper_helmet = np.array([40, 255, 255])\n                mask = cv2.inRange(head_hsv, lower_helmet, upper_helmet)\n                ratio = cv2.countNonZero(mask) / max(mask.size, 1)\n                has_helmet = ratio > 0.05\n            else:\n                has_helmet = True\n\n        # ── Vest detection (middle 40% of person box) ──────────────────────────\n        vest_top = y1 + int((y2 - y1) * 0.35)\n        vest_bot = y1 + int((y2 - y1) * 0.75)\n        has_vest = False\n        if vest_bot > vest_top:\n            vest_roi = frame[vest_top:vest_bot, x1:x2]\n            if vest_roi.size > 0:\n                vest_hsv = cv2.cvtColor(vest_roi, cv2.COLOR_BGR2HSV)\n                # Safety vest: yellow/orange fluorescent\n                lower_v = np.array([0, 20, 80])\n                upper_v = np.array([40, 255, 255])\n                v_mask = cv2.inRange(vest_hsv, lower_v, upper_v)\n                v_ratio = cv2.countNonZero(v_mask) / max(v_mask.size, 1)\n                # Reflective stripes: high brightness, low saturation\n                lower_ref = np.array([0, 0, 180])\n                upper_ref = np.array([180, 30, 255])\n                r_mask = cv2.inRange(vest_hsv, lower_ref, upper_ref)\n                r_ratio = cv2.countNonZero(r_mask) / max(r_mask.size, 1)\n                has_vest = v_ratio > 0.10 or r_ratio > 0.18\n            else:\n                has_vest = True\n\n        return {\n            \"has_helmet\": has_helmet,\n            \"has_vest\": has_vest,\n            \"compliant\": has_helmet and has_vest,\n        }\n\n    def get_violations(self, detections: list[dict]) -> list[dict]:\n        return [d for d in detections if not d.get(\"ppe_status\", {}).get(\"compliant\", True)]\n\n    def get_summary(self, detections: list[dict]) -> dict:\n        total = len(detections)\n        compliant = sum(1 for d in detections if d.get(\"ppe_status\", {}).get(\"compliant\", True))\n        violations = total - compliant\n        no_helmet = sum(1 for d in detections if not d.get(\"ppe_status\", {}).get(\"has_helmet\", True))\n        no_vest = sum(1 for d in detections if not d.get(\"ppe_status\", {}).get(\"has_vest\", True))\n        return {\n            \"total_persons\": total,\n            \"compliant\": compliant,\n            \"violations\": violations,\n            \"no_helmet\": no_helmet,\n            \"no_vest\": no_vest,\n            \"compliance_rate\": round(compliant / total * 100, 1) if total > 0 else 100.0,\n        }\n\n\n# ── Model Downloader ─────────────────────────────────────────────────────────\ndef download_yolov8n_onnx(dest: str = \"yolov8n.onnx\"):\n    \"\"\"Download YOLOv8n ONNX model from Ultralytics GitHub releases.\"\"\"\n    if os.path.exists(dest):\n        print(f\"[Model] Already exists: {dest}\")\n        return\n\n    url = (\n        \"https://github.com/ultralytics/assets/releases/download/v8.2.0/\"\n        \"yolov8n.onnx\"\n    )\n    print(f\"[Model] Downloading YOLOv8n ONNX (~6MB)...\")\n    urllib.request.urlretrieve(url, dest)\n    size_mb = os.path.getsize(dest) / 1_048_576\n    print(f\"[Model] Downloaded: {dest} ({size_mb:.1f} MB)\")\n\n\nif __name__ == \"__main__\":\n    # Test on a sample image or video frame\n    import sys\n\n    print(\"S1 PPE Detector — Test Mode\")\n    print(\"Usage: python detector.py [image_or_video_path]\")\n    print()\n\n    # Try to download ONNX model if not exists\n    if not os.path.exists(\"yolov8n.onnx\"):\n        try:\n            download_yolov8n_onnx()\n        except Exception as e:\n            print(f\"[Model] Download failed: {e}\")\n\n    detector = PPEDetector(\"yolov8n.onnx\" if os.path.exists(\"yolov8n.onnx\") else \"\")\n\n    if len(sys.argv) > 1:\n        # Test on image/video\n        source = sys.argv[1]\n        print(f\"[Test] Processing: {source}\")\n\n        if source.lower().endswith(('.mp4', '.avi', '.mov', '.mkv')):\n            cap = cv2.VideoCapture(source)\n            ret, frame = cap.read()\n            cap.release()\n            if ret:\n                detections = detector.detect_from_frame(frame)\n                print(f\"[Test] Detections: {len(detections)}\")\n                for d in detections:\n                    print(f\"  - {d['class_name']} conf={d['confidence']} bbox={d['bbox']} PPE={d.get('ppe_status', {})}\")\n        else:\n            img = cv2.imread(source)\n            if img is not None:\n                detections = detector.detect_from_frame(img)\n                print(f\"[Test] Detections: {len(detections)}\")\n                for d in detections:\n                    print(f\"  - {d['class_name']} conf={d['confidence']} PPE={d.get('ppe_status', {})}\")\n            else:\n                print(f\"[Error] Cannot read: {source}\")\n    else:\n        print(\"[Test] No input file. Detector ready.\")\n        print(f\"[Test] Demo mode: color-based detection\")\n"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":183,"output":3927,"cacheRead":47208,"cacheWrite":585,"totalTokens":51903,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776788188224,"responseId":"0636d5dd091c2ad4a9a047fa09280290"}}
