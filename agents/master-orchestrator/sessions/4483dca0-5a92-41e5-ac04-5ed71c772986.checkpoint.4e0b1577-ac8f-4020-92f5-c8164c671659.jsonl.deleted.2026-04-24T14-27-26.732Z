{"type":"message","id":"3a5acac9","parentId":"46ff1b43","timestamp":"2026-04-21T17:14:23.695Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now I also need to update the AnnotatedFrame component to fetch its own summary from the API (instead of relying on the parent summary prop, since we set `summary={null}` in VideoPlayer).\n\nLet me update AnnotatedFrame to fetch its own summary.","thinkingSignature":"ff3ed4aa8f20ba1b615039bae70a0aa63d2e962f61381e77948328bc085d6ed5"},{"type":"text","text":"Update `AnnotatedFrame` tự fetch summary riêng:\n"},{"type":"toolCall","id":"call_function_pp54scdkscgh_1","name":"edit","arguments":{"path":"/root/.openclaw/workspaces2/projects/s1-ppe-safety/frontend/src/App.jsx","edits":[{"oldText":"// ── Annotated Frame ──────────────────────────────────────────────────────────\nfunction AnnotatedFrame({ summary }) {\n  const [imgSrc, setImgSrc] = useState(null)\n  const [lastUpdate, setLastUpdate] = useState(null)\n\n  useEffect(() => {\n    const poll = setInterval(async () => {\n      try {\n        const res = await fetch(`${API_BASE}/api/frame`, { cache: 'no-cache' })\n        if (res.ok) {\n          const blob = await res.blob()\n          setImgSrc(URL.createObjectURL(blob))\n          setLastUpdate(new Date().toLocaleTimeString())\n        }\n      } catch {}\n    }, 500)\n    return () => clearInterval(poll)\n  }, [])\n\n  const color = summary?.compliance_rate >= 80 ? '#52c41a'\n    : summary?.compliance_rate >= 50 ? '#faad14' : '#ff4d4f'\n\n  return (\n    <div style={{ position: 'relative', borderRadius: 12, overflow: 'hidden', background: '#000' }}>\n      {imgSrc ? (\n        <img src={imgSrc} alt=\"Detection\" style={{ width: '100%', display: 'block' }} />\n      ) : (\n        <div style={{\n          width: '100%', height: 300,\n          display: 'flex', alignItems: 'center', justifyContent: 'center',\n          background: '#1a1a2e', color: '#555', flexDirection: 'column', gap: 12,\n        }}>\n          <VideoCameraOutlined style={{ fontSize: 40 }} />\n          <span>Đang kết nối camera...</span>\n        </div>\n      )}\n      <div style={{\n        position: 'absolute', top: 10, left: 10,\n        background: 'rgba(0,0,0,0.7)', borderRadius: 6, padding: '4px 10px',\n        fontSize: 10, color: '#aaa', fontFamily: 'monospace',\n      }}>\n        Cập nhật: {lastUpdate || '...'}\n      </div>\n      <div style={{\n        position: 'absolute', top: 10, right: 10,\n        background: 'rgba(0,0,0,0.7)', borderRadius: 6, padding: '4px 10px',\n        fontSize: 10, color: '#0f0', fontFamily: 'monospace',\n      }}>\n        ● DETECTED FRAME\n      </div>\n      {summary && (\n        <div style={{\n          position: 'absolute', bottom: 10, left: 10,\n          background: 'rgba(0,0,0,0.8)', borderRadius: 8, padding: '8px 12px',\n          fontFamily: 'monospace', fontSize: 11,\n        }}>\n          <div style={{ color: '#fff' }}>👤 {summary.total_persons || 0} phát hiện</div>\n          <div style={{ color: '#52c41a' }}>\n            ✅ {summary.compliant || 0}\n            <span style={{ color: '#ff4d4f', marginLeft: 12 }}>❌ {summary.violations || 0}</span>\n          </div>\n          <div style={{ color, marginTop: 2 }}>📊 {summary.compliance_rate || 0}%</div>\n        </div>\n      )}\n    </div>\n  )\n}","newText":"// ── Annotated Frame (surveillance) ───────────────────────────────────────\nfunction AnnotatedFrame({ summary: parentSummary }) {\n  const [imgSrc, setImgSrc] = useState(null)\n  const [summary, setSummary] = useState(parentSummary)\n  const [lastUpdate, setLastUpdate] = useState(null)\n\n  useEffect(() => {\n    const poll = setInterval(async () => {\n      try {\n        // Fetch frame image\n        const res = await fetch(`${API_BASE}/api/frame`, { cache: 'no-cache' })\n        if (res.ok) {\n          const blob = await res.blob()\n          setImgSrc(URL.createObjectURL(blob))\n          setLastUpdate(new Date().toLocaleTimeString())\n        }\n        // Fetch summary\n        const data = await fetchAPI('/api/summary')\n        if (data.summary) setSummary(data.summary)\n      } catch {}\n    }, 500)\n    return () => clearInterval(poll)\n  }, [])\n\n  const color = summary?.compliance_rate >= 80 ? '#52c41a'\n    : summary?.compliance_rate >= 50 ? '#faad14' : '#ff4d4f'\n\n  return (\n    <div style={{ position: 'relative', borderRadius: 12, overflow: 'hidden', background: '#000' }}>\n      {imgSrc ? (\n        <img src={imgSrc} alt=\"Giám sát\" style={{ width: '100%', display: 'block' }} />\n      ) : (\n        <div style={{\n          width: '100%', height: 320,\n          display: 'flex', alignItems: 'center', justifyContent: 'center',\n          background: '#1a1a2e', color: '#555', flexDirection: 'column', gap: 12,\n        }}>\n          <VideoCameraOutlined style={{ fontSize: 40 }} />\n          <span>Đang kết nối camera giám sát...</span>\n        </div>\n      )}\n\n      <div style={{\n        position: 'absolute', top: 10, left: 10,\n        background: 'rgba(0,0,0,0.7)', borderRadius: 6, padding: '4px 10px',\n        fontSize: 10, color: '#aaa', fontFamily: 'monospace',\n      }}>\n        Cập nhật: {lastUpdate || '...'}\n      </div>\n\n      <div style={{\n        position: 'absolute', top: 10, right: 10,\n        background: summary && !summary.compliant && summary.violations > 0 ? 'rgba(255,23,68,0.8)' : 'rgba(0,0,0,0.7)',\n        borderRadius: 6, padding: '4px 10px',\n        fontSize: 10, color: '#0f0', fontFamily: 'monospace',\n      }}>\n        {summary && !summary.compliant && summary.violations > 0 ? '⚠ ALERT' : '● LIVE'}\n      </div>\n\n      {summary && (\n        <div style={{\n          position: 'absolute', bottom: 10, left: 10,\n          background: 'rgba(0,0,0,0.85)', borderRadius: 8, padding: '10px 14px',\n          fontFamily: 'monospace', fontSize: 12,\n        }}>\n          <div style={{ color: '#fff', marginBottom: 4 }}>👤 {summary.total_persons || 0} phát hiện</div>\n          <div style={{ color: '#52c41a' }}>✅ {summary.compliant || 0}</div>\n          <div style={{ color: '#ff4d4f' }}>❌ {summary.violations || 0}</div>\n          <div style={{ color, marginTop: 4, fontSize: 14, fontWeight: 700 }}>\n            📊 {summary.compliance_rate || 0}%\n          </div>\n        </div>\n      )}\n    </div>\n  )\n}"}]}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":77,"output":1928,"cacheRead":139750,"cacheWrite":2846,"totalTokens":144601,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776791645057,"responseId":"0636e35e60d4d46692fa42e1c5550161"}}
