{"type":"message","id":"4832842b","parentId":"1150c2c5","timestamp":"2026-04-21T16:11:40.424Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now the main App component.","thinkingSignature":"ae4bc2cfad90df9497c493c8c219d4ca942786b51f352ff85f35299e9e017752"},{"type":"toolCall","id":"call_function_2otw1k2c47c5_1","name":"write","arguments":{"path":"/root/.openclaw/workspaces2/projects/s1-ppe-safety/frontend/src/App.jsx","content":"import { useState, useEffect, useRef } from 'react'\nimport { io } from 'socket.io-client'\nimport {\n  Layout, Card, Row, Col, Statistic, Table, Tag, Badge,\n  Button, Space, Typography, Alert, Progress, List, Timeline, Tooltip\n} from 'antd'\nimport {\n  SafetyOutlined, AlertOutlined, UserOutlined,\n  CheckCircleOutlined, StopOutlined, PlayCircleOutlined,\n  VideoCameraOutlined, ReloadOutlined\n} from '@ant-design/icons'\n\nconst { Header, Content, Sider } = Layout\nconst { Title, Text } = Typography\n\n// ── API helpers ─────────────────────────────────────────────────────────────\nconst API_BASE = import.meta.env.VITE_API_BASE || ''\n\nasync function fetchAPI(path) {\n  const res = await fetch(`${API_BASE}${path}`)\n  if (!res.ok) throw new Error(`${path} → ${res.status}`)\n  return res.json()\n}\n\n// ── Stats Card ──────────────────────────────────────────────────────────────\nfunction StatsCard({ title, value, icon, color, suffix, sub }) {\n  return (\n    <Card size=\"small\" style={{ borderRadius: 12 }}>\n      <Statistic\n        title={<Text type=\"secondary\" style={{ fontSize: 13 }}>{title}</Text>}\n        value={value}\n        suffix={suffix}\n        valueStyle={{ color, fontSize: 28, fontWeight: 700 }}\n        prefix={<span style={{ marginRight: 8 }}>{icon}</span>}\n      />\n      {sub && <div style={{ marginTop: 4, fontSize: 12, color: '#888' }}>{sub}</div>}\n    </Card>\n  )\n}\n\n// ── Alert Item ───────────────────────────────────────────────────────────────\nfunction AlertItem({ alert }) {\n  const d = alert.detection || {}\n  const isViolation = !d.compliant\n  return (\n    <List.Item style={{ padding: '8px 0' }}>\n      <Space align=\"start\" style={{ width: '100%' }}>\n        <Badge status={isViolation ? 'error' : 'success'} />\n        <div style={{ flex: 1 }}>\n          <Space>\n            {d.has_helmet === false && <Tag color=\"red\">NO HELMET</Tag>}\n            {d.has_vest === false && <Tag color=\"orange\">NO VEST</Tag>}\n            {d.compliant && <Tag color=\"green\">OK</Tag>}\n          </Space>\n          <div style={{ fontSize: 11, color: '#999', marginTop: 2 }}>\n            {alert.timestamp ? new Date(alert.timestamp).toLocaleTimeString() : '—'}\n            {' · conf: '}{d.confidence?.toFixed(2) || '—'}\n          </div>\n        </div>\n      </Space>\n    </List.Item>\n  )\n}\n\n// ── Live Feed Canvas ─────────────────────────────────────────────────────────\nfunction LiveFeedCanvas({ summary }) {\n  const canvasRef = useRef(null)\n  const [frameSrc, setFrameSrc] = useState(null)\n  const intervalRef = useRef(null)\n\n  useEffect(() => {\n    // Poll annotated frame from backend every 2s\n    intervalRef.current = setInterval(async () => {\n      try {\n        const data = await fetchAPI('/api/summary')\n        if (data.detections?.length > 0) {\n          // For demo: show a placeholder visualization on canvas\n          const canvas = canvasRef.current\n          if (!canvas) return\n          const ctx = canvas.getContext('2d')\n          const w = canvas.width\n          const h = canvas.height\n\n          // Background\n          ctx.fillStyle = '#1a1a2e'\n          ctx.fillRect(0, 0, w, h)\n\n          // Grid\n          ctx.strokeStyle = '#16213e'\n          ctx.lineWidth = 1\n          for (let i = 0; i < w; i += 40) {\n            ctx.beginPath(); ctx.moveTo(i, 0); ctx.lineTo(i, h); ctx.stroke()\n          }\n          for (let i = 0; i < h; i += 40) {\n            ctx.beginPath(); ctx.moveTo(0, i); ctx.lineTo(w, i); ctx.stroke()\n          }\n\n          // Draw detection boxes (scaled to canvas)\n          const scaleX = w / 1280\n          const scaleY = h / 720\n          data.detections.forEach(d => {\n            const [x1, y1, x2, y2] = d.bbox.map((v, i) => i % 2 === 0 ? v * scaleX : v * scaleY)\n            const ppe = d.ppe_status\n            ctx.strokeStyle = ppe.compliant ? '#00c853' : '#ff1744'\n            ctx.lineWidth = 2\n            ctx.strokeRect(x1, y1, x2 - x1, y2 - y1)\n            ctx.fillStyle = ppe.compliant ? 'rgba(0,200,83,0.15)' : 'rgba(255,23,68,0.15)'\n            ctx.fillRect(x1, y1, x2 - x1, y2 - y1)\n            // Label\n            ctx.fillStyle = ppe.compliant ? '#00c853' : '#ff1744'\n            ctx.font = 'bold 11px monospace'\n            const label = ppe.compliant ? '✓ OK' : `✗ ${!ppe.has_helmet ? 'NO-HELMET' : ''} ${!ppe.has_vest ? 'NO-VEST' : ''}`\n            ctx.fillText(label.trim(), x1 + 2, y1 - 4)\n          })\n\n          // Stats overlay\n          const s = data.summary || {}\n          ctx.fillStyle = 'rgba(0,0,0,0.7)'\n          ctx.fillRect(8, 8, 180, 70)\n          ctx.fillStyle = '#fff'\n          ctx.font = '12px monospace'\n          ctx.fillText(`Persons: ${s.total_persons || 0}`, 16, 28)\n          ctx.fillStyle = '#00c853'\n          ctx.fillText(`Compliant: ${s.compliant || 0}`, 16, 46)\n          ctx.fillStyle = '#ff1744'\n          ctx.fillText(`Violations: ${s.violations || 0}`, 16, 64)\n        } else {\n          // No detections — show empty state\n          const canvas = canvasRef.current\n          if (!canvas) return\n          const ctx = canvas.getContext('2d')\n          ctx.fillStyle = '#1a1a2e'\n          ctx.fillRect(0, 0, canvas.width, canvas.height)\n          ctx.fillStyle = '#555'\n          ctx.font = '16px monospace'\n          ctx.textAlign = 'center'\n          ctx.fillText('▶ Waiting for video stream...', canvas.width / 2, canvas.height / 2)\n          ctx.textAlign = 'left'\n        }\n      } catch {\n        // ignore polling errors\n      }\n    }, 2000)\n\n    return () => clearInterval(intervalRef.current)\n  }, [])\n\n  return (\n    <div style={{ position: 'relative' }}>\n      <canvas\n        ref={canvasRef}\n        width={640}\n        height={360}\n        style={{\n          width: '100%',\n          borderRadius: 12,\n          border: '1px solid #333',\n          display: 'block',\n        }}\n      />\n      <div style={{\n        position: 'absolute', top: 12, right: 12,\n        background: 'rgba(0,0,0,0.6)',\n        borderRadius: 6, padding: '4px 10px',\n        fontSize: 11, color: '#0f0',\n        fontFamily: 'monospace',\n      }}>\n        LIVE · DEMO CAM\n      </div>\n    </div>\n  )\n}\n\n// ── Main App ─────────────────────────────────────────────────────────────────\nexport default function App() {\n  const [summary, setSummary] = useState({\n    total_persons: 0, compliant: 0, violations: 0,\n    no_helmet: 0, no_vest: 0, compliance_rate: 100,\n  })\n  const [alerts, setAlerts] = useState([])\n  const [alertsPage, setAlertsPage] = useState(1)\n  const [status, setStatus] = useState('connecting') // connecting | live | stopped\n  const [alertStats, setAlertStats] = useState({})\n  const socketRef = useRef(null)\n\n  // ── Socket.IO ──────────────────────────────────────────────────────────────\n  useEffect(() => {\n    const socket = io(API_BASE || window.location.origin, {\n      transports: ['websocket', 'polling'],\n      reconnectionAttempts: 5,\n      reconnectionDelay: 2000,\n    })\n\n    socketRef.current = socket\n\n    socket.on('connect', () => {\n      console.log('[WS] Connected')\n      socket.emit('subscribe', { camera_id: 'demo-camera' })\n      setStatus('live')\n    })\n\n    socket.on('disconnect', () => {\n      console.log('[WS] Disconnected')\n      setStatus('stopped')\n    })\n\n    socket.on('detection_summary', (data) => {\n      if (data.summary) setSummary(data.summary)\n    })\n\n    socket.on('ppe_alert', (alert) => {\n      setAlerts(prev => [alert, ...prev].slice(0, 100))\n      // Play sound\n      try {\n        const audio = new Audio('data:audio/wav;base64,')\n        audio.volume = 0.3\n        audio.play().catch(() => {})\n      } catch {}\n    })\n\n    socket.on('connected', (data) => console.log('[WS] Server ack:', data))\n\n    return () => socket.disconnect()\n  }, [])\n\n  // ── Poll alerts ────────────────────────────────────────────────────────────\n  useEffect(() => {\n    const loadAlerts = async () => {\n      try {\n        const [alertsData, statsData] = await Promise.all([\n          fetchAPI('/api/alerts?limit=20'),\n          fetchAPI('/api/alerts/stats'),\n        ])\n        if (Array.isArray(alertsData)) setAlerts(alertsData)\n        if (statsData) setAlertStats(statsData)\n      } catch {}\n    }\n    loadAlerts()\n    const interval = setInterval(loadAlerts, 10000)\n    return () => clearInterval(interval)\n  }, [])\n\n  const handleStart = async () => {\n    try {\n      await fetch(`${API_BASE}/api/start`, {\n        method: 'POST',\n        headers: { 'Content-Type': 'application/json' },\n        body: JSON.json({}),\n      })\n      setStatus('live')\n    } catch {}\n  }\n\n  const complianceColor = summary.compliance_rate >= 80 ? '#52c41a'\n    : summary.compliance_rate >= 50 ? '#faad14'\n    : '#ff4d4f'\n\n  return (\n    <Layout style={{ minHeight: '100vh', background: '#0f0f1a' }}>\n      {/* ── Header ── */}\n      <Header style={{\n        background: '#1a1a2e',\n        borderBottom: '1px solid #2a2a4a',\n        display: 'flex', alignItems: 'center', justifyContent: 'space-between',\n        padding: '0 24px',\n      }}>\n        <Space>\n          <SafetyOutlined style={{ fontSize: 24, color: '#faad14' }} />\n          <Title level={4} style={{ color: '#fff', margin: 0 }}>\n            PPE Safety Monitor\n          </Title>\n          <Badge\n            status={status === 'live' ? 'processing' : 'error'}\n            text={<Text style={{ color: status === 'live' ? '#52c41a' : '#ff4d4f', fontSize: 12 }}>\n              {status === 'live' ? 'LIVE' : status === 'connecting' ? 'CONNECTING' : 'STOPPED'}\n            </Text>}\n          />\n        </Space>\n        <Space>\n          <Tooltip title=\"Reload alerts\">\n            <Button icon={<ReloadOutlined />} onClick={() => {\n              fetchAPI('/api/alerts?limit=20').then(d => Array.isArray(d) && setAlerts(d))\n            }}>\n              Reload\n            </Button>\n          </Tooltip>\n          {status !== 'live' && (\n            <Button\n              type=\"primary\"\n              icon={<PlayCircleOutlined />}\n              onClick={handleStart}\n              style={{ background: '#faad14', borderColor: '#faad14' }}\n            >\n              Start Detection\n            </Button>\n          )}\n        </Space>\n      </Header>\n\n      <Layout>\n        {/* ── Main Content ── */}\n        <Content style={{ padding: 20, background: '#0f0f1a' }}>\n          {/* Stats Row */}\n          <Row gutter={[16, 16]} style={{ marginBottom: 20 }}>\n            <Col xs={24} sm={12} md={6}>\n              <StatsCard\n                title=\"Tổng người phát hiện\"\n                value={summary.total_persons}\n                icon={<UserOutlined />}\n                color=\"#1890ff\"\n              />\n            </Col>\n            <Col xs={24} sm={12} md={6}>\n              <StatsCard\n                title=\"Tuân thủ (✓)\"\n                value={summary.compliant}\n                icon={<CheckCircleOutlined />}\n                color=\"#52c41a\"\n              />\n            </Col>\n            <Col xs={24} sm={12} md={6}>\n              <StatsCard\n                title=\"Vi phạm (✗)\"\n                value={summary.violations}\n                icon={<StopOutlined />}\n                color=\"#ff4d4f\"\n                sub={\n                  summary.no_helmet > 0 ? `• Không mũ: ${summary.no_helmet}` : null\n                }\n              />\n            </Col>\n            <Col xs={24} sm={12} md={6}>\n              <Card size=\"small\" style={{ borderRadius: 12 }}>\n                <Statistic\n                  title={<Text type=\"secondary\" style={{ fontSize: 13 }}>Tỷ lệ tuân thủ</Text>}\n                  value={summary.compliance_rate}\n                  suffix=\"%\"\n                  valueStyle={{ color: complianceColor, fontSize: 28, fontWeight: 700 }}\n                  prefix={<SafetyOutlined style={{ marginRight: 8 }} />}\n                />\n                <Progress\n                  percent={summary.compliance_rate}\n                  showInfo={false}\n                  strokeColor={complianceColor}\n                  style={{ marginTop: 8 }}\n                />\n              </Card>\n            </Col>\n          </Row>\n\n          {/* Live Feed + Alert Panel */}\n          <Row gutter={[16, 16]}>\n            <Col xs={24} lg={14}>\n              <Card\n                title={\n                  <Space>\n                    <VideoCameraOutlined />\n                    Camera Feed — Demo\n                  </Space>\n                }\n                style={{ background: '#1a1a2e', border: '1px solid #2a2a4a' }}\n                styles={{ header: { color: '#fff', borderBottom: '1px solid #2a2a4a' } }}\n              >\n                <LiveFeedCanvas summary={summary} />\n                <Alert\n                  message=\"Demo mode — sử dụng video file. Kết nối IP camera thực tế qua /api/detect endpoint.\"\n                  type=\"info\"\n                  showIcon\n                  style={{ marginTop: 12 }}\n                />\n              </Card>\n            </Col>\n\n            <Col xs={24} lg={10}>\n              <Card\n                title={\n                  <Space>\n                    <AlertOutlined style={{ color: '#ff4d4f' }} />\n                    Cảnh báo thời gian thực\n                    <Badge count={alerts.length} style={{ backgroundColor: '#ff4d4f' }} />\n                  </Space>\n                }\n                style={{ background: '#1a1a2e', border: '1px solid #2a2a4a', height: '100%' }}\n                styles={{ header: { color: '#fff', borderBottom: '1px solid #2a2a4a' } }}\n                bodyStyle={{ maxHeight: 500, overflow: 'auto' }}\n              >\n                {alerts.length === 0 ? (\n                  <div style={{ textAlign: 'center', padding: 40, color: '#555' }}>\n                    <SafetyOutlined style={{ fontSize: 48, marginBottom: 12 }} />\n                    <div>Không có cảnh báo nào</div>\n                    <div style={{ fontSize: 12, marginTop: 4 }}>Hệ thống đang hoạt động bình thường</div>\n                  </div>\n                ) : (\n                  <List\n                    dataSource={alerts}\n                    renderItem={(item) => <AlertItem alert={item} />}\n                    locale={{ emptyText: 'Không có cảnh báo' }}\n                  />\n                )}\n              </Card>\n            </Col>\n          </Row>\n        </Content>\n\n        {/* ── Sidebar ── */}\n        <Sider\n          width={240}\n          style={{ background: '#1a1a2e', borderLeft: '1px solid #2a2a4a', padding: 16 }}\n        >\n          <Title level={5} style={{ color: '#fff' }}>Thống kê 24h</Title>\n          <Space direction=\"vertical\" style={{ width: '100%' }} size={12}>\n            <Card size=\"small\" style={{ background: '#16213e' }}>\n              <Statistic\n                title={<Text style={{ color: '#aaa', fontSize: 12 }}>Tổng cảnh báo</Text>}\n                value={alertStats.total || alerts.length}\n                valueStyle={{ color: '#fff', fontSize: 24 }}\n              />\n            </Card>\n            <Card size=\"small\" style={{ background: '#16213e' }}>\n              <Statistic\n                title={<Text style={{ color: '#aaa', fontSize: 12 }}>Không đội mũ</Text>}\n                value={alertStats.no_helmet || 0}\n                valueStyle={{ color: '#ff4d4f', fontSize: 24 }}\n              />\n            </Card>\n            <Card size=\"small\" style={{ background: '#16213e' }}>\n              <Statistic\n                title={<Text style={{ color: '#aaa', fontSize: 12 }}>Không áo phản quang</Text>}\n                value={alertStats.no_vest || 0}\n                valueStyle={{ color: '#faad14', fontSize: 24 }}\n              />\n            </Card>\n\n            <div style={{ marginTop: 16 }}>\n              <Title level={5} style={{ color: '#fff' }}>Camera</Title>\n              <Card size=\"small\" style={{ background: '#16213e' }}>\n                <Space>\n                  <Badge status=\"success\" />\n                  <Text style={{ color: '#aaa', fontSize: 13 }}>demo-camera</Text>\n                </Space>\n                <div style={{ fontSize: 11, color: '#666', marginTop: 4 }}>1280×720 · YOLOv8n</div>\n              </Card>\n            </div>\n          </Space>\n        </Sider>\n      </Layout>\n    </Layout>\n  )\n}\n"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":75,"output":4573,"cacheRead":37737,"cacheWrite":334,"totalTokens":42719,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776787848284,"responseId":"0636d48993c8ce577328f4d51f63ec34"}}
