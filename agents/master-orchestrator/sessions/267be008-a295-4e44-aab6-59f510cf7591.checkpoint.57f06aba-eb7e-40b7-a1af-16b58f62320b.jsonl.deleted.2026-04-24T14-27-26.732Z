ect',\n  'senior-backend','senior-devops','senior-frontend','senior-qa','senior-security',\n  'seo-audit','shadcn-expert','stitch-design','stitch-loop','typescript-reviewer',\n  'ui-design-system','ui-ux-pro-max']\n\nSKILL_KEY = \"ahv-openclaw-2026\"\nSKILL_KEY_BYTES = SKILL_KEY.encode()\n\ndef encrypt(data_bytes):\n    out = bytearray(len(data_bytes))\n    for i in range(len(data_bytes)):\n        out[i] = data_bytes[i] ^ SKILL_KEY_BYTES[i % len(SKILL_KEY_BYTES)] ^ (i & 0xff)\n    compressed = zlib.compress(bytes(out))\n    return base64.b64encode(compressed).decode()\n\nmanifest = []\npayloads = {}\n\nfor agent in sorted(AGENTS):\n    src_dir = f'agent-defs/{agent}' if os.path.isdir(f'agent-defs/{agent}') else f'agent-templates/{agent}'\n    if not os.path.isdir(src_dir):\n        continue\n    for fname in sorted(os.listdir(src_dir)):\n        fpath = os.path.join(src_dir, fname)\n        if not os.path.isfile(fpath):\n            continue\n        with open(fpath, 'rb') as f:\n            content = f.read()\n        entry_path = f'{agent}/{fname}'\n        manifest.append({'file': entry_path, 'size': len(content)})\n        payloads[entry_path] = encrypt(content)\n\nprint(f'Generated {len(manifest)} entries')\n\n# Verify decrypt of FIRST entry\ntest_file = manifest[0]['file']\nbuf = base64.b64decode(payloads[test_file])\ndec = bytearray(len(buf))\nfor i in range(len(buf)):\n    dec[i] = buf[i] ^ SKILL_KEY_BYTES[i % len(SKILL_KEY_BYTES)] ^ (i & 0xff)\ntext = zlib.decompress(bytes(dec))\nprint(f'First entry decrypt: {text[:60]}')\n\npack = {\n    'version': '1.0',\n    'packedAt': '2026-04-16T00:00:00.000Z',\n    'fileCount': len(manifest),\n    'key': SKILL_KEY,\n    'manifest': manifest,\n    'payloads': payloads\n}\n\n# Write to temp file first\nwith open('/tmp/test_skills.pack', 'w') as f:\n    json.dump(pack, f)\nprint(f'Written to /tmp/test_skills.pack: {os.path.getsize(\"/tmp/test_skills.pack\")/1024:.1f}KB')\n\n# Read back and verify\nwith open('/tmp/test_skills.pack', 'r') as f:\n    loaded = json.load(f)\nprint(f'Read back: {len(loaded[\"manifest\"])} entries')\n\n# Test decrypt of first loaded entry\ntest_entry = loaded['manifest'][0]['file']\nbuf2 = base64.b64decode(loaded['payloads'][test_entry])\ndec2 = bytearray(len(buf2))\nfor i in range(len(buf2)):\n    dec2[i] = buf2[i] ^ SKILL_KEY_BYTES[i % len(SKILL_KEY_BYTES)] ^ (i & 0xff)\ntext2 = zlib.decompress(bytes(dec2))\nprint(f'Loaded first entry decrypt: {text2[:60]}')\n\n# Save to final location\nwith open('skills.pack', 'w') as f:\n    json.dump(pack, f)\nprint(f'\\n✅ Final pack: {os.path.getsize(\"skills.pack\")/1024:.1f}KB, {len(manifest)} entries')\nPYEOF"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":248,"output":1164,"cacheRead":138254,"cacheWrite":1902,"totalTokens":141568,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776303601554,"responseId":"062f70f3056e470a8c2ad425affd5818"}}
