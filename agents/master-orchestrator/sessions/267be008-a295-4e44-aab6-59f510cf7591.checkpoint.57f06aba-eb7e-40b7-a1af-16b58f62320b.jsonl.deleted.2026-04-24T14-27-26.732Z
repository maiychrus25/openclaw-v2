er\":\"Performance Optimizer\"\n+    };\n+    const displayName = nameMap[agentId] || agentId;\n+\n+    // Copy agent files from existing OpenClaw workspace on this machine\n+    // Try multiple common locations\n+    const searchPaths = [\n+      path.join(process.env.OPENCLAW_HOME || \"\", \"workspaces2\", \"v4-ecosystem-review\", agentId),\n+      path.join(process.env.HOME || \"\", \".openclaw\", \"workspaces2\", \"v4-ecosystem-review\", agentId),\n+      path.join(process.env.HOME || \"\", \".openclaw\", \"workspaces\", agentId),\n+    ];\n+    const coreFiles = [\"SOUL.md\",\"IDENTITY.md\",\"AGENTS.md\",\"USER.md\",\n+      \"BOOTSTRAP.md\",\"HEARTBEAT.md\",\"TOOLS.md\",\"MEMORY.md\",\n+      \"SKILL_GATES.md\",\"DEV_GATE.md\"];\n+\n+    let copied = 0;\n+    for (const srcDir of searchPaths) {\n+      if (fs.existsSync(srcDir)) {\n+        for (const file of coreFiles) {\n+          const src = path.join(srcDir, file);\n+          if (fs.existsSync(src)) {\n+            fs.copyFileSync(src, path.join(wsDir, file));\n+            copied++;\n+          }\n+        }\n+        break; // stop at first found\n+      }\n+    }\n+    if (copied === 0) {\n+      console.log(chalk.yellow(`  ⚠️  No source agent files found for ${agentId} — skipping`));\n+    }\n+    console.log(chalk.dim(`  ✅ ${agentId}`));\n   }\n \n   return openclawPath;\n@@ -455,6 +529,9 @@ async function main() {\n   }\n \n   const configPath = applyConfig(config, answers, team);\n+  const homePath = answers.openclawPath\n+    ? answers.openclawPath.replace(/^\\$HOME\\//, process.env.HOME || \"\")\n+    : (process.env.HOME || \"\") + \"/.openclaw\";\n \n   // Restart gateway\n   restartGateway();\n@@ -462,8 +539,16 @@ async function main() {\n   // Done\n   console.log(chalk.bold(chalk.green(\"\\n✅ Setup hoàn tất!\\n\")));\n   console.log(`  Config: ${configPath}`);\n-  console.log(chalk.dim(\"\\n  Kiểm tra trạng thái: openclaw status\"));\n-  console.log(chalk.dim(\"  Xem sessions: openclaw sessi