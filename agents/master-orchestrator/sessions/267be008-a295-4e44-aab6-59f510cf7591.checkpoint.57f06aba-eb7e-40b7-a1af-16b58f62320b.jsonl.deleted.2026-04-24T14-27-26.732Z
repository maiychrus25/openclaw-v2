nstall first: $2\"\n+    exit 1\n+  fi\n+}\n+\n+main() {\n+  header"}],"details":{"status":"completed","exitCode":0,"durationMs":58,"aggregated":"diff --git a/ahv-openclaw-setup/install.sh b/ahv-openclaw-setup/install.sh\nnew file mode 100755\nindex 0000000..4034f19\n--- /dev/null\n+++ b/ahv-openclaw-setup/install.sh\n@@ -0,0 +1,114 @@\n+#!/usr/bin/env bash\n+# =============================================================================\n+# AHV OpenClaw Setup — ONE COMMAND INSTALL\n+# =============================================================================\n+# Usage:\n+#   # Pipe mode (auto-defaults to team dev, skips prompts):\n+#   curl -fsSL https://raw.githubusercontent.com/maiychrus25/setup-openclaw/main/install.sh | bash\n+#   # Pipe with specific team:\n+#   curl -fsSL https://raw.githubusercontent.com/maiychrus25/setup-openclaw/main/install.sh | bash -s dev\n+#   # Interactive:\n+#   ./install.sh dev\n+# =============================================================================\n+\n+set -e\n+\n+REPO=\"https://github.com/maiychrus25/setup-openclaw.git\"\n+INSTALL_DIR=\"${HOME}/.openclaw-setup\"\n+\n+RED='\\033[0;31m'; GREEN='\\033[0;32m'; YELLOW='\\033[1;33m'\n+CYAN='\\033[0;36m'; BOLD='\\033[1m'; DIM='\\033[2m'; RESET='\\033[0m'\n+\n+log()  { echo -e \"${GREEN}  ✅ $*${RESET}\"; }\n+warn() { echo -e \"${YELLOW}  ⚠️  $*${RESET}\"; }\n+info() { echo -e \"${DIM}  • $*${RESET}\"; }\n+step() { echo -e \"${CYAN}  ▶ $*${RESET}\"; }\n+err()  { echo -e \"${RED}  ❌ $*${RESET}\" >&2; }\n+\n+header() {\n+  echo \"\"\n+  echo -e \"${BOLD}╔══════════════════════════════════════════════════════╗${RESET}\"\n+  echo -e \"${BOLD}║     AHV OpenClaw Setup — ONE COMMAND INSTALL          ║${RESET}\"\n+  echo -e \"${BOLD}╚══════════════════════════════════════════════════════╝${RESET}\"\n+  echo \"\"\n+}\n+\n+need() {\n+  if ! command -v \"$1\" &>/dev/null; then\n+    err \"Missing required: $1 — install first: $2\"\n+    exit 1\n+  fi\n+}\n+\n+main() {\n+  header","cwd":"