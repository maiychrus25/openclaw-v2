nifest) {\n-      const { file } = entry;\n-      const compressed = decrypt(payloads[file], key);\n-      const decompressed = zlib.inflateSync(compressed);\n-      const destPath = path.join(destDir, file);\n-      const destDirName = path.dirname(destPath);\n-      if (!fs.existsSync(destDirName)) fs.mkdirSync(destDirName, { recursive: true });\n-      fs.writeFileSync(destPath, decompressed);\n+    let count = 0;\n+    for (const entry of pack.manifest) {\n+      const buf = Buffer.from(pack.payloads[entry.file], \"base64\");\n+      const kb = Buffer.from(SKILL_KEY, \"utf8\");\n+      const dec = Buffer.alloc(buf.length);\n+      for (let i = 0; i < buf.length; i++) dec[i] = buf[i] ^ kb[i % kb.length] ^ (i & 0xff);\n+      const content = zlib.inflateSync(dec);\n+\n+      // File path: skills/senior-backend/SKILL.md OR skills/senior-backend/references/...\n+      const filePath = path.join(destDir, \"skills\", entry.file);\n+      fs.mkdirSync(path.dirname(filePath), { recursive: true });\n+      fs.writeFileSync(filePath, content);\n+\n+      // chmod 500 only on SKILL.md, 444 on supporting files\n+      if (entry.file.endsWith(\"SKILL.md\")) {\n+        fs.chmodSync(filePath, 0o500);\n+      } else {\n+        fs.chmodSync(filePath, 0o444);\n+      }\n+      count++;\n     }\n-    console.log(`  ${chalk.green(\"✅\")} ${manifest.length} skills unpacked → ${destDir}`);\n+    const skillCount = pack.manifest.filter(e => e.file.endsWith(\"SKILL.md\")).length;\n+    const refCount = pack.manifest.length - skillCount;\n+    console.log(chalk.dim(`  📦 ${skillCount} skills + ${refCount} refs/scripts/templates unpacked`));\n   } catch (err) {\n     console.log(chalk.yellow(`  ⚠️  Unpack failed: ${err.message}`));\n   }\n@@ -67,7 +69,7 @@ const TEAMS = {\n       \"clean-code\", \"coding-standards\", \"refactor-cleaner\",\n       \"realistic-seeder\", \"planner\", \"prompt-optimizer\"\n     ],\n-    mcp: [\"gitlab\", \"confluence-dtlx\", \"confluence-qlhv\", \"stitch\"]