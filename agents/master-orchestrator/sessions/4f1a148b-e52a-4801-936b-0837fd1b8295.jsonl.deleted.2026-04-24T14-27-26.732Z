del instability). Monitor session health closely.\\n\\n━━━━━━━━━━━━━━━━━━━━━\\n\\n**Pipeline Status:** 🟢 HEALTHY\\n**Active Agents:** 34 (v4 ecosystem)\\n**Active Session:** telegram:group:-5212380728\\n\\n━━━━━━━━━━━━━━━━━━━━━\\nOrbis 🌐 — Global Orchestrator\"\n            }\n          ],\n          \"api\": \"anthropic-messages\",\n          \"provider\": \"ahvholding\",\n          \"model\": \"AHV-Holding-DEV\",\n          \"usage\": {\n            \"input\": 328,\n            \"output\": 570,\n            \"totalTokens\": 17958,\n            \"cacheRead\": 14121,\n            \"cacheWrite\": 2939,\n            \"cost\": {\n              \"total\": 0\n            }\n          },\n          \"stopReason\": \"stop\",\n          \"timestamp\": 1776117671474,\n          \"responseId\": \"062c9aa87844c59bbd285766e62b966f\",\n          \"__openclaw\": {\n            \"id\": \"faf39631\",\n            \"seq\": 7\n          }\n        }\n      ]\n    }\n  ]\n}[... 25660 more characters truncated]"}],"details":{"count":20,"sessions":[{"key":"agent:master-orchestrator:cron:ed2d0b5d-fc56-42eb-a8fc-973a48024df7","kind":"other","channel":"webchat","origin":{"provider":"heartbeat"},"label":"Cron: 5p Progress Report","displayName":"webchat:g-agent-master-orchestrator-cron-ed2d0b5d-fc56-42eb-a8fc-973a48024df7","deliveryContext":{"channel":"webchat"},"updatedAt":1776189400272,"sessionId":"4f1a148b-e52a-4801-936b-0837fd1b8295","model":"AHV-Holding-DEV","contextTokens":200000,"totalTokens":11171,"estimatedCostUsd":0,"status":"running","startedAt":1776189399801,"childSessions":["agent:master-orchestrator:subagent:c2d275a5-d70a-4775-a268-fecf4708f133","agent:planner:subagent:63bb70ce-b5f3-48d0-a236-b6cf5d8d7922","agent:planner:subagent:ba49ac6d-ceff-4a9d-b3b1-7b89afdd88cc"],"systemSent":true,"abortedLastRun":false,"lastChannel":"webchat","transcriptPath":"/root/.openclaw/agents/master-orchestrator/sessions/4f1a148b-e52a-4801-936b-0837fd1b8295.jsonl","messages":[{"role":"user","conten