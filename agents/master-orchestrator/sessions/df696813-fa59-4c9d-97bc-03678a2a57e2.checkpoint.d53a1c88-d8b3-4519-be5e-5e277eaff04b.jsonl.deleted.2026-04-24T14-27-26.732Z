{"type":"message","id":"4e3c79ad","parentId":"efce4984","timestamp":"2026-04-22T04:50:16.224Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Let me read all the model files, route files, service files, and docs to understand the complete project structure.","thinkingSignature":"d0da8627aaa0a73f567d77fdf9971af91472fb047557df8de40102045c40290a"},{"type":"toolCall","id":"call_function_dimgzh0yh8xz_1","name":"exec","arguments":{"command":"cat /root/.openclaw/workspaces2/projects/ahv-qlhv-be/src/infrastructure/database/models/*.ts 2>/dev/null | head -2000"}},{"type":"toolCall","id":"call_function_dimgzh0yh8xz_2","name":"exec","arguments":{"command":"cat /root/.openclaw/workspaces2/projects/ahv-qlhv-be/src/interface/routes/index.ts"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":1178,"output":123,"cacheRead":10173,"cacheWrite":2444,"totalTokens":13918,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776833412867,"responseId":"063786856d48b8056aff54359a2c779c"}}
{"type":"message","id":"b7916e54","parentId":"4e3c79ad","timestamp":"2026-04-22T04:50:16.538Z","message":{"role":"toolResult","toolCallId":"call_function_dimgzh0yh8xz_1","toolName":"exec","content":[{"type":"text","text":"import mongoose, { Schema, Document } from 'mongoose';\n\nexport interface IAnnouncement extends Document {\n  title: string;\n  content: string;\n  target_group: 'ALL' | 'STUDENT' | 'TEACHER' | 'STAFF';\n  channels: ('APP' | 'EMAIL' | 'SMS')[];\n  status: 'SENT' | 'SCHEDULED';\n  scheduled_at?: Date;\n  created_by?: mongoose.Types.ObjectId;\n  createdAt: Date;\n  updatedAt: Date;\n}\n\nconst AnnouncementSchema: Schema = new Schema(\n  {\n    title: { type: String, required: true },\n    content: { type: String, required: true },\n    target_group: {\n      type: String,\n      enum: ['ALL', 'STUDENT', 'TEACHER', 'STAFF'],\n      default: 'ALL',\n    },\n    channels: [\n      {\n        type: String,\n        enum: ['APP', 'EMAIL', 'SMS'],\n      },\n    ],\n    status: {\n      type: String,\n      enum: ['SENT', 'SCHEDULED'],\n      default: 'SENT',\n    },\n    scheduled_at: { type: Date },\n    created_by: { type: Schema.Types.ObjectId, ref: 'Users' },\n  },\n  { timestamps: true, collection: 'announcements' },\n);\n\nexport const AnnouncementModel = mongoose.model<IAnnouncement>('Announcement', AnnouncementSchema);\nexport default AnnouncementModel;\nimport mongoose, { Schema, Document } from 'mongoose';\n\nexport interface ICity extends Document {\n  name: string;\n  code: string;\n  created_at: Date;\n  updated_at: Date;\n}\n\nconst CitySchema = new Schema<ICity>(\n  {\n    name: { type: String, required: true },\n    code: { type: String, required: true, unique: true },\n  },\n  {\n    timestamps: { createdAt: 'created_at', updatedAt: 'updated_at' },\n    versionKey: false,\n    collection: 'cities',\n  },\n);\n\nexport const CityModel = mongoose.models.Cities || mongoose.model<ICity>('Cities', CitySchema, 'cities');\nimport mongoose, { Schema, Document, Types } from 'mongoose';\n\nexport interface ICourseFeeStage {\n  name: string;\n  amount: number;\n}\n\nexport interface ICourse extends Document {\n  license_category_id?: Types.ObjectId | null;\n  code: string; // Mã nội bộ của trung tâm\n  name: string; // Tên khóa học\n  system_course_id?: number;\n  system_course_code?: string; // Mã báo cáo lên Sở GTVT\n  curriculum_id?: number;\n  management_record_number?: string;\n  description?: string;\n  report_start_date?: Date;\n  start_date?: Date;\n  end_date?: Date;\n  dat_date?: Date; // Ngày tập trung chạy DAT\n  cabin_date?: Date; // Ngày học Cabin\n  decision_to_sign?: string;\n  duration?: number;\n  status: 'draft' | 'ongoing' | 'completed' | 'canceled';\n  course_fee?: number;\n  max_students?: number;\n  teacher_id?: Types.ObjectId | null;\n\n  // Extension for Web Admin\n  internal_note?: string;\n  note?: string;\n  course_type?: string;\n  fee_stages?: ICourseFeeStage[];\n  created_at: Date;\n  updated_at: Date;\n}\n\nconst CourseSchema = new Schema<ICourse>(\n  {\n    license_category_id: { type: Schema.Types.ObjectId, ref: 'LicenseCategories', default: null },\n    code: { type: String, required: true, unique: true, index: true },\n    name: { type: String, required: true },\n    system_course_id: { type: Number },\n    system_course_code: { type: String },\n    curriculum_id: { type: Number },\n    management_record_number: { type: String },\n    description: { type: String },\n    report_start_date: { type: Date },\n    start_date: { type: Date },\n    end_date: { type: Date },\n    dat_date: { type: Date },\n    cabin_date: { type: Date },\n    decision_to_sign: { type: String },\n    duration: { type: Number },\n    status: {\n      type: String,\n      enum: ['draft', 'ongoing', 'completed', 'canceled'],\n      default: 'draft',\n    },\n    course_fee: { type: Number, default: 0 },\n    max_students: { type: Number, default: 50 },\n    teacher_id: { type: Schema.Types.ObjectId, ref: 'Users', index: true, default: null },\n    internal_note: { type: String },\n    note: { type: String },\n    course_type: { type: String, default: 'trực tiếp' },\n    fee_stages: [\n      {\n        name: { type: String },\n        amount: { type: Number, default: 0 },\n      },\n    ],\n  },\n  {\n    timestamps: { createdAt: 'created_at', updatedAt: 'updated_at' },\n    versionKey: false,\n    collection: 'courses',\n  },\n);\n\nCourseSchema.index({ status: 1 });\nCourseSchema.index({ start_date: -1 });\n\nif (mongoose.models.Courses) {\n  mongoose.deleteModel('Courses');\n}\nexport const CourseModel = mongoose.model<ICourse>('Courses', CourseSchema, 'courses');\nimport mongoose, { Schema, Document, Types } from 'mongoose';\n\nexport interface ICourseStudent extends Document {\n  student_id: Types.ObjectId; // References Student(student_infos)\n  course_id: Types.ObjectId; // References Course(course_infos)\n  stadium_id?: Types.ObjectId | null;\n  teacher_id?: Types.ObjectId | null;\n  sale_id?: Types.ObjectId | null;\n  license_category_id?: Types.ObjectId | null;\n  status: 'unfinished' | 'finished' | 'canceled';\n  km: number;\n  hour: string;\n  fee: number;\n  paid_fee: number;\n  balance?: any; // Treasury balance for this enrollment\n  contract_date?: Date | null;\n  status_detail?: string;\n  progress_flags?: {\n    theory_completed: boolean;\n    sand_yard_completed: boolean;\n    simulation_completed: boolean;\n    dat_completed: boolean;\n    cabin_completed: boolean;\n    graduation_eligible: boolean;\n  };\n  health_check?: {\n    status: string;\n    date: Date | null;\n    hospital: string | null;\n    note: string | null;\n  };\n  created_at: Date;\n  updated_at: Date;\n}\n\nconst CourseStudentSchema = new Schema<ICourseStudent>(\n  {\n    student_id: { type: Schema.Types.ObjectId, ref: 'StudentInfos', required: true, index: true },\n    course_id: { type: Schema.Types.ObjectId, ref: 'Courses', required: true, index: true },\n    stadium_id: { type: Schema.Types.ObjectId, ref: 'Stadiums', default: null },\n    teacher_id: { type: Schema.Types.ObjectId, ref: 'Users', default: null },\n    sale_id: { type: Schema.Types.ObjectId, ref: 'Users', default: null },\n    license_category_id: { type: Schema.Types.ObjectId, ref: 'LicenseCategories', default: null },\n    status: {\n      type: String,\n      enum: ['unfinished', 'finished', 'canceled'],\n      default: 'unfinished',\n    },\n    km: { type: Number, default: 0 },\n    hour: { type: String, default: '00:00' },\n    fee: { type: Number, default: 0 },\n    paid_fee: { type: Number, default: 0 },\n    balance: {\n      type: Schema.Types.Decimal128,\n      default: 0,\n      get: (v: any) => (v ? parseFloat(v.toString()) : 0),\n    },\n    contract_date: { type: Date, default: null },\n    status_detail: { type: String, default: 'Chờ KSK' },\n    progress_flags: {\n      theory_completed: { type: Boolean, default: false },\n      sand_yard_completed: { type: Boolean, default: false },\n      simulation_completed: { type: Boolean, default: false },\n      dat_completed: { type: Boolean, default: false },\n      cabin_completed: { type: Boolean, default: false },\n      graduation_eligible: { type: Boolean, default: false },\n    },\n    health_check: {\n      status: { type: String, enum: ['Chờ khám', 'Đủ điều kiện', 'Không đủ điều kiện'], default: 'Chờ khám' },\n      date: { type: Date, default: null },\n      hospital: { type: String, default: null },\n      note: { type: String, default: null },\n    },\n  },\n  {\n    timestamps: { createdAt: 'created_at', updatedAt: 'updated_at' },\n    versionKey: false,\n    collection: 'coursestudents',\n  },\n);\n\nCourseStudentSchema.index({ student_id: 1, created_at: -1 });\nCourseStudentSchema.index({ course_id: 1, created_at: -1 });\nCourseStudentSchema.index({ status_detail: 1, created_at: -1 });\nCourseStudentSchema.index({ sale_id: 1, created_at: -1 });\nCourseStudentSchema.index({ 'progress_flags.dat_completed': 1, status_detail: 1 });\nCourseStudentSchema.index({ fee: 1, paid_fee: 1 });\n\nexport const CourseStudentModel =\n  mongoose.models.CourseStudents ||\n  mongoose.model<ICourseStudent>('CourseStudents', CourseStudentSchema, 'coursestudents');\nimport mongoose, { Schema, Document, Types } from 'mongoose';\n\nexport enum DatSessionType {\n  Cabin = 'cabin',\n  Dat = 'dat',\n}\n\nexport interface IDatSession extends Document {\n  course_student_id: Types.ObjectId;\n  session_type: DatSessionType;\n  start_time: Date;\n  end_time: Date;\n  distance_km: number;\n  rfid_card?: string;\n  notes?: string;\n  created_at: Date;\n  updated_at: Date;\n}\n\nconst DatSessionSchema = new Schema<IDatSession>(\n  {\n    course_student_id: { type: Schema.Types.ObjectId, ref: 'CourseStudents', required: true, index: true },\n    session_type: { type: String, enum: Object.values(DatSessionType), required: true },\n    start_time: { type: Date, required: true },\n    end_time: { type: Date, required: true },\n    distance_km: { type: Number, required: true, default: 0 },\n    rfid_card: { type: String },\n    notes: { type: String },\n  },\n  {\n    timestamps: { createdAt: 'created_at', updatedAt: 'updated_at' },\n    versionKey: false,\n  },\n);\n\nDatSessionSchema.index({ session_type: 1 });\nDatSessionSchema.index({ start_time: -1 });\n\nexport const DatSessionModel =\n  mongoose.models.DatSession || mongoose.model<IDatSession>('DatSession', DatSessionSchema);\nimport mongoose, { Schema, Document, Types } from 'mongoose';\n\nexport enum ExamType {\n  Graduation = 'graduation',\n  SatHach = 'sat_hach',\n}\n\nexport enum ExamResult {\n  Pass = 'pass',\n  Fail = 'fail',\n  NoResult = 'no_result',\n}\n\nexport interface IExamTypeResult {\n  result: string;\n  name: string;\n  lesson_type_id?: string;\n  description?: string;\n}\n\nexport interface IExam extends Document {\n  course_student_id?: Types.ObjectId | null;\n  exam_types?: Map<string, IExamTypeResult>;\n  stadium_id?: Types.ObjectId | null;\n  license_category_id?: Types.ObjectId | null;\n  parent_id?: Types.ObjectId | null;\n\n  name: string;\n  status: string;\n  exam_type: ExamType;\n\n  start_time?: Date;\n  end_time?: Date;\n\n  description?: string;\n  session?: string;\n  exam_number?: number;\n\n  is_pickup: boolean;\n  pickup_point?: string;\n  location?: string;\n  result: ExamResult;\n  registration_number?: string;\n  studentResults?: any[];\n  teacher_id?: Types.ObjectId | null;\n\n  created_at: Date;\n  updated_at: Date;\n}\n\nconst IExamTypeResultSchema = new Schema(\n  {\n    result: { type: String },\n    name: { type: String },\n    lesson_type_id: { type: String },\n    description: { type: String },\n  },\n  { _id: false },\n);\n\nconst ExamSchema = new Schema<IExam>(\n  {\n    course_student_id: { type: Schema.Types.ObjectId, ref: 'CourseStudents', index: true },\n    exam_types: {\n      type: Map,\n      of: IExamTypeResultSchema,\n    },\n    stadium_id: { type: Schema.Types.ObjectId, ref: 'Stadiums' },\n    license_category_id: { type: Schema.Types.ObjectId, ref: 'LicenseCategories' },\n    parent_id: { type: Schema.Types.ObjectId, ref: 'Exams', default: null },\n\n    name: { type: String, required: true, trim: true },\n    status: { type: String, trim: true },\n    exam_type: { type: String, enum: Object.values(ExamType), required: true },\n\n    start_time: { type: Date, index: true },\n    end_time: { type: Date },\n\n    description: { type: String, default: '' },\n    session: { type: String },\n    exam_number: { type: Number },\n\n    is_pickup: { type: Boolean, default: false },\n    pickup_point: { type: String },\n    location: { type: String },\n    result: { type: String, enum: Object.values(ExamResult), default: ExamResult.NoResult },\n    registration_number: { type: String },\n    studentResults: [{ type: Schema.Types.Mixed }],\n    teacher_id: { type: Schema.Types.ObjectId, ref: 'Users', index: true },\n  },\n  {\n    timestamps: { createdAt: 'created_at', updatedAt: 'updated_at' },\n    versionKey: false,\n  },\n);\n\nExamSchema.index({ exam_type: 1 });\nExamSchema.index({ stadium_id: 1 });\n\nexport const ExamModel = mongoose.models.Exams || mongoose.model<IExam>('Exams', ExamSchema);\nimport mongoose, { Schema, Document, Types } from 'mongoose';\n\nexport interface IExamBatch extends Document {\n  name: string;\n  vehicleType: string;\n  region: string;\n  examDate: Date;\n  officialDate?: Date;\n  venue: string;\n  stadium_id?: string;\n  status: 'upcoming' | 'confirmed' | 'completed' | 'cancelled';\n  studentResults: any[];\n  teacher_id?: Types.ObjectId | null;\n  created_at: Date;\n  updated_at: Date;\n}\n\nconst ExamBatchSchema = new Schema<IExamBatch>(\n  {\n    name: { type: String, required: true, trim: true },\n    vehicleType: { type: String, required: true, trim: true },\n    region: { type: String, required: true, trim: true },\n    examDate: { type: Date, required: true },\n    officialDate: { type: Date },\n    venue: { type: String, required: true, trim: true },\n    stadium_id: { type: String, trim: true },\n    status: {\n      type: String,\n      enum: ['upcoming', 'confirmed', 'completed', 'cancelled'],\n      default: 'upcoming',\n    },\n    studentResults: [{ type: Schema.Types.Mixed }],\n    teacher_id: { type: Schema.Types.ObjectId, ref: 'Users', index: true },\n  },\n  {\n    timestamps: { createdAt: 'created_at', updatedAt: 'updated_at' },\n    versionKey: false,\n  },\n);\n\nExamBatchSchema.index({ name: 1 });\nExamBatchSchema.index({ status: 1 });\nExamBatchSchema.index({ examDate: 1 });\n\nconst ExamBatchModel = mongoose.models.ExamBatch || mongoose.model<IExamBatch>('ExamBatch', ExamBatchSchema);\n\nexport default ExamBatchModel;\nimport mongoose, { Schema, Document, Types } from 'mongoose';\n\nexport interface IExamSchedule extends Document {\n  exam_id: Types.ObjectId;\n  start_time: Date;\n  end_time: Date;\n  note?: string;\n  created_at: Date;\n  updated_at: Date;\n}\n\nconst ExamScheduleSchema = new Schema<IExamSchedule>(\n  {\n    exam_id: { type: Schema.Types.ObjectId, ref: 'Exams', required: true, index: true },\n    start_time: { type: Date, required: true },\n    end_time: { type: Date, required: true },\n    note: { type: String, default: '' },\n  },\n  {\n    timestamps: { createdAt: 'created_at', updatedAt: 'updated_at' },\n    versionKey: false,\n    collection: 'examschedules',\n  },\n);\n\nExamScheduleSchema.index({ start_time: -1 });\nExamScheduleSchema.index({ start_time: 1, end_time: 1 });\n\nexport const ExamScheduleModel =\n  mongoose.models.ExamSchedules || mongoose.model<IExamSchedule>('ExamSchedules', ExamScheduleSchema, 'examschedules');\nimport { UserModel } from './user.model';\nimport { StudentModel } from './student.model';\nimport { CourseModel } from './course.model';\nimport { CourseStudentModel } from './course_student.model';\nimport { CityModel } from './city.model';\nimport { StadiumModel } from './stadium.model';\nimport { LessonModel } from './lesson.model';\nimport { ExamModel } from './exam.model';\nimport { DatSessionModel } from './dat_session.model';\nimport { PaymentModel } from './payment.model';\nimport ExamBatchModel from './exam_batch.model';\nimport { LicenseCategoryModel } from './license_category.model';\nimport { SupportRequestModel } from './support_request.model';\n\nexport {\n  UserModel,\n  StudentModel,\n  CourseModel,\n  CourseStudentModel,\n  CityModel,\n  StadiumModel,\n  LessonModel,\n  ExamModel,\n  DatSessionModel,\n  PaymentModel,\n  ExamBatchModel as ExamBatch,\n  LicenseCategoryModel,\n  SupportRequestModel,\n};\nimport mongoose, { Schema, Document, Types } from 'mongoose';\n\nexport enum LessonStatus {\n  Pending = 'pending',\n  InProgress = 'in_progress',\n  Completed = 'completed',\n  NoTeacher = 'no_teacher',\n  CanceledClass = 'canceled_class',\n  DroppedClass = 'dropped_class',\n  Deleted = 'deleted',\n}\n\nexport enum LessonCategory {\n  Theory = 'theory',\n  Practice = 'practice',\n}\n\nexport interface ILesson extends Document {\n  course_student_id?: Types.ObjectId;\n  student_id?: Types.ObjectId; // References User(student)\n  teacher_id?: Types.ObjectId; // References User(teacher)\n  name: string;\n  category: LessonCategory;\n  status: LessonStatus;\n  start_time: Date;\n  end_time: Date;\n  description?: string;\n  lesson_type_id?: Types.ObjectId;\n  vehicle_id?: Types.ObjectId;\n  is_night_course: boolean;\n  is_automatic_course: boolean;\n  km: number;\n  hour: string;\n  vehicle_type?: string;\n  stadium_id?: Types.ObjectId;\n  order: number;\n  confirmed: boolean;\n  pickup_point?: string;\n  is_pickup: boolean;\n  created_at: Date;\n  updated_at: Date;\n}\n\nconst LessonSchema = new Schema<ILesson>(\n  {\n    course_student_id: { type: Schema.Types.ObjectId, ref: 'CourseStudents', index: true },\n    student_id: { type: Schema.Types.ObjectId, ref: 'Users', index: true },\n    teacher_id: { type: Schema.Types.ObjectId, ref: 'Users', index: true },\n    name: { type: String, required: true },\n    category: {\n      type: String,\n      enum: Object.values(LessonCategory),\n      default: LessonCategory.Practice,\n      required: true,\n    },\n    status: {\n      type: String,\n      enum: Object.values(LessonStatus),\n      default: LessonStatus.Pending,\n      required: true,\n    },\n    start_time: { type: Date, required: true, index: true },\n    end_time: { type: Date, required: true },\n    description: { type: String, default: '' },\n    lesson_type_id: { type: Schema.Types.ObjectId },\n    vehicle_id: { type: Schema.Types.ObjectId },\n    is_night_course: { type: Boolean, default: false },\n    is_automatic_course: { type: Boolean, default: false },\n    km: { type: Number, default: 0 },\n    hour: { type: String, default: '00:00' },\n    vehicle_type: { type: String, enum: ['car', 'motorbike'] },\n    stadium_id: { type: Schema.Types.ObjectId, ref: 'Stadiums' },\n    order: { type: Number, default: 1 },\n    confirmed: { type: Boolean, default: false },\n    pickup_point: { type: String },\n    is_pickup: { type: Boolean, default: false },\n  },\n  {\n    timestamps: { createdAt: 'created_at', updatedAt: 'updated_at' },\n    versionKey: false,\n  },\n);\n\nexport const LessonModel = mongoose.models.Lessons || mongoose.model<ILesson>('Lessons', LessonSchema);\nimport mongoose, { Schema, Document } from 'mongoose';\n\nexport interface ILicenseCategory extends Document {\n  name: string;\n  code: string;\n  description?: string;\n  type: 'Ô tô' | 'Xe máy';\n  fee: string;\n  tags: string[];\n  inactive: string[];\n  dat?: string | null;\n  created_at: Date;\n  updated_at: Date;\n}\n\nconst LicenseCategorySchema = new Schema<ILicenseCategory>(\n  {\n    name: { type: String, required: true },\n    code: { type: String, required: true, unique: true },\n    description: { type: String },\n    type: { type: String, enum: ['Ô tô', 'Xe máy'], default: 'Ô tô' },\n    fee: { type: String, default: '0đ' },\n    tags: { type: [String], default: [] },\n    inactive: { type: [String], default: [] },\n    dat: { type: String, default: null },\n  },\n  {\n    timestamps: { createdAt: 'created_at', updatedAt: 'updated_at' },\n    versionKey: false,\n    collection: 'licensecategories',\n  },\n);\n\nif (mongoose.models.LicenseCategories) {\n  mongoose.deleteModel('LicenseCategories');\n}\nexport const LicenseCategoryModel = mongoose.model<ILicenseCategory>(\n  'LicenseCategories',\n  LicenseCategorySchema,\n  'licensecategories',\n);\nimport mongoose, { Schema, Document, Types } from 'mongoose';\n\nexport interface INotification extends Document {\n  config_id?: Types.ObjectId; // Referencing notification config/template\n  content_id?: Types.ObjectId; // Referencing the actual content\n  is_read: boolean;\n  receive_id: Types.ObjectId; // The recipient User ID\n  receive_type: 'user' | 'student' | 'teacher';\n  category?: 'notif' | 'system';\n\n  // Extension for direct notification if not using config_id/content_id\n  title?: string;\n  body?: string;\n  data?: any; // Extra payload for FCM\n\n  created_at: Date;\n  updated_at: Date;\n}\n\nconst NotificationSchema = new Schema<INotification>(\n  {\n    config_id: { type: Schema.Types.ObjectId, ref: 'NotifyConfigs', index: true },\n    content_id: { type: Schema.Types.ObjectId, ref: 'NotifyContents' },\n    is_read: { type: Boolean, default: false },\n    receive_id: { type: Schema.Types.ObjectId, ref: 'Users', required: true, index: true },\n    receive_type: {\n      type: String,\n      enum: ['user', 'student', 'teacher'],\n      default: 'user',\n    },\n    category: {\n      type: String,\n      enum: ['notif', 'system'],\n      default: 'notif',\n    },\n    title: { type: String },\n    body: { type: String },\n    data: { type: Schema.Types.Mixed },\n  },\n  {\n    timestamps: { createdAt: 'created_at', updatedAt: 'updated_at' },\n    versionKey: false,\n  },\n);\n\nNotificationSchema.index({ created_at: -1 });\n\nexport const NotificationModel =\n  mongoose.models.Notification || mongoose.model<INotification>('Notification', NotificationSchema);\n/**\n * notifies — aligned to ahv-driving-training reference.\n * Collection name: \"notifies\" (plural, all lowercase).\n * Bootstrap-backup fields moved to notifyContents.data.\n */\nimport mongoose, { Schema, Document, Model, Types } from 'mongoose';\n\nexport const INotifyStatus = {\n  Draft: 'draft',\n  Sent: 'sent',\n  Cancel: 'cancel',\n} as const;\nexport type NotifyStatus = (typeof INotifyStatus)[keyof typeof INotifyStatus];\n\nexport interface INotify extends Document {\n  content_id: Types.ObjectId;\n  config_id: Types.ObjectId;\n  status: NotifyStatus;\n  created_at: Date;\n  updated_at: Date;\n}\n\nconst NotifySchema = new Schema<INotify>(\n  {\n    content_id: {\n      type: Schema.Types.ObjectId,\n      ref: 'NotifyContent',\n      required: [true, 'content_id is required'],\n      index: true,\n    },\n    config_id: {\n      type: Schema.Types.ObjectId,\n      ref: 'NotifyConfigs',\n      required: [true, 'config_id is required'],\n      index: true,\n    },\n    status: {\n      type: String,\n      enum: Object.values(INotifyStatus),\n      default: 'draft',\n      required: [true, 'status is required'],\n    },\n  },\n  {\n    timestamps: { createdAt: 'created_at', updatedAt: 'updated_at' },\n    versionKey: false,\n    toJSON: {\n      virtuals: true,\n      transform: (_doc, ret: Record<string, unknown>) => {\n        ret.id = ret._id;\n        delete ret._id;\n        return ret;\n      },\n    },\n    toObject: {\n      virtuals: true,\n      transform: (_doc, ret: Record<string, unknown>) => {\n        ret.id = ret._id;\n        delete ret._id;\n        return ret;\n      },\n    },\n  },\n);\n\nNotifySchema.index({ created_at: -1, status: 1 });\n\nconst Notify: Model<INotify> = mongoose.models.notifies || mongoose.model<INotify>('notifies', NotifySchema);\n\nexport default Notify;\n/**\n * NotifyConfigs — aligned to ahv-driving-training reference.\n * Exact field names preserved. Used as required config_id in notifies.\n */\nimport mongoose, { Schema, Document, Model } from 'mongoose';\n\nexport const INotifyChannelConfig = {\n  Telegram: 'Telegram',\n  Zalo: 'Zalo',\n  CMS: 'CMS',\n  Mobile: 'Mobile',\n} as const;\nexport type NotifyChannelConfig = (typeof INotifyChannelConfig)[keyof typeof INotifyChannelConfig];\n\nexport interface INotifyConfig extends Document {\n  name: string | null;\n  channel: NotifyChannelConfig;\n  channel_config: Record<string, unknown>;\n  schedule_config: { time?: string; days?: number[] } | null;\n  api_config: Record<string, unknown>;\n  active: boolean;\n  is_schedule: boolean;\n  created_at: Date;\n  updated_at: Date;\n}\n\nconst NotifyConfigSchema = new Schema<INotifyConfig>(\n  {\n    name: { type: String, default: null, trim: true },\n    channel: {\n      type: String,\n      enum: Object.values(INotifyChannelConfig),\n      required: [true, 'channel is required'],\n    },\n    channel_config: { type: Schema.Types.Mixed, default: {} },\n    schedule_config: {\n      type: Schema.Types.Mixed,\n      default: null,\n    },\n    api_config: { type: Schema.Types.Mixed, default: {} },\n    active: { type: Boolean, default: true, index: true },\n    is_schedule: { type: Boolean, default: false, index: true },\n  },\n  {\n    timestamps: { createdAt: 'created_at', updatedAt: 'updated_at' },\n    versionKey: false,\n    toJSON: { virtuals: true },\n    toObject: { virtuals: true },\n  },\n);\n\nNotifyConfigSchema.index({ active: 1, is_schedule: 1 });\n\nconst NotifyConfig: Model<INotifyConfig> =\n  mongoose.models.NotifyConfigs || mongoose.model<INotifyConfig>('NotifyConfigs', NotifyConfigSchema);\n\nexport default NotifyConfig;\n/**\n * notifyContents — aligned to ahv-driving-training reference.\n * Bootstrap-backup extensions stored in data{} field.\n */\nimport mongoose, { Schema, Document, Model } from 'mongoose';\n\n// Use exact ITypeNotifies from ahv-driving-training, extended with bootstrap-backup types\nexport const ITypeNotifies = {\n  // ahv-driving-training types\n  Lesson: 'lesson',\n  Coupons: 'coupons',\n  CreateLesson: 'createLesson',\n  UpdateLesson: 'updateLesson',\n  DeleteLesson: 'deleteLesson',\n  CreateExam: 'createExam',\n  UpdateExam: 'updateExam',\n  DeleteExam: 'deleteExam',\n  CreateExamSchedules: 'createExamSchedules',\n  UpdateExamRegistrationStatus: 'updateExamRegistrationStatus',\n  DeleteExamRegistrationStatus: 'deleteExamRegistrationStatus',\n  CreateStudentComment: 'createStudentComment',\n  UpdateStudentComment: 'updateStudentComment',\n  DeleteStudentComment: 'deleteStudentComment',\n  CreateTeacherComment: 'createTeacherComment',\n  UpdateTeacherComment: 'updateTeacherComment',\n  DeleteTeacherComment: 'deleteTeacherComment',\n  // bootstrap-backup extensions\n  Announcement: 'announcement',\n  System: 'system',\n  Payment: 'payment',\n  Dat: 'dat',\n  Manual: 'manual',\n} as const;\nexport type NotifyType = (typeof ITypeNotifies)[keyof typeof ITypeNotifies];\n\nexport interface INotifyContent extends Document {\n  title: string | null;\n  sub_title: string | null;\n  content: string | null;\n  sub_content: string | null;\n  types: NotifyType;\n  data: {\n    // bootstrap-backup extensions (moved from notifies model)\n    source_type?: string;\n    source_id?: string;\n    channel?: string;\n    target_group?: string;\n    scheduled_at?: Date;\n    created_by?: mongoose.Types.ObjectId;\n    channels?: string[];\n    // legacy data from Notification/Announcement\n    [key: string]: unknown;\n  } | null;\n  created_at: Date;\n  updated_at: Date;\n}\n\nconst NotifyContentSchema = new Schema<INotifyContent>(\n  {\n    title: { type: String, default: null, trim: true },\n    sub_title: { type: String, default: null, trim: true },\n    content: { type: String, default: null, trim: true },\n    sub_content: { type: String, default: null, trim: true },\n    types: {\n      type: String,\n      enum: Object.values(ITypeNotifies),\n      required: [true, 'types is required'],\n      index: true,\n    },\n    data: { type: Schema.Types.Mixed, default: null },\n  },\n  {\n    timestamps: { createdAt: 'created_at', updatedAt: 'updated_at' },\n    versionKey: false,\n    toJSON: { virtuals: true },\n    toObject: { virtuals: true },\n  },\n);\n\nNotifyContentSchema.index({ types: 1, created_at: -1 });\n\nconst NotifyContent: Model<INotifyContent> =\n  mongoose.models.NotifyContent || mongoose.model<INotifyContent>('NotifyContent', NotifyContentSchema);\n\nexport default NotifyContent;\n/**\n * notifyUsers — aligned to ahv-driving-training reference.\n * Bootstrap-backup extensions stored in data{} field.\n */\nimport mongoose, { Schema, Document, Model, Types } from 'mongoose';\n\nexport const READ_STATUSES = ['unread', 'read'] as const;\nexport type ReadStatus = (typeof READ_STATUSES)[number];\n\nexport interface INotifyUser extends Document {\n  notify_id: Types.ObjectId;\n  user_id: Types.ObjectId;\n  status: ReadStatus;\n  data: {\n    // bootstrap-backup extensions\n    receive_type?: 'user' | 'student' | 'teacher';\n    delivered_at?: Date;\n    read_at?: Date;\n    [key: string]: unknown;\n  } | null;\n  created_at: Date;\n  updated_at: Date;\n}\n\nconst NotifyUserSchema = new Schema<INotifyUser>(\n  {\n    notify_id: {\n      type: Schema.Types.ObjectId,\n      ref: 'notifies',\n      required: [true, 'notify_id is required'],\n      index: true,\n    },\n    user_id: {\n      type: Schema.Types.ObjectId,\n      ref: 'Users',\n      required: [true, 'user_id is required'],\n      index: true,\n    },\n    status: {\n      type: String,\n      enum: READ_STATUSES,\n      default: 'unread',\n      index: true,\n    },\n    data: { type: Schema.Types.Mixed, default: null },\n  },\n  {\n    timestamps: { createdAt: 'created_at', updatedAt: 'updated_at' },\n    versionKey: false,\n    toJSON: { virtuals: true },\n    toObject: { virtuals: true },\n  },\n);\n\n// Unique: one record per (user, notify) pair\nNotifyUserSchema.index({ user_id: 1, notify_id: 1 }, { unique: true });\nNotifyUserSchema.index({ user_id: 1, created_at: -1 });\n\nconst NotifyUser: Model<INotifyUser> =\n  mongoose.models.notifyUsers || mongoose.model<INotifyUser>('notifyUsers', NotifyUserSchema);\n\nexport default NotifyUser;\nimport mongoose, { Schema, Document, Types } from 'mongoose';\n\nexport enum PaymentType {\n  TuitionFee = 'tuition_fee',\n  ChipRegistrationFee = 'chip_registration_fee',\n  PickupFee = 'pickup_fee',\n  ChipDepositFee = 'chip_deposit_fee',\n  ReExamFee = 're_exam_fee',\n  TheoryCompleted = 'theory_completed',\n  PracticeCompleted = 'practice_completed',\n  GraduationExam = 'graduation_exam',\n  Other = 'other',\n}\n\nexport interface IPayment extends Document {\n  course_student_id: Types.ObjectId;\n  sale_id?: Types.ObjectId;\n  payment_date: Date;\n  type: PaymentType;\n  note?: string;\n  confirmer_id?: Types.ObjectId; // User ID who confirmed the payment\n  is_received: boolean;\n  received_fee: number;\n  stage_name?: string; // Tên đợt đóng phí tùy chỉnh từ settings\n  created_at: Date;\n  updated_at: Date;\n  is_deleted: boolean;\n  deleted_at: Date | null;\n}\n\nconst PaymentSchema = new Schema<IPayment>(\n  {\n    course_student_id: { type: Schema.Types.ObjectId, ref: 'CourseStudents', required: true, index: true },\n    sale_id: { type: Schema.Types.ObjectId, ref: 'Users' },\n    payment_date: { type: Date, required: true },\n    type: {\n      type: String,\n      enum: Object.values(PaymentType),\n      required: true,\n    },\n    note: { type: String },\n    confirmer_id: { type: Schema.Types.ObjectId, ref: 'Users' },\n    is_received: { type: Boolean, default: false },\n    received_fee: { type: Number, default: 0 },\n    stage_name: { type: String },\n  },\n  {\n    timestamps: { createdAt: 'created_at', updatedAt: 'updated_at' },\n    versionKey: false,\n  },\n);\n\nPaymentSchema.index({ payment_date: -1 });\nPaymentSchema.index({ type: 1 });\n\nexport const PaymentModel = mongoose.models.Payments || mongoose.model<IPayment>('Payments', PaymentSchema);\nimport mongoose, { Schema, Document, Types } from 'mongoose';\n\n// Role names as defined in Master AHV system\nexport enum UserRoleName {\n  Admin = 'admin',\n  SuperAdmin = 'superadmin',\n  Teacher = 'teacher',\n  Staff = 'staff',\n  Sale = 'sale',\n  Student = 'student',\n  Lead = 'lead',\n  User = 'user',\n}\n\nexport interface IRole extends Document {\n  _id: Types.ObjectId;\n  role_name: string;\n  created_at: Date;\n  updated_at: Date;\n}\n\nconst RoleSchema = new Schema<IRole>(\n  {\n    role_name: {\n      type: String,\n      trim: true,\n      unique: true,\n      required: [true, 'Tên vai trò là bắt buộc'],\n    },\n  },\n  {\n    timestamps: { createdAt: 'created_at', updatedAt: 'updated_at' },\n    versionKey: false,\n    collection: 'roles',\n  },\n);\n\n// Removed duplicate index since unique: true already creates one\n\nexport const RoleModel = mongoose.models.Roles || mongoose.model<IRole>('Roles', RoleSchema, 'roles');\nimport mongoose, { Schema, Document } from 'mongoose';\n\nexport interface ILicenseCategory {\n  id: string;\n  type: string;\n  name: string;\n  fee: string;\n  tags: string[];\n  inactive: string[];\n  dat?: string | null;\n}\n\nexport interface IClinic {\n  name: string;\n  info: string;\n}\n\nexport interface ISettings extends Document {\n  userId: string;\n  regions: string[];\n  license_categories: ILicenseCategory[];\n  fee_stages: string[];\n  clinic_list: IClinic[];\n  examVenues: string[];\n  requiredFields: string[];\n  practiceTargetMinutes: number;\n  center_name: string;\n  center_website: string;\n  center_address: string;\n  center_phone: string;\n  center_email: string;\n  center_fax?: string;\n  createdAt: Date;\n  updatedAt: Date;\n}\n\nconst SettingsSchema: Schema = new Schema(\n  {\n    userId: { type: Schema.Types.ObjectId, ref: 'Users', required: true, unique: true },\n    regions: { type: [String], default: [] },\n    license_categories: { type: [Schema.Types.Mixed], default: [] },\n    fee_stages: { type: [String], default: [] },\n    clinic_list: { type: [Schema.Types.Mixed], default: [] },\n    examVenues: { type: [String], default: [] },\n    requiredFields: { type: [String], default: [] },\n    practiceTargetMinutes: { type: Number, default: 420 },\n    center_name: { type: String, default: 'AHV Driving Training' },\n    center_website: { type: String, default: 'ahvdriving-training.com' },\n    center_address: { type: String, default: 'Thái Nguyên' },\n    center_phone: { type: String, default: '09278364782' },\n    center_email: { type: String, default: 'ahvdriving@ahvholding.com' },\n    center_fax: { type: String, default: '' },\n  },\n  { timestamps: true },\n);\n\nexport default mongoose.model<ISettings>('Settings', SettingsSchema);\nimport mongoose, { Schema, Document } from 'mongoose';\n\nexport interface IStadium extends Document {\n  name: string;\n  locate?: string; // Master field name\n  note?: string; // Master field name\n  status: 'active' | 'inactive' | 'maintenance';\n  created_at: Date;\n  updated_at: Date;\n}\n\nconst StadiumSchema: Schema = new Schema(\n  {\n    name: { type: String, required: true, trim: true },\n    locate: { type: String, trim: true, default: '' }, // Detailed location/address string\n    address: { type: String, trim: true, default: '' }, // Alias for locate\n    city: { type: String, trim: true, default: '' }, // City name string\n    mapsLink: { type: String, trim: true, default: '' }, // Google Maps URL\n    note: { type: String, trim: true, default: '' }, // Additional info\n    region_id: { type: Schema.Types.ObjectId, ref: 'Cities', default: null }, // Reference to Cities collection\n    status: {\n      type: String,\n      enum: ['active', 'inactive', 'maintenance'],\n      default: 'active',\n      trim: true,\n    },\n  },\n  {\n    timestamps: { createdAt: 'created_at', updatedAt: 'updated_at' },\n    versionKey: false,\n    collection: 'stadium', // Master collection name\n  },\n);\n\nStadiumSchema.index({ name: 1 });\n\nexport const StadiumModel = mongoose.models.Stadiums || mongoose.model<IStadium>('Stadiums', StadiumSchema, 'stadium');\nexport default StadiumModel;\nimport mongoose, { Schema, Document, Types } from 'mongoose';\nimport { IUser } from './user.model';\n\nexport interface IStudent extends Document {\n  user_id: Types.ObjectId | IUser; // Can be ID or populated User object\n  card_id?: string | null;\n  profile_created_at?: Date | null;\n  email_verified_at?: Date | null;\n  lead_manager?: string | null;\n  region_id?: Types.ObjectId | null;\n  license_category_id?: Types.ObjectId | null;\n  course_id?: Types.ObjectId | null;\n  student_code?: string | null;\n  teacher_id?: Types.ObjectId | null;\n  balance?: any;\n  created_at: Date;\n  updated_at: Date;\n  is_deleted: boolean;\n  deleted_at: Date | null;\n  // Merged fields from Enrollment for UI/Tests (Source of truth is CourseStudent)\n  status_detail?: string;\n}\n\nconst StudentSchema = new Schema<IStudent>(\n  {\n    user_id: { type: Schema.Types.ObjectId, ref: 'Users', required: true, index: true },\n    balance: {\n      type: Schema.Types.Decimal128,\n      default: 0,\n      get: (v: any) => (v ? parseFloat(v.toString()) : 0),\n    },\n    card_id: { type: String, default: null },\n    profile_created_at: { type: Date, default: null },\n    email_verified_at: { type: Date, default: null },\n    lead_manager: { type: String, default: null },\n    course_id: { type: Schema.Types.ObjectId, ref: 'Courses', default: null },\n    license_category_id: { type: Schema.Types.ObjectId, ref: 'LicenseCategories', default: null },\n    student_code: { type: String, default: null, index: true },\n    teacher_id: { type: Schema.Types.ObjectId, ref: 'Users', default: null, index: true },\n\n    // Extension\n    region_id: { type: Schema.Types.ObjectId, ref: 'Cities', default: null },\n    is_deleted: { type: Boolean, default: false, index: true },\n    deleted_at: { type: Date, default: null },\n\n    // Merged fields for UI/Tests (Primary source is CourseStudent)\n    status_detail: { type: String, default: 'Chờ KSK' },\n  },\n  {\n    timestamps: { createdAt: 'created_at', updatedAt: 'updated_at' },\n    versionKey: false,\n    collection: 'studentinfos',\n  },\n);\n\nStudentSchema.index({ region_id: 1, created_at: -1 });\nStudentSchema.index({ created_at: -1, is_deleted: 1 });\nStudentSchema.index({ course_id: 1, created_at: -1 });\nStudentSchema.index({ license_category_id: 1, created_at: -1 });\n\nif (mongoose.models.StudentInfos) {\n  mongoose.deleteModel('StudentInfos');\n}\nexport const StudentModel = mongoose.model<IStudent>('StudentInfos', StudentSchema, 'studentinfos');\nimport mongoose, { Schema, Document, Types } from 'mongoose';\nimport { IUser } from './user.model';\n\nexport interface ISupportRequest extends Document {\n  sender_id: Types.ObjectId | IUser;\n  sender_role?: string;\n  topic: string;\n  priority: string;\n  title: string;\n  description: string;\n  attachments?: string[];\n  status: string;\n  resolved_by?: Types.ObjectId | IUser | null;\n  resolution_notes?: string | null;\n  resolved_at?: Date | null;\n  created_at: Date;\n  updated_at: Date;\n}\n\nconst SupportRequestSchema = new Schema<ISupportRequest>(\n  {\n    sender_id: { type: Schema.Types.ObjectId, ref: 'Users', required: true, index: true },\n    sender_role: { type: String, enum: ['teacher', 'admin', 'superadmin', 'student'], default: 'teacher' },\n    topic: { \n      type: String, \n      required: true,\n      enum: ['Lỗi phần mềm', 'Tư vấn tính năng', 'Thanh toán & Nạp tiền', 'Khác'],\n      default: 'Khác' \n    },\n    priority: {\n      type: String,\n      required: true,\n      enum: ['Thấp', 'Bình thường', 'Cao', 'Nghiêm trọng'],\n      default: 'Bình thường'\n    },\n    title: { type: String, required: true, trim: true, maxlength: 150 },\n    description: { type: String, required: true, trim: true, maxlength: 2000 },\n    attachments: { type: [String], default: [] },\n    status: {\n      type: String,\n      required: true,\n      enum: ['Mới', 'Đang xử lý', 'Hoàn thành', 'Đã hủy'],\n      default: 'Mới',\n      index: true\n    },\n    resolved_by: { type: Schema.Types.ObjectId, ref: 'Users', default: null },\n    resolution_notes: { type: String, trim: true, default: null },\n    resolved_at: { type: Date, default: null },\n  },\n  {\n    timestamps: { createdAt: 'created_at', updatedAt: 'updated_at' },\n    versionKey: false,\n    collection: 'support_requests',\n  }\n);\n\n// Indexes to speed up admin queries\nSupportRequestSchema.index({ status: 1, created_at: -1 });\nSupportRequestSchema.index({ sender_id: 1, created_at: -1 });\n\n// Avoid OverwriteModelError\nif (mongoose.models.SupportRequests) {\n  mongoose.deleteModel('SupportRequests');\n}\n\nexport const SupportRequestModel = mongoose.model<ISupportRequest>('SupportRequests', SupportRequestSchema, 'support_requests');\nimport mongoose, { Schema, Document, Types } from 'mongoose';\n\nexport enum ActionType {\n  CREATE = 'CREATE',\n  UPDATE = 'UPDATE',\n  DELETE = 'DELETE',\n  LOGIN = 'LOGIN',\n  LOGOUT = 'LOGOUT',\n}\n\nexport interface ISystemLog extends Document {\n  user_id: Types.ObjectId;\n  title: string;\n  description?: string;\n  action: ActionType;\n  entity_type: string;\n  entity_id: string;\n  old_data?: any;\n  new_data?: any;\n  ip_address?: string;\n  user_agent?: string;\n  created_at: Date;\n  updated_at: Date;\n}\n\nconst SystemLogSchema = new Schema<ISystemLog>(\n  {\n    user_id: { type: Schema.Types.ObjectId, ref: 'Users', required: true, index: true },\n    title: { type: String, trim: true, required: true },\n    description: { type: String, trim: true, default: '' },\n    action: { type: String, enum: Object.values(ActionType), required: true },\n    entity_type: { type: String, required: true },\n    entity_id: { type: String, required: true },\n    old_data: { type: Schema.Types.Mixed },\n    new_data: { type: Schema.Types.Mixed },\n    ip_address: { type: String },\n    user_agent: { type: String },\n  },\n  {\n    timestamps: { createdAt: 'created_at', updatedAt: 'updated_at' },\n    versionKey: false,\n    collection: 'logtasks',\n  },\n);\n\nSystemLogSchema.index({ entity_type: 1, entity_id: 1 });[... 5527 more characters truncated]"}],"details":{"status":"completed","exitCode":0,"durationMs":197,"aggregated":"import mongoose, { Schema, Document } from 'mongoose';\n\nexport interface IAnnouncement extends Document {\n  title: string;\n  content: string;\n  target_group: 'ALL' | 'STUDENT' | 'TEACHER' | 'STAFF';\n  channels: ('APP' | 'EMAIL' | 'SMS')[];\n  status: 'SENT' | 'SCHEDULED';\n  scheduled_at?: Date;\n  created_by?: mongoose.Types.ObjectId;\n  createdAt: Date;\n  updatedAt: Date;\n}\n\nconst AnnouncementSchema: Schema = new Schema(\n  {\n    title: { type: String, required: true },\n    content: { type: String, required: true },\n    target_group: {\n      type: String,\n      enum: ['ALL', 'STUDENT', 'TEACHER', 'STAFF'],\n      default: 'ALL',\n    },\n    channels: [\n      {\n        type: String,\n        enum: ['APP', 'EMAIL', 'SMS'],\n      },\n    ],\n    status: {\n      type: String,\n      enum: ['SENT', 'SCHEDULED'],\n      default: 'SENT',\n    },\n    scheduled_at: { type: Date },\n    created_by: { type: Schema.Types.ObjectId, ref: 'Users' },\n  },\n  { timestamps: true, collection: 'announcements' },\n);\n\nexport const AnnouncementModel = mongoose.model<IAnnouncement>('Announcement', AnnouncementSchema);\nexport default AnnouncementModel;\nimport mongoose, { Schema, Document } from 'mongoose';\n\nexport interface ICity extends Document {\n  name: string;\n  code: string;\n  created_at: Date;\n  updated_at: Date;\n}\n\nconst CitySchema = new Schema<ICity>(\n  {\n    name: { type: String, required: true },\n    code: { type: String, required: true, unique: true },\n  },\n  {\n    timestamps: { createdAt: 'created_at', updatedAt: 'updated_at' },\n    versionKey: false,\n    collection: 'cities',\n  },\n);\n\nexport const CityModel = mongoose.models.Cities || mongoose.model<ICity>('Cities', CitySchema, 'cities');\nimport mongoose, { Schema, Document, Types } from 'mongoose';\n\nexport interface ICourseFeeStage {\n  name: string;\n  amount: number;\n}\n\nexport interface ICourse extends Document {\n  license_category_id?: Types.ObjectId | null;\n  code: string; // Mã nội bộ của trung tâm\n  name: string; // Tên khóa học\n  system_course_id?: number;\n  system_course_code?: string; // Mã báo cáo lên Sở GTVT\n  curriculum_id?: number;\n  management_record_number?: string;\n  description?: string;\n  report_start_date?: Date;\n  start_date?: Date;\n  end_date?: Date;\n  dat_date?: Date; // Ngày tập trung chạy DAT\n  cabin_date?: Date; // Ngày học Cabin\n  decision_to_sign?: string;\n  duration?: number;\n  status: 'draft' | 'ongoing' | 'completed' | 'canceled';\n  course_fee?: number;\n  max_students?: number;\n  teacher_id?: Types.ObjectId | null;\n\n  // Extension for Web Admin\n  internal_note?: string;\n  note?: string;\n  course_type?: string;\n  fee_stages?: ICourseFeeStage[];\n  created_at: Date;\n  updated_at: Date;\n}\n\nconst CourseSchema = new Schema<ICourse>(\n  {\n    license_category_id: { type: Schema.Types.ObjectId, ref: 'LicenseCategories', default: null },\n    code: { type: String, required: true, unique: true, index: true },\n    name: { type: String, required: true },\n    system_course_id: { type: Number },\n    system_course_code: { type: String },\n    curriculum_id: { type: Number },\n    management_record_number: { type: String },\n    description: { type: String },\n    report_start_date: { type: Date },\n    start_date: { type: Date },\n    end_date: { type: Date },\n    dat_date: { type: Date },\n    cabin_date: { type: Date },\n    decision_to_sign: { type: String },\n    duration: { type: Number },\n    status: {\n      type: String,\n      enum: ['draft', 'ongoing', 'completed', 'canceled'],\n      default: 'draft',\n    },\n    course_fee: { type: Number, default: 0 },\n    max_students: { type: Number, default: 50 },\n    teacher_id: { type: Schema.Types.ObjectId, ref: 'Users', index: true, default: null },\n    internal_note: { type: String },\n    note: { type: String },\n    course_type: { type: String, default: 'trực tiếp' },\n    fee_stages: [\n      {\n        name: { type: String },\n        amount: { type: Number, default: 0 },\n      },\n    ],\n  },\n  {\n    timestamps: { createdAt: 'created_at', updatedAt: 'updated_at' },\n    versionKey: false,\n    collection: 'courses',\n  },\n);\n\nCourseSchema.index({ status: 1 });\nCourseSchema.index({ start_date: -1 });\n\nif (mongoose.models.Courses) {\n  mongoose.deleteModel('Courses');\n}\nexport const CourseModel = mongoose.model<ICourse>('Courses', CourseSchema, 'courses');\nimport mongoose, { Schema, Document, Types } from 'mongoose';\n\nexport interface ICourseStudent extends Document {\n  student_id: Types.ObjectId; // References Student(student_infos)\n  course_id: Types.ObjectId; // References Course(course_infos)\n  stadium_id?: Types.ObjectId | null;\n  teacher_id?: Types.ObjectId | null;\n  sale_id?: Types.ObjectId | null;\n  license_category_id?: Types.ObjectId | null;\n  status: 'unfinished' | 'finished' | 'canceled';\n  km: number;\n  hour: string;\n  fee: number;\n  paid_fee: number;\n  balance?: any; // Treasury balance for this enrollment\n  contract_date?: Date | null;\n  status_detail?: string;\n  progress_flags?: {\n    theory_completed: boolean;\n    sand_yard_completed: boolean;\n    simulation_completed: boolean;\n    dat_completed: boolean;\n    cabin_completed: boolean;\n    graduation_eligible: boolean;\n  };\n  health_check?: {\n    status: string;\n    date: Date | null;\n    hospital: string | null;\n    note: string | null;\n  };\n  created_at: Date;\n  updated_at: Date;\n}\n\nconst CourseStudentSchema = new Schema<ICourseStudent>(\n  {\n    student_id: { type: Schema.Types.ObjectId, ref: 'StudentInfos', required: true, index: true },\n    course_id: { type: Schema.Types.ObjectId, ref: 'Courses', required: true, index: true },\n    stadium_id: { type: Schema.Types.ObjectId, ref: 'Stadiums', default: null },\n    teacher_id: { type: Schema.Types.ObjectId, ref: 'Users', default: null },\n    sale_id: { type: Schema.Types.ObjectId, ref: 'Users', default: null },\n    license_category_id: { type: Schema.Types.ObjectId, ref: 'LicenseCategories', default: null },\n    status: {\n      type: String,\n      enum: ['unfinished', 'finished', 'canceled'],\n      default: 'unfinished',\n    },\n    km: { type: Number, default: 0 },\n    hour: { type: String, default: '00:00' },\n    fee: { type: Number, default: 0 },\n    paid_fee: { type: Number, default: 0 },\n    balance: {\n      type: Schema.Types.Decimal128,\n      default: 0,\n      get: (v: any) => (v ? parseFloat(v.toString()) : 0),\n    },\n    contract_date: { type: Date, default: null },\n    status_detail: { type: String, default: 'Chờ KSK' },\n    progress_flags: {\n      theory_completed: { type: Boolean, default: false },\n      sand_yard_completed: { type: Boolean, default: false },\n      simulation_completed: { type: Boolean, default: false },\n      dat_completed: { type: Boolean, default: false },\n      cabin_completed: { type: Boolean, default: false },\n      graduation_eligible: { type: Boolean, default: false },\n    },\n    health_check: {\n      status: { type: String, enum: ['Chờ khám', 'Đủ điều kiện', 'Không đủ điều kiện'], default: 'Chờ khám' },\n      date: { type: Date, default: null },\n      hospital: { type: String, default: null },\n      note: { type: String, default: null },\n    },\n  },\n  {\n    timestamps: { createdAt: 'created_at', updatedAt: 'updated_at' },\n    versionKey: false,\n    collection: 'coursestudents',\n  },\n);\n\nCourseStudentSchema.index({ student_id: 1, created_at: -1 });\nCourseStudentSchema.index({ course_id: 1, created_at: -1 });\nCourseStudentSchema.index({ status_detail: 1, created_at: -1 });\nCourseStudentSchema.index({ sale_id: 1, created_at: -1 });\nCourseStudentSchema.index({ 'progress_flags.dat_completed': 1, status_detail: 1 });\nCourseStudentSchema.index({ fee: 1, paid_fee: 1 });\n\nexport const CourseStudentModel =\n  mongoose.models.CourseStudents ||\n  mongoose.model<ICourseStudent>('CourseStudents', CourseStudentSchema, 'coursestudents');\nimport mongoose, { Schema, Document, Types } from 'mongoose';\n\nexport enum DatSessionType {\n  Cabin = 'cabin',\n  Dat = 'dat',\n}\n\nexport interface IDatSession extends Document {\n  course_student_id: Types.ObjectId;\n  session_type: DatSessionType;\n  start_time: Date;\n  end_time: Date;\n  distance_km: number;\n  rfid_card?: string;\n  notes?: string;\n  created_at: Date;\n  updated_at: Date;\n}\n\nconst DatSessionSchema = new Schema<IDatSession>(\n  {\n    course_student_id: { type: Schema.Types.ObjectId, ref: 'CourseStudents', required: true, index: true },\n    session_type: { type: String, enum: Object.values(DatSessionType), required: true },\n    start_time: { type: Date, required: true },\n    end_time: { type: Date, required: true },\n    distance_km: { type: Number, required: true, default: 0 },\n    rfid_card: { type: String },\n    notes: { type: String },\n  },\n  {\n    timestamps: { createdAt: 'created_at', updatedAt: 'updated_at' },\n    versionKey: false,\n  },\n);\n\nDatSessionSchema.index({ session_type: 1 });\nDatSessionSchema.index({ start_time: -1 });\n\nexport const DatSessionModel =\n  mongoose.models.DatSession || mongoose.model<IDatSession>('DatSession', DatSessionSchema);\nimport mongoose, { Schema, Document, Types } from 'mongoose';\n\nexport enum ExamType {\n  Graduation = 'graduation',\n  SatHach = 'sat_hach',\n}\n\nexport enum ExamResult {\n  Pass = 'pass',\n  Fail = 'fail',\n  NoResult = 'no_result',\n}\n\nexport interface IExamTypeResult {\n  result: string;\n  name: string;\n  lesson_type_id?: string;\n  description?: string;\n}\n\nexport interface IExam extends Document {\n  course_student_id?: Types.ObjectId | null;\n  exam_types?: Map<string, IExamTypeResult>;\n  stadium_id?: Types.ObjectId | null;\n  license_category_id?: Types.ObjectId | null;\n  parent_id?: Types.ObjectId | null;\n\n  name: string;\n  status: string;\n  exam_type: ExamType;\n\n  start_time?: Date;\n  end_time?: Date;\n\n  description?: string;\n  session?: string;\n  exam_number?: number;\n\n  is_pickup: boolean;\n  pickup_point?: string;\n  location?: string;\n  result: ExamResult;\n  registration_number?: string;\n  studentResults?: any[];\n  teacher_id?: Types.ObjectId | null;\n\n  created_at: Date;\n  updated_at: Date;\n}\n\nconst IExamTypeResultSchema = new Schema(\n  {\n    result: { type: String },\n    name: { type: String },\n    lesson_type_id: { type: String },\n    description: { type: String },\n  },\n  { _id: false },\n);\n\nconst ExamSchema = new Schema<IExam>(\n  {\n    course_student_id: { type: Schema.Types.ObjectId, ref: 'CourseStudents', index: true },\n    exam_types: {\n      type: Map,\n      of: IExamTypeResultSchema,\n    },\n    stadium_id: { type: Schema.Types.ObjectId, ref: 'Stadiums' },\n    license_category_id: { type: Schema.Types.ObjectId, ref: 'LicenseCategories' },\n    parent_id: { type: Schema.Types.ObjectId, ref: 'Exams', default: null },\n\n    name: { type: String, required: true, trim: true },\n    status: { type: String, trim: true },\n    exam_type: { type: String, enum: Object.values(ExamType), required: true },\n\n    start_time: { type: Date, index: true },\n    end_time: { type: Date },\n\n    description: { type: String, default: '' },\n    session: { type: String },\n    exam_number: { type: Number },\n\n    is_pickup: { type: Boolean, default: false },\n    pickup_point: { type: String },\n    location: { type: String },\n    result: { type: String, enum: Object.values(ExamResult), default: ExamResult.NoResult },\n    registration_number: { type: String },\n    studentResults: [{ type: Schema.Types.Mixed }],\n    teacher_id: { type: Schema.Types.ObjectId, ref: 'Users', index: true },\n  },\n  {\n    timestamps: { createdAt: 'created_at', updatedAt: 'updated_at' },\n    versionKey: false,\n  },\n);\n\nExamSchema.index({ exam_type: 1 });\nExamSchema.index({ stadium_id: 1 });\n\nexport const ExamModel = mongoose.models.Exams || mongoose.model<IExam>('Exams', ExamSchema);\nimport mongoose, { Schema, Document, Types } from 'mongoose';\n\nexport interface IExamBatch extends Document {\n  name: string;\n  vehicleType: string;\n  region: string;\n  examDate: Date;\n  officialDate?: Date;\n  venue: string;\n  stadium_id?: string;\n  status: 'upcoming' | 'confirmed' | 'completed' | 'cancelled';\n  studentResults: any[];\n  teacher_id?: Types.ObjectId | null;\n  created_at: Date;\n  updated_at: Date;\n}\n\nconst ExamBatchSchema = new Schema<IExamBatch>(\n  {\n    name: { type: String, required: true, trim: true },\n    vehicleType: { type: String, required: true, trim: true },\n    region: { type: String, required: true, trim: true },\n    examDate: { type: Date, required: true },\n    officialDate: { type: Date },\n    venue: { type: String, required: true, trim: true },\n    stadium_id: { type: String, trim: true },\n    status: {\n      type: String,\n      enum: ['upcoming', 'confirmed', 'completed', 'cancelled'],\n      default: 'upcoming',\n    },\n    studentResults: [{ type: Schema.Types.Mixed }],\n    teacher_id: { type: Schema.Types.ObjectId, ref: 'Users', index: true },\n  },\n  {\n    timestamps: { createdAt: 'created_at', updatedAt: 'updated_at' },\n    versionKey: false,\n  },\n);\n\nExamBatchSchema.index({ name: 1 });\nExamBatchSchema.index({ status: 1 });\nExamBatchSchema.index({ examDate: 1 });\n\nconst ExamBatchModel = mongoose.models.ExamBatch || mongoose.model<IExamBatch>('ExamBatch', ExamBatchSchema);\n\nexport default ExamBatchModel;\nimport mongoose, { Schema, Document, Types } from 'mongoose';\n\nexport interface IExamSchedule extends Document {\n  exam_id: Types.ObjectId;\n  start_time: Date;\n  end_time: Date;\n  note?: string;\n  created_at: Date;\n  updated_at: Date;\n}\n\nconst ExamScheduleSchema = new Schema<IExamSchedule>(\n  {\n    exam_id: { type: Schema.Types.ObjectId, ref: 'Exams', required: true, index: true },\n    start_time: { type: Date, required: true },\n    end_time: { type: Date, required: true },\n    note: { type: String, default: '' },\n  },\n  {\n    timestamps: { createdAt: 'created_at', updatedAt: 'updated_at' },\n    versionKey: false,\n    collection: 'examschedules',\n  },\n);\n\nExamScheduleSchema.index({ start_time: -1 });\nExamScheduleSchema.index({ start_time: 1, end_time: 1 });\n\nexport const ExamScheduleModel =\n  mongoose.models.ExamSchedules || mongoose.model<IExamSchedule>('ExamSchedules', ExamScheduleSchema, 'examschedules');\nimport { UserModel } from './user.model';\nimport { StudentModel } from './student.model';\nimport { CourseModel } from './course.model';\nimport { CourseStudentModel } from './course_student.model';\nimport { CityModel } from './city.model';\nimport { StadiumModel } from './stadium.model';\nimport { LessonModel } from './lesson.model';\nimport { ExamModel } from './exam.model';\nimport { DatSessionModel } from './dat_session.model';\nimport { PaymentModel } from './payment.model';\nimport ExamBatchModel from './exam_batch.model';\nimport { LicenseCategoryModel } from './license_category.model';\nimport { SupportRequestModel } from './support_request.model';\n\nexport {\n  UserModel,\n  StudentModel,\n  CourseModel,\n  CourseStudentModel,\n  CityModel,\n  StadiumModel,\n  LessonModel,\n  ExamModel,\n  DatSessionModel,\n  PaymentModel,\n  ExamBatchModel as ExamBatch,\n  LicenseCategoryModel,\n  SupportRequestModel,\n};\nimport mongoose, { Schema, Document, Types } from 'mongoose';\n\nexport enum LessonStatus {\n  Pending = 'pending',\n  InProgress = 'in_progress',\n  Completed = 'completed',\n  NoTeacher = 'no_teacher',\n  CanceledClass = 'canceled_class',\n  DroppedClass = 'dropped_class',\n  Deleted = 'deleted',\n}\n\nexport enum LessonCategory {\n  Theory = 'theory',\n  Practice = 'practice',\n}\n\nexport interface ILesson extends Document {\n  course_student_id?: Types.ObjectId;\n  student_id?: Types.ObjectId; // References User(student)\n  teacher_id?: Types.ObjectId; // References User(teacher)\n  name: string;\n  category: LessonCategory;\n  status: LessonStatus;\n  start_time: Date;\n  end_time: Date;\n  description?: string;\n  lesson_type_id?: Types.ObjectId;\n  vehicle_id?: Types.ObjectId;\n  is_night_course: boolean;\n  is_automatic_course: boolean;\n  km: number;\n  hour: string;\n  vehicle_type?: string;\n  stadium_id?: Types.ObjectId;\n  order: number;\n  confirmed: boolean;\n  pickup_point?: string;\n  is_pickup: boolean;\n  created_at: Date;\n  updated_at: Date;\n}\n\nconst LessonSchema = new Schema<ILesson>(\n  {\n    course_student_id: { type: Schema.Types.ObjectId, ref: 'CourseStudents', index: true },\n    student_id: { type: Schema.Types.ObjectId, ref: 'Users', index: true },\n    teacher_id: { type: Schema.Types.ObjectId, ref: 'Users', index: true },\n    name: { type: String, required: true },\n    category: {\n      type: String,\n      enum: Object.values(LessonCategory),\n      default: LessonCategory.Practice,\n      required: true,\n    },\n    status: {\n      type: String,\n      enum: Object.values(LessonStatus),\n      default: LessonStatus.Pending,\n      required: true,\n    },\n    start_time: { type: Date, required: true, index: true },\n    end_time: { type: Date, required: true },\n    description: { type: String, default: '' },\n    lesson_type_id: { type: Schema.Types.ObjectId },\n    vehicle_id: { type: Schema.Types.ObjectId },\n    is_night_course: { type: Boolean, default: false },\n    is_automatic_course: { type: Boolean, default: false },\n    km: { type: Number, default: 0 },\n    hour: { type: String, default: '00:00' },\n    vehicle_type: { type: String, enum: ['car', 'motorbike'] },\n    stadium_id: { type: Schema.Types.ObjectId, ref: 'Stadiums' },\n    order: { type: Number, default: 1 },\n    confirmed: { type: Boolean, default: false },\n    pickup_point: { type: String },\n    is_pickup: { type: Boolean, default: false },\n  },\n  {\n    timestamps: { createdAt: 'created_at', updatedAt: 'updated_at' },\n    versionKey: false,\n  },\n);\n\nexport const LessonModel = mongoose.models.Lessons || mongoose.model<ILesson>('Lessons', LessonSchema);\nimport mongoose, { Schema, Document } from 'mongoose';\n\nexport interface ILicenseCategory extends Document {\n  name: string;\n  code: string;\n  description?: string;\n  type: 'Ô tô' | 'Xe máy';\n  fee: string;\n  tags: string[];\n  inactive: string[];\n  dat?: string | null;\n  created_at: Date;\n  updated_at: Date;\n}\n\nconst LicenseCategorySchema = new Schema<ILicenseCategory>(\n  {\n    name: { type: String, required: true },\n    code: { type: String, required: true, unique: true },\n    description: { type: String },\n    type: { type: String, enum: ['Ô tô', 'Xe máy'], default: 'Ô tô' },\n    fee: { type: String, default: '0đ' },\n    tags: { type: [String], default: [] },\n    inactive: { type: [String], default: [] },\n    dat: { type: String, default: null },\n  },\n  {\n    timestamps: { createdAt: 'created_at', updatedAt: 'updated_at' },\n    versionKey: false,\n    collection: 'licensecategories',\n  },\n);\n\nif (mongoose.models.LicenseCategories) {\n  mongoose.deleteModel('LicenseCategories');\n}\nexport const LicenseCategoryModel = mongoose.model<ILicenseCategory>(\n  'LicenseCategories',\n  LicenseCategorySchema,\n  'licensecategories',\n);\nimport mongoose, { Schema, Document, Types } from 'mongoose';\n\nexport interface INotification extends Document {\n  config_id?: Types.ObjectId; // Referencing notification config/template\n  content_id?: Types.ObjectId; // Referencing the actual content\n  is_read: boolean;\n  receive_id: Types.ObjectId; // The recipient User ID\n  receive_type: 'user' | 'student' | 'teacher';\n  category?: 'notif' | 'system';\n\n  // Extension for direct notification if not using config_id/content_id\n  title?: string;\n  body?: string;\n  data?: any; // Extra payload for FCM\n\n  created_at: Date;\n  updated_at: Date;\n}\n\nconst NotificationSchema = new Schema<INotification>(\n  {\n    config_id: { type: Schema.Types.ObjectId, ref: 'NotifyConfigs', index: true },\n    content_id: { type: Schema.Types.ObjectId, ref: 'NotifyContents' },\n    is_read: { type: Boolean, default: false },\n    receive_id: { type: Schema.Types.ObjectId, ref: 'Users', required: true, index: true },\n    receive_type: {\n      type: String,\n      enum: ['user', 'student', 'teacher'],\n      default: 'user',\n    },\n    category: {\n      type: String,\n      enum: ['notif', 'system'],\n      default: 'notif',\n    },\n    title: { type: String },\n    body: { type: String },\n    data: { type: Schema.Types.Mixed },\n  },\n  {\n    timestamps: { createdAt: 'created_at', updatedAt: 'updated_at' },\n    versionKey: false,\n  },\n);\n\nNotificationSchema.index({ created_at: -1 });\n\nexport const NotificationModel =\n  mongoose.models.Notification || mongoose.model<INotification>('Notification', NotificationSchema);\n/**\n * notifies — aligned to ahv-driving-training reference.\n * Collection name: \"notifies\" (plural, all lowercase).\n * Bootstrap-backup fields moved to notifyContents.data.\n */\nimport mongoose, { Schema, Document, Model, Types } from 'mongoose';\n\nexport const INotifyStatus = {\n  Draft: 'draft',\n  Sent: 'sent',\n  Cancel: 'cancel',\n} as const;\nexport type NotifyStatus = (typeof INotifyStatus)[keyof typeof INotifyStatus];\n\nexport interface INotify extends Document {\n  content_id: Types.ObjectId;\n  config_id: Types.ObjectId;\n  status: NotifyStatus;\n  created_at: Date;\n  updated_at: Date;\n}\n\nconst NotifySchema = new Schema<INotify>(\n  {\n    content_id: {\n      type: Schema.Types.ObjectId,\n      ref: 'NotifyContent',\n      required: [true, 'content_id is required'],\n      index: true,\n    },\n    config_id: {\n      type: Schema.Types.ObjectId,\n      ref: 'NotifyConfigs',\n      required: [true, 'config_id is required'],\n      index: true,\n    },\n    status: {\n      type: String,\n      enum: Object.values(INotifyStatus),\n      default: 'draft',\n      required: [true, 'status is required'],\n    },\n  },\n  {\n    timestamps: { createdAt: 'created_at', updatedAt: 'updated_at' },\n    versionKey: false,\n    toJSON: {\n      virtuals: true,\n      transform: (_doc, ret: Record<string, unknown>) => {\n        ret.id = ret._id;\n        delete ret._id;\n        return ret;\n      },\n    },\n    toObject: {\n      virtuals: true,\n      transform: (_doc, ret: Record<string, unknown>) => {\n        ret.id = ret._id;\n        delete ret._id;\n        return ret;\n      },\n    },\n  },\n);\n\nNotifySchema.index({ created_at: -1, status: 1 });\n\nconst Notify: Model<INotify> = mongoose.models.notifies || mongoose.model<INotify>('notifies', NotifySchema);\n\nexport default Notify;\n/**\n * NotifyConfigs — aligned to ahv-driving-training reference.\n * Exact field names preserved. Used as required config_id in notifies.\n */\nimport mongoose, { Schema, Document, Model } from 'mongoose';\n\nexport const INotifyChannelConfig = {\n  Telegram: 'Telegram',\n  Zalo: 'Zalo',\n  CMS: 'CMS',\n  Mobile: 'Mobile',\n} as const;\nexport type NotifyChannelConfig = (typeof INotifyChannelConfig)[keyof typeof INotifyChannelConfig];\n\nexport interface INotifyConfig extends Document {\n  name: string | null;\n  channel: NotifyChannelConfig;\n  channel_config: Record<string, unknown>;\n  schedule_config: { time?: string; days?: number[] } | null;\n  api_config: Record<string, unknown>;\n  active: boolean;\n  is_schedule: boolean;\n  created_at: Date;\n  updated_at: Date;\n}\n\nconst NotifyConfigSchema = new Schema<INotifyConfig>(\n  {\n    name: { type: String, default: null, trim: true },\n    channel: {\n      type: String,\n      enum: Object.values(INotifyChannelConfig),\n      required: [true, 'channel is required'],\n    },\n    channel_config: { type: Schema.Types.Mixed, default: {} },\n    schedule_config: {\n      type: Schema.Types.Mixed,\n      default: null,\n    },\n    api_config: { type: Schema.Types.Mixed, default: {} },\n    active: { type: Boolean, default: true, index: true },\n    is_schedule: { type: Boolean, default: false, index: true },\n  },\n  {\n    timestamps: { createdAt: 'created_at', updatedAt: 'updated_at' },\n    versionKey: false,\n    toJSON: { virtuals: true },\n    toObject: { virtuals: true },\n  },\n);\n\nNotifyConfigSchema.index({ active: 1, is_schedule: 1 });\n\nconst NotifyConfig: Model<INotifyConfig> =\n  mongoose.models.NotifyConfigs || mongoose.model<INotifyConfig>('NotifyConfigs', NotifyConfigSchema);\n\nexport default NotifyConfig;\n/**\n * notifyContents — aligned to ahv-driving-training reference.\n * Bootstrap-backup extensions stored in data{} field.\n */\nimport mongoose, { Schema, Document, Model } from 'mongoose';\n\n// Use exact ITypeNotifies from ahv-driving-training, extended with bootstrap-backup types\nexport const ITypeNotifies = {\n  // ahv-driving-training types\n  Lesson: 'lesson',\n  Coupons: 'coupons',\n  CreateLesson: 'createLesson',\n  UpdateLesson: 'updateLesson',\n  DeleteLesson: 'deleteLesson',\n  CreateExam: 'createExam',\n  UpdateExam: 'updateExam',\n  DeleteExam: 'deleteExam',\n  CreateExamSchedules: 'createExamSchedules',\n  UpdateExamRegistrationStatus: 'updateExamRegistrationStatus',\n  DeleteExamRegistrationStatus: 'deleteExamRegistrationStatus',\n  CreateStudentComment: 'createStudentComment',\n  UpdateStudentComment: 'updateStudentComment',\n  DeleteStudentComment: 'deleteStudentComment',\n  CreateTeacherComment: 'createTeacherComment',\n  UpdateTeacherComment: 'updateTeacherComment',\n  DeleteTeacherComment: 'deleteTeacherComment',\n  // bootstrap-backup extensions\n  Announcement: 'announcement',\n  System: 'system',\n  Payment: 'payment',\n  Dat: 'dat',\n  Manual: 'manual',\n} as const;\nexport type NotifyType = (typeof ITypeNotifies)[keyof typeof ITypeNotifies];\n\nexport interface INotifyContent extends Document {\n  title: string | null;\n  sub_title: string | null;\n  content: string | null;\n  sub_content: string | null;\n  types: NotifyType;\n  data: {\n    // bootstrap-backup extensions (moved from notifies model)\n    source_type?: string;\n    source_id?: string;\n    channel?: string;\n    target_group?: string;\n    scheduled_at?: Date;\n    created_by?: mongoose.Types.ObjectId;\n    channels?: string[];\n    // legacy data from Notification/Announcement\n    [key: string]: unknown;\n  } | null;\n  created_at: Date;\n  updated_at: Date;\n}\n\nconst NotifyContentSchema = new Schema<INotifyContent>(\n  {\n    title: { type: String, default: null, trim: true },\n    sub_title: { type: String, default: null, trim: true },\n    content: { type: String, default: null, trim: true },\n    sub_content: { type: String, default: null, trim: true },\n    types: {\n      type: String,\n      enum: Object.values(ITypeNotifies),\n      required: [true, 'types is required'],\n      index: true,\n    },\n    data: { type: Schema.Types.Mixed, default: null },\n  },\n  {\n    timestamps: { createdAt: 'created_at', updatedAt: 'updated_at' },\n    versionKey: false,\n    toJSON: { virtuals: true },\n    toObject: { virtuals: true },\n  },\n);\n\nNotifyContentSchema.index({ types: 1, created_at: -1 });\n\nconst NotifyContent: Model<INotifyContent> =\n  mongoose.models.NotifyContent || mongoose.model<INotifyContent>('NotifyContent', NotifyContentSchema);\n\nexport default NotifyContent;\n/**\n * notifyUsers — aligned to ahv-driving-training reference.\n * Bootstrap-backup extensions stored in data{} field.\n */\nimport mongoose, { Schema, Document, Model, Types } from 'mongoose';\n\nexport const READ_STATUSES = ['unread', 'read'] as const;\nexport type ReadStatus = (typeof READ_STATUSES)[number];\n\nexport interface INotifyUser extends Document {\n  notify_id: Types.ObjectId;\n  user_id: Types.ObjectId;\n  status: ReadStatus;\n  data: {\n    // bootstrap-backup extensions\n    receive_type?: 'user' | 'student' | 'teacher';\n    delivered_at?: Date;\n    read_at?: Date;\n    [key: string]: unknown;\n  } | null;\n  created_at: Date;\n  updated_at: Date;\n}\n\nconst NotifyUserSchema = new Schema<INotifyUser>(\n  {\n    notify_id: {\n      type: Schema.Types.ObjectId,\n      ref: 'notifies',\n      required: [true, 'notify_id is required'],\n      index: true,\n    },\n    user_id: {\n      type: Schema.Types.ObjectId,\n      ref: 'Users',\n      required: [true, 'user_id is required'],\n      index: true,\n    },\n    status: {\n      type: String,\n      enum: READ_STATUSES,\n      default: 'unread',\n      index: true,\n    },\n    data: { type: Schema.Types.Mixed, default: null },\n  },\n  {\n    timestamps: { createdAt: 'created_at', updatedAt: 'updated_at' },\n    versionKey: false,\n    toJSON: { virtuals: true },\n    toObject: { virtuals: true },\n  },\n);\n\n// Unique: one record per (user, notify) pair\nNotifyUserSchema.index({ user_id: 1, notify_id: 1 }, { unique: true });\nNotifyUserSchema.index({ user_id: 1, created_at: -1 });\n\nconst NotifyUser: Model<INotifyUser> =\n  mongoose.models.notifyUsers || mongoose.model<INotifyUser>('notifyUsers', NotifyUserSchema);\n\nexport default NotifyUser;\nimport mongoose, { Schema, Document, Types } from 'mongoose';\n\nexport enum PaymentType {\n  TuitionFee = 'tuition_fee',\n  ChipRegistrationFee = 'chip_registration_fee',\n  PickupFee = 'pickup_fee',\n  ChipDepositFee = 'chip_deposit_fee',\n  ReExamFee = 're_exam_fee',\n  TheoryCompleted = 'theory_completed',\n  PracticeCompleted = 'practice_completed',\n  GraduationExam = 'graduation_exam',\n  Other = 'other',\n}\n\nexport interface IPayment extends Document {\n  course_student_id: Types.ObjectId;\n  sale_id?: Types.ObjectId;\n  payment_date: Date;\n  type: PaymentType;\n  note?: string;\n  confirmer_id?: Types.ObjectId; // User ID who confirmed the payment\n  is_received: boolean;\n  received_fee: number;\n  stage_name?: string; // Tên đợt đóng phí tùy chỉnh từ settings\n  created_at: Date;\n  updated_at: Date;\n  is_deleted: boolean;\n  deleted_at: Date | null;\n}\n\nconst PaymentSchema = new Schema<IPayment>(\n  {\n    course_student_id: { type: Schema.Types.ObjectId, ref: 'CourseStudents', required: true, index: true },\n    sale_id: { type: Schema.Types.ObjectId, ref: 'Users' },\n    payment_date: { type: Date, required: true },\n    type: {\n      type: String,\n      enum: Object.values(PaymentType),\n      required: true,\n    },\n    note: { type: String },\n    confirmer_id: { type: Schema.Types.ObjectId, ref: 'Users' },\n    is_received: { type: Boolean, default: false },\n    received_fee: { type: Number, default: 0 },\n    stage_name: { type: String },\n  },\n  {\n    timestamps: { createdAt: 'created_at', updatedAt: 'updated_at' },\n    versionKey: false,\n  },\n);\n\nPaymentSchema.index({ payment_date: -1 });\nPaymentSchema.index({ type: 1 });\n\nexport const PaymentModel = mongoose.models.Payments || mongoose.model<IPayment>('Payments', PaymentSchema);\nimport mongoose, { Schema, Document, Types } from 'mongoose';\n\n// Role names as defined in Master AHV system\nexport enum UserRoleName {\n  Admin = 'admin',\n  SuperAdmin = 'superadmin',\n  Teacher = 'teacher',\n  Staff = 'staff',\n  Sale = 'sale',\n  Student = 'student',\n  Lead = 'lead',\n  User = 'user',\n}\n\nexport interface IRole extends Document {\n  _id: Types.ObjectId;\n  role_name: string;\n  created_at: Date;\n  updated_at: Date;\n}\n\nconst RoleSchema = new Schema<IRole>(\n  {\n    role_name: {\n      type: String,\n      trim: true,\n      unique: true,\n      required: [true, 'Tên vai trò là bắt buộc'],\n    },\n  },\n  {\n    timestamps: { createdAt: 'created_at', updatedAt: 'updated_at' },\n    versionKey: false,\n    collection: 'roles',\n  },\n);\n\n// Removed duplicate index since unique: true already creates one\n\nexport const RoleModel = mongoose.models.Roles || mongoose.model<IRole>('Roles', RoleSchema, 'roles');\nimport mongoose, { Schema, Document } from 'mongoose';\n\nexport interface ILicenseCategory {\n  id: string;\n  type: string;\n  name: string;\n  fee: string;\n  tags: string[];\n  inactive: string[];\n  dat?: string | null;\n}\n\nexport interface IClinic {\n  name: string;\n  info: string;\n}\n\nexport interface ISettings extends Document {\n  userId: string;\n  regions: string[];\n  license_categories: ILicenseCategory[];\n  fee_stages: string[];\n  clinic_list: IClinic[];\n  examVenues: string[];\n  requiredFields: string[];\n  practiceTargetMinutes: number;\n  center_name: string;\n  center_website: string;\n  center_address: string;\n  center_phone: string;\n  center_email: string;\n  center_fax?: string;\n  createdAt: Date;\n  updatedAt: Date;\n}\n\nconst SettingsSchema: Schema = new Schema(\n  {\n    userId: { type: Schema.Types.ObjectId, ref: 'Users', required: true, unique: true },\n    regions: { type: [String], default: [] },\n    license_categories: { type: [Schema.Types.Mixed], default: [] },\n    fee_stages: { type: [String], default: [] },\n    clinic_list: { type: [Schema.Types.Mixed], default: [] },\n    examVenues: { type: [String], default: [] },\n    requiredFields: { type: [String], default: [] },\n    practiceTargetMinutes: { type: Number, default: 420 },\n    center_name: { type: String, default: 'AHV Driving Training' },\n    center_website: { type: String, default: 'ahvdriving-training.com' },\n    center_address: { type: String, default: 'Thái Nguyên' },\n    center_phone: { type: String, default: '09278364782' },\n    center_email: { type: String, default: 'ahvdriving@ahvholding.com' },\n    center_fax: { type: String, default: '' },\n  },\n  { timestamps: true },\n);\n\nexport default mongoose.model<ISettings>('Settings', SettingsSchema);\nimport mongoose, { Schema, Document } from 'mongoose';\n\nexport interface IStadium extends Document {\n  name: string;\n  locate?: string; // Master field name\n  note?: string; // Master field name\n  status: 'active' | 'inactive' | 'maintenance';\n  created_at: Date;\n  updated_at: Date;\n}\n\nconst StadiumSchema: Schema = new Schema(\n  {\n    name: { type: String, required: true, trim: true },\n    locate: { type: String, trim: true, default: '' }, // Detailed location/address string\n    address: { type: String, trim: true, default: '' }, // Alias for locate\n    city: { type: String, trim: true, default: '' }, // City name string\n    mapsLink: { type: String, trim: true, default: '' }, // Google Maps URL\n    note: { type: String, trim: true, default: '' }, // Additional info\n    region_id: { type: Schema.Types.ObjectId, ref: 'Cities', default: null }, // Reference to Cities collection\n    status: {\n      type: String,\n      enum: ['active', 'inactive', 'maintenance'],\n      default: 'active',\n      trim: true,\n    },\n  },\n  {\n    timestamps: { createdAt: 'created_at', updatedAt: 'updated_at' },\n    versionKey: false,\n    collection: 'stadium', // Master collection name\n  },\n);\n\nStadiumSchema.index({ name: 1 });\n\nexport const StadiumModel = mongoose.models.Stadiums || mongoose.model<IStadium>('Stadiums', StadiumSchema, 'stadium');\nexport default StadiumModel;\nimport mongoose, { Schema, Document, Types } from 'mongoose';\nimport { IUser } from './user.model';\n\nexport interface IStudent extends Document {\n  user_id: Types.ObjectId | IUser; // Can be ID or populated User object\n  card_id?: string | null;\n  profile_created_at?: Date | null;\n  email_verified_at?: Date | null;\n  lead_manager?: string | null;\n  region_id?: Types.ObjectId | null;\n  license_category_id?: Types.ObjectId | null;\n  course_id?: Types.ObjectId | null;\n  student_code?: string | null;\n  teacher_id?: Types.ObjectId | null;\n  balance?: any;\n  created_at: Date;\n  updated_at: Date;\n  is_deleted: boolean;\n  deleted_at: Date | null;\n  // Merged fields from Enrollment for UI/Tests (Source of truth is CourseStudent)\n  status_detail?: string;\n}\n\nconst StudentSchema = new Schema<IStudent>(\n  {\n    user_id: { type: Schema.Types.ObjectId, ref: 'Users', required: true, index: true },\n    balance: {\n      type: Schema.Types.Decimal128,\n      default: 0,\n      get: (v: any) => (v ? parseFloat(v.toString()) : 0),\n    },\n    card_id: { type: String, default: null },\n    profile_created_at: { type: Date, default: null },\n    email_verified_at: { type: Date, default: null },\n    lead_manager: { type: String, default: null },\n    course_id: { type: Schema.Types.ObjectId, ref: 'Courses', default: null },\n    license_category_id: { type: Schema.Types.ObjectId, ref: 'LicenseCategories', default: null },\n    student_code: { type: String, default: null, index: true },\n    teacher_id: { type: Schema.Types.ObjectId, ref: 'Users', default: null, index: true },\n\n    // Extension\n    region_id: { type: Schema.Types.ObjectId, ref: 'Cities', default: null },\n    is_deleted: { type: Boolean, default: false, index: true },\n    deleted_at: { type: Date, default: null },\n\n    // Merged fields for UI/Tests (Primary source is CourseStudent)\n    status_detail: { type: String, default: 'Chờ KSK' },\n  },\n  {\n    timestamps: { createdAt: 'created_at', updatedAt: 'updated_at' },\n    versionKey: false,\n    collection: 'studentinfos',\n  },\n);\n\nStudentSchema.index({ region_id: 1, created_at: -1 });\nStudentSchema.index({ created_at: -1, is_deleted: 1 });\nStudentSchema.index({ course_id: 1, created_at: -1 });\nStudentSchema.index({ license_category_id: 1, created_at: -1 });\n\nif (mongoose.models.StudentInfos) {\n  mongoose.deleteModel('StudentInfos');\n}\nexport const StudentModel = mongoose.model<IStudent>('StudentInfos', StudentSchema, 'studentinfos');\nimport mongoose, { Schema, Document, Types } from 'mongoose';\nimport { IUser } from './user.model';\n\nexport interface ISupportRequest extends Document {\n  sender_id: Types.ObjectId | IUser;\n  sender_role?: string;\n  topic: string;\n  priority: string;\n  title: string;\n  description: string;\n  attachments?: string[];\n  status: string;\n  resolved_by?: Types.ObjectId | IUser | null;\n  resolution_notes?: string | null;\n  resolved_at?: Date | null;\n  created_at: Date;\n  updated_at: Date;\n}\n\nconst SupportRequestSchema = new Schema<ISupportRequest>(\n  {\n    sender_id: { type: Schema.Types.ObjectId, ref: 'Users', required: true, index: true },\n    sender_role: { type: String, enum: ['teacher', 'admin', 'superadmin', 'student'], default: 'teacher' },\n    topic: { \n      type: String, \n      required: true,\n      enum: ['Lỗi phần mềm', 'Tư vấn tính năng', 'Thanh toán & Nạp tiền', 'Khác'],\n      default: 'Khác' \n    },\n    priority: {\n      type: String,\n      required: true,\n      enum: ['Thấp', 'Bình thường', 'Cao', 'Nghiêm trọng'],\n      default: 'Bình thường'\n    },\n    title: { type: String, required: true, trim: true, maxlength: 150 },\n    description: { type: String, required: true, trim: true, maxlength: 2000 },\n    attachments: { type: [String], default: [] },\n    status: {\n      type: String,\n      required: true,\n      enum: ['Mới', 'Đang xử lý', 'Hoàn thành', 'Đã hủy'],\n      default: 'Mới',\n      index: true\n    },\n    resolved_by: { type: Schema.Types.ObjectId, ref: 'Users', default: null },\n    resolution_notes: { type: String, trim: true, default: null },\n    resolved_at: { type: Date, default: null },\n  },\n  {\n    timestamps: { createdAt: 'created_at', updatedAt: 'updated_at' },\n    versionKey: false,\n    collection: 'support_requests',\n  }\n);\n\n// Indexes to speed up admin queries\nSupportRequestSchema.index({ status: 1, created_at: -1 });\nSupportRequestSchema.index({ sender_id: 1, created_at: -1 });\n\n// Avoid OverwriteModelError\nif (mongoose.models.SupportRequests) {\n  mongoose.deleteModel('SupportRequests');\n}\n\nexport const SupportRequestModel = mongoose.model<ISupportRequest>('SupportRequests', SupportRequestSchema, 'support_requests');\nimport mongoose, { Schema, Document, Types } from 'mongoose';\n\nexport enum ActionType {\n  CREATE = 'CREATE',\n  UPDATE = 'UPDATE',\n  DELETE = 'DELETE',\n  LOGIN = 'LOGIN',\n  LOGOUT = 'LOGOUT',\n}\n\nexport interface ISystemLog extends Document {\n  user_id: Types.ObjectId;\n  title: string;\n  description?: string;\n  action: ActionType;\n  entity_type: string;\n  entity_id: string;\n  old_data?: any;\n  new_data?: any;\n  ip_address?: string;\n  user_agent?: string;\n  created_at: Date;\n  updated_at: Date;\n}\n\nconst SystemLogSchema = new Schema<ISystemLog>(\n  {\n    user_id: { type: Schema.Types.ObjectId, ref: 'Users', required: true, index: true },\n    title: { type: String, trim: true, required: true },\n    description: { type: String, trim: true, default: '' },\n    action: { type: String, enum: Object.values(ActionType), required: true },\n    entity_type: { type: String, required: true },\n    entity_id: { type: String, required: true },\n    old_data: { type: Schema.Types.Mixed },\n    new_data: { type: Schema.Types.Mixed },\n    ip_address: { type: String },\n    user_agent: { type: String },\n  },\n  {\n    timestamps: { createdAt: 'created_at', updatedAt: 'updated_at' },\n    versionKey: false,\n    collection: 'logtasks',\n  },\n);\n\nSystemLogSchema.index({ entity_type: 1, entity_id: 1 });\nSystemLogSchema.index({ entity_id: 1, created_at: -1 });\nSystemLogSchema.index({ user_id: 1, created_at: -1 });\n\nexport const SystemLogModel =\n  mongoose.models.LogTasks || mongoose.model<ISystemLog>('LogTasks', SystemLogSchema, 'logtasks');\nimport mongoose, { Schema, Document } from 'mongoose';\n\nexport enum UserGender {\n  Male = 'male',\n  Female = 'female',\n  Another = 'another',\n}\n\nexport enum UserStatus {\n  Active = 'active',\n  InActive = 'inactive',\n  Deleted = 'deleted',\n}\n\nexport enum UserRole {\n  Admin = 'admin',\n  SuperAdmin = 'superadmin',\n  Staff = 'staff',\n  Teacher = 'teacher',\n  Student = 'student',\n}\n\nexport interface IUser extends Document {\n  username: string;\n  first_name: string;\n  last_name: string;\n  email: string;\n  phone: string;\n  image?: string;\n  bio?: string;\n  gender: UserGender;\n  dob?: Date;\n  address: string;\n  identity_card: string;\n  status: UserStatus;\n  // NOTE: 'role' is removed — use UserRoleModel (userroles collection) instead\n  password: string;\n  refresh_token?: string;\n  existing_license_num?: string;\n  existing_license_rank?: string;\n  zalo_user_id?: string;\n  fcm_token?: string;\n  created_at: Date;\n  updated_at: Date;\n}\n\nconst UserSchema = new Schema<IUser>(\n  {\n    username: { type: String, required: true, unique: true, lowercase: true, trim: true },\n    first_name: { type: String, required: true },\n    last_name: { type: String, required: true },\n    email: { type: String, required: true, unique: true, lowercase: true, trim: true },\n    phone: { type: String, required: true },\n    image: { type: String },\n    bio: { type: String },\n    gender: { type: String, enum: Object.values(UserGender), default: UserGender.Male },\n    dob: { type: Date },\n    address: { type: String, required: true },\n    identity_card: {\n      type: String,\n      required: true,\n      validate: {\n        validator: function (v: string) {\n          return /^\\d{12}$/.test(v);\n        },\n        message: (props: any) => `${props.value} không phải là số CCCD hợp lệ (phải có đúng 12 chữ số)!`,\n      },\n    },\n    status: { type: String, enum: Object.values(UserStatus), default: UserStatus.Active },\n    password: { type: String, required: true },\n    refresh_token: { type: String },\n    existing_license_num: { type: String, default: null },\n    existing_license_rank: { type: String, default: null },\n    zalo_user_id: { type: String, default: null },\n    fcm_token: { type: String, default: null },\n  },\n  {\n    timestamps: { createdAt: 'created_at', updatedAt: 'updated_at' },\n    versionKey: false,\n  },\n);\n\nUserSchema.index(\n  {\n    first_name: 'text',\n    last_name: 'text',\n    phone: 'text',\n    identity_card: 'text',\n  },\n  {\n    name: 'SearchIndex',\n    weights: { first_name: 10, last_name: 5, phone: 5, identity_card: 3 },\n  },\n);\nUserSchema.index({ phone: 1 });\nUserSchema.index({ identity_card: 1 });\nUserSchema.index({ created_at: -1 });\n\nexport const UserModel = mongoose.models.Users || mongoose.model<IUser>('Users', UserSchema);\nimport mongoose, { Schema, Document, Types } from 'mongoose';\n\nexport interface IUserAgent extends Document {\n  user_id: Types.ObjectId;\n  agent_id: Types.ObjectId;\n  created_at: Date;\n  updated_at: Date;\n}\n\nconst UserAgentSchema = new Schema<IUserAgent>(\n  {\n    user_id: {\n      type: Schema.Types.ObjectId,\n      ref: 'Users',\n      required: [true, 'User ID là bắt buộc'],\n      index: true,\n    },\n    agent_id: {\n      type: Schema.Types.ObjectId,\n      ref: 'Agents',\n      required: [true, 'Agent ID là bắt buộc'],\n      index: true,\n    },\n  },\n  {\n    timestamps: { createdAt: 'created_at', updatedAt: 'updated_at' },\n    versionKey: false,\n    collection: 'useragents',\n  },\n);\n\nUserAgentSchema.index({ user_id: 1, agent_id: 1 }, { unique: true });\n\nexport const UserAgentModel =\n  mongoose.models.UserAgents || mongoose.model<IUserAgent>('UserAgents', UserAgentSchema, 'useragents');\nimport mongoose, { Schema, Document, Types } from 'mongoose';\n\nexport interface IUserRole extends Document {\n  user_id: Types.ObjectId;\n  role_id: Types.ObjectId;\n  created_at: Date;\n  updated_at: Date;\n}\n\nconst UserRoleSchema = new Schema<IUserRole>(\n  {\n    user_id: {\n      type: Schema.Types.ObjectId,\n      ref: 'Users',\n      required: [true, 'User ID là bắt buộc'],\n      index: true,\n    },\n    role_id: {\n      type: Schema.Types.ObjectId,\n      ref: 'Roles',\n      required: [true, 'Role ID là bắt buộc'],\n    },\n  },\n  {\n    timestamps: { createdAt: 'created_at', updatedAt: 'updated_at' },\n    versionKey: false,\n    collection: 'userroles',\n  },\n);\n\n// Compound unique index: one user can have one role per entry\nUserRoleSchema.index({ user_id: 1, role_id: 1 }, { unique: true });\n\nexport const UserRoleModel =\n  mongoose.models.UserRole || mongoose.model<IUserRole>('UserRole', UserRoleSchema, 'userroles');\nimport mongoose, { Schema, Document } from 'mongoose';\n\nexport interface IVipQr extends Document {\n  userId: string;\n  bankBin: string;\n  accountNumber: string;\n  accountName: string;\n  qrTemplate: string;\n  remainingUses: number;\n}\n\nconst VipQrSchema: Schema = new Schema(\n  {\n    userId: { type: Schema.Types.ObjectId, ref: 'Users', required: true, unique: true },\n    bankBin: { type: String, required: true },\n    accountNumber: { type: String, required: true },\n    accountName: { type: String, required: true },\n    qrTemplate: { type: String, required: true },\n    remainingUses: { type: Number, default: 0 },\n  },\n  { timestamps: true },\n);\n\nexport default mongoose.model<IVipQr>('VipQr', VipQrSchema);","cwd":"/root/.openclaw/workspaces2/v4-ecosystem-review/master-orchestrator"},"isError":false,"timestamp":1776833416523}}
{"type":"message","id":"aa1e217e","parentId":"b7916e54","timestamp":"2026-04-22T04:50:16.555Z","message":{"role":"toolResult","toolCallId":"call_function_dimgzh0yh8xz_2","toolName":"exec","content":[{"type":"text","text":"import { Router } from 'express';\nimport authRoutes from './auth.routes';\nimport studentRoutes from './student.routes';\nimport courseRoutes from './course.routes';\nimport examRoutes from './exam.routes';\nimport paymentRoutes from './payment.routes';\nimport examBatchRoutes from './exam_batch.routes';\nimport vipQrRoutes from './vip_qr.routes';\nimport notificationRoutes from './notification.routes';\nimport settingsRoutes from './settings.routes';\nimport licenseCategoryRoutes from './license-category.routes';\nimport stadiumRoutes from './stadium.routes';\nimport dashboardRoutes from './dashboard.routes';\nimport cityRoutes from './city.routes';\nimport datRoutes from './dat.routes';\nimport announcementRoutes from './announcement.routes';\nimport examScheduleRoutes from './exam_schedule.routes';\nimport lessonRoutes from './lesson.routes';\nimport dataRoutes from './data.routes';\nimport supportRequestRoutes from './support_request.route';\nimport { Role } from '@/domain/constants/rbac';\nimport { authenticateJWT } from '@/interface/middlewares/auth.middleware';\nimport { systemLogMiddleware } from '@/interface/middlewares/system_log.middleware';\nimport { authRateLimit } from '@/interface/middlewares/rate-limit.middleware';\nimport { rbacMiddleware as rbacGuard, moduleAccessGuard } from '@/interface/middlewares/rbac.middleware';\n\nconst router = Router();\n\n// Public Routes\nrouter.get('/health', (req, res) => {\n  res.status(200).json({\n    status: 'ok',\n    timestamp: new Date().toISOString(),\n    uptime: process.uptime(),\n  });\n});\n\nrouter.use('/auth', authRateLimit, authRoutes);\n\n// Protected Routes (JWT and Audit Logging)\nrouter.use(authenticateJWT, systemLogMiddleware);\n\n// --- Module Access Control ---\n\n// Strictly Su