{"type":"message","id":"c0832464","parentId":"06ffaca3","timestamp":"2026-04-22T04:50:40.324Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me read the service files.","thinkingSignature":"4db475bb3158d3cdf3367f43acbbbaceddfe70a5fa1b51c0f084d2f1b3d58452"},{"type":"toolCall","id":"call_function_yek6vi8246zi_1","name":"exec","arguments":{"command":"cat /root/.openclaw/workspaces2/projects/ahv-qlhv-be/src/application/services/student.service.ts"}},{"type":"toolCall","id":"call_function_yek6vi8246zi_2","name":"exec","arguments":{"command":"cat /root/.openclaw/workspaces2/projects/ahv-qlhv-be/src/application/services/course.service.ts"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":424,"output":99,"cacheRead":28895,"cacheWrite":1112,"totalTokens":30530,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776833436659,"responseId":"0637869d65a9fa9641d5b0ba309fd7c5"}}
{"type":"message","id":"a2da0b34","parentId":"c0832464","timestamp":"2026-04-22T04:50:40.483Z","message":{"role":"toolResult","toolCallId":"call_function_yek6vi8246zi_1","toolName":"exec","content":[{"type":"text","text":"import mongoose from 'mongoose';\nimport { StudentRepository } from '@/infrastructure/repositories/student.repository';\nimport { PaymentRepository } from '@/infrastructure/repositories/payment.repository';\nimport { IStudent } from '@/domain/interfaces/student.interface';\nimport { COURSE_TYPES } from '@/domain/constants/course.constants';\nimport { STUDENT_STATUSES } from '@/domain/constants/student.constants';\nimport { ExcelHelper } from '@/infrastructure/utils/excel.helper';\nimport { Response } from 'express';\nimport { SystemLogModel } from '../../infrastructure/database/models/system_log.model';\nimport { StudentModel } from '../../infrastructure/database/models/student.model';\nimport { CourseStudentModel } from '../../infrastructure/database/models/course_student.model';\nimport { CourseModel } from '../../infrastructure/database/models/course.model';\nimport { LicenseCategoryModel } from '../../infrastructure/database/models/license_category.model';\nimport { CityModel } from '../../infrastructure/database/models/city.model';\nimport { NotificationModel } from '../../infrastructure/database/models/notification.model';\nimport { UserService } from './user.service';\nimport { NotifyService } from './notify.service';\nimport { StatusTransitionHelper } from './status-transition.helper';\nimport { PaginationOptions } from '@/domain/types/pagination.types';\nimport fs from 'fs';\nimport { AppError } from '@/domain/exceptions/app-error';\nimport { UserModel } from '../../infrastructure/database/models/user.model';\nimport { RoleModel, UserRoleName } from '../../infrastructure/database/models/role.model';\nimport { UserRoleModel } from '../../infrastructure/database/models/user_role.model';\n\nexport class StudentService {\n  private studentRepository: StudentRepository;\n  private paymentRepository: PaymentRepository;\n  private userService: UserService;\n  private excelHelper: ExcelHelper;\n  private notifyService: NotifyService;\n\n  constructor() {\n    this.studentRepository = new StudentRepository();\n    this.paymentRepository = new PaymentRepository();\n    this.userService = new UserService();\n    this.excelHelper = new ExcelHelper();\n    this.notifyService = new NotifyService();\n  }\n\n  async getAllStudents(filters = {}, options: PaginationOptions = { page: 1, limit: 10 }, currentUser?: any) {\n    return await this.studentRepository.findAll(filters, options, currentUser);\n  }\n\n  async getStudentById(id: string, currentUser?: any) {\n    const student = await this.studentRepository.findById(id, currentUser);\n    if (!student) {\n      throw new AppError('Học viên không tồn tại hoặc bạn không có quyền truy cập', 404);\n    }\n    return student;\n  }\n\n  async updateStudent(id: string, data: any) {\n    const student = await this.studentRepository.findById(id);\n    if (!student) throw new AppError('Học viên không tồn tại', 404);\n\n    // Business Logic Guard: Validate status transition if requested\n    if (data.status) {\n      StatusTransitionHelper.validate(student, data.status);\n    }\n\n    // 1. Update Core User Data\n    const userId = (student.user_id as any)._id || student.user_id;\n    const coreFields = [\n      'name',\n      'first_name',\n      'last_name',\n      'phone',\n      'identity_number',\n      'identity_card',\n      'email',\n      'existing_license_num',\n      'existing_license_rank',\n    ];\n    if (Object.keys(data).some((k) => coreFields.includes(k))) {\n      await this.userService.updateUserProfile(userId, data);\n    }\n\n    // 2. Map and Update Core Student Attributes (Demographics & Category)\n    const demographicUpdate: any = {};\n    if (data.city !== undefined) {\n      demographicUpdate.region_id =\n        data.city === ''\n          ? null\n          : mongoose.Types.ObjectId.isValid(data.city)\n            ? new mongoose.Types.ObjectId(data.city)\n            : data.city;\n    }\n    if (data.region_id !== undefined) {\n      demographicUpdate.region_id =\n        data.region_id === ''\n          ? null\n          : mongoose.Types.ObjectId.isValid(data.region_id)\n            ? new mongoose.Types.ObjectId(data.region_id)\n            : data.region_id;\n    }\n\n    // ENSURE: license_category_id is ALSO updated on the Student document, not just CourseStudent\n    if (data.rank !== undefined && data.rank !== '') {\n      demographicUpdate.license_category_id = await this._resolveLicenseCategoryId(data.rank);\n    } else if (data.license_category_id !== undefined && data.license_category_id !== '') {\n      demographicUpdate.license_category_id = await this._resolveLicenseCategoryId(data.license_category_id);\n    }\n\n    if (data.status !== undefined && data.status !== '') {\n      let sanitizedStatus = data.status;\n      if (sanitizedStatus === 'Đã xong KSK') sanitizedStatus = 'Đã KSK';\n      demographicUpdate.status_detail = sanitizedStatus;\n    }\n\n    if (data.lead_manager !== undefined) {\n      demographicUpdate.lead_manager = data.lead_manager === '' ? null : data.lead_manager;\n    }\n\n    if (Object.keys(demographicUpdate).length > 0) {\n      await this.studentRepository.update(id, demographicUpdate);\n    }\n\n    // 3. Map Course details for latest CourseStudent Enrollment\n    const courseUpdate = await this._mapCourseUpdateData(data);\n\n    const needsEnrollmentUpdate =\n      Object.keys(courseUpdate).length > 0 ||\n      [\n        'health_check_status',\n        'health_check_date',\n        'hospital_id',\n        'health_check_note',\n        'theory_completed',\n        'sand_yard_completed',\n        'simulation_completed',\n        'dat_completed',\n        'cabin_completed',\n        'graduation_eligible',\n      ].some((k) => data[k] !== undefined);\n\n    if (needsEnrollmentUpdate) {\n      const latestEnrollment = await CourseStudentModel.findOne({ student_id: id }).sort({ created_at: -1 });\n      if (latestEnrollment) {\n        this._mergeLatestEnrollmentFlags(courseUpdate, latestEnrollment, data);\n        await CourseStudentModel.updateOne({ _id: latestEnrollment._id }, { $set: courseUpdate });\n      } else if (courseUpdate.course_id) {\n        // Create new enrollment if none exists but course info is provided\n        await CourseStudentModel.create({\n          student_id: id,\n          ...courseUpdate,\n        });\n      }\n    }\n\n    return await this.studentRepository.findById(id);\n  }\n\n  private async _mapCourseUpdateData(data: any): Promise<any> {\n    const courseUpdate: any = {};\n    if (data.status !== undefined) {\n      // Sanitize old status labels coming from legacy clients or old constants\n      let sanitizedStatus = data.status;\n      if (sanitizedStatus === 'Đã xong KSK') sanitizedStatus = 'Đã KSK';\n      courseUpdate.status_detail = sanitizedStatus;\n    }\n    if (data.course !== undefined && data.course !== '') {\n      courseUpdate.course_id = data.course;\n      // Fetch course fee to initialize tuition\n      const course = await CourseModel.findById(data.course).select('course_fee').lean().exec();\n      if (course) {\n        courseUpdate.fee = (course as any).course_fee || 0;\n      }\n    }\n    if (data.rank !== undefined && data.rank !== '') {\n      courseUpdate.license_category_id = await this._resolveLicenseCategoryId(data.rank);\n    }\n    return courseUpdate;\n  }\n\n  private async _resolveLicenseCategoryId(rank: string | null | undefined): Promise<any> {\n    if (!rank) return null;\n    // Check if it's already an ObjectId\n    if (mongoose.Types.ObjectId.isValid(rank)) return rank;\n\n    // Look up by name or code\n    const category = await LicenseCategoryModel.findOne({\n      $or: [{ name: rank }, { code: rank }],\n    }).exec();\n\n    return category ? category._id : null;\n  }\n\n  private _mergeLatestEnrollmentFlags(courseUpdate: any, latestEnrollment: any, data: any) {\n    const { health_check_status, health_check_date, hospital_id, health_check_note } = data;\n    if ([health_check_status, health_check_date, hospital_id, health_check_note].some((v) => v !== undefined)) {\n      const hc: any = latestEnrollment.health_check || {};\n\n      let parsedDate = hc.date ?? null;\n      if (health_check_date === '' || health_check_date === null) {\n        parsedDate = null;\n      } else if (health_check_date && health_check_date !== 'Invalid Date') {\n        const d = new Date(health_check_date);\n        if (!isNaN(d.getTime())) {\n          parsedDate = d;\n        }\n      }\n\n      courseUpdate.health_check = {\n        status: health_check_status ?? hc.status ?? 'Chờ khám',\n        date: parsedDate,\n        hospital: hospital_id ?? hc.hospital ?? null,\n        note: health_check_note ?? hc.note ?? null,\n      };\n\n      // --- DATA SYNCHRONIZATION: Health Check -> Dashboard Status ---\n      // If health check status is updated to 'Đủ điều kiện', auto-set dashboard status to 'Đã KSK'\n      // This ensures dashboard stats stay in sync with actual biological/medical progress.\n      if (courseUpdate.health_check.status === 'Đủ điều kiện' && courseUpdate.status_detail !== 'Đã KSK') {\n        courseUpdate.status_detail = 'Đã KSK';\n      } else if (courseUpdate.health_check.status === 'Chờ khám' && latestEnrollment.status_detail === 'Đã KSK') {\n        // If downgraded or reset, sync back to 'Chờ KSK'\n        courseUpdate.status_detail = 'Chờ KSK';\n      }\n    }\n\n    const {\n      theory_completed,\n      sand_yard_completed,\n      simulation_completed,\n      dat_completed,\n      cabin_completed,\n      graduation_eligible,\n    } = data;\n    if (\n      [\n        theory_completed,\n        sand_yard_completed,\n        simulation_completed,\n        dat_completed,\n        cabin_completed,\n        graduation_eligible,\n      ].some((v) => v !== undefined)\n    ) {\n      const pf: any = latestEnrollment.progress_flags || {};\n      courseUpdate.progress_flags = {\n        theory_completed: theory_completed ?? pf.theory_completed ?? false,\n        sand_yard_completed: sand_yard_completed ?? pf.sand_yard_completed ?? false,\n        simulation_completed: simulation_completed ?? pf.simulation_completed ?? false,\n        dat_completed: dat_completed ?? pf.dat_completed ?? false,\n        cabin_completed: cabin_completed ?? pf.cabin_completed ?? false,\n        graduation_eligible: graduation_eligible ?? pf.graduation_eligible ?? false,\n      };\n\n      // --- DATA SYNCHRONIZATION: Exam Eligibility ---\n      // If graduation_eligible is true, and status is still a training status, advance it to 'Đang thi'\n      if (\n        courseUpdate.progress_flags.graduation_eligible &&\n        ['Đang học', 'Đang học LT', 'Đang học TH', 'Đã KSK', 'Nộp HS'].includes(latestEnrollment.status_detail)\n      ) {\n        courseUpdate.status_detail = 'Đang thi';\n      }\n    }\n  }\n\n  async createStudent(data: any) {\n    const {\n      phone,\n      identity_card,\n      user_id,\n      region_id,\n      course_id,\n      fee,\n      status_detail,\n      license_category_id,\n      amount,\n      installment,\n      lead_manager,\n      student_code,\n      teacher_id,\n    } = data;\n\n    let targetUserId = user_id;\n\n    // Sanitize status_detail\n    let sanitizedStatus = status_detail || (course_id ? 'Đã vào khóa' : 'Chờ KSK');\n    if (sanitizedStatus === 'Đã xong KSK') sanitizedStatus = 'Đã KSK';\n\n    if (!targetUserId) {\n      const existingUser = await this.userService.findExistingUser(phone, identity_card);\n      if (existingUser) {\n        // Check if this user already has a student record\n        const existingStudent = await StudentModel.findOne({ user_id: existingUser._id, is_deleted: false }).exec();\n        if (existingStudent) {\n          throw new AppError('Học viên với số điện thoại hoặc CCCD này đã tồn tại.', 400);\n        }\n        targetUserId = existingUser._id;\n      } else {\n        const user = await this.userService.createStudentUser(data);\n        targetUserId = user._id;\n      }\n    } else {\n      // Check if this specific user_id is already a student\n      const existingStudent = await StudentModel.findOne({ user_id: targetUserId, is_deleted: false }).exec();\n      if (existingStudent) {\n        throw new AppError('Người dùng này đã có hồ sơ học viên trên hệ thống.', 400);\n      }\n    }\n\n    // Capture rank and status for the student profile (StudentInfos)\n    const licenseCategoryId = await this._resolveLicenseCategoryId(license_category_id);\n\n    let resolvedRegionId;\n    if (region_id && typeof region_id === 'string' && !mongoose.Types.ObjectId.isValid(region_id)) {\n      const city = await CityModel.findOne({ name: region_id }).select('_id').lean().exec();\n      resolvedRegionId = city ? (city as any)._id : null;\n    } else if (region_id && mongoose.Types.ObjectId.isValid(region_id)) {\n      resolvedRegionId = new mongoose.Types.ObjectId(region_id);\n    } else {\n      resolvedRegionId = null;\n    }\n\n    const student = await this.studentRepository.create({\n      user_id: targetUserId,\n      region_id: resolvedRegionId as any,\n      license_category_id: licenseCategoryId,\n      status_detail: sanitizedStatus,\n      lead_manager: lead_manager || null,\n      student_code: student_code || null,\n      teacher_id: teacher_id ? new mongoose.Types.ObjectId(teacher_id) : null,\n    });\n\n    if (course_id) {\n      let actualFee = fee;\n      if (!actualFee || actualFee === 0) {\n        const course = await CourseModel.findById(course_id).select('course_fee').lean().exec();\n        actualFee = (course as any)?.course_fee || 0;\n      }\n\n      const enrollment = await CourseStudentModel.create({\n        student_id: student._id,\n        course_id: course_id,\n        teacher_id: teacher_id ? new mongoose.Types.ObjectId(teacher_id) : null,\n        license_category_id: licenseCategoryId,\n        fee: actualFee,\n        status_detail: sanitizedStatus,\n      });\n\n      // Create initial payment if amount > 0\n      if (amount && amount > 0) {\n        // eslint-disable-next-line @typescript-eslint/no-require-imports\n        const { PaymentModel } = require('@/infrastructure/database/models/payment.model');\n        const receiptCode = await this.paymentRepository.getNextReceiptCode();\n\n        await PaymentModel.create({\n          course_student_id: enrollment._id,\n          payment_date: new Date(),\n          received_fee: amount,\n          type: 'tuition_fee',\n          stage_name: installment || 'Lần đóng 1',\n          note: receiptCode,\n          is_received: true,\n        });\n      }\n    }\n\n    // Return enriched data for immediate UI feedback\n    return await this.getStudentById(student._id.toString());\n  }\n\n  async deleteStudent(id: string, currentUser?: any) {\n    // 1. Verify existence and ownership\n    await this.getStudentById(id, currentUser);\n\n    // 2. Cascade delete any course enrollments mapped to this student\n    await CourseStudentModel.deleteMany({ student_id: id });\n    return await this.studentRepository.delete(id);\n  }\n\n  async exportStudentsToExcel(res: Response, filters: any, currentUser?: any): Promise<void> {\n    const { data } = await this.studentRepository.findAll(filters, { page: 1, limit: 5000 }, currentUser);\n\n    const { workbook, worksheet } = this.excelHelper.createWorkbook('Danh sách học viên');\n\n    this.excelHelper.applyHeaderStyle(worksheet, [\n      { header: 'Họ và tên', key: 'name', width: 25 },\n      { header: 'Số điện thoại', key: 'phone', width: 15 },\n      { header: 'CCCD/CMND', key: 'id_card', width: 15 },\n      { header: 'Hạng GPLX', key: 'license', width: 12 },\n      { header: 'Hệ đào tạo', key: 'system', width: 15 },\n      { header: 'Khu vực', key: 'region', width: 15 },\n      { header: 'Trạng thái', key: 'status', width: 20 },\n      { header: 'Ngày đăng ký', key: 'created_at', width: 15 },\n    ]);\n\n    data.forEach((s: any) => {\n      const user = s.user_id || {};\n      worksheet.addRow({\n        name: `${user.last_name || ''} ${user.first_name || ''}`.trim(),\n        phone: user.phone || '',\n        id_card: user.id_card || '',\n        license: s.license_category_name || '',\n        system: s.course_type || '',\n        region: s.region_name || s.region_id?.name || '',\n        status: s.status_detail || s.status_main || '',\n        created_at: s.created_at ? new Date(s.created_at).toLocaleDateString('vi-VN') : '',\n      });\n    });\n\n    this.excelHelper.applyRowStyle(worksheet);\n    await this.excelHelper.sendWorkbook(res, workbook, 'danh_sach_hoc_vien');\n  }\n\n  async getStudentHistory(id: string, options: PaginationOptions = { page: 1, limit: 20 }) {\n    const { page, limit } = options;\n    const skip = (page - 1) * limit;\n\n    const logs = await SystemLogModel.find({ entity_id: id })\n      .sort({ created_at: -1 })\n      .skip(skip)\n      .limit(limit)\n      .populate('user_id', 'first_name last_name email')\n      .exec();\n\n    const total = await SystemLogModel.countDocuments({ entity_id: id });\n\n    return {\n      data: logs,\n      meta: {\n        total,\n        page,\n        limit,\n        total_pages: Math.ceil(total / limit),\n      },\n    };\n  }\n\n  async isStudentAssignedToTeacher(studentId: string, teacherId: string): Promise<boolean> {\n    // 1. Check in Enrollments\n    const enrolled = await CourseStudentModel.countDocuments({\n      student_id: studentId,\n      teacher_id: teacherId,\n    });\n    if (enrolled > 0) return true;\n\n    // 2. Check in Direct Ownership\n    const owned = await StudentModel.countDocuments({\n      _id: studentId,\n      teacher_id: teacherId,\n    });\n    return owned > 0;\n  }\n\n  async getImportManagementStats(currentUser?: any) {\n    const baseMatch: any = { is_deleted: false };\n\n    if (currentUser?.role === 'teacher') {\n      const assignedIds = await this.studentRepository.getAssignedStudentIds(currentUser.id);\n      baseMatch._id = { $in: assignedIds };\n    }\n\n    const [total, enrolled, unassigned, waiting, remaining, today] = await Promise.all([\n      StudentModel.countDocuments(baseMatch),\n      StudentModel.countDocuments({ ...baseMatch, status_detail: 'Đã vào khóa' }),\n      StudentModel.countDocuments({ ...baseMatch, status_detail: 'Chưa vào khóa' }),\n      StudentModel.countDocuments({ ...baseMatch, status_detail: 'Chờ xếp khóa' }),\n      StudentModel.countDocuments({ ...baseMatch, status_detail: 'Học viên tồn' }),\n      StudentModel.countDocuments({\n        ...baseMatch,\n        created_at: { $gte: new Date().setHours(0, 0, 0, 0) },\n      }),\n    ]);\n\n    return { total, today, enrolled, unassigned, waiting, remaining };\n  }\n\n  /**\n   * Get list of potential leads (Managers/Sales/Staff)\n   */\n  async getLeads() {\n    // 1. Find roles that can be managers\n    const targetRoles = [UserRoleName.Lead, UserRoleName.Sale, UserRoleName.Staff, UserRoleName.Admin];\n    const roles = await RoleModel.find({ role_name: { $in: targetRoles } })\n      .select('_id role_name')\n      .lean()\n      .exec();\n    const roleIds = roles.map((r) => r._id);\n\n    // 2. Find user links with those roles\n    const userRoleLinks = await UserRoleModel.find({ role_id: { $in: roleIds } })\n      .select('user_id')\n      .lean()\n      .exec();\n    const userIds = userRoleLinks.map((link) => link.user_id);\n\n    // 3. Get user details\n    const users = await UserModel.find({\n      _id: { $in: userIds },\n      status: 'active',\n    })\n      .select('_id first_name last_name email phone')\n      .sort({ last_name: 1, first_name: 1 })\n      .lean()\n      .exec();\n\n    return users.map((u) => ({\n      _id: u._id,\n      name: `${u.last_name} ${u.first_name}`.trim(),\n      email: u.email,\n      phone: u.phone,\n    }));\n  }\n\n  async importStudentsFromExcel(filePath: string, userId: string, userRole: string = 'user', courseId?: string) {\n    // We do NOT await this in the controller. It runs in the background.\n    const runImport = async () => {\n      try {\n        const data = await this.excelHelper.parseStudentExcel(filePath);\n        const results = {\n          success: 0,\n          failed: 0,\n          skipped: 0,\n          errors: [] as any[],\n        };\n\n        // Determine notification context\n        const contextType = userRole === 'teacher' || userRole === 'student' ? userRole : 'user';\n\n        for (const item of data) {\n          try {\n            if (!item.firstName) {\n              results.failed++;\n              results.errors.push({ name: 'Ẩn danh', error: 'Thiếu tên học viên' });\n              continue;\n            }\n\n            const duplicate = await this.userService.findExistingUser(item.phone, item.cccd);\n            if (duplicate) {\n              // Only skip if the user is ALREADY a student\n              const isAlreadyStudent = await StudentModel.findOne({ user_id: duplicate._id, is_deleted: false })\n                .select('_id')\n                .lean()\n                .exec();\n              if (isAlreadyStudent) {\n                results.skipped++;\n                continue;\n              }\n              // If user exists but is not a student, continue to createStudent which will handle the conversion\n            }\n\n            const genderInput = item.gender?.toString().toLowerCase();\n            const gender = genderInput === 'nam' ? 'male' : genderInput === 'nữ' ? 'female' : 'male';\n\n            await this.createStudent({\n              first_name: item.firstName,\n              last_name: item.lastName || '',\n              phone: item.phone,\n              identity_card: item.identity_card || item.cccd,\n              address: item.address,\n              license_category_id: item.license_category_id || item.licenseRank,\n              existing_license_num: item.existing_license_num || item.licenseNum,\n              gender: gender,\n              dob: item.dob,\n              course_id: courseId,\n              amount: item.amount,\n              installment: item.installment,\n              lead_manager: item.lead_manager || item.leadManager,\n              student_code: item.student_code,\n              teacher_id: userId,\n            });\n\n            results.success++;\n\n            // Progress notification every 5 students\n            if (results.success % 5 === 0) {\n              await this.notifyService.send({\n                userId,\n                title: '⏳ Đang nhập dữ liệu...',\n                content: `Đã xử lý thành công ${results.success} học viên.`,\n                channel: 'in_app',\n              });\n            }\n          } catch (error: any) {\n            results.failed++;\n            results.errors.push({ name: item.firstName, error: error.message });\n          }\n        }\n\n        // --- GENERATE SUMMARY REPORT AFTER IMPORT ---\n        const stats = await this.getImportManagementStats();\n\n        const summaryContent = [\n          `Đã xử lý xong file Excel.`,\n          `✅ Thành công: ${results.success}`,\n          `⏭️ Bỏ qua (Trùng): ${results.skipped}`,\n          `❌ Lỗi: ${results.failed}`,\n          results.errors.length > 0\n            ? `Chi tiết lỗi: ${results.errors\n                .slice(0, 3)\n                .map((e) => `${e.name}: ${e.error}`)\n                .join('; ')}${results.errors.length > 3 ? '...' : ''}`\n            : '',\n          `\\n📊 BÁO CÁO TỔNG HỢP HỆ THỐNG:`,\n          `• Tổng số học viên: ${stats.total}`,\n          `• Đã vào khóa: ${stats.enrolled}`,\n          `• Chưa vào khóa: ${stats.unassigned}`,\n          `• Chờ xếp khóa: ${stats.waiting}`,\n          `• Học viên tồn: ${stats.remaining}`,\n        ]\n          .filter((line) => line !== '')\n          .join('\\n');\n\n        // Create FINAL notification with the summary report\n        await this.notifyService.send({\n          userId,\n          title: '📑 Hoàn tất nhập dữ liệu học viên',\n          content: summaryContent,\n          channel: 'in_app',\n        });\n      } catch (error: any) {\n        console.error('Import process failed:', error);\n\n        await this.notifyService.send({\n          userId,\n          title: 'Lỗi nhập dữ liệu học viên',\n          content: `Đã xảy ra lỗi nghiêm trọng khi xử lý file: ${error.message}`,\n          channel: 'in_app',\n        });\n      } finally {\n        // Cleanup the file\n        if (fs.existsSync(filePath)) {\n          fs.unlinkSync(filePath);\n        }\n      }\n    };\n\n    // Trigger background execution\n    runImport();\n    return { message: 'Quá trình nhập dữ liệu đã bắt đầu chạy ngầm' };\n  }\n}"}],"details":{"status":"completed","exitCode":0,"durationMs":84,"aggregated":"import mongoose from 'mongoose';\nimport { StudentRepository } from '@/infrastructure/repositories/student.repository';\nimport { PaymentRepository } from '@/infrastructure/repositories/payment.repository';\nimport { IStudent } from '@/domain/interfaces/student.interface';\nimport { COURSE_TYPES } from '@/domain/constants/course.constants';\nimport { STUDENT_STATUSES } from '@/domain/constants/student.constants';\nimport { ExcelHelper } from '@/infrastructure/utils/excel.helper';\nimport { Response } from 'express';\nimport { SystemLogModel } from '../../infrastructure/database/models/system_log.model';\nimport { StudentModel } from '../../infrastructure/database/models/student.model';\nimport { CourseStudentModel } from '../../infrastructure/database/models/course_student.model';\nimport { CourseModel } from '../../infrastructure/database/models/course.model';\nimport { LicenseCategoryModel } from '../../infrastructure/database/models/license_category.model';\nimport { CityModel } from '../../infrastructure/database/models/city.model';\nimport { NotificationModel } from '../../infrastructure/database/models/notification.model';\nimport { UserService } from './user.service';\nimport { NotifyService } from './notify.service';\nimport { StatusTransitionHelper } from './status-transition.helper';\nimport { PaginationOptions } from '@/domain/types/pagination.types';\nimport fs from 'fs';\nimport { AppError } from '@/domain/exceptions/app-error';\nimport { UserModel } from '../../infrastructure/database/models/user.model';\nimport { RoleModel, UserRoleName } from '../../infrastructure/database/models/role.model';\nimport { UserRoleModel } from '../../infrastructure/database/models/user_role.model';\n\nexport class StudentService {\n  private studentRepository: StudentRepository;\n  private paymentRepository: PaymentRepository;\n  private userService: UserService;\n  private excelHelper: ExcelHelper;\n  private notifyService: NotifyService;\n\n  constructor() {\n    this.studentRepository = new StudentRepository();\n    this.paymentRepository = new PaymentRepository();\n    this.userService = new UserService();\n    this.excelHelper = new ExcelHelper();\n    this.notifyService = new NotifyService();\n  }\n\n  async getAllStudents(filters = {}, options: PaginationOptions = { page: 1, limit: 10 }, currentUser?: any) {\n    return await this.studentRepository.findAll(filters, options, currentUser);\n  }\n\n  async getStudentById(id: string, currentUser?: any) {\n    const student = await this.studentRepository.findById(id, currentUser);\n    if (!student) {\n      throw new AppError('Học viên không tồn tại hoặc bạn không có quyền truy cập', 404);\n    }\n    return student;\n  }\n\n  async updateStudent(id: string, data: any) {\n    const student = await this.studentRepository.findById(id);\n    if (!student) throw new AppError('Học viên không tồn tại', 404);\n\n    // Business Logic Guard: Validate status transition if requested\n    if (data.status) {\n      StatusTransitionHelper.validate(student, data.status);\n    }\n\n    // 1. Update Core User Data\n    const userId = (student.user_id as any)._id || student.user_id;\n    const coreFields = [\n      'name',\n      'first_name',\n      'last_name',\n      'phone',\n      'identity_number',\n      'identity_card',\n      'email',\n      'existing_license_num',\n      'existing_license_rank',\n    ];\n    if (Object.keys(data).some((k) => coreFields.includes(k))) {\n      await this.userService.updateUserProfile(userId, data);\n    }\n\n    // 2. Map and Update Core Student Attributes (Demographics & Category)\n    const demographicUpdate: any = {};\n    if (data.city !== undefined) {\n      demographicUpdate.region_id =\n        data.city === ''\n          ? null\n          : mongoose.Types.ObjectId.isValid(data.city)\n            ? new mongoose.Types.ObjectId(data.city)\n            : data.city;\n    }\n    if (data.region_id !== undefined) {\n      demographicUpdate.region_id =\n        data.region_id === ''\n          ? null\n          : mongoose.Types.ObjectId.isValid(data.region_id)\n            ? new mongoose.Types.ObjectId(data.region_id)\n            : data.region_id;\n    }\n\n    // ENSURE: license_category_id is ALSO updated on the Student document, not just CourseStudent\n    if (data.rank !== undefined && data.rank !== '') {\n      demographicUpdate.license_category_id = await this._resolveLicenseCategoryId(data.rank);\n    } else if (data.license_category_id !== undefined && data.license_category_id !== '') {\n      demographicUpdate.license_category_id = await this._resolveLicenseCategoryId(data.license_category_id);\n    }\n\n    if (data.status !== undefined && data.status !== '') {\n      let sanitizedStatus = data.status;\n      if (sanitizedStatus === 'Đã xong KSK') sanitizedStatus = 'Đã KSK';\n      demographicUpdate.status_detail = sanitizedStatus;\n    }\n\n    if (data.lead_manager !== undefined) {\n      demographicUpdate.lead_manager = data.lead_manager === '' ? null : data.lead_manager;\n    }\n\n    if (Object.keys(demographicUpdate).length > 0) {\n      await this.studentRepository.update(id, demographicUpdate);\n    }\n\n    // 3. Map Course details for latest CourseStudent Enrollment\n    const courseUpdate = await this._mapCourseUpdateData(data);\n\n    const needsEnrollmentUpdate =\n      Object.keys(courseUpdate).length > 0 ||\n      [\n        'health_check_status',\n        'health_check_date',\n        'hospital_id',\n        'health_check_note',\n        'theory_completed',\n        'sand_yard_completed',\n        'simulation_completed',\n        'dat_completed',\n        'cabin_completed',\n        'graduation_eligible',\n      ].some((k) => data[k] !== undefined);\n\n    if (needsEnrollmentUpdate) {\n      const latestEnrollment = await CourseStudentModel.findOne({ student_id: id }).sort({ created_at: -1 });\n      if (latestEnrollment) {\n        this._mergeLatestEnrollmentFlags(courseUpdate, latestEnrollment, data);\n        await CourseStudentModel.updateOne({ _id: latestEnrollment._id }, { $set: courseUpdate });\n      } else if (courseUpdate.course_id) {\n        // Create new enrollment if none exists but course info is provided\n        await CourseStudentModel.create({\n          student_id: id,\n          ...courseUpdate,\n        });\n      }\n    }\n\n    return await this.studentRepository.findById(id);\n  }\n\n  private async _mapCourseUpdateData(data: any): Promise<any> {\n    const courseUpdate: any = {};\n    if (data.status !== undefined) {\n      // Sanitize old status labels coming from legacy clients or old constants\n      let sanitizedStatus = data.status;\n      if (sanitizedStatus === 'Đã xong KSK') sanitizedStatus = 'Đã KSK';\n      courseUpdate.status_detail = sanitizedStatus;\n    }\n    if (data.course !== undefined && data.course !== '') {\n      courseUpdate.course_id = data.course;\n      // Fetch course fee to initialize tuition\n      const course = await CourseModel.findById(data.course).select('course_fee').lean().exec();\n      if (course) {\n        courseUpdate.fee = (course as any).course_fee || 0;\n      }\n    }\n    if (data.rank !== undefined && data.rank !== '') {\n      courseUpdate.license_category_id = await this._resolveLicenseCategoryId(data.rank);\n    }\n    return courseUpdate;\n  }\n\n  private async _resolveLicenseCategoryId(rank: string | null | undefined): Promise<any> {\n    if (!rank) return null;\n    // Check if it's already an ObjectId\n    if (mongoose.Types.ObjectId.isValid(rank)) return rank;\n\n    // Look up by name or code\n    const category = await LicenseCategoryModel.findOne({\n      $or: [{ name: rank }, { code: rank }],\n    }).exec();\n\n    return category ? category._id : null;\n  }\n\n  private _mergeLatestEnrollmentFlags(courseUpdate: any, latestEnrollment: any, data: any) {\n    const { health_check_status, health_check_date, hospital_id, health_check_note } = data;\n    if ([health_check_status, health_check_date, hospital_id, health_check_note].some((v) => v !== undefined)) {\n      const hc: any = latestEnrollment.health_check || {};\n\n      let parsedDate = hc.date ?? null;\n      if (health_check_date === '' || health_check_date === null) {\n        parsedDate = null;\n      } else if (health_check_date && health_check_date !== 'Invalid Date') {\n        const d = new Date(health_check_date);\n        if (!isNaN(d.getTime())) {\n          parsedDate = d;\n        }\n      }\n\n      courseUpdate.health_check = {\n        status: health_check_status ?? hc.status ?? 'Chờ khám',\n        date: parsedDate,\n        hospital: hospital_id ?? hc.hospital ?? null,\n        note: health_check_note ?? hc.note ?? null,\n      };\n\n      // --- DATA SYNCHRONIZATION: Health Check -> Dashboard Status ---\n      // If health check status is updated to 'Đủ điều kiện', auto-set dashboard status to 'Đã KSK'\n      // This ensures dashboard stats stay in sync with actual biological/medical progress.\n      if (courseUpdate.health_check.status === 'Đủ điều kiện' && courseUpdate.status_detail !== 'Đã KSK') {\n        courseUpdate.status_detail = 'Đã KSK';\n      } else if (courseUpdate.health_check.status === 'Chờ khám' && latestEnrollment.status_detail === 'Đã KSK') {\n        // If downgraded or reset, sync back to 'Chờ KSK'\n        courseUpdate.status_detail = 'Chờ KSK';\n      }\n    }\n\n    const {\n      theory_completed,\n      sand_yard_completed,\n      simulation_completed,\n      dat_completed,\n      cabin_completed,\n      graduation_eligible,\n    } = data;\n    if (\n      [\n        theory_completed,\n        sand_yard_completed,\n        simulation_completed,\n        dat_completed,\n        cabin_completed,\n        graduation_eligible,\n      ].some((v) => v !== undefined)\n    ) {\n      const pf: any = latestEnrollment.progress_flags || {};\n      courseUpdate.progress_flags = {\n        theory_completed: theory_completed ?? pf.theory_completed ?? false,\n        sand_yard_completed: sand_yard_completed ?? pf.sand_yard_completed ?? false,\n        simulation_completed: simulation_completed ?? pf.simulation_completed ?? false,\n        dat_completed: dat_completed ?? pf.dat_completed ?? false,\n        cabin_completed: cabin_completed ?? pf.cabin_completed ?? false,\n        graduation_eligible: graduation_eligible ?? pf.graduation_eligible ?? false,\n      };\n\n      // --- DATA SYNCHRONIZATION: Exam Eligibility ---\n      // If graduation_eligible is true, and status is still a training status, advance it to 'Đang thi'\n      if (\n        courseUpdate.progress_flags.graduation_eligible &&\n        ['Đang học', 'Đang học LT', 'Đang học TH', 'Đã KSK', 'Nộp HS'].includes(latestEnrollment.status_detail)\n      ) {\n        courseUpdate.status_detail = 'Đang thi';\n      }\n    }\n  }\n\n  async createStudent(data: any) {\n    const {\n      phone,\n      identity_card,\n      user_id,\n      region_id,\n      course_id,\n      fee,\n      status_detail,\n      license_category_id,\n      amount,\n      installment,\n      lead_manager,\n      student_code,\n      teacher_id,\n    } = data;\n\n    let targetUserId = user_id;\n\n    // Sanitize status_detail\n    let sanitizedStatus = status_detail || (course_id ? 'Đã vào khóa' : 'Chờ KSK');\n    if (sanitizedStatus === 'Đã xong KSK') sanitizedStatus = 'Đã KSK';\n\n    if (!targetUserId) {\n      const existingUser = await this.userService.findExistingUser(phone, identity_card);\n      if (existingUser) {\n        // Check if this user already has a student record\n        const existingStudent = await StudentModel.findOne({ user_id: existingUser._id, is_deleted: false }).exec();\n        if (existingStudent) {\n          throw new AppError('Học viên với số điện thoại hoặc CCCD này đã tồn tại.', 400);\n        }\n        targetUserId = existingUser._id;\n      } else {\n        const user = await this.userService.createStudentUser(data);\n        targetUserId = user._id;\n      }\n    } else {\n      // Check if this specific user_id is already a student\n      const existingStudent = await StudentModel.findOne({ user_id: targetUserId, is_deleted: false }).exec();\n      if (existingStudent) {\n        throw new AppError('Người dùng này đã có hồ sơ học viên trên hệ thống.', 400);\n      }\n    }\n\n    // Capture rank and status for the student profile (StudentInfos)\n    const licenseCategoryId = await this._resolveLicenseCategoryId(license_category_id);\n\n    let resolvedRegionId;\n    if (region_id && typeof region_id === 'string' && !mongoose.Types.ObjectId.isValid(region_id)) {\n      const city = await CityModel.findOne({ name: region_id }).select('_id').lean().exec();\n      resolvedRegionId = city ? (city as any)._id : null;\n    } else if (region_id && mongoose.Types.ObjectId.isValid(region_id)) {\n      resolvedRegionId = new mongoose.Types.ObjectId(region_id);\n    } else {\n      resolvedRegionId = null;\n    }\n\n    const student = await this.studentRepository.create({\n      user_id: targetUserId,\n      region_id: resolvedRegionId as any,\n      license_category_id: licenseCategoryId,\n      status_detail: sanitizedStatus,\n      lead_manager: lead_manager || null,\n      student_code: student_code || null,\n      teacher_id: teacher_id ? new mongoose.Types.ObjectId(teacher_id) : null,\n    });\n\n    if (course_id) {\n      let actualFee = fee;\n      if (!actualFee || actualFee === 0) {\n        const course = await CourseModel.findById(course_id).select('course_fee').lean().exec();\n        actualFee = (course as any)?.course_fee || 0;\n      }\n\n      const enrollment = await CourseStudentModel.create({\n        student_id: student._id,\n        course_id: course_id,\n        teacher_id: teacher_id ? new mongoose.Types.ObjectId(teacher_id) : null,\n        license_category_id: licenseCategoryId,\n        fee: actualFee,\n        status_detail: sanitizedStatus,\n      });\n\n      // Create initial payment if amount > 0\n      if (amount && amount > 0) {\n        // eslint-disable-next-line @typescript-eslint/no-require-imports\n        const { PaymentModel } = require('@/infrastructure/database/models/payment.model');\n        const receiptCode = await this.paymentRepository.getNextReceiptCode();\n\n        await PaymentModel.create({\n          course_student_id: enrollment._id,\n          payment_date: new Date(),\n          received_fee: amount,\n          type: 'tuition_fee',\n          stage_name: installment || 'Lần đóng 1',\n          note: receiptCode,\n          is_received: true,\n        });\n      }\n    }\n\n    // Return enriched data for immediate UI feedback\n    return await this.getStudentById(student._id.toString());\n  }\n\n  async deleteStudent(id: string, currentUser?: any) {\n    // 1. Verify existence and ownership\n    await this.getStudentById(id, currentUser);\n\n    // 2. Cascade delete any course enrollments mapped to this student\n    await CourseStudentModel.deleteMany({ student_id: id });\n    return await this.studentRepository.delete(id);\n  }\n\n  async exportStudentsToExcel(res: Response, filters: any, currentUser?: any): Promise<void> {\n    const { data } = await this.studentRepository.findAll(filters, { page: 1, limit: 5000 }, currentUser);\n\n    const { workbook, worksheet } = this.excelHelper.createWorkbook('Danh sách học viên');\n\n    this.excelHelper.applyHeaderStyle(worksheet, [\n      { header: 'Họ và tên', key: 'name', width: 25 },\n      { header: 'Số điện thoại', key: 'phone', width: 15 },\n      { header: 'CCCD/CMND', key: 'id_card', width: 15 },\n      { header: 'Hạng GPLX', key: 'license', width: 12 },\n      { header: 'Hệ đào tạo', key: 'system', width: 15 },\n      { header: 'Khu vực', key: 'region', width: 15 },\n      { header: 'Trạng thái', key: 'status', width: 20 },\n      { header: 'Ngày đăng ký', key: 'created_at', width: 15 },\n    ]);\n\n    data.forEach((s: any) => {\n      const user = s.user_id || {};\n      worksheet.addRow({\n        name: `${user.last_name || ''} ${user.first_name || ''}`.trim(),\n        phone: user.phone || '',\n        id_card: user.id_card || '',\n        license: s.license_category_name || '',\n        system: s.course_type || '',\n        region: s.region_name || s.region_id?.name || '',\n        status: s.status_detail || s.status_main || '',\n        created_at: s.created_at ? new Date(s.created_at).toLocaleDateString('vi-VN') : '',\n      });\n    });\n\n    this.excelHelper.applyRowStyle(worksheet);\n    await this.excelHelper.sendWorkbook(res, workbook, 'danh_sach_hoc_vien');\n  }\n\n  async getStudentHistory(id: string, options: PaginationOptions = { page: 1, limit: 20 }) {\n    const { page, limit } = options;\n    const skip = (page - 1) * limit;\n\n    const logs = await SystemLogModel.find({ entity_id: id })\n      .sort({ created_at: -1 })\n      .skip(skip)\n      .limit(limit)\n      .populate('user_id', 'first_name last_name email')\n      .exec();\n\n    const total = await SystemLogModel.countDocuments({ entity_id: id });\n\n    return {\n      data: logs,\n      meta: {\n        total,\n        page,\n        limit,\n        total_pages: Math.ceil(total / limit),\n      },\n    };\n  }\n\n  async isStudentAssignedToTeacher(studentId: string, teacherId: string): Promise<boolean> {\n    // 1. Check in Enrollments\n    const enrolled = await CourseStudentModel.countDocuments({\n      student_id: studentId,\n      teacher_id: teacherId,\n    });\n    if (enrolled > 0) return true;\n\n    // 2. Check in Direct Ownership\n    const owned = await StudentModel.countDocuments({\n      _id: studentId,\n      teacher_id: teacherId,\n    });\n    return owned > 0;\n  }\n\n  async getImportManagementStats(currentUser?: any) {\n    const baseMatch: any = { is_deleted: false };\n\n    if (currentUser?.role === 'teacher') {\n      const assignedIds = await this.studentRepository.getAssignedStudentIds(currentUser.id);\n      baseMatch._id = { $in: assignedIds };\n    }\n\n    const [total, enrolled, unassigned, waiting, remaining, today] = await Promise.all([\n      StudentModel.countDocuments(baseMatch),\n      StudentModel.countDocuments({ ...baseMatch, status_detail: 'Đã vào khóa' }),\n      StudentModel.countDocuments({ ...baseMatch, status_detail: 'Chưa vào khóa' }),\n      StudentModel.countDocuments({ ...baseMatch, status_detail: 'Chờ xếp khóa' }),\n      StudentModel.countDocuments({ ...baseMatch, status_detail: 'Học viên tồn' }),\n      StudentModel.countDocuments({\n        ...baseMatch,\n        created_at: { $gte: new Date().setHours(0, 0, 0, 0) },\n      }),\n    ]);\n\n    return { total, today, enrolled, unassigned, waiting, remaining };\n  }\n\n  /**\n   * Get list of potential leads (Managers/Sales/Staff)\n   */\n  async getLeads() {\n    // 1. Find roles that can be managers\n    const targetRoles = [UserRoleName.Lead, UserRoleName.Sale, UserRoleName.Staff, UserRoleName.Admin];\n    const roles = await RoleModel.find({ role_name: { $in: targetRoles } })\n      .select('_id role_name')\n      .lean()\n      .exec();\n    const roleIds = roles.map((r) => r._id);\n\n    // 2. Find user links with those roles\n    const userRoleLinks = await UserRoleModel.find({ role_id: { $in: roleIds } })\n      .select('user_id')\n      .lean()\n      .exec();\n    const userIds = userRoleLinks.map((link) => link.user_id);\n\n    // 3. Get user details\n    const users = await UserModel.find({\n      _id: { $in: userIds },\n      status: 'active',\n    })\n      .select('_id first_name last_name email phone')\n      .sort({ last_name: 1, first_name: 1 })\n      .lean()\n      .exec();\n\n    return users.map((u) => ({\n      _id: u._id,\n      name: `${u.last_name} ${u.first_name}`.trim(),\n      email: u.email,\n      phone: u.phone,\n    }));\n  }\n\n  async importStudentsFromExcel(filePath: string, userId: string, userRole: string = 'user', courseId?: string) {\n    // We do NOT await this in the controller. It runs in the background.\n    const runImport = async () => {\n      try {\n        const data = await this.excelHelper.parseStudentExcel(filePath);\n        const results = {\n          success: 0,\n          failed: 0,\n          skipped: 0,\n          errors: [] as any[],\n        };\n\n        // Determine notification context\n        const contextType = userRole === 'teacher' || userRole === 'student' ? userRole : 'user';\n\n        for (const item of data) {\n          try {\n            if (!item.firstName) {\n              results.failed++;\n              results.errors.push({ name: 'Ẩn danh', error: 'Thiếu tên học viên' });\n              continue;\n            }\n\n            const duplicate = await this.userService.findExistingUser(item.phone, item.cccd);\n            if (duplicate) {\n              // Only skip if the user is ALREADY a student\n              const isAlreadyStudent = await StudentModel.findOne({ user_id: duplicate._id, is_deleted: false })\n                .select('_id')\n                .lean()\n                .exec();\n              if (isAlreadyStudent) {\n                results.skipped++;\n                continue;\n              }\n              // If user exists but is not a student, continue to createStudent which will handle the conversion\n            }\n\n            const genderInput = item.gender?.toString().toLowerCase();\n            const gender = genderInput === 'nam' ? 'male' : genderInput === 'nữ' ? 'female' : 'male';\n\n            await this.createStudent({\n              first_name: item.firstName,\n              last_name: item.lastName || '',\n              phone: item.phone,\n              identity_card: item.identity_card || item.cccd,\n              address: item.address,\n              license_category_id: item.license_category_id || item.licenseRank,\n              existing_license_num: item.existing_license_num || item.licenseNum,\n              gender: gender,\n              dob: item.dob,\n              course_id: courseId,\n              amount: item.amount,\n              installment: item.installment,\n              lead_manager: item.lead_manager || item.leadManager,\n              student_code: item.student_code,\n              teacher_id: userId,\n            });\n\n            results.success++;\n\n            // Progress notification every 5 students\n            if (results.success % 5 === 0) {\n              await this.notifyService.send({\n                userId,\n                title: '⏳ Đang nhập dữ liệu...',\n                content: `Đã xử lý thành công ${results.success} học viên.`,\n                channel: 'in_app',\n              });\n            }\n          } catch (error: any) {\n            results.failed++;\n            results.errors.push({ name: item.firstName, error: error.message });\n          }\n        }\n\n        // --- GENERATE SUMMARY REPORT AFTER IMPORT ---\n        const stats = await this.getImportManagementStats();\n\n        const summaryContent = [\n          `Đã xử lý xong file Excel.`,\n          `✅ Thành công: ${results.success}`,\n          `⏭️ Bỏ qua (Trùng): ${results.skipped}`,\n          `❌ Lỗi: ${results.failed}`,\n          results.errors.length > 0\n            ? `Chi tiết lỗi: ${results.errors\n                .slice(0, 3)\n                .map((e) => `${e.name}: ${e.error}`)\n                .join('; ')}${results.errors.length > 3 ? '...' : ''}`\n            : '',\n          `\\n📊 BÁO CÁO TỔNG HỢP HỆ THỐNG:`,\n          `• Tổng số học viên: ${stats.total}`,\n          `• Đã vào khóa: ${stats.enrolled}`,\n          `• Chưa vào khóa: ${stats.unassigned}`,\n          `• Chờ xếp khóa: ${stats.waiting}`,\n          `• Học viên tồn: ${stats.remaining}`,\n        ]\n          .filter((line) => line !== '')\n          .join('\\n');\n\n        // Create FINAL notification with the summary report\n        await this.notifyService.send({\n          userId,\n          title: '📑 Hoàn tất nhập dữ liệu học viên',\n          content: summaryContent,\n          channel: 'in_app',\n        });\n      } catch (error: any) {\n        console.error('Import process failed:', error);\n\n        await this.notifyService.send({\n          userId,\n          title: 'Lỗi nhập dữ liệu học viên',\n          content: `Đã xảy ra lỗi nghiêm trọng khi xử lý file: ${error.message}`,\n          channel: 'in_app',\n        });\n      } finally {\n        // Cleanup the file\n        if (fs.existsSync(filePath)) {\n          fs.unlinkSync(filePath);\n        }\n      }\n    };\n\n    // Trigger background execution\n    runImport();\n    return { message: 'Quá trình nhập dữ liệu đã bắt đầu chạy ngầm' };\n  }\n}","cwd":"/root/.openclaw/workspaces2/v4-ecosystem-review/master-orchestrator"},"isError":false,"timestamp":1776833440466}}
{"type":"message","id":"d29b5800","parentId":"a2da0b34","timestamp":"2026-04-22T04:50:40.496Z","message":{"role":"toolResult","toolCallId":"call_function_yek6vi8246zi_2","toolName":"exec","content":[{"type":"text","text":"import { CourseRepository } from '@/infrastructure/repositories/course.repository';\nimport { ICourse } from '@/infrastructure/database/models/course.model';\nimport { StudentRepository } from '@/infrastructure/repositories/student.repository';\nimport { ExcelHelper } from '@/infrastructure/utils/excel.helper';\nimport { Response } from 'express';\nimport mongoose from 'mongoose';\nimport { LicenseCategoryModel } from '../../infrastructure/database/models/license_category.model';\nimport { CourseStudentModel } from '../../infrastructure/database/models/course_student.model';\nimport { PaginationOptions } from '@/domain/types/pagination.types';\nimport { COURSE_STATUS_DISPLAY, COURSE_TYPES } from '@/domain/constants/course.constants';\nimport { NotifyService } from './notify.service';\nimport fs from 'fs';\n\nexport class CourseService {\n  private courseRepository: CourseRepository;\n  private studentRepository: StudentRepository;\n  private excelHelper: ExcelHelper;\n  private notifyService: NotifyService;\n\n  constructor() {\n    this.courseRepository = new CourseRepository();\n    this.studentRepository = new StudentRepository();\n    this.excelHelper = new ExcelHelper();\n    this.notifyService = new NotifyService();\n  }\n\n  async getAllCourses(filters = {}, options: PaginationOptions = { page: 1, limit: 10 }, currentUser?: any) {\n    return await this.courseRepository.findAll(filters, options, currentUser);\n  }\n\n  async getCourseById(id: string, currentUser?: any) {\n    const course = await this.courseRepository.findById(id, currentUser);\n    if (!course) {\n      throw new Error('Không tìm thấy khóa học hoặc bạn không có quyền truy cập');\n    }\n    return course;\n  }\n\n  private async resolveLicenseCategoryId(data: Partial<ICourse>) {\n    if (data.license_category_id && !mongoose.Types.ObjectId.isValid(String(data.license_category_id))) {\n      const val = String(data.license_category_id);\n      let cat = await LicenseCategoryModel.findOne({ code: val });\n      if (!cat) {\n        cat = await LicenseCategoryModel.findOne({ name: val });\n      }\n\n      if (cat) {\n        data.license_category_id = cat._id as any;\n      } else {\n        delete data.license_category_id;\n      }\n    }\n  }\n\n  async createCourse(data: Partial<ICourse>) {\n    if (data.code) {\n      const existing = await this.courseRepository.findByCode(data.code);\n      if (existing) {\n        throw new Error('Mã khóa học đã tồn tại');\n      }\n    }\n    await this.resolveLicenseCategoryId(data);\n    return await this.courseRepository.create(data);\n  }\n\n  async updateCourse(id: string, data: Partial<ICourse>, currentUser?: any) {\n    await this.resolveLicenseCategoryId(data);\n    return await this.courseRepository.update(id, data);\n  }\n\n  async deleteCourse(id: string, currentUser?: any) {\n    return await this.courseRepository.delete(id);\n  }\n\n  async assignStudentsToCourse(courseId: string, studentIds: string[]) {\n    if (!studentIds || studentIds.length === 0) {\n      throw new Error('Vui lòng chọn học viên');\n    }\n    const records = studentIds.map((sid) => ({\n      student_id: sid,\n      course_id: courseId,\n      status: 'unfinished',\n    }));\n    return await CourseStudentModel.insertMany(records);\n  }\n\n  async getUnassignedStudents(filters = {}, options: PaginationOptions = { page: 1, limit: 100 }) {\n    return await this.studentRepository.findUnassigned(filters, options);\n  }\n\n  async exportCoursesToExcel(res: Response, filters: any, currentUser?: any): Promise<void> {\n    const { data } = await this.courseRepository.findAll(filters, { page: 1, limit: 1000 }, currentUser);\n\n    const { workbook, worksheet } = this.excelHelper.createWorkbook('Danh sách khóa học');\n\n    this.excelHelper.applyHeaderStyle(worksheet, [\n      { header: 'Mã khóa học', key: 'code', width: 15 },\n      { header: 'Tên khóa học', key: 'name', width: 30 },\n      { header: 'Hạng GPLX', key: 'license', width: 12 },\n      { header: 'Hệ đào tạo', key: 'system', width: 20 },\n      { header: 'Ngày khai giảng', key: 'start_date', width: 18 },\n      { header: 'Ngày bế giảng', key: 'end_date', width: 18 },\n      { header: 'Trạng thái', key: 'status', width: 15 },\n    ]);\n\n    data.forEach((c: any) => {\n      worksheet.addRow({\n        code: c.code || '',\n        name: c.name || '',\n        license: c.license_category_name || c.license_category_code || '',\n        system: c.course_type || COURSE_TYPES.DIRECT,\n        start_date: c.start_date ? new Date(c.start_date).toLocaleDateString('vi-VN') : '',\n        end_date: c.end_date ? new Date(c.end_date).toLocaleDateString('vi-VN') : '',\n        status: COURSE_STATUS_DISPLAY[c.status as keyof typeof COURSE_STATUS_DISPLAY] || c.status,\n      });\n    });\n\n    this.excelHelper.applyRowStyle(worksheet);\n    await this.excelHelper.sendWorkbook(res, workbook, 'danh_sach_khoa_hoc');\n  }\n\n  async getCourseImportTemplate(res: Response) {\n    return await this.excelHelper.getCourseImportTemplate(res);\n  }\n\n  async getCourseStats(currentUser?: any) {\n    return await this.courseRepository.getStats(currentUser);\n  }\n\n  async importCoursesFromExcel(filePath: string, userId: string, userRole: string = 'user') {\n    const runImport = async () => {\n      try {\n        const data = await this.excelHelper.parseCourseExcel(filePath);\n        const results = {\n          success: 0,\n          failed: 0,\n          errors: [] as any[],\n        };\n\n        const licenseCats = await LicenseCategoryModel.find({ is_deleted: { $ne: true } })\n          .lean()\n          .exec();\n\n        for (const item of data) {\n          try {\n            if (!item.name || !item.code) {\n              results.failed++;\n              results.errors.push({ name: item.name || 'Ẩn danh', error: 'Thiếu tên hoặc mã khóa học' });\n              continue;\n            }\n\n            // Resolve license category ID\n            const category = licenseCats.find(\n              (lc) =>\n                lc.name.toLowerCase().includes(item.licenseRank.toLowerCase()) ||\n                lc.code.toLowerCase() === item.licenseRank.toLowerCase(),\n            );\n\n            if (!category && item.licenseRank) {\n              results.failed++;\n              results.errors.push({ name: item.name, error: `Không tìm thấy hạng đào tạo: ${item.licenseRank}` });\n              continue;\n            }\n\n            // Map course type\n            const courseType = item.courseType?.toLowerCase().includes('nâng') ? 'Nâng hạng' : 'Học trực tiếp';\n\n            await this.courseRepository.create({\n              name: item.name,\n              code: item.code,\n              license_category_id: category?._id,\n              course_type: courseType,\n              start_date: item.startDate,\n              end_date: item.endDate,\n              max_students: item.maxStudents,\n              course_fee: item.courseFee,\n              note: item.note,\n              status: 'draft',\n              teacher_id: userId as any,\n            });\n\n            results.success++;\n\n            // Progress notification\n            if (results.success % 5 === 0) {\n              await this.notifyService.send({\n                userId,\n                title: '⏳ Đang nhập khóa học...',\n                content: `Đã xử lý thành công ${results.success} khóa học.`,\n                channel: 'in_app',\n              });\n            }\n          } catch (error: any) {\n            results.failed++;\n            results.errors.push({ name: item.name, error: error.message });\n          }\n        }\n\n        // Final notification\n        await this.notifyService.send({\n          userId,\n          title: '📑 Hoàn tất nhập danh sách khóa học',\n          content: `Đã xử lý xong file Excel.\\n✅ Thành công: ${results.success}\\n❌ Lỗi: ${results.failed}${\n            results.errors.length > 0\n              ? `\\nChi tiết lỗi: ${results.errors\n                  .slice(0, 3)\n                  .map((e) => `${e.name}: ${e.error}`)\n                  .join('; ')}${results.errors.length > 3 ? '...' : ''}`\n              : ''\n          }`,\n          channel: 'in_app',\n        });\n      } catch (error: any) {\n        console.error('Course import failed:', error);\n        await this.notifyService.send({\n          userId,\n          title: 'Lỗi nhập danh sách khóa học',\n          content: `Đã xảy ra lỗi nghiêm trọng: ${error.message}`,\n          channel: 'in_app',\n        });\n      } finally {\n        if (fs.existsSync(filePath)) {\n          fs.unlinkSync(filePath);\n        }\n      }\n    };\n\n    runImport();\n    return { message: 'Quá trình nhập dữ liệu đã bắt đầu chạy ngầm' };\n  }\n}"}],"details":{"status":"completed","exitCode":0,"durationMs":83,"aggregated":"import { CourseRepository } from '@/infrastructure/repositories/course.repository';\nimport { ICourse } from '@/infrastructure/database/models/course.model';\nimport { StudentRepository } from '@/infrastructure/repositories/student.repository';\nimport { ExcelHelper } from '@/infrastructure/utils/excel.helper';\nimport { Response } from 'express';\nimport mongoose from 'mongoose';\nimport { LicenseCategoryModel } from '../../infrastructure/database/models/license_category.model';\nimport { CourseStudentModel } from '../../infrastructure/database/models/course_student.model';\nimport { PaginationOptions } from '@/domain/types/pagination.types';\nimport { COURSE_STATUS_DISPLAY, COURSE_TYPES } from '@/domain/constants/course.constants';\nimport { NotifyService } from './notify.service';\nimport fs from 'fs';\n\nexport class CourseService {\n  private courseRepository: CourseRepository;\n  private studentRepository: StudentRepository;\n  private excelHelper: ExcelHelper;\n  private notifyService: NotifyService;\n\n  constructor() {\n    this.courseRepository = new CourseRepository();\n    this.studentRepository = new StudentRepository();\n    this.excelHelper = new ExcelHelper();\n    this.notifyService = new NotifyService();\n  }\n\n  async getAllCourses(filters = {}, options: PaginationOptions = { page: 1, limit: 10 }, currentUser?: any) {\n    return await this.courseRepository.findAll(filters, options, currentUser);\n  }\n\n  async getCourseById(id: string, currentUser?: any) {\n    const course = await this.courseRepository.findById(id, currentUser);\n    if (!course) {\n      throw new Error('Không tìm thấy khóa học hoặc bạn không có quyền truy cập');\n    }\n    return course;\n  }\n\n  private async resolveLicenseCategoryId(data: Partial<ICourse>) {\n    if (data.license_category_id && !mongoose.Types.ObjectId.isValid(String(data.license_category_id))) {\n      const val = String(data.license_category_id);\n      let cat = await LicenseCategoryModel.findOne({ code: val });\n      if (!cat) {\n        cat = await LicenseCategoryModel.findOne({ name: val });\n      }\n\n      if (cat) {\n        data.license_category_id = cat._id as any;\n      } else {\n        delete data.license_category_id;\n      }\n    }\n  }\n\n  async createCourse(data: Partial<ICourse>) {\n    if (data.code) {\n      const existing = await this.courseRepository.findByCode(data.code);\n      if (existing) {\n        throw new Error('Mã khóa học đã tồn tại');\n      }\n    }\n    await this.resolveLicenseCategoryId(data);\n    return await this.courseRepository.create(data);\n  }\n\n  async updateCourse(id: string, data: Partial<ICourse>, currentUser?: any) {\n    await this.resolveLicenseCategoryId(data);\n    return await this.courseRepository.update(id, data);\n  }\n\n  async deleteCourse(id: string, currentUser?: any) {\n    return await this.courseRepository.delete(id);\n  }\n\n  async assignStudentsToCourse(courseId: string, studentIds: string[]) {\n    if (!studentIds || studentIds.length === 0) {\n      throw new Error('Vui lòng chọn học viên');\n    }\n    const records = studentIds.map((sid) => ({\n      student_id: sid,\n      course_id: courseId,\n      status: 'unfinished',\n    }));\n    return await CourseStudentModel.insertMany(records);\n  }\n\n  async getUnassignedStudents(filters = {}, options: PaginationOptions = { page: 1, limit: 100 }) {\n    return await this.studentRepository.findUnassigned(filters, options);\n  }\n\n  async exportCoursesToExcel(res: Response, filters: any, currentUser?: any): Promise<void> {\n    const { data } = await this.courseRepository.findAll(filters, { page: 1, limit: 1000 }, currentUser);\n\n    const { workbook, worksheet } = this.excelHelper.createWorkbook('Danh sách khóa học');\n\n    this.excelHelper.applyHeaderStyle(worksheet, [\n      { header: 'Mã khóa học', key: 'code', width: 15 },\n      { header: 'Tên khóa học', key: 'name', width: 30 },\n      { header: 'Hạng GPLX', key: 'license', width: 12 },\n      { header: 'Hệ đào tạo', key: 'system', width: 20 },\n      { header: 'Ngày khai giảng', key: 'start_date', width: 18 },\n      { header: 'Ngày bế giảng', key: 'end_date', width: 18 },\n      { header: 'Trạng thái', key: 'status', width: 15 },\n    ]);\n\n    data.forEach((c: any) => {\n      worksheet.addRow({\n        code: c.code || '',\n        name: c.name || '',\n        license: c.license_category_name || c.license_category_code || '',\n        system: c.course_type || COURSE_TYPES.DIRECT,\n        start_date: c.start_date ? new Date(c.start_date).toLocaleDateString('vi-VN') : '',\n        end_date: c.end_date ? new Date(c.end_date).toLocaleDateString('vi-VN') : '',\n        status: COURSE_STATUS_DISPLAY[c.status as keyof typeof COURSE_STATUS_DISPLAY] || c.status,\n      });\n    });\n\n    this.excelHelper.applyRowStyle(worksheet);\n    await this.excelHelper.sendWorkbook(res, workbook, 'danh_sach_khoa_hoc');\n  }\n\n  async getCourseImportTemplate(res: Response) {\n    return await this.excelHelper.getCourseImportTemplate(res);\n  }\n\n  async getCourseStats(currentUser?: any) {\n    return await this.courseRepository.getStats(currentUser);\n  }\n\n  async importCoursesFromExcel(filePath: string, userId: string, userRole: string = 'user') {\n    const runImport = async () => {\n      try {\n        const data = await this.excelHelper.parseCourseExcel(filePath);\n        const results = {\n          success: 0,\n          failed: 0,\n          errors: [] as any[],\n        };\n\n        const licenseCats = await LicenseCategoryModel.find({ is_deleted: { $ne: true } })\n          .lean()\n          .exec();\n\n        for (const item of data) {\n          try {\n            if (!item.name || !item.code) {\n              results.failed++;\n              results.errors.push({ name: item.name || 'Ẩn danh', error: 'Thiếu tên hoặc mã khóa học' });\n              continue;\n            }\n\n            // Resolve license category ID\n            const category = licenseCats.find(\n              (lc) =>\n                lc.name.toLowerCase().includes(item.licenseRank.toLowerCase()) ||\n                lc.code.toLowerCase() === item.licenseRank.toLowerCase(),\n            );\n\n            if (!category && item.licenseRank) {\n              results.failed++;\n              results.errors.push({ name: item.name, error: `Không tìm thấy hạng đào tạo: ${item.licenseRank}` });\n              continue;\n            }\n\n            // Map course type\n            const courseType = item.courseType?.toLowerCase().includes('nâng') ? 'Nâng hạng' : 'Học trực tiếp';\n\n            await this.courseRepository.create({\n              name: item.name,\n              code: item.code,\n              license_category_id: category?._id,\n              course_type: courseType,\n              start_date: item.startDate,\n              end_date: item.endDate,\n              max_students: item.maxStudents,\n              course_fee: item.courseFee,\n              note: item.note,\n              status: 'draft',\n              teacher_id: userId as any,\n            });\n\n            results.success++;\n\n            // Progress notification\n            if (results.success % 5 === 0) {\n              await this.notifyService.send({\n                userId,\n                title: '⏳ Đang nhập khóa học...',\n                content: `Đã xử lý thành công ${results.success} khóa học.`,\n                channel: 'in_app',\n              });\n            }\n          } catch (error: any) {\n            results.failed++;\n            results.errors.push({ name: item.name, error: error.message });\n          }\n        }\n\n        // Final notification\n        await this.notifyService.send({\n          userId,\n          title: '📑 Hoàn tất nhập danh sách khóa học',\n          content: `Đã xử lý xong file Excel.\\n✅ Thành công: ${results.success}\\n❌ Lỗi: ${results.failed}${\n            results.errors.length > 0\n              ? `\\nChi tiết lỗi: ${results.errors\n                  .slice(0, 3)\n                  .map((e) => `${e.name}: ${e.error}`)\n                  .join('; ')}${results.errors.length > 3 ? '...' : ''}`\n              : ''\n          }`,\n          channel: 'in_app',\n        });\n      } catch (error: any) {\n        console.error('Course import failed:', error);\n        await this.notifyService.send({\n          userId,\n          title: 'Lỗi nhập danh sách khóa học',\n          content: `Đã xảy ra lỗi nghiêm trọng: ${error.message}`,\n          channel: 'in_app',\n        });\n      } finally {\n        if (fs.existsSync(filePath)) {\n          fs.unlinkSync(filePath);\n        }\n      }\n    };\n\n    runImport();\n    return { message: 'Quá trình nhập dữ liệu đã bắt đầu chạy ngầm' };\n  }\n}","cwd":"/root/.openclaw/workspaces2/v4-ecosystem-review/master-orchestrator"},"isError":false,"timestamp":1776833440484}}
{"type":"message","id":"234568ab","parentId":"d29b5800","timestamp":"2026-04-22T04:50:46.538Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Let me read more service files and the dashboard/exam services.","thinkingSignature":"8f809b6444fb414b501567a16ae1b24d8c1e9ef7572a97c09a9d8b8bfcb12ff5"},{"type":"toolCall","id":"call_function_58fsiayqh4jo_1","name":"exec","arguments":{"command":"cat /root/.openclaw/workspaces2/projects/ahv-qlhv-be/src/application/services/exam.service.ts"}},{"type":"toolCall","id":"call_function_58fsiayqh4jo_2","name":"exec","arguments":{"command":"cat /root/.openclaw/workspaces2/projects/ahv-qlhv-be/src/application/services/payment.service.ts"}},{"type":"toolCall","id":"call_function_58fsiayqh4jo_3","name":"exec","arguments":{"command":"cat /root/.openclaw/workspaces2/projects/ahv-qlhv-be/src/application/services/stadium.service.ts"}},{"type":"toolCall","id":"call_function_58fsiayqh4jo_4","name":"exec","arguments":{"command":"cat /root/.openclaw/workspaces2/projects/ahv-qlhv-be/src/application/services/lesson.service.ts"}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-DEV","usage":{"input":8037,"output":188,"cacheRead":29726,"cacheWrite":772,"totalTokens":38723,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776833440499,"responseId":"063786a189b55a7ff343d813296debc7"}}
{"type":"message","id":"cbdf9ea0","parentId":"234568ab","timestamp":"2026-04-22T04:50:46.758Z","message":{"role":"toolResult","toolCallId":"call_function_58fsiayqh4jo_1","toolName":"exec","content":[{"type":"text","text":"import { ExamRepository } from '../../infrastructure/repositories/exam.repository';\nimport { StudentRepository } from '../../infrastructure/repositories/student.repository';\nimport { IExam, ExamType } from '../../infrastructure/database/models/exam.model';\nimport { UserModel } from '@/infrastructure/database/models/user.model';\nimport { StudentModel } from '@/infrastructure/database/models/student.model';\nimport { PaginationOptions } from '@/domain/types/pagination.types';\nimport { ExcelHelper } from '@/infrastructure/utils/excel.helper';\nimport { Response } from 'express';\n\n// Service for exam domain operations\nexport class ExamService {\n  private examRepository: ExamRepository;\n  private studentRepository: StudentRepository;\n  private excelHelper: ExcelHelper;\n\n  constructor() {\n    this.examRepository = new ExamRepository();\n    this.studentRepository = new StudentRepository();\n    this.excelHelper = new ExcelHelper();\n  }\n\n  async getAllExams(filters = {}, options: PaginationOptions = { page: 1, limit: 10 }, currentUser?: any) {\n    return await this.examRepository.findAll(filters, options, currentUser);\n  }\n\n  async getExamById(id: string, currentUser?: any) {\n    const exam = await this.examRepository.findById(id, currentUser);\n    if (!exam) {\n      throw new Error('Không tìm thấy kỳ thi hoặc bạn không có quyền truy cập');\n    }\n    return exam;\n  }\n\n  async createExam(data: Partial<IExam>) {\n    return await this.examRepository.create(data);\n  }\n\n  async updateExam(id: string, data: Partial<IExam>) {\n    return await this.examRepository.update(id, data);\n  }\n\n  async deleteExam(id: string) {\n    return await this.examRepository.delete(id);\n  }\n\n  async getExamsByType(type: ExamType, options: PaginationOptions = { page: 1, limit: 10 }) {\n    return await this.examRepository.findByType(type, options);\n  }\n\n  async getExamStudents(id: string, options: PaginationOptions = { page: 1, limit: 10 }, currentUser?: any) {\n    return await this.examRepository.getStudents(id, options, currentUser);\n  }\n\n  async updateStudentResult(examId: string, studentId: string, result: string) {\n    return await this.examRepository.updateStudentResult(examId, studentId, result);\n  }\n\n  async removeStudentFromExam(examId: string, studentId: string) {\n    return await this.examRepository.removeStudentFromExam(examId, studentId);\n  }\n\n  async getExamsByStudent(studentId: string) {\n    return await this.examRepository.findByStudentId(studentId);\n  }\n\n  async isAuthorized(examId: string, teacherId: string): Promise<boolean> {\n    const exam = await this.examRepository.findById(examId);\n    if (!exam) return false;\n\n    // Strict Ownership Check: Is the teacher the creator of this exam batch/session?\n    if (exam.teacher_id && exam.teacher_id.toString() === teacherId) return true;\n\n    return false;\n  }\n\n  async exportExamsToExcel(res: Response, filters: any): Promise<void> {\n    const { data } = await this.examRepository.findAll(filters, { page: 1, limit: 5000 });\n\n    const { workbook, worksheet } = this.excelHelper.createWorkbook('Danh sách kỳ thi sát hạch');\n\n    this.excelHelper.applyHeaderStyle(worksheet, [\n      { header: 'Tên kỳ thi', key: 'name', width: 30 },\n      { header: 'Loại thi', key: 'exam_type', width: 15 },\n      { header: 'Sân thi', key: 'stadium', width: 20 },\n      { header: 'Ngày thi', key: 'start_time', width: 18 },\n      { header: 'Buổi', key: 'session', width: 10 },\n      { header: 'Trạng thái', key: 'status', width: 15 },\n      { header: 'Tổng thí sinh', key: 'total', width: 15 },\n      { header: 'Số đậu', key: 'passed', width: 12 },\n      { header: 'Số rớt', key: 'failed', width: 12 },\n      { header: 'Kết quả chung', key: 'result', width: 15 },\n    ]);\n\n    data.forEach((exam: any) => {\n      const results: any[] = exam.studentResults || [];\n      const passedCount = results.filter((r: any) => r.result === 'pass').length;\n      const failedCount = results.filter((r: any) => r.result === 'fail').length;\n\n      const examTypeLabel = exam.exam_type === 'sat_hach' ? 'Sát hạch' : 'Tốt nghiệp';\n      const resultLabel = exam.result === 'pass' ? 'Đậu' : exam.result === 'fail' ? 'Rớt' : 'Chưa có';\n\n      worksheet.addRow({\n        name: exam.name || '',\n        exam_type: examTypeLabel,\n        stadium: exam.stadium_id?.name || '',\n        start_time: exam.start_time ? new Date(exam.start_time).toLocaleDateString('vi-VN') : '',\n        session: exam.session || '',\n        status: exam.status || '',\n        total: exam.total_examinees ?? results.length,\n        passed: passedCount,\n        failed: failedCount,\n        result: resultLabel,\n      });\n    });\n\n    this.excelHelper.applyRowStyle(worksheet);\n    await this.excelHelper.sendWorkbook(res, workbook, 'danh_sach_ky_thi');\n  }\n\n  async getExamStats(type: ExamType, currentUser?: any) {\n    const [examStats, eligibleCount] = await Promise.all([\n      this.examRepository.getStats(type, currentUser),\n      currentUser?.role === 'teacher'\n        ? this.studentRepository.countEligibleByTeacher(currentUser.id || currentUser._id)\n        : this.studentRepository.countEligibleForGraduation(),\n    ]);\n\n    return {\n      ...examStats,\n      eligibleStudents: eligibleCount,\n    };\n  }\n\n  async importResults(examId: string, filePath: string) {\n    const results = await this.excelHelper.parseExamResults(filePath);\n    let successCount = 0;\n    let failCount = 0;\n\n    for (const item of results) {\n      try {\n        // Find student by CCCD or Code\n        const user = await UserModel.findOne({\n          $or: [{ identity_card: item.cccd }, { username: item.studentCode }],\n        })\n          .select('_id')\n          .lean()\n          .exec();\n\n        if (user) {\n          const student = await StudentModel.findOne({ user_id: user._id }).select('_id').lean().exec();\n          if (student) {\n            await this.examRepository.updateStudentResult(examId, student._id.toString(), item.result);\n            successCount++;\n          } else {\n            failCount++;\n          }\n        } else {\n          failCount++;\n        }\n      } catch (err) {\n        failCount++;\n      }\n    }\n\n    return { successCount, failCount };\n  }\n\n  async getResultTemplate(res: Response) {\n    return await this.excelHelper.getExamResultTemplate(res);\n  }\n}"}],"details":{"status":"completed","exitCode":0,"durationMs":141,"aggregated":"import { ExamRepository } from '../../infrastructure/repositories/exam.repository';\nimport { StudentRepository } from '../../infrastructure/repositories/student.repository';\nimport { IExam, ExamType } from '../../infrastructure/database/models/exam.model';\nimport { UserModel } from '@/infrastructure/database/models/user.model';\nimport { StudentModel } from '@/infrastructure/database/models/student.model';\nimport { PaginationOptions } from '@/domain/types/pagination.types';\nimport { ExcelHelper } from '@/infrastructure/utils/excel.helper';\nimport { Response } from 'express';\n\n// Service for exam domain operations\nexport class ExamService {\n  private examRepository: ExamRepository;\n  private studentRepository: StudentRepository;\n  private excelHelper: ExcelHelper;\n\n  constructor() {\n    this.examRepository = new ExamRepository();\n    this.studentRepository = new StudentRepository();\n    this.excelHelper = new ExcelHelper();\n  }\n\n  async getAllExams(filters = {}, options: PaginationOptions = { page: 1, limit: 10 }, currentUser?: any) {\n    return await this.examRepository.findAll(filters, options, currentUser);\n  }\n\n  async getExamById(id: string, currentUser?: any) {\n    const exam = await this.examRepository.findById(id, currentUser);\n    if (!exam) {\n      throw new Error('Không tìm thấy kỳ thi hoặc bạn không có quyền truy cập');\n    }\n    return exam;\n  }\n\n  async createExam(data: Partial<IExam>) {\n    return await this.examRepository.create(data);\n  }\n\n  async updateExam(id: string, data: Partial<IExam>) {\n    return await this.examRepository.update(id, data);\n  }\n\n  async deleteExam(id: string) {\n    return await this.examRepository.delete(id);\n  }\n\n  async getExamsByType(type: ExamType, options: PaginationOptions = { page: 1, limit: 10 }) {\n    return await this.examRepository.findByType(type, options);\n  }\n\n  async getExamStudents(id: string, options: PaginationOptions = { page: 1, limit: 10 }, currentUser?: any) {\n    return await this.examRepository.getStudents(id, options, currentUser);\n  }\n\n  async updateStudentResult(examId: string, studentId: string, result: string) {\n    return await this.examRepository.updateStudentResult(examId, studentId, result);\n  }\n\n  async removeStudentFromExam(examId: string, studentId: string) {\n    return await this.examRepository.removeStudentFromExam(examId, studentId);\n  }\n\n  async getExamsByStudent(studentId: string) {\n    return await this.examRepository.findByStudentId(studentId);\n  }\n\n  async isAuthorized(examId: string, teacherId: string): Promise<boolean> {\n    const exam = await this.examRepository.findById(examId);\n    if (!exam) return false;\n\n    // Strict Ownership Check: Is the teacher the creator of this exam batch/session?\n    if (exam.teacher_id && exam.teacher_id.toString() === teacherId) return true;\n\n    return false;\n  }\n\n  async exportExamsToExcel(res: Response, filters: any): Promise<void> {\n    const { data } = await this.examRepository.findAll(filters, { page: 1, limit: 5000 });\n\n    const { workbook, worksheet } = this.excelHelper.createWorkbook('Danh sách kỳ thi sát hạch');\n\n    this.excelHelper.applyHeaderStyle(worksheet, [\n      { header: 'Tên kỳ thi', key: 'name', width: 30 },\n      { header: 'Loại thi', key: 'exam_type', width: 15 },\n      { header: 'Sân thi', key: 'stadium', width: 20 },\n      { header: 'Ngày thi', key: 'start_time', width: 18 },\n      { header: 'Buổi', key: 'session', width: 10 },\n      { header: 'Trạng thái', key: 'status', width: 15 },\n      { header: 'Tổng thí sinh', key: 'total', width: 15 },\n      { header: 'Số đậu', key: 'passed', width: 12 },\n      { header: 'Số rớt', key: 'failed', width: 12 },\n      { header: 'Kết quả chung', key: 'result', width: 15 },\n    ]);\n\n    data.forEach((exam: any) => {\n      const results: any[] = exam.studentResults || [];\n      const passedCount = results.filter((r: any) => r.result === 'pass').length;\n      const failedCount = results.filter((r: any) => r.result === 'fail').length;\n\n      const examTypeLabel = exam.exam_type === 'sat_hach' ? 'Sát hạch' : 'Tốt nghiệp';\n      const resultLabel = exam.result === 'pass' ? 'Đậu' : exam.result === 'fail' ? 'Rớt' : 'Chưa có';\n\n      worksheet.addRow({\n        name: exam.name || '',\n        exam_type: examTypeLabel,\n        stadium: exam.stadium_id?.name || '',\n        start_time: exam.start_time ? new Date(exam.start_time).toLocaleDateString('vi-VN') : '',\n        session: exam.session || '',\n        status: exam.status || '',\n        total: exam.total_examinees ?? results.length,\n        passed: passedCount,\n        failed: failedCount,\n        result: resultLabel,\n      });\n    });\n\n    this.excelHelper.applyRowStyle(worksheet);\n    await this.excelHelper.sendWorkbook(res, workbook, 'danh_sach_ky_thi');\n  }\n\n  async getExamStats(type: ExamType, currentUser?: any) {\n    const [examStats, eligibleCount] = await Promise.all([\n      this.examRepository.getStats(type, currentUser),\n      currentUser?.role === 'teacher'\n        ? this.studentRepository.countEligibleByTeacher(currentUser.id || currentUser._id)\n        : this.studentRepository.countEligibleForGraduation(),\n    ]);\n\n    return {\n      ...examStats,\n      eligibleStudents: eligibleCount,\n    };\n  }\n\n  async importResults(examId: string, filePath: string) {\n    const results = await this.excelHelper.parseExamResults(filePath);\n    let successCount = 0;\n    let failCount = 0;\n\n    for (const item of results) {\n      try {\n        // Find student by CCCD or Code\n        const user = await UserModel.findOne({\n          $or: [{ identity_card: item.cccd }, { username: item.studentCode }],\n        })\n          .select('_id')\n          .lean()\n          .exec();\n\n        if (user) {\n          const student = await StudentModel.findOne({ user_id: user._id }).select('_id').lean().exec();\n          if (student) {\n            await this.examRepository.updateStudentResult(examId, student._id.toString(), item.result);\n            successCount++;\n          } else {\n            failCount++;\n          }\n        } else {\n          failCount++;\n        }\n      } catch (err) {\n        failCount++;\n      }\n    }\n\n    return { successCount, failCount };\n  }\n\n  async getResultTemplate(res: Response) {\n    return await this.excelHelper.getExamResultTemplate(res);\n  }\n}","cwd":"/root/.openclaw/workspaces2/v4-ecosystem-review/master-orchestrator"},"isError":false,"timestamp":1776833446744}}
{"type":"message","id":"c0901bcc","parentId":"cbdf9ea0","timestamp":"2026-04-22T04:50:46.771Z","message":{"role":"toolResult","toolCallId":"call_function_58fsiayqh4jo_2","toolName":"exec","content":[{"type":"text","text":"import { PaymentRepository } from '@/infrastructure/repositories/payment.repository';\nimport { IPayment } from '@/infrastructure/database/models/payment.model';\nimport { ExcelHelper } from '@/infrastructure/utils/excel.helper';\nimport { Response } from 'express';\nimport { PaginationOptions } from '@/domain/types/pagination.types';\n\nexport class PaymentService {\n  private paymentRepository: PaymentRepository;\n  private excelHelper: ExcelHelper;\n\n  constructor() {\n    this.paymentRepository = new PaymentRepository();\n    this.excelHelper = new ExcelHelper();\n  }\n\n  async getAllPayments(filters = {}, options: PaginationOptions = { page: 1, limit: 10 }, currentUser?: any) {\n    return await this.paymentRepository.getTuitionAccounts(filters, options, currentUser);\n  }\n\n  async getPaymentStats(currentUser?: any) {\n    return await this.paymentRepository.getStats(currentUser);\n  }\n\n  async getPaymentsByStudent(studentId: string, options: PaginationOptions = { page: 1, limit: 10 }) {\n    return await this.paymentRepository.findByStudent(studentId, options);\n  }\n\n  async getPaymentById(id: string, currentUser?: any) {\n    const payment = await this.paymentRepository.findById(id, currentUser);\n    if (!payment) {\n      throw new Error('Không tìm thấy bản ghi thanh toán hoặc bạn không có quyền truy cập');\n    }\n    return payment;\n  }\n\n  async createPayment(data: Partial<IPayment>) {\n    return await this.paymentRepository.create(data);\n  }\n\n  async updatePayment(id: string, data: Partial<IPayment>, currentUser?: any) {\n    return await this.paymentRepository.update(id, data);\n  }\n\n  async deletePayment(id: string, currentUser?: any) {\n    return await this.paymentRepository.delete(id);\n  }\n\n  async isAuthorized(paymentId: string, teacherId: string): Promise<boolean> {\n    const payment = await this.paymentRepository.findById(paymentId);\n    if (!payment) return false;\n\n    // eslint-disable-next-line @typescript-eslint/no-require-imports\n    const { CourseStudentModel } = require('@/infrastructure/database/models/course_student.model');\n    const enrollment = await CourseStudentModel.findById(payment.course_student_id).select('teacher_id').exec();\n\n    return enrollment && enrollment.teacher_id && enrollment.teacher_id.toString() === teacherId;\n  }\n\n  async exportPaymentsToExcel(res: Response, filters: any, currentUser?: any): Promise<void> {\n    const { data } = await this.paymentRepository.findAll(filters, { page: 1, limit: 5000 }, currentUser);\n\n    const { workbook, worksheet } = this.excelHelper.createWorkbook('Báo cáo học phí');\n\n    this.excelHelper.applyHeaderStyle(worksheet, [\n      { header: 'Mã phiếu', key: 'code', width: 15 },\n      { header: 'Họ tên học viên', key: 'student_name', width: 25 },\n      { header: 'Số điện thoại', key: 'phone', width: 15 },\n      { header: 'Khóa học', key: 'course', width: 20 },\n      { header: 'Hạng', key: 'rank', width: 10 },\n      { header: 'Số tiền thu', key: 'amount', width: 18 },\n      { header: 'Giai đoạn', key: 'stage', width: 18 },\n      { header: 'Ngày thu', key: 'date', width: 15 },\n      { header: 'Đã nhận tiền', key: 'is_received', width: 15 },\n      { header: 'Ghi chú', key: 'note', width: 30 },\n    ]);\n\n    data.forEach((p: any) => {\n      // Repository populates: course_student_id → { student_id: { user_id: {...} }, course_id: {...} }\n      const courseStudent = p.course_student_id || {};\n      const studentDoc = courseStudent.student_id || {};\n      const userDoc = studentDoc.user_id || {};\n      const courseDoc = courseStudent.course_id || {};\n\n      const fullName = `${userDoc.last_name || ''} ${userDoc.first_name || ''}`.trim() || 'N/A';\n\n      worksheet.addRow({\n        code: (p._id || '').toString().slice(-8).toUpperCase(),\n        student_name: fullName,\n        phone: userDoc.phone || '',\n        course: courseDoc.name || '',\n        rank: courseDoc.license_category_id?.name || 'B2',\n        amount: p.received_fee != null ? p.received_fee.toLocaleString('vi-VN') + 'đ' : '0đ',\n        stage: p.stage_name || (p.type === 'tuition_fee' ? 'Học phí' : 'Khác'),\n        date: p.payment_date\n          ? new Date(p.payment_date).toLocaleDateString('vi-VN')\n          : p.created_at\n            ? new Date(p.created_at).toLocaleDateString('vi-VN')\n            : '',\n        is_received: p.is_received ? 'Đã nhận' : 'Chưa nhận',\n        note: p.note || '',\n      });\n    });\n\n    this.excelHelper.applyRowStyle(worksheet);\n    await this.excelHelper.sendWorkbook(res, workbook, 'bao_cao_hoc_phi');\n  }\n\n  async exportPremiumFinancialReport(res: Response, filters: any, currentUser?: any): Promise<void> {\n    // 1. Fetch data for all sheets\n    const [stats, accountsRes, paymentsRes] = await Promise.all([\n      this.paymentRepository.getStats(currentUser),\n      this.paymentRepository.getTuitionAccounts(filters, { page: 1, limit: 10000 }, currentUser),\n      this.paymentRepository.findAll(filters, { page: 1, limit: 10000 }, currentUser),\n    ]);\n\n    const accounts = accountsRes.data || [];\n    const payments = paymentsRes.data || [];\n\n    // --- WORKBOOK INITIALIZATION ---\n    const { workbook, worksheet: summarySheet } = this.excelHelper.createWorkbook('1. Tổng quan');\n\n    // --- SHEET 1: TỔNG QUAN (DASHBOARD STYLE) ---\n    summarySheet.views = [{ state: 'frozen', ySplit: 0, xSplit: 0 }];\n    summarySheet.properties.defaultRowHeight = 35;\n\n    summarySheet.columns = [\n      { header: 'CHỈ SỐ TÀI CHÍNH', key: 'label', width: 45 },\n      { header: 'GIÁ TRỊ (VNĐ)', key: 'value', width: 35 },\n    ];\n\n    // Double-header or \"Logo\" area\n    const logoRow = summarySheet.insertRow(1, ['BÁO CÁO TÀI CHÍNH TỔNG HỢP - HỆ THỐNG AHV', '']);\n    summarySheet.mergeCells('A1:B1');\n    logoRow.height = 50;\n    logoRow.getCell(1).font = { bold: true, size: 20, color: { argb: 'FFFFFFFF' } };\n    logoRow.getCell(1).fill = { type: 'pattern', pattern: 'solid', fgColor: { argb: 'FF4F46E5' } };\n    logoRow.getCell(1).alignment = { vertical: 'middle', horizontal: 'center' };\n\n    summarySheet.addRows([\n      { label: '👉 Tổng doanh thu dự kiến (Định mức học phí)', value: Number(stats.total_receivable || 0) },\n      { label: '💰 Tổng số tiền đã thực thu (Tiền mặt/Chuyển khoản)', value: Number(stats.total_received || 0) },\n      { label: '📉 Tổng công nợ còn lại (Cần thu hồi)', value: Number(stats.total_debt || 0) },\n      { label: '👥 Số lượng học viên còn nợ', value: Number(stats.debtor_count || 0) },\n      {\n        label: '📈 Tỷ lệ hoàn thành thu nợ',\n        value:\n          stats.total_receivable > 0 ? ((stats.total_received / stats.total_receivable) * 100).toFixed(2) + '%' : '0%',\n      },\n    ]);\n\n    // Style the Dashboard\n    summarySheet.getColumn('value').numFmt = '#,##0';\n    summarySheet.eachRow((row, rowNumber) => {\n      if (rowNumber === 1) return;\n      if (rowNumber === 2) {\n        row.height = 40;\n        row.eachCell((c) => {\n          c.fill = { type: 'pattern', pattern: 'solid', fgColor: { argb: 'FF1E293B' } };\n          c.font = { bold: true, color: { argb: 'FFFFFFFF' }, size: 12 };\n          c.alignment = { vertical: 'middle', horizontal: 'center' };\n        });\n        return;\n      }\n      row.getCell(1).font = { bold: true, size: 12, color: { argb: 'FF4B5563' } };\n      row.getCell(2).font = { bold: true, size: 14, color: { argb: rowNumber === 5 ? 'FFE11D48' : 'FF059669' } };\n      row.getCell(1).alignment = { vertical: 'middle', indent: 2 };\n      row.getCell(2).alignment = { vertical: 'middle', horizontal: 'right' };\n      row.border = { bottom: { style: 'thin', color: { argb: 'FFE5E7EB' } } };\n    });\n\n    // --- HELPER: Create Grouped Summary Sheet ---\n    const createSummarySheet = (name: string, data: any[], categoryLabel: string) => {\n      const sheet = workbook.addWorksheet(name, { views: [{ state: 'frozen', ySplit: 1 }] });\n      const cols = [\n        { header: 'STT', key: 'stt', width: 8 },\n        { header: categoryLabel, key: 'name', width: 35 },\n        { header: 'Số lượng HV', key: 'count', width: 15 },\n        { header: 'Tổng học phí', key: 'receivable', width: 22 },\n        { header: 'Đã đóng', key: 'paid', width: 22 },\n        { header: 'Công nợ', key: 'debt', width: 22 },\n        { header: '% Thu hồi', key: 'ratio', width: 15 },\n      ];\n      this.excelHelper.applyHeaderStyle(sheet, cols);\n\n      data.forEach((item, index) => {\n        const ratio = item.receivable > 0 ? (item.paid / item.receivable) * 100 : 0;\n        const row = sheet.addRow({\n          stt: index + 1,\n          name: item.name,\n          count: item.count || 0,\n          receivable: Number(item.receivable || 0),\n          paid: Number(item.paid || 0),\n          debt: Number(item.debt || 0),\n          ratio: ratio.toFixed(1) + '%',\n        });\n\n        // Color coding for ratio\n        const ratioCell = row.getCell('ratio');\n        if (ratio >= 90) ratioCell.font = { color: { argb: 'FF059669' }, bold: true };\n        else if (ratio < 60) ratioCell.font = { color: { argb: 'FFE11D48' }, bold: true };\n\n        row.getCell('debt').font = { color: { argb: 'FFE11D48' }, bold: item.debt > 0 };\n      });\n\n      sheet.getColumn('receivable').numFmt = '#,##0';\n      sheet.getColumn('paid').numFmt = '#,##0';\n      sheet.getColumn('debt').numFmt = '#,##0';\n      sheet.getColumn('count').alignment = { horizontal: 'center' };\n      sheet.getColumn('ratio').alignment = { horizontal: 'center' };\n      this.excelHelper.applyRowStyle(sheet);\n    };\n\n    // --- SHEET 2: THEO HẠNG BẰNG ---\n    createSummarySheet('2. Theo Hạng bằng', stats.by_category || [], 'Hạng đào tạo');\n\n    // --- SHEET 3: THEO KHÓA HỌC ---\n    createSummarySheet('3. Theo Khóa học', stats.by_course || [], 'Tên khóa học');\n\n    // --- SHEET 4: THEO TRUNG TÂM ---\n    createSummarySheet('4. Theo Trung tâm', stats.by_region || [], 'Trung tâm / Tỉnh TP');\n\n    // --- SHEET 5: CÔNG NỢ CHI TIẾT ---\n    const accountSheet = workbook.addWorksheet('5. Công nợ chi tiết', { views: [{ state: 'frozen', ySplit: 1 }] });\n    const accountCols = [\n      { header: 'STT', key: 'stt', width: 8 },\n      { header: 'Mã HV', key: 'code', width: 15 },\n      { header: 'Họ tên', key: 'name', width: 25 },\n      { header: 'Số điện thoại', key: 'phone', width: 18 },\n      { header: 'Khóa học', key: 'course', width: 25 },\n      { header: 'Hạng', key: 'rank', width: 10 },\n      { header: 'Học phí', key: 'total', width: 18 },\n      { header: 'Đã đóng', key: 'paid', width: 18 },\n      { header: 'Còn nợ', key: 'debt', width: 18 },\n      { header: 'Trạng thái', key: 'status', width: 15 },\n    ];\n    this.excelHelper.applyHeaderStyle(accountSheet, accountCols);\n\n    accounts.forEach((acc: any, index: number) => {\n      const cs = acc.course_student_id || {};\n      const fee = Number(cs.fee || 0);\n      const paid = Number(cs.paid_fee || 0);\n      const debt = fee - paid;\n      const row = accountSheet.addRow({\n        stt: index + 1,\n        code: (cs._id || '').toString().slice(-6).toUpperCase(),\n        name: `${cs.student_id?.user_id?.last_name || ''} ${cs.student_id?.user_id?.first_name || ''}`.trim(),\n        phone: cs.student_id?.user_id?.phone || '',\n        course: cs.course_id?.name || '',\n        rank: cs.course_id?.license_category_id?.name || 'B2',\n        total: fee,\n        paid: paid,\n        debt: debt,\n        status: debt <= 0 ? '✔️ Hoàn thành' : '⏳ Còn nợ',\n      });\n      if (debt > 0) row.getCell('debt').font = { color: { argb: 'FFE11D48' }, bold: true };\n    });\n    accountSheet.getColumn('total').numFmt = '#,##0';\n    accountSheet.getColumn('paid').numFmt = '#,##0';\n    accountSheet.getColumn('debt').numFmt = '#,##0';\n    this.excelHelper.applyRowStyle(accountSheet);\n\n    // --- SHEET 6: NHẬT KÝ GIAO DỊCH ---\n    const logSheet = workbook.addWorksheet('6. Nhật ký giao dịch', { views: [{ state: 'frozen', ySplit: 1 }] });\n    const logCols = [\n      { header: 'Mã phiếu', key: 'id', width: 15 },\n      { header: 'Ngày thu', key: 'date', width: 20 },\n      { header: 'Học viên', key: 'student', width: 25 },\n      { header: 'Nội dung', key: 'type', width: 20 },\n      { header: 'Số tiền', key: 'amount', width: 18 },\n      { header: 'Người thu', key: 'confirmer', width: 20 },\n    ];\n    this.excelHelper.applyHeaderStyle(logSheet, logCols);\n    payments.forEach((p: any) => {\n      const user = p.course_student_id?.student_id?.user_id || {};\n      logSheet.addRow({\n        id: (p._id || '').toString().slice(-8).toUpperCase(),\n        date: p.payment_date ? new Date(p.payment_date) : new Date(),\n        student: `${user.last_name || ''} ${user.first_name || ''}`.trim(),\n        type: p.stage_name ? `Học phí (${p.stage_name})` : p.type === 'tuition_fee' ? 'Học phí' : 'Khác',\n        amount: Number(p.received_fee || 0),\n        confirmer: p.confirmer_id?.username || 'Hệ thống',\n      });\n    });\n    logSheet.getColumn('date').numFmt = 'dd/mm/yyyy';\n    logSheet.getColumn('amount').numFmt = '#,##0';\n    this.excelHelper.applyRowStyle(logSheet);\n\n    await this.excelHelper.sendWorkbook(\n      res,\n      workbook,\n      `Bao_cao_tai_chinh_premium_${new Date().toISOString().split('T')[0]}`,\n    );\n  }\n\n  async importPayments(filePath: string, confirmerId: string) {\n    const data = await this.excelHelper.parseTuitionExcel(filePath);\n\n    // eslint-disable-next-line @typescript-eslint/no-require-imports\n    const { UserModel } = require('@/infrastructure/database/models/user.model');\n    // eslint-disable-next-line @typescript-eslint/no-require-imports\n    const { CourseStudentModel } = require('@/infrastructure/database/models/course_student.model');\n\n    let successCount = 0;\n    let failCount = 0;\n    const errors: string[] = [];\n\n    for (const item of data) {\n      try {\n        if (!item.cccd && !item.studentCode) {\n          throw new Error('Thiếu CCCD hoặc Mã học viên');\n        }\n\n        // 1. Find User\n        const user = await UserModel.findOne({\n          $or: [{ identity_card: item.cccd }, { username: item.studentCode }],\n        })\n          .select('_id')\n          .lean()\n          .exec();\n\n        if (!user) {\n          throw new Error(`Không tìm thấy học viên với CCCD/Mã: ${item.cccd || item.studentCode}`);\n        }\n\n        // 2. Find StudentInfo ID from User\n        // eslint-disable-next-line @typescript-eslint/no-require-imports\n        const { StudentModel } = require('@/infrastructure/database/models/student.model');\n        const student = await StudentModel.findOne({ user_id: user._id }).select('_id').lean().exec();\n\n        if (!student) {\n          throw new Error(`Học viên chưa có hồ sơ StudentInfo (User: ${user._id})`);\n        }\n\n        // 3. Find most recent Enrollment (CourseStudent)\n        const enrollment = await CourseStudentModel.findOne({\n          student_id: student._id,\n          status: 'unfinished',\n        })\n          .sort({ created_at: -1 })\n          .select('_id fee paid_fee')\n          .lean()\n          .exec();\n\n        if (!enrollment) {\n          throw new Error(`Học viên ${item.fullName} hiện không trong khóa học nào hoặc đã hoàn thành.`);\n        }\n\n        // 4. Generate Receipt ID if missing\n        let receiptCode = item.note;\n        if (!receiptCode) {\n          receiptCode = await this.paymentRepository.getNextReceiptCode();\n        }\n\n        // 5. Create Payment\n        await this.paymentRepository.create({\n          course_student_id: enrollment._id,\n          payment_date: item.date,\n          received_fee: item.amount,\n          type: 'tuition_fee' as any,\n          stage_name: item.stageName,\n          note: receiptCode,\n          confirmer_id: confirmerId as any,\n          is_received: true,\n        });\n\n        successCount++;\n      } catch (err: any) {\n        failCount++;\n        errors.push(`${item.fullName || 'N/A'}: ${err.message}`);\n      }\n    }\n\n    return { successCount, failCount, errors };\n  }\n\n  async getImportTemplate(res: Response) {\n    return await this.excelHelper.getTuitionImportTemplate(res);\n  }\n}"}],"details":{"status":"completed","exitCode":0,"durationMs":140,"aggregated":"import { PaymentRepository } from '@/infrastructure/repositories/payment.repository';\nimport { IPayment } from '@/infrastructure/database/models/payment.model';\nimport { ExcelHelper } from '@/infrastructure/utils/excel.helper';\nimport { Response } from 'express';\nimport { PaginationOptions } from '@/domain/types/pagination.types';\n\nexport class PaymentService {\n  private paymentRepository: PaymentRepository;\n  private excelHelper: ExcelHelper;\n\n  constructor() {\n    this.paymentRepository = new PaymentRepository();\n    this.excelHelper = new ExcelHelper();\n  }\n\n  async getAllPayments(filters = {}, options: PaginationOptions = { page: 1, limit: 10 }, currentUser?: any) {\n    return await this.paymentRepository.getTuitionAccounts(filters, options, currentUser);\n  }\n\n  async getPaymentStats(currentUser?: any) {\n    return await this.paymentRepository.getStats(currentUser);\n  }\n\n  async getPaymentsByStudent(studentId: string, options: PaginationOptions = { page: 1, limit: 10 }) {\n    return await this.paymentRepository.findByStudent(studentId, options);\n  }\n\n  async getPaymentById(id: string, currentUser?: any) {\n    const payment = await this.paymentRepository.findById(id, currentUser);\n    if (!payment) {\n      throw new Error('Không tìm thấy bản ghi thanh toán hoặc bạn không có quyền truy cập');\n    }\n    return payment;\n  }\n\n  async createPayment(data: Partial<IPayment>) {\n    return await this.paymentRepository.create(data);\n  }\n\n  async updatePayment(id: string, data: Partial<IPayment>, currentUser?: any) {\n    return await this.paymentRepository.update(id, data);\n  }\n\n  async deletePayment(id: string, currentUser?: any) {\n    return await this.paymentRepository.delete(id);\n  }\n\n  async isAuthorized(paymentId: string, teacherId: string): Promise<boolean> {\n    const payment = await this.paymentRepository.findById(paymentId);\n    if (!payment) return false;\n\n    // eslint-disable-next-line @typescript-eslint/no-require-imports\n    const { CourseStudentModel } = require('@/infrastructure/database/models/course_student.model');\n    const enrollment = await CourseStudentModel.findById(payment.course_student_id).select('teacher_id').exec();\n\n    return enrollment && enrollment.teacher_id && enrollment.teacher_id.toString() === teacherId;\n  }\n\n  async exportPaymentsToExcel(res: Response, filters: any, currentUser?: any): Promise<void> {\n    const { data } = await this.paymentRepository.findAll(filters, { page: 1, limit: 5000 }, currentUser);\n\n    const { workbook, worksheet } = this.excelHelper.createWorkbook('Báo cáo học phí');\n\n    this.excelHelper.applyHeaderStyle(worksheet, [\n      { header: 'Mã phiếu', key: 'code', width: 15 },\n      { header: 'Họ tên học viên', key: 'student_name', width: 25 },\n      { header: 'Số điện thoại', key: 'phone', width: 15 },\n      { header: 'Khóa học', key: 'course', width: 20 },\n      { header: 'Hạng', key: 'rank', width: 10 },\n      { header: 'Số tiền thu', key: 'amount', width: 18 },\n      { header: 'Giai đoạn', key: 'stage', width: 18 },\n      { header: 'Ngày thu', key: 'date', width: 15 },\n      { header: 'Đã nhận tiền', key: 'is_received', width: 15 },\n      { header: 'Ghi chú', key: 'note', width: 30 },\n    ]);\n\n    data.forEach((p: any) => {\n      // Repository populates: course_student_id → { student_id: { user_id: {...} }, course_id: {...} }\n      const courseStudent = p.course_student_id || {};\n      const studentDoc = courseStudent.student_id || {};\n      const userDoc = studentDoc.user_id || {};\n      const courseDoc = courseStudent.course_id || {};\n\n      const fullName = `${userDoc.last_name || ''} ${userDoc.first_name || ''}`.trim() || 'N/A';\n\n      worksheet.addRow({\n        code: (p._id || '').toString().slice(-8).toUpperCase(),\n        student_name: fullName,\n        phone: userDoc.phone || '',\n        course: courseDoc.name || '',\n        rank: courseDoc.license_category_id?.name || 'B2',\n        amount: p.received_fee != null ? p.received_fee.toLocaleString('vi-VN') + 'đ' : '0đ',\n        stage: p.stage_name || (p.type === 'tuition_fee' ? 'Học phí' : 'Khác'),\n        date: p.payment_date\n          ? new Date(p.payment_date).toLocaleDateString('vi-VN')\n          : p.created_at\n            ? new Date(p.created_at).toLocaleDateString('vi-VN')\n            : '',\n        is_received: p.is_received ? 'Đã nhận' : 'Chưa nhận',\n        note: p.note || '',\n      });\n    });\n\n    this.excelHelper.applyRowStyle(worksheet);\n    await this.excelHelper.sendWorkbook(res, workbook, 'bao_cao_hoc_phi');\n  }\n\n  async exportPremiumFinancialReport(res: Response, filters: any, currentUser?: any): Promise<void> {\n    // 1. Fetch data for all sheets\n    const [stats, accountsRes, paymentsRes] = await Promise.all([\n      this.paymentRepository.getStats(currentUser),\n      this.paymentRepository.getTuitionAccounts(filters, { page: 1, limit: 10000 }, currentUser),\n      this.paymentRepository.findAll(filters, { page: 1, limit: 10000 }, currentUser),\n    ]);\n\n    const accounts = accountsRes.data || [];\n    const payments = paymentsRes.data || [];\n\n    // --- WORKBOOK INITIALIZATION ---\n    const { workbook, worksheet: summarySheet } = this.excelHelper.createWorkbook('1. Tổng quan');\n\n    // --- SHEET 1: TỔNG QUAN (DASHBOARD STYLE) ---\n    summarySheet.views = [{ state: 'frozen', ySplit: 0, xSplit: 0 }];\n    summarySheet.properties.defaultRowHeight = 35;\n\n    summarySheet.columns = [\n      { header: 'CHỈ SỐ TÀI CHÍNH', key: 'label', width: 45 },\n      { header: 'GIÁ TRỊ (VNĐ)', key: 'value', width: 35 },\n    ];\n\n    // Double-header or \"Logo\" area\n    const logoRow = summarySheet.insertRow(1, ['BÁO CÁO TÀI CHÍNH TỔNG HỢP - HỆ THỐNG AHV', '']);\n    summarySheet.mergeCells('A1:B1');\n    logoRow.height = 50;\n    logoRow.getCell(1).font = { bold: true, size: 20, color: { argb: 'FFFFFFFF' } };\n    logoRow.getCell(1).fill = { type: 'pattern', pattern: 'solid', fgColor: { argb: 'FF4F46E5' } };\n    logoRow.getCell(1).alignment = { vertical: 'middle', horizontal: 'center' };\n\n    summarySheet.addRows([\n      { label: '👉 Tổng doanh thu dự kiến (Định mức học phí)', value: Number(stats.total_receivable || 0) },\n      { label: '💰 Tổng số tiền đã thực thu (Tiền mặt/Chuyển khoản)', value: Number(stats.total_received || 0) },\n      { label: '📉 Tổng công nợ còn lại (Cần thu hồi)', value: Number(stats.total_debt || 0) },\n      { label: '👥 Số lượng học viên còn nợ', value: Number(stats.debtor_count || 0) },\n      {\n        label: '📈 Tỷ lệ hoàn thành thu nợ',\n        value:\n          stats.total_receivable > 0 ? ((stats.total_received / stats.total_receivable) * 100).toFixed(2) + '%' : '0%',\n      },\n    ]);\n\n    // Style the Dashboard\n    summarySheet.getColumn('value').numFmt = '#,##0';\n    summarySheet.eachRow((row, rowNumber) => {\n      if (rowNumber === 1) return;\n      if (rowNumber === 2) {\n        row.height = 40;\n        row.eachCell((c) => {\n          c.fill = { type: 'pattern', pattern: 'solid', fgColor: { argb: 'FF1E293B' } };\n          c.font = { bold: true, color: { argb: 'FFFFFFFF' }, size: 12 };\n          c.alignment = { vertical: 'middle', horizontal: 'center' };\n        });\n        return;\n      }\n      row.getCell(1).font = { bold: true, size: 12, color: { argb: 'FF4B5563' } };\n      row.getCell(2).font = { bold: true, size: 14, color: { argb: rowNumber === 5 ? 'FFE11D48' : 'FF059669' } };\n      row.getCell(1).alignment = { vertical: 'middle', indent: 2 };\n      row.getCell(2).alignment = { vertical: 'middle', horizontal: 'right' };\n      row.border = { bottom: { style: 'thin', color: { argb: 'FFE5E7EB' } } };\n    });\n\n    // --- HELPER: Create Grouped Summary Sheet ---\n    const createSummarySheet = (name: string, data: any[], categoryLabel: string) => {\n      const sheet = workbook.addWorksheet(name, { views: [{ state: 'frozen', ySplit: 1 }] });\n      const cols = [\n        { header: 'STT', key: 'stt', width: 8 },\n        { header: categoryLabel, key: 'name', width: 35 },\n        { header: 'Số lượng HV', key: 'count', width: 15 },\n        { header: 'Tổng học phí', key: 'receivable', width: 22 },\n        { header: 'Đã đóng', key: 'paid', width: 22 },\n        { header: 'Công nợ', key: 'debt', width: 22 },\n        { header: '% Thu hồi', key: 'ratio', width: 15 },\n      ];\n      this.excelHelper.applyHeaderStyle(sheet, cols);\n\n      data.forEach((item, index) => {\n        const ratio = item.receivable > 0 ? (item.paid / item.receivable) * 100 : 0;\n        const row = sheet.addRow({\n          stt: index + 1,\n          name: item.name,\n          count: item.count || 0,\n          receivable: Number(item.receivable || 0),\n          paid: Number(item.paid || 0),\n          debt: Number(item.debt || 0),\n          ratio: ratio.toFixed(1) + '%',\n        });\n\n        // Color coding for ratio\n        const ratioCell = row.getCell('ratio');\n        if (ratio >= 90) ratioCell.font = { color: { argb: 'FF059669' }, bold: true };\n        else if (ratio < 60) ratioCell.font = { color: { argb: 'FFE11D48' }, bold: true };\n\n        row.getCell('debt').font = { color: { argb: 'FFE11D48' }, bold: item.debt > 0 };\n      });\n\n      sheet.getColumn('receivable').numFmt = '#,##0';\n      sheet.getColumn('paid').numFmt = '#,##0';\n      sheet.getColumn('debt').numFmt = '#,##0';\n      sheet.getColumn('count').alignment = { horizontal: 'center' };\n      sheet.getColumn('ratio').alignment = { horizontal: 'center' };\n      this.excelHelper.applyRowStyle(sheet);\n    };\n\n    // --- SHEET 2: THEO HẠNG BẰNG ---\n    createSummarySheet('2. Theo Hạng bằng', stats.by_category || [], 'Hạng đào tạo');\n\n    // --- SHEET 3: THEO KHÓA HỌC ---\n    createSummarySheet('3. Theo Khóa học', stats.by_course || [], 'Tên khóa học');\n\n    // --- SHEET 4: THEO TRUNG TÂM ---\n    createSummarySheet('4. Theo Trung tâm', stats.by_region || [], 'Trung tâm / Tỉnh TP');\n\n    // --- SHEET 5: CÔNG NỢ CHI TIẾT ---\n    const accountSheet = workbook.addWorksheet('5. Công nợ chi tiết', { views: [{ state: 'frozen', ySplit: 1 }] });\n    const accountCols = [\n      { header: 'STT', key: 'stt', width: 8 },\n      { header: 'Mã HV', key: 'code', width: 15 },\n      { header: 'Họ tên', key: 'name', width: 25 },\n      { header: 'Số điện thoại', key: 'phone', width: 18 },\n      { header: 'Khóa học', key: 'course', width: 25 },\n      { header: 'Hạng', key: 'rank', width: 10 },\n      { header: 'Học phí', key: 'total', width: 18 },\n      { header: 'Đã đóng', key: 'paid', width: 18 },\n      { header: 'Còn nợ', key: 'debt', width: 18 },\n      { header: 'Trạng thái', key: 'status', width: 15 },\n    ];\n    this.excelHelper.applyHeaderStyle(accountSheet, accountCols);\n\n    accounts.forEach((acc: any, index: number) => {\n      const cs = acc.course_student_id || {};\n      const fee = Number(cs.fee || 0);\n      const paid = Number(cs.paid_fee || 0);\n      const debt = fee - paid;\n      const row = accountSheet.addRow({\n        stt: index + 1,\n        code: (cs._id || '').toString().slice(-6).toUpperCase(),\n        name: `${cs.student_id?.user_id?.last_name || ''} ${cs.student_id?.user_id?.first_name || ''}`.trim(),\n        phone: cs.student_id?.user_id?.phone || '',\n        course: cs.course_id?.name || '',\n        rank: cs.course_id?.license_category_id?.name || 'B2',\n        total: fee,\n        paid: paid,\n        debt: debt,\n        status: debt <= 0 ? '✔️ Hoàn thành' : '⏳ Còn nợ',\n      });\n      if (debt > 0) row.getCell('debt').font = { color: { argb: 'FFE11D48' }, bold: true };\n    });\n    accountSheet.getColumn('total').numFmt = '#,##0';\n    accountSheet.getColumn('paid').numFmt = '#,##0';\n    accountSheet.getColumn('debt').numFmt = '#,##0';\n    this.excelHelper.applyRowStyle(accountSheet);\n\n    // --- SHEET 6: NHẬT KÝ GIAO DỊCH ---\n    const logSheet = workbook.addWorksheet('6. Nhật ký giao dịch', { views: [{ state: 'frozen', ySplit: 1 }] });\n    const logCols = [\n      { header: 'Mã phiếu', key: 'id', width: 15 },\n      { header: 'Ngày thu', key: 'date', width: 20 },\n      { header: 'Học viên', key: 'student', width: 25 },\n      { header: 'Nội dung', key: 'type', width: 20 },\n      { header: 'Số tiền', key: 'amount', width: 18 },\n      { header: 'Người thu', key: 'confirmer', width: 20 },\n    ];\n    this.excelHelper.applyHeaderStyle(logSheet, logCols);\n    payments.forEach((p: any) => {\n      const user = p.course_student_id?.student_id?.user_id || {};\n      logSheet.addRow({\n        id: (p._id || '').toString().slice(-8).toUpperCase(),\n        date: p.payment_date ? new Date(p.payment_date) : new Date(),\n        student: `${user.last_name || ''} ${user.first_name || ''}`.trim(),\n        type: p.stage_name ? `Học phí (${p.stage_name})` : p.type === 'tuition_fee' ? 'Học phí' : 'Khác',\n        amount: Number(p.received_fee || 0),\n        confirmer: p.confirmer_id?.username || 'Hệ thống',\n      });\n    });\n    logSheet.getColumn('date').numFmt = 'dd/mm/yyyy';\n    logSheet.getColumn('amount').numFmt = '#,##0';\n    this.excelHelper.applyRowStyle(logSheet);\n\n    await this.excelHelper.sendWorkbook(\n      res,\n      workbook,\n      `Bao_cao_tai_chinh_premium_${new Date().toISOString().split('T')[0]}`,\n    );\n  }\n\n  async importPayments(filePath: string, confirmerId: string) {\n    const data = await this.excelHelper.parseTuitionExcel(filePath);\n\n    // eslint-disable-next-line @typescript-eslint/no-require-imports\n    const { UserModel } = require('@/infrastructure/database/models/user.model');\n    // eslint-disable-next-line @typescript-eslint/no-require-imports\n    const { CourseStudentModel } = require('@/infrastructure/database/models/course_student.model');\n\n    let successCount = 0;\n    let failCount = 0;\n    const errors: string[] = [];\n\n    for (const item of data) {\n      try {\n        if (!item.cccd && !item.studentCode) {\n          throw new Error('Thiếu CCCD hoặc Mã học viên');\n        }\n\n        // 1. Find User\n        const user = await UserModel.findOne({\n          $or: [{ identity_card: item.cccd }, { username: item.studentCode }],\n        })\n          .select('_id')\n          .lean()\n          .exec();\n\n        if (!user) {\n          throw new Error(`Không tìm thấy học viên với CCCD/Mã: ${item.cccd || item.studentCode}`);\n        }\n\n        // 2. Find StudentInfo ID from User\n        // eslint-disable-next-line @typescript-eslint/no-require-imports\n        const { StudentModel } = require('@/infrastructure/database/models/student.model');\n        const student = await StudentModel.findOne({ user_id: user._id }).select('_id').lean().exec();\n\n        if (!student) {\n          throw new Error(`Học viên chưa có hồ sơ StudentInfo (User: ${user._id})`);\n        }\n\n        // 3. Find most recent Enrollment (CourseStudent)\n        const enrollment = await CourseStudentModel.findOne({\n          student_id: student._id,\n          status: 'unfinished',\n        })\n          .sort({ created_at: -1 })\n          .select('_id fee paid_fee')\n          .lean()\n          .exec();\n\n        if (!enrollment) {\n          throw new Error(`Học viên ${item.fullName} hiện không trong khóa học nào hoặc đã hoàn thành.`);\n        }\n\n        // 4. Generate Receipt ID if missing\n        let receiptCode = item.note;\n        if (!receiptCode) {\n          receiptCode = await this.paymentRepository.getNextReceiptCode();\n        }\n\n        // 5. Create Payment\n        await this.paymentRepository.create({\n          course_student_id: enrollment._id,\n          payment_date: item.date,\n          received_fee: item.amount,\n          type: 'tuition_fee' as any,\n          stage_name: item.stageName,\n          note: receiptCode,\n          confirmer_id: confirmerId as any,\n          is_received: true,\n        });\n\n        successCount++;\n      } catch (err: any) {\n        failCount++;\n        errors.push(`${item.fullName || 'N/A'}: ${err.message}`);\n      }\n    }\n\n    return { successCount, failCount, errors };\n  }\n\n  async getImportTemplate(res: Response) {\n    return await this.excelHelper.getTuitionImportTemplate(res);\n  }\n}","cwd":"/root/.openclaw/workspaces2/v4-ecosystem-review/master-orchestrator"},"isError":false,"timestamp":1776833446758}}
{"type":"message","id":"ae824523","parentId":"c0901bcc","timestamp":"2026-04-22T04:50:46.784Z","message":{"role":"toolResult","toolCallId":"call_function_58fsiayqh4jo_3","toolName":"exec","content":[{"type":"text","text":"import mongoose from 'mongoose';\nimport { StadiumRepository } from '@/infrastructure/repositories/stadium.repository';\n\nexport class StadiumService {\n  private stadiumRepository: StadiumRepository;\n\n  constructor() {\n    this.stadiumRepository = new StadiumRepository();\n  }\n\n  async getAllStadiums(filters: any, pagination: any) {\n    return this.stadiumRepository.findAll(filters, pagination);\n  }\n\n  async getStadiumById(id: string) {\n    return this.stadiumRepository.findById(id);\n  }\n\n  async createStadium(data: any) {\n    // If locate is empty but region_id is present, try to populate it with region info\n    if (!data.locate && data.region_id) {\n      const city = await mongoose.model('Cities').findById(data.region_id);\n      if (city) {\n        data.locate = (city as any).name;\n      }\n    }\n    return this.stadiumRepository.create(data);\n  }\n\n  async updateStadium(id: string, data: any) {\n    return this.stadiumRepository.update(id, data);\n  }\n\n  async deleteStadium(id: string) {\n    return this.stadiumRepository.delete(id);\n  }\n}"}],"details":{"status":"completed","exitCode":0,"durationMs":139,"aggregated":"import mongoose from 'mongoose';\nimport { StadiumRepository } from '@/infrastructure/repositories/stadium.repository';\n\nexport class StadiumService {\n  private stadiumRepository: StadiumRepository;\n\n  constructor() {\n    this.stadiumRepository = new StadiumRepository();\n  }\n\n  async getAllStadiums(filters: any, pagination: any) {\n    return this.stadiumRepository.findAll(filters, pagination);\n  }\n\n  async getStadiumById(id: string) {\n    return this.stadiumRepository.findById(id);\n  }\n\n  async createStadium(data: any) {\n    // If locate is empty but region_id is present, try to populate it with region info\n    if (!data.locate && data.region_id) {\n      const city = await mongoose.model('Cities').findById(data.region_id);\n      if (city) {\n        data.locate = (city as any).name;\n      }\n    }\n    return this.stadiumRepository.create(data);\n  }\n\n  async updateStadium(id: string, data: any) {\n    return this.stadiumRepository.update(id, data);\n  }\n\n  async deleteStadium(id: string) {\n    return this.stadiumRepository.delete(id);\n  }\n}","cwd":"/root/.openclaw/workspaces2/v4-ecosystem-review/master-orchestrator"},"isError":false,"timestamp":1776833446771}}
{"type":"message","id":"f52a8b1e","parentId":"ae824523","timestamp":"2026-04-22T04:50:46.841Z","message":{"role":"toolResult","toolCallId":"call_function_58fsiayqh4jo_4","toolName":"exec","content":[{"type":"text","text":"import { ILessonRepository } from '@/domain/repositories/lesson.repository.interface';\nimport { LessonRepository } from '@/infrastructure/repositories/lesson.repository';\nimport { ILesson } from '@/infrastructure/database/models/lesson.model';\nimport { PaginationOptions, PaginatedResult } from '@/domain/types/pagination.types';\n\nexport class LessonService {\n  private lessonRepository: ILessonRepository;\n\n  constructor(lessonRepository: ILessonRepository = new LessonRepository()) {\n    this.lessonRepository = lessonRepository;\n  }\n\n  async createLesson(data: Partial<ILesson>): Promise<ILesson> {\n    return await this.lessonRepository.create(data);\n  }\n\n  async getLessonById(id: string): Promise<ILesson | null> {\n    return await this.lessonRepository.findById(id);\n  }\n\n  async findLessons(filter: any, options?: PaginationOptions): Promise<PaginatedResult<ILesson>> {\n    return await this.lessonRepository.find(filter, options);\n  }\n\n  async getLessonsByTeacher(teacherId: string, options?: PaginationOptions): Promise<PaginatedResult<ILesson>> {\n    return await this.lessonRepository.findByTeacher(teacherId, options);\n  }\n\n  async getLessonsByStudent(courseStudentId: string, options?: PaginationOptions): Promise<PaginatedResult<ILesson>> {\n    return await this.lessonRepository.findByStudent(courseStudentId, options);\n  }\n\n  async updateLesson(id: string, data: Partial<ILesson>): Promise<ILesson | null> {\n    return await this.lessonRepository.update(id, data);\n  }\n\n  async deleteLesson(id: string): Promise<ILesson | null> {\n    return await this.lessonRepository.delete(id);\n  }\n\n  async isLessonAssignedToTeacher(lessonId: string, teacherId: string): Promise<boolean> {\n    const lesson = await this.lessonRepository.findById(lessonId);\n    return lesson?.teacher_id?.toString() === teacherId;\n  }\n}"}],"details":{"status":"completed","exitCode":0,"durationMs":222,"aggregated":"import { ILessonRepository } from '@/domain/repositories/lesson.repository.interface';\nimport { LessonRepository } from '@/infrastructure/repositories/lesson.repository';\nimport { ILesson } from '@/infrastructure/database/models/lesson.model';\nimport { PaginationOptions, PaginatedResult } from '@/domain/types/pagination.types';\n\nexport class LessonService {\n  private lessonRepository: ILessonRepository;\n\n  constructor(lessonRepository: ILessonRepository = new LessonRepository()) {\n    this.lessonRepository = lessonRepository;\n  }\n\n  async createLesson(data: Partial<ILesson>): Promise<ILesson> {\n    return await this.lessonRepository.create(data);\n  }\n\n  async getLessonById(id: string): Promise<ILesson | null> {\n    return await this.lessonRepository.findById(id);\n  }\n\n  async findLessons(filter: any, options?: PaginationOptions): Promise<PaginatedResult<ILesson>> {\n    return await this.lessonRepository.find(filter, options);\n  }\n\n  async getLessonsByTeacher(teacherId: string, options?: PaginationOptions): Promise<PaginatedResult<ILesson>> {\n    return await this.lessonRepository.findByTeacher(teacherId, options);\n  }\n\n  async getLessonsByStudent(courseStudentId: string, options?: PaginationOptions): Promise<PaginatedResult<ILesson>> {\n    return await this.lessonRepository.findByStudent(courseStudentId, options);\n  }\n\n  async updateLesson(id: string, data: Partial<ILesson>): Promise<ILesson | null> {\n    return await this.lessonRepository.update(id, data);\n  }\n\n  async deleteLesson(id: string): Promise<ILesson | null> {\n    return await this.lessonRepository.delete(id);\n  }\n\n  async isLessonAssignedToTeacher(lessonId: string, teacherId: string): Promise<boolean> {\n    const lesson = await this.lessonRepository.findById(lessonId);\n    return lesson?.teacher_id?.toString() === teacherId;\n  }\n}","cwd":"/root/.openclaw/workspaces2/v4-ecosystem-review/master-orchestrator"},"isError":false,"timestamp":1776833446825}}
