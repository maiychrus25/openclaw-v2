SystemFont,\"Segoe UI\",sans-serif;background:radial-gradient(circle at top,#17213d 0%,#0d152a 30%,var(--bg) 68%);color:var(--text);line-height:1.72}}\n.shell{{max-width:1240px;margin:0 auto;padding:32px 20px 72px}}\n.topbar{{display:flex;justify-content:space-between;gap:16px;align-items:center;margin-bottom:20px;flex-wrap:wrap}}\n.back{{display:inline-flex;align-items:center;gap:8px;color:var(--primary);text-decoration:none;font-weight:700;font-size:14px}}\n.back:hover{{text-decoration:underline}}\n.badge{{display:inline-flex;align-items:center;gap:8px;padding:8px 12px;border:1px solid var(--border);border-radius:999px;background:rgba(255,255,255,.04);color:var(--muted);font-size:12px}}\n.layout{{display:grid;grid-template-columns:260px minmax(0,1fr);gap:24px;align-items:start}}\n.sidebar{{position:sticky;top:20px;background:var(--panel);backdrop-filter:blur(12px);border:1px solid var(--border);border-radius:20px;box-shadow:var(--shadow);padding:18px}}\n.sidebar h3{{margin:0 0 12px;font-size:14px;color:var(--muted);text-transform:uppercase;letter-spacing:.08em}}\n.sidebar a{{display:block;padding:9px 10px;border-radius:10px;color:#cfe0ff;text-decoration:none;font-size:14px}}\n.sidebar a:hover{{background:rgba(125,179,255,.08)}}\n.content{{background:var(--panel);backdrop-filter:blur(14px);border:1px solid var(--border);border-radius:28px;box-shadow:var(--shadow);overflow:hidden}}\n.hero{{padding:34px 34px 22px;border-bottom:1px solid var(--border);background:linear-gradient(180deg,rgba(125,179,255,.08),rgba(125,179,255,0))}}\n.hero-kicker{{display:inline-block;text-transform:uppercase;letter-spacing:.16em;font-size:12px;color:var(--primary);margin-bottom:10px;font-weight:800}}\nh1{{margin:0 0 10px;font-size:42px;line-height:1.05;letter-spacing:-.02em}}\n.subtitle{{max-width:820px;color:var(--muted);font-size:16px;margin:0}}\n.article{{padding:28px 34px 40px}}\nh2{{margin:40px 0 14px;font-size:28px;line-height:1.2;padding-bottom:10px;border-bottom:1px solid var(--border)}}\nh3{{margin:28px 0 10px;font-size:20px;color:#dbe8ff}}\nh4{{margin:18px 0 8px;font-size:12px;color:var(--muted);text-transform:uppercase;letter-spacing:.12em}}\np{{margin:0 0 14px;color:#dfe9fb}}\nul,ol{{margin:0 0 14px;padding-left:22px}}\nli{{margin-bottom:6px;color:#d8e4f8}}\nblockquote{{margin:16px 0;padding:14px 16px;background:linear-gradient(180deg,rgba(125,179,255,.08),rgba(125,179,255,.04));border:1px solid rgba(125,179,255,.14);border-left:4px solid var(--primary);border-radius:14px;color:var(--muted)}}\nblockquote p{{margin:0;color:var(--muted)}}\ntable{{width:100%;border-collapse:separate;border-spacing:0;margin:16px 0;font-size:13px;background:rgba(255,255,255,.02);border:1px solid var(--border);border-radius:14px;overflow:hidden}}\nth{{background:rgba(255,255,255,.04);color:var(--primary);padding:12px 14px;text-align:left;border-bottom:1px solid rgba(125,179,255,.18);text-transform:uppercase;letter-spacing:.08em;font-size:11px;font-weight:800}}\ntd{{padding:12px 14px;border-bottom:1px solid var(--border);vertical-align:top;line-height:1.55;color:#dce7fa}}\ntr:last-child td{{border-bottom:none}}\ncode{{background:rgba(125,179,255,.12);color:#9bc3ff;padding:2px 6px;border-radius:6px;font-size:.88em;font-family:'Fira Code',ui-monospace,SFMono-Regular,monospace}}\npre{{background:#08101d;border:1px solid var(--border);border-radius:16px;padding:16px 18px;overflow-x:auto;margin:16px 0;box-shadow:inset 0 1px 0 rgba(255,255,255,.03)}}\npre code{{background:none;padding:0;color:#d8eeff;font-size:.86em;line-height:1.65}}\na{{color:var(--primary)}}\na:hover{{text-decoration:none}}\nhr{{border:none;border-top:1px solid var(--border);margin:28px 0}}\n.mermaid-wrap{{margin:18px 0 24px;padding:18px;border:1px solid var(--border);border-radius:18px;background:linear-gradient(180deg,rgba(255,255,255,.03),rgba(255,255,255,.015));overflow:auto}}\n.mermaid{{min-width:720px}}\n.mermaid svg{{max-width:100%;height:auto !important;display:block;margin:0 auto}}\n.note-grid{{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:14px;margin:18px 0 8px}}\n.note-card{{padding:14px;border:1px solid var(--border);border-radius:16px;background:rgba(255,255,255,.03)}}\n.note-card strong{{display:block;font-size:13px;margin-bottom:6px;color:#fff}}\n.note-card span{{font-size:13px;color:var(--muted)}}\n@media(max-width:980px){{.layout{{grid-template-columns:1fr}}.sidebar{{position:relative;top:auto}}.mermaid{{min-width:640px}}}}\n@media(max-width:640px){{.shell{{padding:18px 12px 48px}}.hero,.article{{padding-left:18px;padding-right:18px}}h1{{font-size:30px}}h2{{font-size:22px}}table{{font-size:11px}}.mermaid{{min-width:560px}}}}\n</style>\n<script type=\"module\">\n  import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs';\n  mermaid.initialize({{\n    startOnLoad: true,\n    theme: 'base',\n    securityLevel: 'loose',\n    fontFamily: 'Inter, Segoe UI, Arial, sans-serif',\n    themeVariables: {{\n      darkMode: true,\n      background: '#0f172a',\n      primaryColor: '#15233f',\n      primaryTextColor: '#ecf3ff',\n      primaryBorderColor: '#6ea8fe',\n      lineColor: '#8ab9ff',\n      secondaryColor: '#132847',\n      tertiaryColor: '#0b1222',\n      clusterBkg: '#0f1b32',\n      clusterBorder: '#507fd1',\n      mainBkg: '#13213d',\n      nodeBorder: '#6ea8fe',\n      edgeLabelBackground: '#0f172a',\n      fontSize: '15px'\n    }},\n    flowchart: {{ useMaxWidth: true, htmlLabels: true, curve: 'basis' }},\n    themeCSS: '.label, .nodeLabel, .edgeLabel p {{ color:#ecf3ff !important; }}'\n  }});\n</script>\n</head>\n<body>\n<div class=\"shell\">\n  <div class=\"topbar\">\n    <a class=\"back\" href=\"../index.html\">&#8592; Quay lại portal</a>\n    <span class=\"badge\">Official Team Docs · Multi-Agent Ecosystem</span>\n  </div>\n  <div class=\"layout\">\n    <aside class=\"sidebar\">\n      <h3>Điều hướng</h3>\n      <a href=\"#top\">Tổng quan</a>\n      <a href=\"#so-do-tong-the-luong-hoat-dong\">Luồng tổng thể</a>\n      <a href=\"#luong-chi-tiet-control-layer\">Control Layer</a>\n      <a href=\"#luong-chi-tiet-specialist-layer\">Specialist Layer</a>\n      <a href=\"#so-do-5-workflow-chuan\">5 Workflow chuẩn</a>\n      <a href=\"#luong-escalation-xu-ly-ngoai-le\">Escalation</a>\n      <a href=\"#so-do-tong-hop-mot-trang\">One-page view</a>\n      <a href=\"#bang-tong-hop-ai-lam-gi\">Bảng trách nhiệm</a>\n      <a href=\"#mermaid-diagram-cau-truc-he-thong-theo-layer\">Topology</a>\n      <a href=\"#mermaid-trang-thai-agent-theo-lifecycle\">Lifecycle</a>\n    </aside>\n    <main class=\"content\" id=\"top\">\n      <section class=\"hero\">\n        <span class=\"hero-kicker\">Agent Architecture</span>\n        <h1>{title}</h1>\n        <p class=\"subtitle\">Tài liệu chính thức mô tả cách hệ Multi-Agent tiếp nhận yêu cầu, điều phối chuyên gia, xử lý ngoại lệ, tổng hợp đầu ra và vận hành như một nền tảng làm việc chuẩn cho team.</p>\n        <div class=\"note-grid\">\n          <div class=\"note-card\"><strong>Auto-render Mermaid</strong><span>Sơ đồ được render trực tiếp trên trình duyệt.</span></div>\n          <div class=\"note-card\"><strong>Docs-first</strong><span>Thiết kế theo kiểu technical documentation hiện đại.</span></div>\n          <div class=\"note-card\"><strong>Team-ready</strong><span>Dùng làm tài liệu onboarding và operating model.</span></div>\n        </div>\n      </section>\n      <article class=\"article\">\n        {body}\n      </article>\n    </main>\n  </div>\n</div>\n</body>\n</html>'''"}]}}],"api":"anthropic-messages","provider":"ahvholding","model":"AHV-Holding-TroLy","usage":{"input":8727,"output":4350,"cacheRead":59904,"cacheWrite":0,"totalTokens":72981,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776933678989,"responseId":"1776933680658"}}
