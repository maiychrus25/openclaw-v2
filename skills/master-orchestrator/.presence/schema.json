{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AgentPresence",
  "type": "object",
  "properties": {
    "agent_id": { "type": "string" },
    "status": { "type": "string", "enum": ["active", "idle", "failed", "unknown"] },
    "task": { "type": "string" },
    "project": { "type": "string" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "required": ["agent_id", "status", "updated_at"]
}
